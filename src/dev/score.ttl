    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Facilitating-factor .

hedt:Facilitating-factor-catamenial a hed:HedTag ;
    rdfs:label "Facilitating-factor-catamenial" ;
    heda:inLibrary "score" ;
