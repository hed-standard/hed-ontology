    heda:takesValue true ;
    heda:valueClass hedu:nameClass ;
    hed:hasHedParent hedt:Time-block .

hedt:Time-interval-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:timeUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Time-interval .

hedt:Time-out a hed:HedTag ;
    rdfs:label "Time-out" ;
    rdfs:comment "A cancellation or cessation that automatically occurs when a predefined interval of time has passed without a certain event occurring." ;
    hed:hasHedParent hedt:Temporal-marker .

hedt:Time-sync a hed:HedTag ;
    rdfs:label "Time-sync" ;
    rdfs:comment "A synchronization signal whose purpose to help synchronize different signals or processes. Often used to indicate a marker inserted into the recorded data to allow post hoc synchronization of concurrently recorded data streams." ;
    hed:hasHedParent hedt:Temporal-marker .

hedt:Time-value-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:timeUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Time-value .

hedt:Timed a hed:HedTag ;
    rdfs:label "Timed" ;
    rdfs:comment "Something planned or scheduled to be done at a particular time or lasting for a specified amount of time." ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:To-left-of a hed:HedTag ;
    rdfs:label "To-left-of" ;
    rdfs:comment "(A, (To-left-of, B)) means A is located on or directed toward the side to the west of B when B is facing north. This term is used when A is not part of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:To-right-of a hed:HedTag ;
    rdfs:label "To-right-of" ;
    rdfs:comment "(A, (To-right-of, B)) means A is located on or directed toward the side to the east of B when B is facing north. This term is used when A is not part of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Toe-off a hed:HedTag ;
    rdfs:label "Toe-off" ;
    rdfs:comment "Push with toe as part of a stride." ;
    hed:hasHedParent hedt:Step .

hedt:Toes a hed:HedTag ;
    rdfs:label "Toes" ;
    rdfs:comment "The terminal digits of the foot." ;
    hed:hasHedParent hedt:Foot .

hedt:Tomato a hed:HedTag ;
    rdfs:label "Tomato" ;
    rdfs:comment "CSS-color 0xFF6347." ;
    hed:hasHedParent hedt:Orange-color .

hedt:Tone a hed:HedTag ;
    rdfs:label "Tone" ;
    rdfs:comment "A musical note, warble, or other sound used as a particular signal on a telephone or answering machine." ;
    hed:hasHedParent hedt:Musical-sound .

hedt:Tonic-clonic-motor-onset-seizure a hed:HedTag ;
    rdfs:label "Tonic-clonic-motor-onset-seizure" ;
