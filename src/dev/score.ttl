hedt:Word a hed:HedTag ;
    rdfs:label "Word" ;
    rdfs:comment "A word is the smallest free form (an item that may be expressed in isolation with semantic or pragmatic content) in a language." ;
    hed:hasHedParent hedt:Language-item .

hedt:Wrist a hed:HedTag ;
    rdfs:label "Wrist" ;
    rdfs:comment "A joint between the distal end of the radius and the proximal row of carpal bones." ;
    hed:hasHedParent hedt:Upper-extremity .

hedt:Write a hed:HedTag ;
    rdfs:label "Write" ;
    rdfs:comment "Communicate or express by means of letters or symbols written or imprinted on a surface." ;
    hed:hasHedParent hedt:Perform .

hedt:X-position-Placeholder a hed:HedPlaceholder ;
