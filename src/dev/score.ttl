hedt:Walk a hed:HedTag ;
    rdfs:label "Walk" ;
    rdfs:comment "Move at a regular pace by lifting and setting down each foot in turn never having both feet off the ground at once." ;
    hed:hasHedParent hedt:Move-lower-extremity .

hedt:Warning a hed:HedTag ;
    rdfs:label "Warning" ;
    rdfs:comment "Something that should warn the participant that the parameters of the task have been or are about to be exceeded such as a warning message about getting too close to the shoulder of the road in a driving task." ;
    hed:hasHedParent hedt:Task-event-role .

hedt:Waterfall a hed:HedTag ;
    rdfs:label "Waterfall" ;
    rdfs:comment "A sudden descent of water over a step or ledge in the bed of a river." ;
    hed:hasHedParent hedt:Natural-feature .

hedt:Wave a hed:HedTag ;
    rdfs:label "Wave" ;
    rdfs:comment "Raise hand and move left and right, as a greeting or sign of departure." ;
    heda:relatedTag hedt:Move-upper-extremity ;
    hed:hasHedParent hedt:Communicate-gesturally .

hedt:Weight-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:weightUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Weight .

hedt:Wheat a hed:HedTag ;
    rdfs:label "Wheat" ;
    rdfs:comment "CSS-color 0xF5DEB3." ;
    hed:hasHedParent hedt:Brown-color .

hedt:Whisper a hed:HedTag ;
    rdfs:label "Whisper" ;
    rdfs:comment "Speak very softly using breath without vocal cords." ;
    hed:hasHedParent hedt:Communicate-vocally .

hedt:Whistle a hed:HedTag ;
    rdfs:label "Whistle" ;
    rdfs:comment "Produce a shrill clear sound by forcing breath out or air in through the puckered lips." ;
    hed:hasHedParent hedt:Communicate-musically .

hedt:White a hed:HedTag ;
    rdfs:label "White" ;
    rdfs:comment "CSS-color 0xFFFFFF." ;
    hed:hasHedParent hedt:White-color .

hedt:WhiteSmoke a hed:HedTag ;
    rdfs:label "WhiteSmoke" ;
    rdfs:comment "CSS-color 0xF5F5F5." ;
    hed:hasHedParent hedt:White-color .

hedt:Wicket-spikes a hed:HedTag ;
    rdfs:label "Wicket-spikes" ;
    rdfs:comment "Spike-like monophasic negative single waves or trains of waves occurring over the temporal regions during drowsiness that have an arcuate or mu-like appearance. These are mainly seen in older individuals and represent a benign variant that is of little clinical significance." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Widen-eyes a hed:HedTag ;
    rdfs:label "Widen-eyes" ;
    rdfs:comment "Open eyes and possibly with eyebrows lifted especially to express surprise or fear." ;
    heda:relatedTag hedt:Move-eyes,
        hedt:Move-face ;
    hed:hasHedParent hedt:Communicate-gesturally .

hedt:Width-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:physicalLengthUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Width .

hedt:Wink a hed:HedTag ;
    rdfs:label "Wink" ;
