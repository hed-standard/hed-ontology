    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Theta-activity-morphology .

hedt:Thigh a hed:HedTag ;
    rdfs:label "Thigh" ;
    rdfs:comment "Upper part of the leg between hip and knee." ;
    hed:hasHedParent hedt:Lower-extremity .

hedt:Thistle a hed:HedTag ;
    rdfs:label "Thistle" ;
    rdfs:comment "CSS-color 0xD8BFD8." ;
    hed:hasHedParent hedt:Purple-color .

hedt:Threat a hed:HedTag ;
    rdfs:label "Threat" ;
