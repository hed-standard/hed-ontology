    hed:hasHedParent hedt:Organizational-property .

hedt:Evolving-periodic-discharge-dynamics a hed:HedTag ;
    rdfs:label "Evolving-periodic-discharge-dynamics" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-dynamics .

hedt:Expected a hed:HedTag ;
    rdfs:label "Expected" ;
    rdfs:comment "Considered likely, probable or anticipated. Something of low information value as in frequent non-targets in an RSVP paradigm." ;
    heda:relatedTag hedt:Unexpected ;
    heda:suggestedTag hedt:Target ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:Experimental-intertrial a hed:HedTag ;
    rdfs:label "Experimental-intertrial" ;
    rdfs:comment "A tag used to indicate a part of the experiment between trials usually where nothing is happening." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Experimental-note a hed:HedTag ;
    rdfs:label "Experimental-note" ;
    rdfs:comment "A brief written record about the experiment." ;
    hed:hasHedParent hedt:Metadata .

hedt:Experimental-trial a hed:HedTag ;
    rdfs:label "Experimental-trial" ;
    rdfs:comment "Designates a run or execution of an activity, for example, one execution of a script. A tag used to indicate a particular organizational part in the experimental design often containing a stimulus-response pair or stimulus-response-feedback triad." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Explicit a hed:HedTag ;
    rdfs:label "Explicit" ;
    rdfs:comment "Stated clearly and in detail, leaving no room for confusion or doubt." ;
    heda:relatedTag hedt:Implicit ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Eye-closure-sensitivity a hed:HedTag ;
    rdfs:label "Eye-closure-sensitivity" ;
    rdfs:comment "Eye closure sensitivity." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Eyelid-location a hed:HedTag ;
    rdfs:label "Eyelid-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Eyelid-myoclonia-absence-seizure a hed:HedTag ;
    rdfs:label "Eyelid-myoclonia-absence-seizure" ;
    rdfs:comment "Eyelid myoclonia are myoclonic jerks of the eyelids and upward deviation of the eyes, often precipitated by closing the eyes or by light. Eyelid myoclonia can be associated with absences, but also can be motor seizures without a corresponding absence, making them difficult to categorize. The 2017 classification groups them with nonmotor (absence) seizures, which may seem counterintuitive, but the myoclonia in this instance is meant to link with absence, rather than with nonmotor. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Absence-seizure .

hedt:Face-location a hed:HedTag ;
    rdfs:label "Face-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Facilitating-factor-alcohol a hed:HedTag ;
    rdfs:label "Facilitating-factor-alcohol" ;
    heda:inLibrary "score" ;
