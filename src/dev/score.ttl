@prefix hed: <https://purl.org/hed/core#> .
@prefix heda: <https://purl.org/hed/attributes/#> .
@prefix hedt: <https://purl.org/hed/tag#> .
@prefix hedu: <https://purl.org/hed/aux#> .
@prefix hedum: <https://purl.org/hed/aux/unit_modifier#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

heda:SIUnit a owl:DatatypeProperty ;
    rdfs:label "SIUnit" ;
    rdfs:comment "A schema attribute indicating that this unit element is an SI unit and can be modified by multiple and submultiple names. Note that some units such as byte are designated as SI units although they are not part of the standard." ;
    rdfs:domain hed:HedUnit ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitProperty true .

heda:SIUnitModifier a owl:DatatypeProperty ;
    rdfs:label "SIUnitModifier" ;
    rdfs:comment "A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a base unit rather than a unit symbol." ;
    rdfs:domain hed:HedUnitModifier ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitModifierProperty true .

heda:SIUnitSymbolModifier a owl:DatatypeProperty ;
    rdfs:label "SIUnitSymbolModifier" ;
    rdfs:comment "A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a unit symbol rather than a base symbol." ;
    rdfs:domain hed:HedUnitModifier ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitModifierProperty true .

heda:allowedCharacter a owl:DatatypeProperty ;
    rdfs:label "allowedCharacter" ;
    rdfs:comment "A schema attribute of value classes specifying a special character that is allowed in expressing the value of a placeholder. Normally the allowed characters are listed individually. However, the word letters designates the upper and lower case alphabetic characters and the word digits designates the digits 0-9. The word blank designates the blank character." ;
    rdfs:domain hed:HedValueClass ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:valueClassProperty true .

heda:boolProperty a owl:AnnotationProperty ;
    rdfs:label "boolProperty" ;
    rdfs:comment "Indicates that the schema attribute represents something that is either true or false and does not have a value. Attributes without this value are assumed to have string values." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:conversionFactor a owl:DatatypeProperty ;
    rdfs:label "conversionFactor" ;
    rdfs:comment "The multiplicative factor to multiply these units to convert to default units." ;
    rdfs:domain hed:HedUnit,
        hed:HedUnitModifier ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:unitModifierProperty true ;
    heda:unitProperty true .

heda:defaultUnits a owl:ObjectProperty ;
    rdfs:label "defaultUnits" ;
    rdfs:comment "A schema attribute of unit classes specifying the default units to use if the placeholder has a unit class but the substituted value has no units." ;
    rdfs:domain hed:HedUnitClass ;
    rdfs:range hed:HedUnit ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:unitClassProperty true .

heda:deprecatedFrom a owl:DatatypeProperty ;
    rdfs:label "deprecatedFrom" ;
    rdfs:comment "Indicates that this element is deprecated. The value of the attribute is the latest schema version in which the element appeared in undeprecated form." ;
    rdfs:domain hed:HedElement ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:elementProperty true .

heda:elementProperty a owl:AnnotationProperty ;
    rdfs:label "elementProperty" ;
    rdfs:comment "Indicates this schema attribute can apply to any type of element(tag term, unit class, etc)." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:extensionAllowed a owl:DatatypeProperty ;
    rdfs:label "extensionAllowed" ;
    rdfs:comment "A schema attribute indicating that users can add unlimited levels of child nodes under this tag. This tag is propagated to child nodes with the exception of the hashtag placeholders." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:isInheritedProperty true ;
    heda:nodeProperty true .

heda:inLibrary a owl:DatatypeProperty ;
    rdfs:label "inLibrary" ;
    rdfs:comment "Indicates this schema element came from the named library schema, not the standard schema. This attribute is added by tools when a library schema is merged into its partnered standard schema." ;
    rdfs:domain hed:HedElement ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:elementProperty true .

heda:isInheritedProperty a owl:AnnotationProperty ;
    rdfs:label "isInheritedProperty" ;
    rdfs:comment "Indicates that this attribute is inherited by child nodes. This property only applies to schema attributes for nodes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:nodeProperty a owl:AnnotationProperty ;
    rdfs:label "nodeProperty" ;
    rdfs:comment "Indicates this schema attribute applies to node (tag-term) elements. This was added to allow for an attribute to apply to multiple elements." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:recommended a owl:DatatypeProperty ;
    rdfs:label "recommended" ;
    rdfs:comment "A schema attribute indicating that the event-level HED string should include this tag." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:relatedTag a owl:ObjectProperty ;
    rdfs:label "relatedTag" ;
    rdfs:comment "A schema attribute suggesting HED tags that are closely related to this tag. This attribute is used by tagging tools." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedTag ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:isInheritedProperty true ;
    heda:nodeProperty true .

heda:requireChild a owl:DatatypeProperty ;
    rdfs:label "requireChild" ;
    rdfs:comment "A schema attribute indicating that one of the node elements descendants must be included when using this tag." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:required a owl:DatatypeProperty ;
    rdfs:label "required" ;
    rdfs:comment "A schema attribute indicating that every event-level HED string should include this tag." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:reserved a owl:DatatypeProperty ;
    rdfs:label "reserved" ;
    rdfs:comment "A schema attribute indicating that this tag has special meaning and requires special handling by tools." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:rooted a owl:ObjectProperty ;
    rdfs:label "rooted" ;
    rdfs:comment "Indicates a top-level library schema node is identical to a node of the same name in the partnered standard schema. This attribute can only appear in nodes that have the inLibrary schema attribute." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedTag ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:nodeProperty true .

heda:suggestedTag a owl:ObjectProperty ;
    rdfs:label "suggestedTag" ;
    rdfs:comment "A schema attribute that indicates another tag  that is often associated with this tag. This attribute is used by tagging tools to provide tagging suggestions." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedTag ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:isInheritedProperty true ;
    heda:nodeProperty true .

heda:tagGroup a owl:DatatypeProperty ;
    rdfs:label "tagGroup" ;
    rdfs:comment "A schema attribute indicating the tag can only appear inside a tag group." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:takesValue a owl:DatatypeProperty ;
    rdfs:label "takesValue" ;
    rdfs:comment "A schema attribute indicating the tag is a hashtag placeholder that is expected to be replaced with a user-defined value." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:topLevelTagGroup a owl:DatatypeProperty ;
    rdfs:label "topLevelTagGroup" ;
    rdfs:comment "A schema attribute indicating that this tag (or its descendants) can only appear in a top-level tag group. A tag group can have at most one tag with this attribute." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:unique a owl:DatatypeProperty ;
    rdfs:label "unique" ;
    rdfs:comment "A schema attribute indicating that only one of this tag or its descendants can be used  in the event-level HED string." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:unitClass a owl:ObjectProperty ;
    rdfs:label "unitClass" ;
    rdfs:comment "A schema attribute specifying which unit class this value tag belongs to." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedUnitClass ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:nodeProperty true .

heda:unitClassProperty a owl:AnnotationProperty ;
    rdfs:label "unitClassProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to unit classes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:unitModifierProperty a owl:AnnotationProperty ;
    rdfs:label "unitModifierProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to unit modifier classes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:unitPrefix a owl:DatatypeProperty ;
    rdfs:label "unitPrefix" ;
    rdfs:comment "A schema attribute applied specifically to unit elements to designate that the unit indicator is a prefix (e.g., dollar sign in the currency units)." ;
    rdfs:domain hed:HedUnit ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitProperty true .

heda:unitProperty a owl:AnnotationProperty ;
    rdfs:label "unitProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to units within a unit class." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:unitSymbol a owl:DatatypeProperty ;
    rdfs:label "unitSymbol" ;
    rdfs:comment "A schema attribute indicating this tag is an abbreviation or symbol representing a type of unit. Unit symbols represent both the singular and the plural and thus cannot be pluralized." ;
    rdfs:domain hed:HedUnit ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitProperty true .

heda:valueClass a owl:ObjectProperty ;
    rdfs:label "valueClass" ;
    rdfs:comment "A schema attribute specifying which value class this value tag belongs to." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedValueClass ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:nodeProperty true .

heda:valueClassProperty a owl:AnnotationProperty ;
    rdfs:label "valueClassProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to value classes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

<https://purl.org/hed/aux#$> a hed:HedUnit ;
    rdfs:label "$" ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:currencyUnits ;
    heda:unitPrefix true ;
    heda:unitSymbol true .

hedu:B a hed:HedUnit ;
    rdfs:label "B" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:memorySizeUnits ;
    heda:unitSymbol true .

hedu:Hz a hed:HedUnit ;
    rdfs:label "Hz" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:frequencyUnits ;
    heda:unitSymbol true .

hedu:T a hed:HedUnit ;
    rdfs:label "T" ;
    heda:SIUnit true ;
    heda:conversionFactor "10^-15" ;
    heda:unitClass hedu:magneticFieldUnits ;
    heda:unitSymbol true .

hedu:Volt a hed:HedUnit ;
    rdfs:label "Volt" ;
    heda:SIUnit true ;
    heda:conversionFactor "0.000001" ;
    heda:unitClass hedu:electricPotentialUnits .

hedu:byte a hed:HedUnit ;
    rdfs:label "byte" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:memorySizeUnits .

hedu:candela a hed:HedUnit ;
    rdfs:label "candela" ;
    rdfs:comment "Units used to express light intensity." ;
    heda:SIUnit true ;
    heda:unitClass hedu:intensityUnits .

hedu:cd a hed:HedUnit ;
    rdfs:label "cd" ;
    rdfs:comment "Units used to express light intensity." ;
    heda:SIUnit true ;
    heda:unitClass hedu:intensityUnits ;
    heda:unitSymbol true .

hedu:dB a hed:HedUnit ;
    rdfs:label "dB" ;
    rdfs:comment "Intensity expressed as ratio to a threshold. May be used for sound intensity." ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:intensityUnits ;
    heda:unitSymbol true .

hedu:day a hed:HedUnit ;
    rdfs:label "day" ;
    heda:conversionFactor "86400" ;
    heda:unitClass hedu:timeUnits .

hedu:degree a hed:HedUnit ;
    rdfs:label "degree" ;
    heda:conversionFactor "0.0174533" ;
    heda:unitClass hedu:angleUnits .

hedu:degree_Celsius a hed:HedUnit ;
    rdfs:label "degree Celsius" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:temperatureUnits .

hedu:dollar a hed:HedUnit ;
    rdfs:label "dollar" ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:currencyUnits .

hedu:euro a hed:HedUnit ;
    rdfs:label "euro" ;
    heda:unitClass hedu:currencyUnits .

hedu:foot a hed:HedUnit ;
    rdfs:label "foot" ;
    heda:conversionFactor "0.3048" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:g a hed:HedUnit ;
    rdfs:label "g" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:weightUnits ;
    heda:unitSymbol true .

hedu:gram a hed:HedUnit ;
    rdfs:label "gram" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:weightUnits .

hedu:hertz a hed:HedUnit ;
    rdfs:label "hertz" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:frequencyUnits .

hedu:hour a hed:HedUnit ;
    rdfs:label "hour" ;
    rdfs:comment "Should be in 24-hour format." ;
    heda:conversionFactor "3600" ;
    heda:unitClass hedu:timeUnits .

hedu:inch a hed:HedUnit ;
    rdfs:label "inch" ;
    heda:conversionFactor "0.0254" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:kph a hed:HedUnit ;
    rdfs:label "kph" ;
    heda:conversionFactor "0.277778" ;
    heda:unitClass hedu:speedUnits ;
    heda:unitSymbol true .

hedu:lb a hed:HedUnit ;
    rdfs:label "lb" ;
    heda:conversionFactor "453.592" ;
    heda:unitClass hedu:weightUnits .

hedu:m a hed:HedUnit ;
    rdfs:label "m" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:physicalLengthUnits ;
    heda:unitSymbol true .

hedu:m-per-s a hed:HedUnit ;
    rdfs:label "m-per-s" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:speedUnits ;
    heda:unitSymbol true .

hedu:m-per-s_2 a hed:HedUnit ;
    rdfs:label "m-per-s^2" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:accelerationUnits ;
    heda:unitSymbol true .

hedu:m-per-s_3 a hed:HedUnit ;
    rdfs:label "m-per-s^3" ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:jerkUnits ;
    heda:unitSymbol true .

hedu:m_2 a hed:HedUnit ;
    rdfs:label "m^2" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:areaUnits ;
    heda:unitSymbol true .

hedu:m_3 a hed:HedUnit ;
    rdfs:label "m^3" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:volumeUnits ;
    heda:unitSymbol true .

hedu:meter a hed:HedUnit ;
    rdfs:label "meter" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:metre a hed:HedUnit ;
    rdfs:label "metre" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:mile a hed:HedUnit ;
    rdfs:label "mile" ;
    heda:conversionFactor "1609.34" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:minute a hed:HedUnit ;
    rdfs:label "minute" ;
    heda:conversionFactor "60" ;
    heda:unitClass hedu:timeUnits .

hedu:mph a hed:HedUnit ;
    rdfs:label "mph" ;
    heda:conversionFactor "0.44704" ;
    heda:unitClass hedu:speedUnits ;
    heda:unitSymbol true .

hedu:oC a hed:HedUnit ;
    rdfs:label "oC" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:temperatureUnits ;
    heda:unitSymbol true .

hedu:point a hed:HedUnit ;
    rdfs:label "point" ;
    heda:unitClass hedu:currencyUnits .

hedu:posixPath a hed:HedValueClass ;
    rdfs:label "posixPath" ;
    rdfs:comment "Posix path specification." ;
    heda:allowedCharacter "/",
        ":",
        "digits",
        "letters" .

hedu:pound a hed:HedUnit ;
    rdfs:label "pound" ;
    heda:conversionFactor "453.592" ;
    heda:unitClass hedu:weightUnits .

hedu:rad a hed:HedUnit ;
    rdfs:label "rad" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:angleUnits ;
    heda:unitSymbol true .

hedu:radian a hed:HedUnit ;
    rdfs:label "radian" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:angleUnits .

hedu:s a hed:HedUnit ;
    rdfs:label "s" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:timeUnits ;
    heda:unitSymbol true .

hedu:second a hed:HedUnit ;
    rdfs:label "second" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:timeUnits .

hedu:tesla a hed:HedUnit ;
    rdfs:label "tesla" ;
    heda:SIUnit true ;
    heda:conversionFactor "10^-15" ;
    heda:unitClass hedu:magneticFieldUnits .

hedu:v a hed:HedUnit ;
    rdfs:label "v" ;
    heda:SIUnit true ;
    heda:conversionFactor "0.000001" ;
    heda:unitClass hedu:electricPotentialUnits ;
    heda:unitSymbol true .

hedum:E a hed:HedUnitModifier ;
    rdfs:label "E" ;
    rdfs:comment "SI unit multiple representing 10^18." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^18" .

hedum:G a hed:HedUnitModifier ;
    rdfs:label "G" ;
    rdfs:comment "SI unit multiple representing 10^9." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^9" .

hedum:M a hed:HedUnitModifier ;
    rdfs:label "M" ;
    rdfs:comment "SI unit multiple representing 10^6." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^6" .

hedum:P a hed:HedUnitModifier ;
    rdfs:label "P" ;
    rdfs:comment "SI unit multiple representing 10^15." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^15" .

hedum:T a hed:HedUnitModifier ;
    rdfs:label "T" ;
    rdfs:comment "SI unit multiple representing 10^12." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^12" .

hedum:Y a hed:HedUnitModifier ;
    rdfs:label "Y" ;
    rdfs:comment "SI unit multiple representing 10^24." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^24" .

hedum:Z a hed:HedUnitModifier ;
    rdfs:label "Z" ;
    rdfs:comment "SI unit multiple representing 10^21." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^21" .

hedum:a a hed:HedUnitModifier ;
    rdfs:label "a" ;
    rdfs:comment "SI unit submultiple representing 10^-18." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-18" .

hedum:atto a hed:HedUnitModifier ;
    rdfs:label "atto" ;
    rdfs:comment "SI unit submultiple representing 10^-18." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-18" .

hedum:c a hed:HedUnitModifier ;
    rdfs:label "c" ;
    rdfs:comment "SI unit submultiple representing 10^-2." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "0.01" .

hedum:centi a hed:HedUnitModifier ;
    rdfs:label "centi" ;
    rdfs:comment "SI unit submultiple representing 10^-2." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "0.01" .

hedum:d a hed:HedUnitModifier ;
    rdfs:label "d" ;
    rdfs:comment "SI unit submultiple representing 10^-1." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "0.1" .

hedum:da a hed:HedUnitModifier ;
    rdfs:label "da" ;
    rdfs:comment "SI unit multiple representing 10^1." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10.0" .

hedum:deca a hed:HedUnitModifier ;
    rdfs:label "deca" ;
    rdfs:comment "SI unit multiple representing 10^1." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10.0" .

hedum:deci a hed:HedUnitModifier ;
    rdfs:label "deci" ;
    rdfs:comment "SI unit submultiple representing 10^-1." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "0.1" .

hedum:exa a hed:HedUnitModifier ;
    rdfs:label "exa" ;
    rdfs:comment "SI unit multiple representing 10^18." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^18" .

hedum:f a hed:HedUnitModifier ;
    rdfs:label "f" ;
    rdfs:comment "SI unit submultiple representing 10^-15." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-15" .

hedum:femto a hed:HedUnitModifier ;
    rdfs:label "femto" ;
    rdfs:comment "SI unit submultiple representing 10^-15." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-15" .

hedum:giga a hed:HedUnitModifier ;
    rdfs:label "giga" ;
    rdfs:comment "SI unit multiple representing 10^9." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^9" .

hedum:h a hed:HedUnitModifier ;
    rdfs:label "h" ;
    rdfs:comment "SI unit multiple representing 10^2." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "100.0" .

hedum:hecto a hed:HedUnitModifier ;
    rdfs:label "hecto" ;
    rdfs:comment "SI unit multiple representing 10^2." ;
    heda:SIUnitModifier true ;
