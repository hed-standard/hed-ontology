    heda:requireChild true ;
    hed:hasHedParent hedt:Absence-of-posterior-dominant-rhythm .

hedt:Abundant-finding-incidence a hed:HedTag ;
    rdfs:label "Abundant-finding-incidence" ;
    rdfs:comment "Greater than 1/10 s)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-incidence .

hedt:Abundant-finding-prevalence a hed:HedTag ;
    rdfs:label "Abundant-finding-prevalence" ;
    rdfs:comment "50 to 89 percent." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-prevalence .

hedt:Acceleration a hed:HedTag ;
    rdfs:label "Acceleration" ;
    rdfs:comment "Magnitude of the rate of change in either speed or direction. The direction of change should be given separately." ;
    hed:hasHedParent hedt:Rate-of-change .

hedt:Activation-of-pre-existing-epileptogenic-area-intermittent-photic-stimulation-effect a hed:HedTag ;
    rdfs:label "Activation-of-pre-existing-epileptogenic-area-intermittent-photic-stimulation-effect" ;
