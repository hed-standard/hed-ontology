    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Episode-consciousness .

hedt:Episode-consciousness-mildly-affected a hed:HedTag ;
    rdfs:label "Episode-consciousness-mildly-affected" ;
    heda:inLibrary "score" ;
