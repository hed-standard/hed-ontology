    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Variable-appearance-mode .

hedt:Varying a hed:HedTag ;
    rdfs:label "Varying" ;
    rdfs:comment "Differing in size, amount, degree, or nature." ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Vegetative a hed:HedTag ;
    rdfs:label "Vegetative" ;
    rdfs:comment "A state of wakefulness and conscience, but (in contrast to coma) with involuntary opening of the eyes and movements (such as teeth grinding, yawning, or thrashing of the extremities)." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:Version-identifier-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Usually is a semantic version." ;
    heda:takesValue true ;
    hed:hasHedParent hedt:Version-identifier .

hedt:Vertex-wave a hed:HedTag ;
    rdfs:label "Vertex-wave" ;
    rdfs:comment "Sharp potential, maximal at the vertex, negative relative to other areas, apparently occurring spontaneously during sleep or in response to a sensory stimulus during sleep or wakefulness. May be single or repetitive. Amplitude varies but rarely exceeds 250 microV. Abbreviation: V wave. Synonym: vertex sharp wave." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-amplitude-asymmetry,
        hedt:Finding-significance-to-recording,
        hedt:Sensors ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Very-brief-periodic-discharge-duration-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Very-brief-periodic-discharge-duration .

hedt:Very-long-periodic-discharge-duration-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Very-long-periodic-discharge-duration .

hedt:Vestibular-attribute a hed:HedTag ;
    rdfs:label "Vestibular-attribute" ;
    rdfs:comment "Pertaining to the sense of balance or body position." ;
    hed:hasHedParent hedt:Sensory-attribute .

hedt:Vestibular-presentation a hed:HedTag ;
    rdfs:label "Vestibular-presentation" ;
    rdfs:comment "The sense balance used in the presentation to the user." ;
    hed:hasHedParent hedt:Sensory-presentation .

hedt:Video-clip a hed:HedTag ;
    rdfs:label "Video-clip" ;
    rdfs:comment "A short segment of video." ;
    hed:hasHedParent hedt:Media-clip .

hedt:Violet a hed:HedTag ;
    rdfs:label "Violet" ;
    rdfs:comment "CSS-color 0xEE82EE." ;
    hed:hasHedParent hedt:Purple-color .

hedt:Virtual-world a hed:HedTag ;
    rdfs:label "Virtual-world" ;
    rdfs:comment "Using technology that creates immersive, computer-generated experiences that a person can interact with and navigate through. The digital content is generally delivered to the user through some type of headset and responds to changes in head position or through interaction with other types of sensors. Existing in a virtual setting such as a simulation or game environment." ;
    hed:hasHedParent hedt:Environmental-property .

hedt:Visceral-location-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Visceral-location .

hedt:Vocalize a hed:HedTag ;
    rdfs:label "Vocalize" ;
    rdfs:comment "Utter vocal sounds." ;
    hed:hasHedParent hedt:Communicate-musically .

hedt:Vocalized-sound a hed:HedTag ;
    rdfs:label "Vocalized-sound" ;
    rdfs:comment "Musical sound produced by vocal cords in a biological agent." ;
    hed:hasHedParent hedt:Musical-sound .

hedt:Volume-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:volumeUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Volume .

hedt:Waist a hed:HedTag ;
    rdfs:label "Waist" ;
    rdfs:comment "The abdominal circumference at the navel." ;
    hed:hasHedParent hedt:Torso .

hedt:Waiting-for a hed:HedTag ;
    rdfs:label "Waiting-for" ;
