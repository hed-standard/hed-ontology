    heda:valueClass hedu:nameClass ;
    hed:hasHedParent hedt:Label .

hedt:Lambda-wave a hed:HedTag ;
    rdfs:label "Lambda-wave" ;
    rdfs:comment "Diphasic sharp transient occurring over occipital regions of the head of waking subjects during visual exploration. The main component is positive relative to other areas. Time-locked to saccadic eye movement. Amplitude varies but is generally below 50 micro V." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Physiologic-pattern .

hedt:Lane a hed:HedTag ;
    rdfs:label "Lane" ;
