    rdfs:comment "Limited to the stimulus-train." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-frequency ;
    hed:hasHedParent hedt:Intermittent-photic-stimulation-effect .

hedt:Generalized-photoparoxysmal-intermittent-photic-stimulation-response-self-sustained a hed:HedTag ;
    rdfs:label "Generalized-photoparoxysmal-intermittent-photic-stimulation-response-self-sustained" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-frequency ;
    hed:hasHedParent hedt:Intermittent-photic-stimulation-effect .

hedt:Go-signal a hed:HedTag ;
    rdfs:label "Go-signal" ;
    rdfs:comment "An indicator to proceed with a planned action." ;
    heda:relatedTag hedt:Stop-signal ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:Gradual-periodic-discharge-onset a hed:HedTag ;
    rdfs:label "Gradual-periodic-discharge-onset" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-onset .

hedt:Grayscale a hed:HedTag ;
    rdfs:label "Grayscale" ;
    rdfs:comment "Using a color map composed of shades of gray, varying from black at the weakest intensity to white at the strongest." ;
    hed:hasHedParent hedt:Color .

hedt:Greater-than-3-periodic-discharge-phases a hed:HedTag ;
    rdfs:label "Greater-than-3-periodic-discharge-phases" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Number-of-periodic-discharge-phases .

hedt:HSV-value a hed:HedTag ;
    rdfs:label "HSV-value" ;
    rdfs:comment "An attribute of a visual sensation according to which an area appears to emit more or less light." ;
    hed:hasHedParent hedt:HSV-color .

hedt:Healthy a hed:HedTag ;
    rdfs:label "Healthy" ;
    rdfs:comment "Having no significant health-related issues." ;
    heda:relatedTag hedt:Sick ;
    hed:hasHedParent hedt:Agent-physiological-state .

hedt:Height a hed:HedTag ;
    rdfs:label "Height" ;
    rdfs:comment "The vertical measurement or distance from the base to the top of an object." ;
    hed:hasHedParent hedt:Size .

hedt:Hemi-location a hed:HedTag ;
    rdfs:label "Hemi-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:High-periodic-discharge-absolute-amplitude a hed:HedTag ;
    rdfs:label "High-periodic-discharge-absolute-amplitude" ;
    rdfs:comment "Greater than 200 microV." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-absolute-amplitude .

hedt:High-posterior-dominant-rhythm-amplitude-range a hed:HedTag ;
    rdfs:label "High-posterior-dominant-rhythm-amplitude-range" ;
    rdfs:comment "High (more than 70 microV)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-amplitude-range .

hedt:Horizontally-oriented a hed:HedTag ;
    rdfs:label "Horizontally-oriented" ;
    rdfs:comment "Oriented parallel to or in the plane of the horizon." ;
    heda:relatedTag hedt:Vertically-oriented ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:Hot a hed:HedTag ;
    rdfs:label "Hot" ;
    rdfs:comment "Having an excess of heat." ;
    heda:relatedTag hedt:Cold ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Hue a hed:HedTag ;
    rdfs:label "Hue" ;
    rdfs:comment "Attribute of a visual sensation according to which an area appears to be similar to one of the perceived colors." ;
    hed:hasHedParent hedt:HSV-color .

hedt:Hyperkinetic-motor-seizure a hed:HedTag ;
    rdfs:label "Hyperkinetic-motor-seizure" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Hyperventilation a hed:HedTag ;
    rdfs:label "Hyperventilation" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulator .

hedt:Hyperventilation-excellent-effort a hed:HedTag ;
    rdfs:label "Hyperventilation-excellent-effort" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Quality-of-hyperventilation .

hedt:Hyperventilation-good-effort a hed:HedTag ;
    rdfs:label "Hyperventilation-good-effort" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Quality-of-hyperventilation .

hedt:Hyperventilation-poor-effort a hed:HedTag ;
    rdfs:label "Hyperventilation-poor-effort" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Quality-of-hyperventilation .

hedt:Hyperventilation-provoked a hed:HedTag ;
    rdfs:label "Hyperventilation-provoked" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Provocative-factor .

hedt:Hyperventilation-refused-procedure a hed:HedTag ;
    rdfs:label "Hyperventilation-refused-procedure" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Quality-of-hyperventilation .

hedt:Hypopnea-respiration a hed:HedTag ;
    rdfs:label "Hypopnea-respiration" ;
    rdfs:comment "Add duration (range in seconds) and comments in free text" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Respiration-feature .

hedt:ID a hed:HedTag ;
    rdfs:label "ID" ;
    rdfs:comment "An alphanumeric name that identifies either a unique object or a unique class of objects. Here the object or class may be an idea, physical countable object (or class), or physical uncountable substance (or class)." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Informational-property .

hedt:Ictal-EEG-patterns-obscured-by-artifacts a hed:HedTag ;
    rdfs:label "Ictal-EEG-patterns-obscured-by-artifacts" ;
    rdfs:comment "The interpretation of the EEG is not possible due to artifacts." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Ictal-EEG-patterns .

hedt:Implicit a hed:HedTag ;
    rdfs:label "Implicit" ;
    rdfs:comment "Implied though not plainly expressed." ;
    heda:relatedTag hedt:Explicit ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Inappropriate-action a hed:HedTag ;
    rdfs:label "Inappropriate-action" ;
    rdfs:comment "An action not in keeping with what is correct or proper for the task." ;
    heda:relatedTag hedt:Appropriate-action ;
    hed:hasHedParent hedt:Task-action-type .

hedt:Inaudible a hed:HedTag ;
    rdfs:label "Inaudible" ;
    rdfs:comment "A sound below the threshold of perception of the participant." ;
    heda:relatedTag hedt:Audible ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Incongruent a hed:HedTag ;
    rdfs:label "Incongruent" ;
    rdfs:comment "Not in agreement or harmony." ;
    heda:relatedTag hedt:Congruent ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Increasing a hed:HedTag ;
    rdfs:label "Increasing" ;
    rdfs:comment "Becoming greater in size, amount, or degree." ;
    heda:relatedTag hedt:Decreasing ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Indicator-variable a hed:HedTag ;
    rdfs:label "Indicator-variable" ;
    rdfs:comment "An aspect of the experiment or task that is measured as task conditions are varied during the experiment. Experiment indicators are sometimes called dependent variables." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Induced-sleep a hed:HedTag ;
    rdfs:label "Induced-sleep" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Sleep-modulator .

hedt:Intermediate-periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Intermediate-periodic-discharge-duration" ;
    rdfs:comment "1 to 4.9 min." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-duration .

hedt:Intermittent-appearance-mode a hed:HedTag ;
    rdfs:label "Intermittent-appearance-mode" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Appearance-mode .

hedt:Intermittent-photic-stimulation a hed:HedTag ;
    rdfs:label "Intermittent-photic-stimulation" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Intermittent-photic-stimulation-effect ;
    hed:hasHedParent hedt:Stimulation-modulator .

hedt:Invalid a hed:HedTag ;
    rdfs:label "Invalid" ;
    rdfs:comment "Not allowed or not conforming to the correct format or specifications." ;
    heda:relatedTag hedt:Valid ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Involuntary a hed:HedTag ;
    rdfs:label "Involuntary" ;
    rdfs:comment "An action that is not made by choice. In the body, involuntary actions (such as blushing) occur automatically, and cannot be controlled by choice." ;
    heda:relatedTag hedt:Voluntary ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Item-count a hed:HedTag ;
    rdfs:label "Item-count" ;
    rdfs:comment "The integer count of something which is usually grouped with the entity it is counting. (Item-count/3, A) indicates that 3 of A have occurred up to this point." ;
    hed:hasHedParent hedt:Quantitative-value .

hedt:Item-index a hed:HedTag ;
    rdfs:label "Item-index" ;
    rdfs:comment "The index of an item in a collection, sequence or other structure. (A (Item-index/3, B)) means that A is item number 3 in B." ;
    hed:hasHedParent hedt:Quantitative-value .

hedt:Item-interval a hed:HedTag ;
    rdfs:label "Item-interval" ;
    rdfs:comment "An integer indicating how many items or entities have passed since the last one of these. An item interval of 0 indicates the current item." ;
    hed:hasHedParent hedt:Quantitative-value .

hedt:Jerk-rate a hed:HedTag ;
    rdfs:label "Jerk-rate" ;
    rdfs:comment "Magnitude of the rate at which the acceleration of an object changes with respect to time. The direction of change should be given separately." ;
    hed:hasHedParent hedt:Rate-of-change .

hedt:Keyboard a hed:HedTag ;
    rdfs:label "Keyboard" ;
    rdfs:comment "A device consisting of mechanical keys that are pressed to create input to a computer." ;
    hed:hasHedParent hedt:Input-device .

hedt:Keyboard-key a hed:HedTag ;
    rdfs:label "Keyboard-key" ;
    rdfs:comment "A button on a keyboard usually representing letters, numbers, functions, or symbols." ;
    hed:hasHedParent hedt:Keyboard .

hedt:Keypad a hed:HedTag ;
    rdfs:label "Keypad" ;
    rdfs:comment "A device consisting of keys, usually in a block arrangement, that provides limited input to a system." ;
    hed:hasHedParent hedt:Input-device .

hedt:Keypad-key a hed:HedTag ;
    rdfs:label "Keypad-key" ;
    rdfs:comment "A key on a separate section of a computer keyboard that groups together numeric keys and those for mathematical or other special functions in an arrangement like that of a calculator." ;
    hed:hasHedParent hedt:Keypad .

hedt:Label a hed:HedTag ;
    rdfs:label "Label" ;
    rdfs:comment "A string of 20 or fewer characters identifying something. Labels usually refer to general classes of things while IDs refer to specific instances. A term that is associated with some entity. A brief description given for purposes of identification. An identifying or descriptive marker that is attached to an object." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Informational-property .

hedt:Large a hed:HedTag ;
    rdfs:label "Large" ;
    rdfs:comment "Having a great extent such as in physical dimensions, period of time, amplitude or frequency." ;
    heda:relatedTag hedt:Small ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Left-side-of a hed:HedTag ;
    rdfs:label "Left-side-of" ;
    rdfs:comment "(A, (Left-side-of, B)) means A is located on the left side of B usually as part of B." ;
    heda:relatedTag hedt:Right-side-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Leg-location a hed:HedTag ;
    rdfs:label "Leg-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Length a hed:HedTag ;
    rdfs:label "Length" ;
    rdfs:comment "The linear extent in space from one end of something to the other end, or the extent of something from beginning to end." ;
    hed:hasHedParent hedt:Size .

hedt:Library-name a hed:HedTag ;
    rdfs:label "Library-name" ;
    rdfs:comment "Official name of a HED library." ;
    hed:hasHedParent hedt:Metadata .

hedt:Long-periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Long-periodic-discharge-duration" ;
    rdfs:comment "5 to 59 min." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-duration .

hedt:Loud a hed:HedTag ;
    rdfs:label "Loud" ;
    rdfs:comment "Having a perceived high intensity of sound." ;
    heda:relatedTag hedt:Quiet ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Loudness a hed:HedTag ;
    rdfs:label "Loudness" ;
    rdfs:comment "Perceived intensity of a sound." ;
    hed:hasHedParent hedt:Auditory-attribute .

hedt:Low-periodic-discharge-absolute-amplitude a hed:HedTag ;
    rdfs:label "Low-periodic-discharge-absolute-amplitude" ;
    rdfs:comment "20 to 49 microV." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-absolute-amplitude .

hedt:Low-posterior-dominant-rhythm-amplitude-range a hed:HedTag ;
    rdfs:label "Low-posterior-dominant-rhythm-amplitude-range" ;
    rdfs:comment "Low (less than 20 microV)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-amplitude-range .

hedt:Manual-eye-closure a hed:HedTag ;
    rdfs:label "Manual-eye-closure" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Eye-modulator .

hedt:Manual-eye-opening a hed:HedTag ;
    rdfs:label "Manual-eye-opening" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Eye-modulator .

hedt:Masked a hed:HedTag ;
    rdfs:label "Masked" ;
    rdfs:comment "Information exists but is not provided or is partially obscured due to security,  privacy, or other concerns." ;
    heda:relatedTag hedt:Unmasked ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Measurement-device a hed:HedTag ;
    rdfs:label "Measurement-device" ;
    rdfs:comment "A device in which a measure function inheres." ;
    hed:hasHedParent hedt:Device .

hedt:Medication-administered-during-recording a hed:HedTag ;
    rdfs:label "Medication-administered-during-recording" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Medication-modulator .

hedt:Medication-withdrawal-or-reduction-during-recording a hed:HedTag ;
    rdfs:label "Medication-withdrawal-or-reduction-during-recording" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Medication-modulator .

hedt:Medium a hed:HedTag ;
    rdfs:label "Medium" ;
    rdfs:comment "Mid-way between small and large in number, quantity, magnitude or extent." ;
    heda:relatedTag hedt:High,
        hedt:Low ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Medium-periodic-discharge-absolute-amplitude a hed:HedTag ;
    rdfs:label "Medium-periodic-discharge-absolute-amplitude" ;
    rdfs:comment "50 to 199 microV." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-absolute-amplitude .

hedt:Medium-posterior-dominant-rhythm-amplitude-range a hed:HedTag ;
    rdfs:label "Medium-posterior-dominant-rhythm-amplitude-range" ;
    rdfs:comment "Medium (between 20 and 70 microV)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-amplitude-range .

hedt:Modulators-effect-change-of-patterns a hed:HedTag ;
    rdfs:label "Modulators-effect-change-of-patterns" ;
    rdfs:comment "Change of patterns during sleep/awakening." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulators-effect .

hedt:Modulators-effect-continuous-during-NRS a hed:HedTag ;
    rdfs:label "Modulators-effect-continuous-during-NRS" ;
    rdfs:comment "Continuous during non-rapid-eye-movement-sleep (NRS)" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulators-effect .

hedt:Modulators-effect-only-during a hed:HedTag ;
    rdfs:label "Modulators-effect-only-during" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulators-effect .

hedt:Modulators-reactivity a hed:HedTag ;
    rdfs:label "Modulators-reactivity" ;
    rdfs:comment "Susceptibility of individual rhythms or the EEG as a whole to change following sensory stimulation or other physiologic actions." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Move-torso a hed:HedTag ;
    rdfs:label "Move-torso" ;
    rdfs:comment "Move body trunk." ;
    hed:hasHedParent hedt:Move-body-part .

hedt:Myoclonic-absence-seizure a hed:HedTag ;
    rdfs:label "Myoclonic-absence-seizure" ;
    rdfs:comment "A myoclonic absence seizure refers to an absence seizure with rhythmic three-per-second myoclonic movements, causing ratcheting abduction of the upper limbs leading to progressive arm elevation, and associated with three-per-second generalized spike-wave discharges. Duration is typically 10 to 60 s. Impairment of consciousness may not be obvious. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Absence-seizure .

hedt:Myoclonic-atonic-motor-seizure a hed:HedTag ;
    rdfs:label "Myoclonic-atonic-motor-seizure" ;
    rdfs:comment "A generalized seizure type with a myoclonic jerk leading to an atonic motor component. This type was previously called myoclonic astatic. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Myoclonic-tonic-clonic-motor-seizure a hed:HedTag ;
    rdfs:label "Myoclonic-tonic-clonic-motor-seizure" ;
    rdfs:comment "One or a few jerks of limbs bilaterally, followed by a tonic clonic seizure. The initial jerks can be considered to be either a brief period of clonus or myoclonus. Seizures with this characteristic are common in juvenile myoclonic epilepsy. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Natural-sleep a hed:HedTag ;
    rdfs:label "Natural-sleep" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Sleep-modulator .

hedt:Negative a hed:HedTag ;
    rdfs:label "Negative" ;
    rdfs:comment "Involving disadvantage or harm." ;
    heda:relatedTag hedt:Positive ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Negative-myoclonus a hed:HedTag ;
    rdfs:label "Negative-myoclonus" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:EMG-myoclonus .

hedt:No-posterior-dominant-rhythm-caveat a hed:HedTag ;
    rdfs:label "No-posterior-dominant-rhythm-caveat" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-caveat .

hedt:Nociceptive-stimulation a hed:HedTag ;
    rdfs:label "Nociceptive-stimulation" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Stimulation-modulator .

hedt:Normal a hed:HedTag ;
    rdfs:label "Normal" ;
    rdfs:comment "Being approximately average or within certain limits. Conforming with or constituting a norm or standard or level or type or social norm." ;
    heda:relatedTag hedt:Abnormal ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:OBO-identifier a hed:HedTag ;
    rdfs:label "OBO-identifier" ;
    rdfs:comment "The identifier of a term in some Open Biology Ontology (OBO) ontology." ;
    hed:hasHedParent hedt:Metadata .

hedt:Occasional-finding-incidence a hed:HedTag ;
    rdfs:label "Occasional-finding-incidence" ;
    rdfs:comment "1/min to 1/5min." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-incidence .

hedt:Occasional-finding-prevalence a hed:HedTag ;
    rdfs:label "Occasional-finding-prevalence" ;
    rdfs:comment "1 to 9 percent." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-prevalence .

hedt:Only-once-finding-incidence a hed:HedTag ;
    rdfs:label "Only-once-finding-incidence" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-incidence .

hedt:Ordered a hed:HedTag ;
    rdfs:label "Ordered" ;
    rdfs:comment "Conforming to a logical or comprehensible arrangement of separate elements." ;
    heda:relatedTag hedt:Disordered ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Other-ECG-feature a hed:HedTag ;
    rdfs:label "Other-ECG-feature" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:ECG-feature .

hedt:Other-EMG-features a hed:HedTag ;
    rdfs:label "Other-EMG-features" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:EMG-feature .

hedt:Other-artifact a hed:HedTag ;
    rdfs:label "Other-artifact" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Artifact-significance-to-recording ;
    hed:hasHedParent hedt:Artifact .

hedt:Other-episode a hed:HedTag ;
    rdfs:label "Other-episode" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Other-modulator-or-procedure a hed:HedTag ;
    rdfs:label "Other-modulator-or-procedure" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulator .

hedt:Other-modulators-effect-EEG a hed:HedTag ;
    rdfs:label "Other-modulators-effect-EEG" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Other-modulators-effect-clinical a hed:HedTag ;
    rdfs:label "Other-modulators-effect-clinical" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Other-organized-rhythm a hed:HedTag ;
    rdfs:label "Other-organized-rhythm" ;
    rdfs:comment "EEG activity that consisting of waves of approximately constant period, which is considered as part of the background (ongoing) activity, but does not fulfill the criteria of the posterior dominant rhythm." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Finding-significance-to-recording,
        hedt:Rhythmic-activity-morphology,
        hedt:Sensors ;
    hed:hasHedParent hedt:Background-activity .

hedt:Other-physiologic-pattern a hed:HedTag ;
    rdfs:label "Other-physiologic-pattern" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Physiologic-pattern .

hedt:Other-polygraphic-channel a hed:HedTag ;
    rdfs:label "Other-polygraphic-channel" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:Other-respiration-feature a hed:HedTag ;
    rdfs:label "Other-respiration-feature" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Respiration-feature .

hedt:Other-uncertain-significant-pattern a hed:HedTag ;
    rdfs:label "Other-uncertain-significant-pattern" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Overt-attention a hed:HedTag ;
    rdfs:label "Overt-attention" ;
    rdfs:comment "Selectively processing one location over others by moving the eyes to point at that location." ;
    heda:relatedTag hedt:Covert-attention ;
    hed:hasHedParent hedt:Task-attentional-demand .

hedt:Parameter-label a hed:HedTag ;
    rdfs:label "Parameter-label" ;
    rdfs:comment "The name of the parameter." ;
