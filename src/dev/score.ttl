    rdfs:comment "Information obtained from a device that is used to measure material properties or make other observations." ;
    hed:hasHedParent hedt:Data-source-type .

hedt:Instrument-sound a hed:HedTag ;
    rdfs:label "Instrument-sound" ;
    rdfs:comment "Sound produced by a musical instrument." ;
    hed:hasHedParent hedt:Musical-sound .

hedt:Intended-effect a hed:HedTag ;
    rdfs:label "Intended-effect" ;
    rdfs:comment "A phenomenon that is intended to follow and be caused by some previous phenomenon." ;
    hed:hasHedParent hedt:Task-effect-evidence .

hedt:Interacts-with a hed:HedTag ;
    rdfs:label "Interacts-with" ;
    rdfs:comment "(A, (Interacts-with, B)) indicates A and B interact, possibly reciprocally." ;
    hed:hasHedParent hedt:Connective-relation .

