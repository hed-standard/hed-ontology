hedt:Spatial-resolution a hed:HedTag ;
    rdfs:label "Spatial-resolution" ;
    rdfs:comment "Linear spacing of a spatial measurement." ;
    hed:hasHedParent hedt:Data-resolution .

hedt:Spectral-resolution a hed:HedTag ;
    rdfs:label "Spectral-resolution" ;
    rdfs:comment "Measures the ability of a sensor to  resolve features in the electromagnetic spectrum." ;
    hed:hasHedParent hedt:Data-resolution .

hedt:Speed a hed:HedTag ;
    rdfs:label "Speed" ;
    rdfs:comment "A scalar measure of the rate of movement of the object expressed either as the distance travelled divided by the time taken (average speed) or the rate of change of position with respect to time at a particular point (instantaneous speed). The direction of change should be given separately." ;
    hed:hasHedParent hedt:Rate-of-change .

hedt:Spiky-periodic-discharge-sharpness a hed:HedTag ;
    rdfs:label "Spiky-periodic-discharge-sharpness" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-sharpness .

hedt:Standard-deviation a hed:HedTag ;
    rdfs:label "Standard-deviation" ;
    rdfs:comment "A measure of the range of values in a set of numbers. Standard deviation is a statistic used as a measure of the dispersion or variation in a distribution, equal to the square root of the arithmetic mean of the squares of the deviations from the arithmetic mean." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Static-periodic-discharge-dynamics a hed:HedTag ;
    rdfs:label "Static-periodic-discharge-dynamics" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-dynamics .

hedt:Statistical-accuracy a hed:HedTag ;
    rdfs:label "Statistical-accuracy" ;
    rdfs:comment "A measure of closeness to true value expressed as a number between 0 and 1." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Statistical-precision a hed:HedTag ;
    rdfs:label "Statistical-precision" ;
    rdfs:comment "A quantitative representation of the degree of accuracy necessary for or associated with a particular action." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Statistical-recall a hed:HedTag ;
    rdfs:label "Statistical-recall" ;
    rdfs:comment "Sensitivity is a measurement datum qualifying a binary classification test and is computed by substracting the false negative rate to the integral numeral 1." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Statistical-uncertainty a hed:HedTag ;
    rdfs:label "Statistical-uncertainty" ;
    rdfs:comment "A measure of the inherent variability of repeated observation measurements of a quantity including quantities evaluated by statistical methods and by other means." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Stop-signal a hed:HedTag ;
    rdfs:label "Stop-signal" ;
    rdfs:comment "An indicator that the agent should stop the current activity." ;
    heda:relatedTag hedt:Go-signal ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:Subject-identifier a hed:HedTag ;
    rdfs:label "Subject-identifier" ;
    rdfs:comment "A sequence of characters used to identify, name, or characterize a trial or study subject." ;
    hed:hasHedParent hedt:Metadata .

hedt:Sudden-periodic-discharge-onset a hed:HedTag ;
    rdfs:label "Sudden-periodic-discharge-onset" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-onset .

hedt:Swallow a hed:HedTag ;
    rdfs:label "Swallow" ;
    rdfs:comment "Cause or allow something, especially food or drink to pass down the throat." ;
    hed:hasHedParent hedt:Move-face .

hedt:Symmetrical a hed:HedTag ;
    rdfs:label "Symmetrical" ;
    rdfs:comment "Made up of exactly similar parts facing each other or around an axis. Showing aspects of symmetry." ;
    heda:relatedTag hedt:Asymmetrical ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Tachypnea-respiration a hed:HedTag ;
    rdfs:label "Tachypnea-respiration" ;
    rdfs:comment "Cycles/min. Frequency can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Rate-of-change/Frequency" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Respiration-feature .

hedt:Task a hed:HedTag ;
    rdfs:label "Task" ;
    rdfs:comment "An assigned piece of work, usually with a time allotment. A tag used to indicate a linkage the structured activities performed as part of the experiment." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Temperature a hed:HedTag ;
    rdfs:label "Temperature" ;
    rdfs:comment "A measure of hot or cold based on the average kinetic energy of the atoms or molecules in the system." ;
    hed:hasHedParent hedt:Physical-value .

hedt:Temporal-rate a hed:HedTag ;
    rdfs:label "Temporal-rate" ;
    rdfs:comment "The number of items per unit of time." ;
    hed:hasHedParent hedt:Rate-of-change .

hedt:Temporal-resolution a hed:HedTag ;
    rdfs:label "Temporal-resolution" ;
    rdfs:comment "Measures the ability of a sensor to  resolve features in time." ;
    hed:hasHedParent hedt:Data-resolution .

hedt:Theta-activity-morphology a hed:HedTag ;
    rdfs:label "Theta-activity-morphology" ;
    rdfs:comment "EEG rhythm in the theta (4-8 Hz) range that does not belong to the posterior dominant rhythm (scored under other organized rhythm)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-amplitude,
        hedt:Finding-frequency ;
    hed:hasHedParent hedt:Rhythmic-activity-morphology .

hedt:Thick a hed:HedTag ;
    rdfs:label "Thick" ;
    rdfs:comment "Wide in width, extent or cross-section." ;
    heda:relatedTag hedt:Thin ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Thin a hed:HedTag ;
    rdfs:label "Thin" ;
    rdfs:comment "Narrow in width, extent or cross-section." ;
    heda:relatedTag hedt:Thick ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Thirsty a hed:HedTag ;
    rdfs:label "Thirsty" ;
    rdfs:comment "Feeling a need to drink." ;
    heda:relatedTag hedt:Hungry ;
    hed:hasHedParent hedt:Agent-physiological-state .

hedt:Timbre a hed:HedTag ;
    rdfs:label "Timbre" ;
    rdfs:comment "The perceived sound quality of a singing voice or musical instrument." ;
    hed:hasHedParent hedt:Auditory-attribute .

hedt:Time-block a hed:HedTag ;
    rdfs:label "Time-block" ;
    rdfs:comment "A tag used to indicate a contiguous time block in the experiment during which something is fixed or noted." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Time-interval a hed:HedTag ;
    rdfs:label "Time-interval" ;
    rdfs:comment "The period of time separating two instances, events, or occurrences." ;
    hed:hasHedParent hedt:Temporal-value .

hedt:Time-value a hed:HedTag ;
    rdfs:label "Time-value" ;
    rdfs:comment "A value with units of time. Usually grouped with tags identifying what the value represents." ;
    hed:hasHedParent hedt:Temporal-value .

hedt:Tired a hed:HedTag ;
    rdfs:label "Tired" ;
    rdfs:comment "Feeling in need of sleep or rest." ;
    heda:relatedTag hedt:Rested ;
    hed:hasHedParent hedt:Agent-physiological-state .

hedt:Top-down-attention a hed:HedTag ;
    rdfs:label "Top-down-attention" ;
    rdfs:comment "Voluntary allocation of attention to certain features. Sometimes this is referred to goal-oriented attention." ;
    heda:relatedTag hedt:Bottom-up-attention ;
    hed:hasHedParent hedt:Task-attentional-demand .

hedt:True a hed:HedTag ;
    rdfs:label "True" ;
    rdfs:comment "Conforming to facts, reality or definitive criteria." ;
    heda:relatedTag hedt:False ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Trunk-location a hed:HedTag ;
    rdfs:label "Trunk-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Typical-absence-seizure a hed:HedTag ;
    rdfs:label "Typical-absence-seizure" ;
    rdfs:comment "A sudden onset, interruption of ongoing activities, a blank stare, possibly a brief upward deviation of the eyes. Usually the patient will be unresponsive when spoken to. Duration is a few seconds to half a minute with very rapid recovery. Although not always available, an EEG would show generalized epileptiform discharges during the event. An absence seizure is by definition a seizure of generalized onset. The word is not synonymous with a blank stare, which also can be encountered with focal onset seizures. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Absence-seizure .

hedt:Uncommon-finding-incidence a hed:HedTag ;
    rdfs:label "Uncommon-finding-incidence" ;
    rdfs:comment "1/5 min to 1/h." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-incidence .

hedt:Unconstrained a hed:HedTag ;
    rdfs:label "Unconstrained" ;
    rdfs:comment "Moving without restriction." ;
    heda:relatedTag hedt:Constrained ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Unmasked a hed:HedTag ;
    rdfs:label "Unmasked" ;
    rdfs:comment "Information is revealed." ;
    heda:relatedTag hedt:Masked ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Unmodified-intermittent-photic-stimulation-effect a hed:HedTag ;
    rdfs:label "Unmodified-intermittent-photic-stimulation-effect" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Intermittent-photic-stimulation-effect .

hedt:Unplanned a hed:HedTag ;
    rdfs:label "Unplanned" ;
    rdfs:comment "Something that has not been planned as part of the task." ;
    heda:relatedTag hedt:Planned ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:Valid a hed:HedTag ;
    rdfs:label "Valid" ;
    rdfs:comment "Allowable, usable, or acceptable." ;
    heda:relatedTag hedt:Invalid ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Variable-appearance-mode a hed:HedTag ;
    rdfs:label "Variable-appearance-mode" ;
    rdfs:comment "Occurrence of non-ictal EEG pattern / graphoelements, that is sometimes rhythmic or periodic, other times random, throughout the recording." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Appearance-mode .

hedt:Version-identifier a hed:HedTag ;
    rdfs:label "Version-identifier" ;
    rdfs:comment "An alphanumeric character string that identifies a form or variant of a type or original." ;
    hed:hasHedParent hedt:Metadata .

hedt:Vertically-oriented a hed:HedTag ;
    rdfs:label "Vertically-oriented" ;
    rdfs:comment "Oriented perpendicular to the plane of the horizon." ;
    heda:relatedTag hedt:Horizontally-oriented ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:Very-brief-periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Very-brief-periodic-discharge-duration" ;
    rdfs:comment "Less than 10 sec." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-duration .

hedt:Very-long-periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Very-long-periodic-discharge-duration" ;
    rdfs:comment "Greater than 1 hour." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-duration .

hedt:Visceral-location a hed:HedTag ;
    rdfs:label "Visceral-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Volume a hed:HedTag ;
    rdfs:label "Volume" ;
    rdfs:comment "The amount of three dimensional space occupied by an object or the capacity of a space or container." ;
    hed:hasHedParent hedt:Size .

hedt:Voluntary a hed:HedTag ;
    rdfs:label "Voluntary" ;
    rdfs:comment "Using free will or design; not forced or compelled; controlled by individual volition." ;
    heda:relatedTag hedt:Involuntary ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Weight a hed:HedTag ;
    rdfs:label "Weight" ;
    rdfs:comment "The relative mass or the quantity of matter contained by something." ;
    hed:hasHedParent hedt:Physical-value .

hedt:Width a hed:HedTag ;
    rdfs:label "Width" ;
    rdfs:comment "The extent or measurement of something from side to side." ;
    hed:hasHedParent hedt:Size .

hedt:Wrong a hed:HedTag ;
    rdfs:label "Wrong" ;
    rdfs:comment "Inaccurate or not correct." ;
    heda:relatedTag hedt:Correct ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:X-position a hed:HedTag ;
    rdfs:label "X-position" ;
    rdfs:comment "The position along the x-axis of the frame of reference." ;
    hed:hasHedParent hedt:Position .

hedt:Y-position a hed:HedTag ;
    rdfs:label "Y-position" ;
    rdfs:comment "The position along the y-axis of the frame of reference." ;
    hed:hasHedParent hedt:Position .

hedt:Z-position a hed:HedTag ;
    rdfs:label "Z-position" ;
    rdfs:comment "The position along the z-axis of the frame of reference." ;
    hed:hasHedParent hedt:Position .

hedu:accelerationUnits a hed:HedUnitClass ;
    rdfs:label "accelerationUnits" ;
    heda:defaultUnits "m-per-s^2" .

hedu:areaUnits a hed:HedUnitClass ;
    rdfs:label "areaUnits" ;
    heda:defaultUnits "m^2" .

hedu:jerkUnits a hed:HedUnitClass ;
    rdfs:label "jerkUnits" ;
    heda:defaultUnits "m-per-s^3" .

hedu:magneticFieldUnits a hed:HedUnitClass ;
    rdfs:label "magneticFieldUnits" ;
    rdfs:comment "Units used to magnetic field intensity." ;
    heda:defaultUnits "fT" .

hedu:memorySizeUnits a hed:HedUnitClass ;
    rdfs:label "memorySizeUnits" ;
    heda:defaultUnits "B" .

hedu:volumeUnits a hed:HedUnitClass ;
    rdfs:label "volumeUnits" ;
    heda:defaultUnits "m^3" .

hedt:All a hed:HedTag ;
    rdfs:label "All" ;
    rdfs:comment "To a complete degree or to the full or entire extent." ;
    heda:relatedTag hedt:None,
        hedt:Some ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Anatomical-item a hed:HedTag ;
    rdfs:label "Anatomical-item" ;
    rdfs:comment "A biological structure, system, fluid or other substance excluding single molecular entities." ;
    hed:hasHedParent hedt:Biological-item .

hedt:Assistive-device a hed:HedTag ;
    rdfs:label "Assistive-device" ;
    rdfs:comment "A device that help an individual accomplish a task." ;
    hed:hasHedParent hedt:Device .

hedt:Atonic-motor-seizure a hed:HedTag ;
    rdfs:label "Atonic-motor-seizure" ;
    rdfs:comment "Sudden loss or diminution of muscle tone without apparent preceding myoclonic or tonic event lasting  about 1 to 2 s, involving head, trunk, jaw, or limb musculature. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Auditory-device a hed:HedTag ;
    rdfs:label "Auditory-device" ;
    rdfs:comment "A device designed to produce sound." ;
    hed:hasHedParent hedt:Output-device .

hedt:Behavior-arrest-nonmotor-seizure a hed:HedTag ;
    rdfs:label "Behavior-arrest-nonmotor-seizure" ;
    rdfs:comment "Arrest (pause) of activities, freezing, immobilization, as in behavior arrest seizure. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Nonmotor-seizure .

hedt:Biological-item a hed:HedTag ;
    rdfs:label "Biological-item" ;
    rdfs:comment "An entity that is biological, that is related to living organisms." ;
    hed:hasHedParent hedt:Item .

hedt:Clonic-motor-seizure a hed:HedTag ;
    rdfs:label "Clonic-motor-seizure" ;
    rdfs:comment "Jerking, either symmetric or asymmetric, that is regularly repetitive and involves the same muscle groups. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Color-shade a hed:HedTag ;
    rdfs:label "Color-shade" ;
    rdfs:comment "A slight degree of difference between colors, especially with regard to how light or dark it is or as distinguished from one nearly like it." ;
    hed:hasHedParent hedt:Color .

hedt:Computer-mouse a hed:HedTag ;
    rdfs:label "Computer-mouse" ;
    rdfs:comment "A hand-held pointing device that detects two-dimensional motion relative to a surface." ;
    hed:hasHedParent hedt:Input-device .

hedt:Continuous a hed:HedTag ;
    rdfs:label "Continuous" ;
    rdfs:comment "Uninterrupted in time, sequence, substance, or extent." ;
    heda:relatedTag hedt:Discontinuous,
        hedt:Discrete ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Correct-action a hed:HedTag ;
    rdfs:label "Correct-action" ;
    rdfs:comment "An action that was a correct response in the context of the task." ;
    heda:relatedTag hedt:Incorrect-action,
        hedt:Indeterminate-action ;
    hed:hasHedParent hedt:Task-action-type .

hedt:DC-shift-morphology a hed:HedTag ;
    rdfs:label "DC-shift-morphology" ;
    rdfs:comment "Shift of negative polarity of the direct current recordings, during seizures." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Data-marker a hed:HedTag ;
    rdfs:label "Data-marker" ;
    rdfs:comment "An indicator placed to mark something." ;
    hed:hasHedParent hedt:Data-property .

hedt:Delay a hed:HedTag ;
    rdfs:label "Delay" ;
    rdfs:comment "The time at which an event start time is delayed from the current onset time. This tag defines the start time of an event of temporal extent and may be used with the Duration tag." ;
    heda:relatedTag hedt:Duration ;
    heda:reserved true ;
    heda:topLevelTagGroup true ;
    hed:hasHedParent hedt:Temporal-value .

hedt:Deterministic a hed:HedTag ;
    rdfs:label "Deterministic" ;
    rdfs:comment "No randomness is involved in the development of the future states of the element." ;
    heda:relatedTag hedt:Random,
        hedt:Stochastic ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Directional-relation a hed:HedTag ;
    rdfs:label "Directional-relation" ;
    rdfs:comment "A relationship indicating direction of change of one entity relative to another. The first entity is the focus." ;
    hed:hasHedParent hedt:Relation .

hedt:Disappearance-of-ongoing-activity-morphology a hed:HedTag ;
    rdfs:label "Disappearance-of-ongoing-activity-morphology" ;
    rdfs:comment "Disappearance of the EEG activity that preceded the ictal event but still remnants of background activity (thus not enough to name it electrodecremental change)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Discontinuous a hed:HedTag ;
    rdfs:label "Discontinuous" ;
    rdfs:comment "Having a gap in time, sequence, substance, or extent." ;
    heda:relatedTag hedt:Continuous ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Distance a hed:HedTag ;
    rdfs:label "Distance" ;
    rdfs:comment "A measure of the space separating two objects or points." ;
    hed:hasHedParent hedt:Spatial-value .

hedt:Duration a hed:HedTag ;
    rdfs:label "Duration" ;
    rdfs:comment "The period of time during which an event occurs. This tag defines the end time of an event of temporal extent and may be used with the Delay tag." ;
    heda:relatedTag hedt:Delay ;
    heda:reserved true ;
    heda:topLevelTagGroup true ;
    hed:hasHedParent hedt:Temporal-value .

hedt:ECG-channel-finding a hed:HedTag ;
    rdfs:label "ECG-channel-finding" ;
    rdfs:comment "Electrocardiography." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-significance-to-recording ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:EMG-asymmetric-activation a hed:HedTag ;
    rdfs:label "EMG-asymmetric-activation" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:EMG-feature .

hedt:Electrodecremental-change-morphology a hed:HedTag ;
    rdfs:label "Electrodecremental-change-morphology" ;
    rdfs:comment "Sudden desynchronization of electrical activity." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Environmental-sound a hed:HedTag ;
    rdfs:label "Environmental-sound" ;
    rdfs:comment "Sounds occuring in the environment. An accumulation of noise pollution that occurs outside. This noise can be caused by transport, industrial, and recreational activities." ;
    hed:hasHedParent hedt:Sound .

hedt:Expert-level a hed:HedTag ;
    rdfs:label "Expert-level" ;
    rdfs:comment "Having comprehensive and authoritative knowledge of or skill in a particular area related to the task." ;
    heda:relatedTag hedt:Intermediate-experience-level,
        hedt:Novice-level ;
    hed:hasHedParent hedt:Agent-experience-level .

hedt:Eye-modulator a hed:HedTag ;
    rdfs:label "Eye-modulator" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulator .

hedt:Familiar a hed:HedTag ;
    rdfs:label "Familiar" ;
    rdfs:comment "Recognized, familiar, or within the scope of knowledge." ;
    heda:relatedTag hedt:Famous,
        hedt:Unfamiliar ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Famous a hed:HedTag ;
    rdfs:label "Famous" ;
    rdfs:comment "A person who has a high degree of recognition by the general population for his or her success or accomplishments. A famous person." ;
    heda:relatedTag hedt:Familiar,
        hedt:Unfamiliar ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Fast-spike-activity-morphology a hed:HedTag ;
    rdfs:label "Fast-spike-activity-morphology" ;
    rdfs:comment "A burst consisting of a sequence of spikes. Duration greater than 1 s. Frequency at least in the alpha range." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Finding-propagation a hed:HedTag ;
    rdfs:label "Finding-propagation" ;
    rdfs:comment "When propagation within the graphoelement is observed, first the location of the onset region is scored. Then, the location of the propagation can be noted." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Property-absence,
        hedt:Property-exists,
        hedt:Sensors ;
    hed:hasHedParent hedt:Location-property .

hedt:Frontal-intermittent-rhythmic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Frontal-intermittent-rhythmic-delta-activity-morphology" ;
    rdfs:comment "Frontal intermittent rhythmic delta activity (FIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 1.5-2.5 Hz over the frontal areas of one or both sides of the head. Comment: most commonly associated with unspecified encephalopathy, in adults." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:High a hed:HedTag ;
    rdfs:label "High" ;
    rdfs:comment "Having a greater than normal degree, intensity, or amount." ;
    heda:relatedTag hedt:Low,
        hedt:Medium ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:High-frequency-oscillation-morphology a hed:HedTag ;
    rdfs:label "High-frequency-oscillation-morphology" ;
    rdfs:comment "HFO." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Hungry a hed:HedTag ;
    rdfs:label "Hungry" ;
    rdfs:comment "Being in a state of craving or desiring food." ;
    heda:relatedTag hedt:Sated,
        hedt:Thirsty ;
    hed:hasHedParent hedt:Agent-physiological-state .

hedt:Hypsarrhythmia-classic-morphology a hed:HedTag ;
    rdfs:label "Hypsarrhythmia-classic-morphology" ;
    rdfs:comment "Abnormal interictal high amplitude waves and a background of irregular spikes." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Hypsarrhythmia-modified-morphology a hed:HedTag ;
    rdfs:label "Hypsarrhythmia-modified-morphology" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Incorrect-action a hed:HedTag ;
    rdfs:label "Incorrect-action" ;
    rdfs:comment "An action considered wrong or incorrect in the context of the task." ;
    heda:relatedTag hedt:Correct-action,
        hedt:Indeterminate-action ;
    hed:hasHedParent hedt:Task-action-type .

hedt:Indeterminate-action a hed:HedTag ;
    rdfs:label "Indeterminate-action" ;
    rdfs:comment "An action that cannot be distinguished between two or more possibibities in the current context. This tag might be applied when an outside evaluator or a classification algorithm cannot determine a definitive result." ;
    heda:relatedTag hedt:Correct-action,
        hedt:Incorrect-action,
        hedt:Miss,
        hedt:Near-miss ;
    hed:hasHedParent hedt:Task-action-type .

hedt:Inset a hed:HedTag ;
    rdfs:label "Inset" ;
    rdfs:comment "Marks an intermediate point in an ongoing event of temporal extent." ;
    heda:relatedTag hedt:Offset,
        hedt:Onset ;
    heda:reserved true ;
    heda:topLevelTagGroup true ;
    hed:hasHedParent hedt:Temporal-marker .

hedt:Interictal-special-patterns a hed:HedTag ;
    rdfs:label "Interictal-special-patterns" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Interictal-finding .

hedt:Intermediate-experience-level a hed:HedTag ;
    rdfs:label "Intermediate-experience-level" ;
    rdfs:comment "Having a moderate amount of knowledge or skill related to the task." ;
    heda:relatedTag hedt:Expert-level,
        hedt:Novice-level ;
    hed:hasHedParent hedt:Agent-experience-level .

hedt:Irregular-delta-or-theta-activity-morphology a hed:HedTag ;
    rdfs:label "Irregular-delta-or-theta-activity-morphology" ;
    rdfs:comment "EEG activity consisting of repetitive waves of inconsistent wave-duration but in delta and/or theta rang (greater than 125 ms)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Liminal a hed:HedTag ;
    rdfs:label "Liminal" ;
    rdfs:comment "Situated at a sensory threshold that is barely perceptible or capable of eliciting a response." ;
    heda:relatedTag hedt:Subliminal,
        hedt:Supraliminal ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Logical-relation a hed:HedTag ;
    rdfs:label "Logical-relation" ;
    rdfs:comment "Indicating a logical relationship between entities. The first entity is usually the focus." ;
    hed:hasHedParent hedt:Relation .

hedt:Low a hed:HedTag ;
    rdfs:label "Low" ;
    rdfs:comment "Less than normal in degree, intensity or amount." ;
    heda:relatedTag hedt:High ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Low-voltage-fast-activity-morphology a hed:HedTag ;
    rdfs:label "Low-voltage-fast-activity-morphology" ;
    rdfs:comment "Refers to the fast, and often recruiting activity which can be recorded at the onset of an ictal discharge, particularly in invasive EEG recording of a seizure." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Media a hed:HedTag ;
    rdfs:label "Media" ;
    rdfs:comment "Media are audo/visual/audiovisual modes of communicating information for mass consumption." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:Medication-modulator a hed:HedTag ;
    rdfs:label "Medication-modulator" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulator .

hedt:Miss a hed:HedTag ;
    rdfs:label "Miss" ;
    rdfs:comment "An action considered to be a failure in the context of the task. For example, if the agent is supposed to try to hit a target and misses." ;
    heda:relatedTag hedt:Near-miss ;
    hed:hasHedParent hedt:Task-action-type .

hedt:Myoclonic-motor-seizure a hed:HedTag ;
    rdfs:label "Myoclonic-motor-seizure" ;
    rdfs:comment "Sudden, brief ( lower than 100 msec) involuntary single or multiple contraction(s) of muscles(s) or muscle groups of variable topography (axial, proximal limb, distal). Myoclonus is less regularly repetitive and less sustained than is clonus. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Natural-object a hed:HedTag ;
    rdfs:label "Natural-object" ;
    rdfs:comment "Something that exists in or is produced by nature, and is not artificial or man-made." ;
    hed:hasHedParent hedt:Object .

hedt:Near-miss a hed:HedTag ;
    rdfs:label "Near-miss" ;
    rdfs:comment "An action barely satisfied the requirements of the task. In a driving experiment for example this could pertain to a narrowly avoided collision or other accident." ;
    heda:relatedTag hedt:Miss ;
    hed:hasHedParent hedt:Task-action-type .

hedt:None a hed:HedTag ;
    rdfs:label "None" ;
    rdfs:comment "No person or thing, nobody, not any." ;
    heda:relatedTag hedt:All,
        hedt:Some ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Novice-level a hed:HedTag ;
    rdfs:label "Novice-level" ;
    rdfs:comment "Being inexperienced in a field or situation related to the task." ;
    heda:relatedTag hedt:Expert-level,
        hedt:Intermediate-experience-level ;
    hed:hasHedParent hedt:Agent-experience-level .

hedt:Occipital-intermittent-rhythmic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Occipital-intermittent-rhythmic-delta-activity-morphology" ;
    rdfs:comment "Occipital intermittent rhythmic delta activity (OIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 2-3 Hz over the occipital or posterior head regions of one or both sides of the head. Frequently blocked or attenuated by opening the eyes. Comment: most commonly associated with unspecified encephalopathy, in children." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Offset a hed:HedTag ;
    rdfs:label "Offset" ;
    rdfs:comment "Marks the end of an event of temporal extent." ;
    heda:relatedTag hedt:Inset,
        hedt:Onset ;
    heda:reserved true ;
    heda:topLevelTagGroup true ;
    hed:hasHedParent hedt:Temporal-marker .

hedt:Onset a hed:HedTag ;
    rdfs:label "Onset" ;
    rdfs:comment "Marks the start of an ongoing event of temporal extent." ;
    heda:relatedTag hedt:Inset,
        hedt:Offset ;
    heda:reserved true ;
    heda:topLevelTagGroup true ;
    hed:hasHedParent hedt:Temporal-marker .

hedt:Output-device a hed:HedTag ;
    rdfs:label "Output-device" ;
    rdfs:comment "Any piece of computer hardware equipment which converts information into human understandable form." ;
    hed:hasHedParent hedt:IO-device .

hedt:Parameter a hed:HedTag ;
    rdfs:label "Parameter" ;
    rdfs:comment "Something user-defined for this experiment." ;
    hed:hasHedParent hedt:Informational-property .

hedt:Pattern a hed:HedTag ;
    rdfs:label "Pattern" ;
    rdfs:comment "An arrangement of objects, facts, behaviors, or other things which have scientific, mathematical, geometric, statistical, or other meaning." ;
    hed:hasHedParent hedt:Geometric-object .

hedt:Periodic-discharge-onset a hed:HedTag ;
    rdfs:label "Periodic-discharge-onset" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-time-related-features .

hedt:Periodic-discharge-triphasic-morphology a hed:HedTag ;
    rdfs:label "Periodic-discharge-triphasic-morphology" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Physical-value a hed:HedTag ;
    rdfs:label "Physical-value" ;
    rdfs:comment "The value of some physical property of something." ;
    hed:hasHedParent hedt:Data-value .

hedt:Polygraphic-channel-relation-to-episode a hed:HedTag ;
    rdfs:label "Polygraphic-channel-relation-to-episode" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-property .

hedt:Polymorphic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Polymorphic-delta-activity-morphology" ;
    rdfs:comment "EEG activity consisting of waves in the delta range (over 250 ms duration for each wave) but of different morphology." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Polysharp-waves-morphology a hed:HedTag ;
    rdfs:label "Polysharp-waves-morphology" ;
    rdfs:comment "A sequence of two or more sharp-waves." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Posterior-dominant-rhythm-frequency-asymmetry a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-frequency-asymmetry" ;
    rdfs:comment "When symmetrical could be labeled with base schema Symmetrical tag." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Provocative-factor a hed:HedTag ;
    rdfs:label "Provocative-factor" ;
    rdfs:comment "Provocative factors are defined as transient and sporadic endogenous or exogenous elements capable of evoking/triggering seizures immediately following the exposure to it." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Random a hed:HedTag ;
    rdfs:label "Random" ;
    rdfs:comment "Governed by or depending on chance. Lacking any definite plan or order or purpose." ;
    heda:relatedTag hedt:Deterministic,
        hedt:Stochastic ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Respiration-channel-finding a hed:HedTag ;
    rdfs:label "Respiration-channel-finding" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-significance-to-recording ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:Runs-of-rapid-spikes-morphology a hed:HedTag ;
    rdfs:label "Runs-of-rapid-spikes-morphology" ;
    rdfs:comment "Bursts of spike discharges at a rate from 10 to 25/sec (in most cases somewhat irregular). The bursts last more than 2 seconds (usually 2 to 10 seconds) and it is typically seen in sleep. Synonyms: rhythmic spikes, generalized paroxysmal fast activity, fast paroxysmal rhythms, grand mal discharge, fast beta activity." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Semiology-experiential-mnemonic a hed:HedTag ;
    rdfs:label "Semiology-experiential-mnemonic" ;
    rdfs:comment "Components that reflect ictal dysmnesia such as feelings of familiarity (deja-vu) and unfamiliarity (jamais-vu)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-experiential .

hedt:Sensory-property a hed:HedTag ;
    rdfs:label "Sensory-property" ;
    rdfs:comment "Relating to sensation or the physical senses." ;
    hed:hasHedParent hedt:Property .

hedt:Sharp-wave-morphology a hed:HedTag ;
    rdfs:label "Sharp-wave-morphology" ;
    rdfs:comment "A transient clearly distinguished from background activity, with pointed peak at a conventional paper speed or time scale, and duration of 70-200 ms, i.e. over 1/4-1/5 s approximately. Main component is generally negative relative to other areas. Amplitude varies." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Sleep-architecture a hed:HedTag ;
    rdfs:label "Sleep-architecture" ;
    rdfs:comment "For longer recordings. Only to be scored if whole-night sleep is part of the recording. It is a global descriptor of the structure and pattern of sleep: estimation of the amount of time spent in REM and NREM sleep, sleep duration, NREM-REM cycle." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Slow-sharp-wave-morphology a hed:HedTag ;
    rdfs:label "Slow-sharp-wave-morphology" ;
    rdfs:comment "A transient that bears all the characteristics of a sharp-wave, but exceeds 200 ms. Synonym: blunted sharp wave." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Slow-wave-large-amplitude-morphology a hed:HedTag ;
    rdfs:label "Slow-wave-large-amplitude-morphology" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Somatic-attribute a hed:HedTag ;
    rdfs:label "Somatic-attribute" ;
    rdfs:comment "Pertaining to the feelings in the body or of the nervous system." ;
    hed:hasHedParent hedt:Sensory-attribute .

hedt:Some a hed:HedTag ;
    rdfs:label "Some" ;
    rdfs:comment "At least a small amount or number of, but not a large amount of, or often." ;
    heda:relatedTag hedt:All,
        hedt:None ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Source-analysis-property a hed:HedTag ;
    rdfs:label "Source-analysis-property" ;
    rdfs:comment "How the current in the brain reaches the electrode sensors." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Spike-morphology a hed:HedTag ;
    rdfs:label "Spike-morphology" ;
    rdfs:comment "A transient, clearly distinguished from background activity, with pointed peak at a conventional paper speed or time scale and duration from 20 to under 70 ms, i.e. 1/50-1/15 s approximately. Main component is generally negative relative to other areas. Amplitude varies." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Step a hed:HedTag ;
    rdfs:label "Step" ;
    rdfs:comment "Put one leg in front of the other and shift weight onto it." ;
    hed:hasHedParent hedt:Move-lower-extremity .

hedt:Stochastic a hed:HedTag ;
    rdfs:label "Stochastic" ;
    rdfs:comment "Uses  a random probability distribution or pattern that may be analysed statistically but may not be predicted precisely to determine future states." ;
    heda:relatedTag hedt:Deterministic,
        hedt:Random ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Subliminal a hed:HedTag ;
    rdfs:label "Subliminal" ;
    rdfs:comment "Situated below a sensory threshold that is imperceptible or not capable of eliciting a response." ;
    heda:relatedTag hedt:Liminal,
        hedt:Supraliminal ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Supraliminal a hed:HedTag ;
    rdfs:label "Supraliminal" ;
    rdfs:comment "Situated above a sensory threshold that is perceptible or capable of eliciting a response." ;
    heda:relatedTag hedt:Liminal,
        hedt:Subliminal ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Task-relationship a hed:HedTag ;
    rdfs:label "Task-relationship" ;
    rdfs:comment "Specifying organizational importance of sub-tasks." ;
    hed:hasHedParent hedt:Task-property .

hedt:Temporal-intermittent-rhythmic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Temporal-intermittent-rhythmic-delta-activity-morphology" ;
    rdfs:comment "Temporal intermittent rhythmic delta activity (TIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at over the temporal areas of one side of the head. Comment: most commonly associated with temporal lobe epilepsy." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Tonic-clonic-motor-seizure a hed:HedTag ;
    rdfs:label "Tonic-clonic-motor-seizure" ;
    rdfs:comment "A sequence consisting of a tonic followed by a clonic phase. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Tonic-motor-seizure a hed:HedTag ;
    rdfs:label "Tonic-motor-seizure" ;
    rdfs:comment "A sustained increase in muscle contraction lasting a few seconds to minutes. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Unexpected a hed:HedTag ;
    rdfs:label "Unexpected" ;
    rdfs:comment "Something that is not anticipated." ;
    heda:relatedTag hedt:Expected ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:Unfamiliar a hed:HedTag ;
    rdfs:label "Unfamiliar" ;
    rdfs:comment "Not having knowledge or experience of." ;
    heda:relatedTag hedt:Familiar,
        hedt:Famous ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Writing-device a hed:HedTag ;
    rdfs:label "Writing-device" ;
    rdfs:comment "A device used for writing." ;
    hed:hasHedParent hedt:Assistive-device .

hedu:electricPotentialUnits a hed:HedUnitClass ;
    rdfs:label "electricPotentialUnits" ;
    heda:defaultUnits "uv" .

hedu:temperatureUnits a hed:HedUnitClass ;
    rdfs:label "temperatureUnits" .

hedt:Agent-experience-level a hed:HedTag ;
    rdfs:label "Agent-experience-level" ;
    rdfs:comment "Amount of skill or knowledge that the agent has as pertains to the task." ;
    hed:hasHedParent hedt:Agent-trait .

hedt:Artifact a hed:HedTag ;
    rdfs:label "Artifact" ;
    rdfs:comment "When relevant for the clinical interpretation, artifacts can be scored by specifying the type and the location." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Bottom-edge-of a hed:HedTag ;
    rdfs:label "Bottom-edge-of" ;
    rdfs:comment "(A, (Bottom-edge-of, B)) means A is on the bottom most part or or near the boundary of B." ;
    heda:relatedTag hedt:Left-edge-of,
        hedt:Right-edge-of,
        hedt:Top-edge-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Communicate a hed:HedTag ;
    rdfs:label "Communicate" ;
    rdfs:comment "Convey knowledge of or information about something." ;
    hed:hasHedParent hedt:Action .

hedt:Critically-ill-patients-patterns a hed:HedTag ;
    rdfs:label "Critically-ill-patients-patterns" ;
    rdfs:comment "Rhythmic or periodic patterns in critically ill patients (RPPs) are scored according to the 2012 version of the American Clinical Neurophysiology Society Standardized Critical Care EEG Terminology (Hirsch et al., 2013)." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Display-device a hed:HedTag ;
    rdfs:label "Display-device" ;
    rdfs:comment "An output device for presentation of information in visual or tactile form the latter used for example in tactile electronic displays for blind people." ;
    hed:hasHedParent hedt:Output-device .

hedt:Downward a hed:HedTag ;
    rdfs:label "Downward" ;
    rdfs:comment "Moving or leading toward a lower place or level." ;
    heda:relatedTag hedt:Leftward,
        hedt:Rightward,
        hedt:Upward ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:EMG-channel-finding a hed:HedTag ;
    rdfs:label "EMG-channel-finding" ;
    rdfs:comment "electromyography" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-significance-to-recording ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:EMG-muscle-side a hed:HedTag ;
    rdfs:label "EMG-muscle-side" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:EMG-channel-finding .

hedt:Epileptic-spasm-episode a hed:HedTag ;
    rdfs:label "Epileptic-spasm-episode" ;
    rdfs:comment "A sudden flexion, extension, or mixed extension flexion of predominantly proximal and truncal muscles that is usually more sustained than a myoclonic movement but not as sustained as a tonic seizure. Limited forms may occur: Grimacing, head nodding, or subtle eye movements. Epileptic spasms frequently occur in clusters. Infantile spasms are the best known form, but spasms can occur at all ages. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Geometric-object a hed:HedTag ;
    rdfs:label "Geometric-object" ;
    rdfs:comment "An object or a representation that has structure and topology in space." ;
    hed:hasHedParent hedt:Object .

hedt:HSV-color a hed:HedTag ;
    rdfs:label "HSV-color" ;
    rdfs:comment "A color representation that models how colors appear under light." ;
    hed:hasHedParent hedt:Color .

hedt:Hand a hed:HedTag ;
    rdfs:label "Hand" ;
    rdfs:comment "The distal portion of the upper extremity. It consists of the carpus, metacarpus, and digits." ;
    hed:hasHedParent hedt:Upper-extremity .

hedt:Handedness a hed:HedTag ;
    rdfs:label "Handedness" ;
    rdfs:comment "Individual preference for use of a hand, known as the dominant hand." ;
    hed:hasHedParent hedt:Agent-trait .

hedt:Head a hed:HedTag ;
    rdfs:label "Head" ;
    rdfs:comment "The upper part of the human body, or the front or upper part of the body of an animal, typically separated from the rest of the body by a neck, and containing the brain, mouth, and sense organs." ;
    hed:hasHedParent hedt:Body-part .

hedt:Interictal-finding a hed:HedTag ;
    rdfs:label "Interictal-finding" ;
    rdfs:comment "EEG pattern / transient that is distinguished form the background activity, considered abnormal, but is not recorded during ictal period (seizure) or postictal period; the presence of an interictal finding does not necessarily imply that the patient has epilepsy." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Left-edge-of a hed:HedTag ;
    rdfs:label "Left-edge-of" ;
    rdfs:comment "(A, (Left-edge-of, B)) means A is located on the left side of B on or near the boundary of B." ;
    heda:relatedTag hedt:Bottom-edge-of,
        hedt:Right-edge-of,
        hedt:Top-edge-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Leftward a hed:HedTag ;
    rdfs:label "Leftward" ;
    rdfs:comment "Going toward or facing the left." ;
    heda:relatedTag hedt:Downward,
        hedt:Rightward,
        hedt:Upward ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:Map-view a hed:HedTag ;
    rdfs:label "Map-view" ;
    rdfs:comment "A diagrammatic representation of an area of land or sea showing physical features, cities, roads." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:Media-clip a hed:HedTag ;
    rdfs:label "Media-clip" ;
    rdfs:comment "A short segment of media." ;
    hed:hasHedParent hedt:Media .

hedt:Modulators-effect a hed:HedTag ;
    rdfs:label "Modulators-effect" ;
    rdfs:comment "Tags for describing the influence of the modulators" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Move a hed:HedTag ;
    rdfs:label "Move" ;
    rdfs:comment "Move in a specified direction or manner. Change position or posture." ;
    hed:hasHedParent hedt:Action .

hedt:Musical-sound a hed:HedTag ;
    rdfs:label "Musical-sound" ;
    rdfs:comment "Sound produced by continuous and regular vibrations, as opposed to noise." ;
    hed:hasHedParent hedt:Sound .

hedt:Navigational-object a hed:HedTag ;
    rdfs:label "Navigational-object" ;
    rdfs:comment "An object whose purpose is to assist directed movement from one location to another." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:Organism a hed:HedTag ;
    rdfs:label "Organism" ;
    rdfs:comment "A living entity, more specifically a biological entity that consists of one or more cells and is capable of genomic replication (independently or not)." ;
    hed:hasHedParent hedt:Biological-item .

hedt:Periodic-discharge-dynamics a hed:HedTag ;
    rdfs:label "Periodic-discharge-dynamics" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-time-related-features .

hedt:Periodic-discharge-relative-amplitude a hed:HedTag ;
    rdfs:label "Periodic-discharge-relative-amplitude" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Periodic-discharge-superimposed-activity a hed:HedTag ;
    rdfs:label "Periodic-discharge-superimposed-activity" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Polyspike-and-slow-wave-morphology a hed:HedTag ;
    rdfs:label "Polyspike-and-slow-wave-morphology" ;
    rdfs:comment "Two or more consecutive spikes associated with one or more slow waves." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Polyspikes-morphology a hed:HedTag ;
    rdfs:label "Polyspikes-morphology" ;
    rdfs:comment "Two or more consecutive spikes." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Position a hed:HedTag ;
    rdfs:label "Position" ;
    rdfs:comment "A reference to the alignment of an object, a particular situation or view of a situation, or the location of an object. Coordinates with respect a specified frame of reference or the default Screen-frame if no frame is given." ;
    hed:hasHedParent hedt:Spatial-value .

hedt:Posterior-dominant-rhythm-amplitude-range a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-amplitude-range" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Posterior-dominant-rhythm-eye-opening-reactivity a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-eye-opening-reactivity" ;
    rdfs:comment "Change (disappearance or measurable decrease in amplitude) of a posterior dominant rhythm following eye-opening. Eye closure has the opposite effect." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Posterior-dominant-rhythm-organization a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-organization" ;
    rdfs:comment "When normal could be labeled with base schema Normal tag." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:RGB-color a hed:HedTag ;
    rdfs:label "RGB-color" ;
    rdfs:comment "A color from the RGB schema." ;
    hed:hasHedParent hedt:Color .

hedt:Right-edge-of a hed:HedTag ;
    rdfs:label "Right-edge-of" ;
    rdfs:comment "(A, (Right-edge-of, B)) means A is located on the right side of B on or near the boundary of B." ;
    heda:relatedTag hedt:Bottom-edge-of,
        hedt:Left-edge-of,
        hedt:Top-edge-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Rightward a hed:HedTag ;
    rdfs:label "Rightward" ;
    rdfs:comment "Going toward or situated on the right." ;
    heda:relatedTag hedt:Downward,
        hedt:Leftward,
        hedt:Upward ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:Semiology-motor-manifestation a hed:HedTag ;
    rdfs:label "Semiology-motor-manifestation" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Seizure-semiology-manifestation .

hedt:Semiology-motor-tonic-clonic a hed:HedTag ;
    rdfs:label "Semiology-motor-tonic-clonic" ;
    rdfs:comment "A sequence consisting of a tonic followed by a clonic phase. Variants such as clonic-tonic-clonic may be seen. Asymmetry of limb posture during the tonic phase of a GTC: one arm is rigidly extended at the elbow (often with the fist clenched tightly and flexed at the wrist), whereas the opposite arm is flexed at the elbow." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Sex a hed:HedTag ;
    rdfs:label "Sex" ;
    rdfs:comment "Physical properties or qualities by which male is distinguished from female." ;
    hed:hasHedParent hedt:Agent-trait .

hedt:Sharp-and-slow-wave-morphology a hed:HedTag ;
    rdfs:label "Sharp-and-slow-wave-morphology" ;
    rdfs:comment "A sequence of a sharp wave and a slow wave." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Spatiotemporal-value a hed:HedTag ;
    rdfs:label "Spatiotemporal-value" ;
    rdfs:comment "A property relating to space and/or time." ;
    hed:hasHedParent hedt:Data-value .

hedt:Spike-and-slow-wave-morphology a hed:HedTag ;
    rdfs:label "Spike-and-slow-wave-morphology" ;
    rdfs:comment "A pattern consisting of a spike followed by a slow wave." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Stimulation-modulator a hed:HedTag ;
    rdfs:label "Stimulation-modulator" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulator .

hedt:Target a hed:HedTag ;
    rdfs:label "Target" ;
    rdfs:comment "Something fixed as a goal, destination, or point of examination." ;
    hed:hasHedParent hedt:Task-stimulus-role .

hedt:Top-edge-of a hed:HedTag ;
    rdfs:label "Top-edge-of" ;
    rdfs:comment "(A, (Top-edge-of, B)) means A is on the uppermost part or or near the boundary of B." ;
    heda:relatedTag hedt:Bottom-edge-of,
        hedt:Left-edge-of,
        hedt:Right-edge-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Upper-left-of a hed:HedTag ;
    rdfs:label "Upper-left-of" ;
    rdfs:comment "(A, (Upper-left-of, B)) means A is situated on the upper left part of B. This relation is often used to specify qualitative information about screen position." ;
    heda:relatedTag hedt:Center-of,
        hedt:Lower-center-of,
        hedt:Lower-left-of,
        hedt:Lower-right-of,
        hedt:Upper-center-of,
        hedt:Upper-right-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Upward a hed:HedTag ;
    rdfs:label "Upward" ;
    rdfs:comment "Moving, pointing, or leading to a higher place, point, or level." ;
    heda:relatedTag hedt:Downward,
        hedt:Leftward,
        hedt:Rightward ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:Visual-attribute a hed:HedTag ;
    rdfs:label "Visual-attribute" ;
    rdfs:comment "Pertaining to the sense of sight." ;
    hed:hasHedParent hedt:Sensory-attribute .

hedu:angleUnits a hed:HedUnitClass ;
    rdfs:label "angleUnits" ;
    heda:defaultUnits "radian" .

hedu:currencyUnits a hed:HedUnitClass ;
    rdfs:label "currencyUnits" ;
    rdfs:comment "Units indicating the worth of something." ;
    heda:defaultUnits "$" .

hedu:intensityUnits a hed:HedUnitClass ;
    rdfs:label "intensityUnits" ;
    heda:defaultUnits "dB" .

hedu:speedUnits a hed:HedUnitClass ;
    rdfs:label "speedUnits" ;
    heda:defaultUnits "m-per-s" .

hedt:Absence-seizure a hed:HedTag ;
    rdfs:label "Absence-seizure" ;
    rdfs:comment "Absence seizures present with a sudden cessation of activity and awareness. Absence seizures tend to occur in younger age groups, have more sudden start and termination, and they usually display less complex automatisms than do focal seizures with impaired awareness, but the distinctions are not absolute. EEG information may be required for accurate classification. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Seizure-classification .

hedt:Agent-property a hed:HedTag ;
    rdfs:label "Agent-property" ;
    rdfs:comment "Something that pertains to an agent." ;
    heda:extensionAllowed true ;
    hed:hasHedParent hedt:Property .

hedt:Agent-state a hed:HedTag ;
    rdfs:label "Agent-state" ;
    rdfs:comment "The state of the agent." ;
    hed:hasHedParent hedt:Agent-property .

hedt:Agent-task-role a hed:HedTag ;
    rdfs:label "Agent-task-role" ;
    rdfs:comment "The function or part that is ascribed to an agent in performing the task." ;
    hed:hasHedParent hedt:Agent-property .

hedt:Auditory-presentation a hed:HedTag ;
    rdfs:label "Auditory-presentation" ;
    rdfs:comment "The sense of hearing is used in the presentation to the user." ;
    hed:hasHedParent hedt:Sensory-presentation .

hedt:Background-activity a hed:HedTag ;
    rdfs:label "Background-activity" ;
    rdfs:comment "An EEG activity representing the setting in which a given normal or abnormal pattern appears and from which such pattern is distinguished." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Body-part a hed:HedTag ;
    rdfs:label "Body-part" ;
    rdfs:comment "Any part of an organism." ;
    hed:hasHedParent hedt:Anatomical-item .

hedt:Categorical-value a hed:HedTag ;
    rdfs:label "Categorical-value" ;
    rdfs:comment "Indicates that something can take on a limited and usually fixed number of possible values." ;
    hed:hasHedParent hedt:Data-value .

hedt:Computing-device a hed:HedTag ;
    rdfs:label "Computing-device" ;
    rdfs:comment "An electronic device which take inputs and processes results from the inputs." ;
    hed:hasHedParent hedt:Device .

hedt:Epileptic-seizure a hed:HedTag ;
    rdfs:label "Epileptic-seizure" ;
    rdfs:comment "The ILAE presented a revised seizure classification that divides seizures into focal, generalized onset, or unknown onset." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Focal-onset-epileptic-seizure a hed:HedTag ;
    rdfs:label "Focal-onset-epileptic-seizure" ;
    rdfs:comment "Focal seizures can be divided into focal aware and impaired awareness seizures, with additional motor and nonmotor classifications." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Atonic-motor-seizure,
        hedt:Automatism-motor-seizure,
        hedt:Autonomic-nonmotor-seizure,
        hedt:Behavior-arrest-nonmotor-seizure,
        hedt:Clinical-EEG-temporal-relationship,
        hedt:Clonic-motor-seizure,
        hedt:Cognitive-nonmotor-seizure,
        hedt:Emotional-nonmotor-seizure,
        hedt:Epileptic-spasm-episode,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Hyperkinetic-motor-seizure,
        hedt:Myoclonic-motor-seizure,
        hedt:Seizure-dynamics,
        hedt:Sensory-nonmotor-seizure,
        hedt:State-episode-start,
        hedt:Tonic-motor-seizure ;
    hed:hasHedParent hedt:Epileptic-seizure .

hedt:IO-device a hed:HedTag ;
    rdfs:label "IO-device" ;
    rdfs:comment "Hardware used by a human (or other system) to communicate with a computer." ;
    hed:hasHedParent hedt:Device .

hedt:Ictal-EEG-patterns a hed:HedTag ;
    rdfs:label "Ictal-EEG-patterns" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Episode-property .

hedt:Interictal-periodic-discharges a hed:HedTag ;
    rdfs:label "Interictal-periodic-discharges" ;
    rdfs:comment "Periodic discharge not further specified (PDs)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Periodic-discharge-morphology,
        hedt:Periodic-discharge-time-related-features,
        hedt:Sensors ;
    hed:hasHedParent hedt:Interictal-special-patterns .

hedt:Item a hed:HedTag ;
    rdfs:label "Item" ;
    rdfs:comment "An independently existing thing (living or nonliving)." ;
    heda:extensionAllowed true .

hedt:Object a hed:HedTag ;
    rdfs:label "Object" ;
    rdfs:comment "Something perceptible by one or more of the senses, especially by vision or touch. A material thing." ;
    heda:suggestedTag hedt:Sensory-presentation ;
    hed:hasHedParent hedt:Item .

hedt:Pediatric-episode a hed:HedTag ;
    rdfs:label "Pediatric-episode" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Periodic-discharge-polarity a hed:HedTag ;
    rdfs:label "Periodic-discharge-polarity" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Quality-of-hyperventilation a hed:HedTag ;
    rdfs:label "Quality-of-hyperventilation" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Seizure-classification a hed:HedTag ;
    rdfs:label "Seizure-classification" ;
    rdfs:comment "Seizure classification refers to the grouping of seizures based on their clinical features, EEG patterns, and other characteristics. Epileptic seizures are named using the current ILAE seizure classification (Fisher et al., 2017, Beniczky et al., 2017)." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-property .

hedt:Seizure-semiology-manifestation a hed:HedTag ;
    rdfs:label "Seizure-semiology-manifestation" ;
    rdfs:comment "Seizure semiology refers to the clinical features or signs that are observed during a seizure, such as the type of movements or behaviors exhibited by the person having the seizure, the duration of the seizure, the level of consciousness, and any associated symptoms such as aura or postictal confusion. In other words, seizure semiology describes the physical manifestations of a seizure. Semiology is described according to the ILAE Glossary of Descriptive Terminology for Ictal Semiology (Blume et al., 2001). Besides the name, the semiologic finding can also be characterized by the somatotopic modifier, laterality, body part and centricity. Uses Location-property tags." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-property .

hedt:Sleep-stage-reached a hed:HedTag ;
    rdfs:label "Sleep-stage-reached" ;
    rdfs:comment "For normal sleep patterns the sleep stages reached during the recording can be specified" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Finding-significance-to-recording,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Sound a hed:HedTag ;
    rdfs:label "Sound" ;
    rdfs:comment "Mechanical vibrations transmitted by an elastic medium. Something that can be heard." ;
    hed:hasHedParent hedt:Item .

hedt:Sound-envelope a hed:HedTag ;
    rdfs:label "Sound-envelope" ;
    rdfs:comment "Description of how a sound changes over time." ;
    hed:hasHedParent hedt:Auditory-attribute .

hedt:Spatial-value a hed:HedTag ;
    rdfs:label "Spatial-value" ;
    rdfs:comment "Value of an item involving space." ;
    hed:hasHedParent hedt:Spatiotemporal-value .

hedt:Tactile-attribute a hed:HedTag ;
    rdfs:label "Tactile-attribute" ;
    rdfs:comment "Pertaining to the sense of touch." ;
    hed:hasHedParent hedt:Sensory-attribute .

hedt:Task-effect-evidence a hed:HedTag ;
    rdfs:label "Task-effect-evidence" ;
    rdfs:comment "The evidence supporting the conclusion that the event had the specified effect." ;
    hed:hasHedParent hedt:Task-property .

hedt:Temporal-value a hed:HedTag ;
    rdfs:label "Temporal-value" ;
    rdfs:comment "A characteristic of or relating to time or limited by time." ;
    hed:hasHedParent hedt:Spatiotemporal-value .

hedt:Upper-right-of a hed:HedTag ;
    rdfs:label "Upper-right-of" ;
    rdfs:comment "(A, (Upper-right-of, B)) means A is situated on the upper right part of B. This relation is often used to specify qualitative information about screen position." ;
    heda:relatedTag hedt:Center-of,
        hedt:Lower-center-of,
        hedt:Lower-left-of,
        hedt:Lower-right-of,
        hedt:Upper-center-of,
        hedt:Upper-left-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedu:weightUnits a hed:HedUnitClass ;
    rdfs:label "weightUnits" ;
    heda:defaultUnits "g" .

hedt:3D-shape a hed:HedTag ;
    rdfs:label "3D-shape" ;
    rdfs:comment "A geometric three-dimensional shape." ;
    hed:hasHedParent hedt:Geometric-object .

hedt:Action a hed:HedTag ;
    rdfs:label "Action" ;
    rdfs:comment "Do something." ;
    heda:extensionAllowed true .

hedt:Auditory-attribute a hed:HedTag ;
    rdfs:label "Auditory-attribute" ;
    rdfs:comment "Pertaining to the sense of hearing." ;
    hed:hasHedParent hedt:Sensory-attribute .

hedt:Building a hed:HedTag ;
    rdfs:label "Building" ;
    rdfs:comment "A structure that has a roof and walls and stands more or less permanently in one place." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:Color a hed:HedTag ;
    rdfs:label "Color" ;
    rdfs:comment "The appearance of objects (or light sources) described in terms of perception of their hue and lightness (or brightness) and saturation." ;
    hed:hasHedParent hedt:Visual-attribute .

hedt:Communicate-musically a hed:HedTag ;
    rdfs:label "Communicate-musically" ;
    rdfs:comment "Communicate using music." ;
    hed:hasHedParent hedt:Communicate .

hedt:Data-source-type a hed:HedTag ;
    rdfs:label "Data-source-type" ;
    rdfs:comment "The type of place, person, or thing from which the data comes or can be obtained." ;
    hed:hasHedParent hedt:Data-property .

hedt:Data-value a hed:HedTag ;
    rdfs:label "Data-value" ;
    rdfs:comment "Designation of the type of a data item." ;
    hed:hasHedParent hedt:Data-property .

hedt:Document a hed:HedTag ;
    rdfs:label "Document" ;
    rdfs:comment "A physical object, or electronic counterpart, that is characterized by containing writing which is meant to be human-readable." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:EMG-myoclonus a hed:HedTag ;
    rdfs:label "EMG-myoclonus" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:EMG-feature .

hedt:Finding-triggered-by a hed:HedTag ;
    rdfs:label "Finding-triggered-by" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Finger a hed:HedTag ;
    rdfs:label "Finger" ;
    rdfs:comment "Any of the digits of the hand." ;
    hed:hasHedParent hedt:Hand .

hedt:Foot a hed:HedTag ;
    rdfs:label "Foot" ;
    rdfs:comment "The structure found below the ankle joint required for locomotion." ;
    hed:hasHedParent hedt:Lower-extremity .

hedt:Gustatory-attribute a hed:HedTag ;
    rdfs:label "Gustatory-attribute" ;
    rdfs:comment "Pertaining to the sense of taste." ;
    hed:hasHedParent hedt:Sensory-attribute .

hedt:Image a hed:HedTag ;
    rdfs:label "Image" ;
    rdfs:comment "Any record of an imaging event whether physical or electronic." ;
    hed:hasHedParent hedt:Visualization .

hedt:Informational-property a hed:HedTag ;
    rdfs:label "Informational-property" ;
    rdfs:comment "Something that pertains to a task." ;
    heda:extensionAllowed true ;
    hed:hasHedParent hedt:Property .

hedt:Lower-center-of a hed:HedTag ;
    rdfs:label "Lower-center-of" ;
    rdfs:comment "(A, (Lower-center-of, B)) means A is situated on the lower center part of B (due south). This relation is often used to specify qualitative information about screen position." ;
    heda:relatedTag hedt:Center-of,
        hedt:Lower-left-of,
        hedt:Lower-right-of,
        hedt:Upper-center-of,
        hedt:Upper-right-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Lower-left-of a hed:HedTag ;
    rdfs:label "Lower-left-of" ;
    rdfs:comment "(A, (Lower-left-of, B)) means A is situated on the lower left part of B. This relation is often used to specify qualitative information about screen position." ;
    heda:relatedTag hedt:Center-of,
        hedt:Lower-center-of,
        hedt:Lower-right-of,
        hedt:Upper-center-of,
        hedt:Upper-left-of,
        hedt:Upper-right-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Manufactured-material a hed:HedTag ;
    rdfs:label "Manufactured-material" ;
    rdfs:comment "Substances created or extracted from raw materials." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:Natural-feature a hed:HedTag ;
    rdfs:label "Natural-feature" ;
    rdfs:comment "A feature that occurs in nature. A prominent or identifiable aspect, region, or site of interest." ;
    hed:hasHedParent hedt:Natural-object .

hedt:Nonmotor-seizure a hed:HedTag ;
    rdfs:label "Nonmotor-seizure" ;
    rdfs:comment "Focal or generalized seizure types in which motor activity is not prominent. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Seizure-classification .

hedt:Number-of-periodic-discharge-phases a hed:HedTag ;
    rdfs:label "Number-of-periodic-discharge-phases" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Orange-color a hed:HedTag ;
    rdfs:label "Orange-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Perceive a hed:HedTag ;
    rdfs:label "Perceive" ;
    rdfs:comment "Produce an internal, conscious image through stimulating a sensory system." ;
    hed:hasHedParent hedt:Action .

hedt:Periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Periodic-discharge-duration" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-time-related-features .

hedt:Periodic-discharge-sharpness a hed:HedTag ;
    rdfs:label "Periodic-discharge-sharpness" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Polygraphic-channel-finding a hed:HedTag ;
    rdfs:label "Polygraphic-channel-finding" ;
    rdfs:comment "Changes observed in polygraphic channels can be scored: EOG, Respiration, ECG, EMG, other polygraphic channel (+ free text), and their significance logged (normal, abnormal, no definite abnormality)." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Posterior-dominant-rhythm-caveat a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-caveat" ;
    rdfs:comment "Caveat to the annotation of PDR." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Recording-device a hed:HedTag ;
    rdfs:label "Recording-device" ;
    rdfs:comment "A device that copies information in a signal into a persistent information bearer." ;
    hed:hasHedParent hedt:IO-device .

hedt:Semiology-experiential a hed:HedTag ;
    rdfs:label "Semiology-experiential" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-language-related a hed:HedTag ;
    rdfs:label "Semiology-language-related" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-non-motor-manifestation a hed:HedTag ;
    rdfs:label "Semiology-non-motor-manifestation" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Seizure-semiology-manifestation .

hedt:Absence-of-posterior-dominant-rhythm a hed:HedTag ;
    rdfs:label "Absence-of-posterior-dominant-rhythm" ;
    rdfs:comment "Reason for absence of PDR." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Center-of a hed:HedTag ;
    rdfs:label "Center-of" ;
    rdfs:comment "(A, (Center-of, B)) means A is at a point or or in an area that is approximately central within B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Data-resolution a hed:HedTag ;
    rdfs:label "Data-resolution" ;
    rdfs:comment "Smallest change in a quality being measured by an sensor that causes a perceptible change." ;
    hed:hasHedParent hedt:Data-property .

hedt:EMG-feature a hed:HedTag ;
    rdfs:label "EMG-feature" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:EMG-channel-finding .

hedt:Finding-amplitude a hed:HedTag ;
    rdfs:label "Finding-amplitude" ;
    rdfs:comment "Value in microvolts (number) typed in." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Input-device a hed:HedTag ;
    rdfs:label "Input-device" ;
    rdfs:comment "A piece of equipment used to provide data and control signals to an information processing system such as a computer or information appliance." ;
    hed:hasHedParent hedt:IO-device .

hedt:Lower-extremity a hed:HedTag ;
    rdfs:label "Lower-extremity" ;
    rdfs:comment "Refers to the whole inferior limb (leg and/or foot)." ;
    hed:hasHedParent hedt:Body-part .

hedt:Lower-right-of a hed:HedTag ;
    rdfs:label "Lower-right-of" ;
    rdfs:comment "(A, (Lower-right-of, B)) means A is situated on the lower right part of B. This relation is often used to specify qualitative information about screen position." ;
    heda:relatedTag hedt:Center-of,
        hedt:Lower-center-of,
        hedt:Lower-left-of,
        hedt:Lower-right-of,
        hedt:Upper-center-of,
        hedt:Upper-left-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Move-body-part a hed:HedTag ;
    rdfs:label "Move-body-part" ;
    rdfs:comment "Move one part of a body." ;
    hed:hasHedParent hedt:Move .

hedt:Move-head a hed:HedTag ;
    rdfs:label "Move-head" ;
    rdfs:comment "Move head." ;
    hed:hasHedParent hedt:Move-body-part .

hedt:Non-biological-artifact a hed:HedTag ;
    rdfs:label "Non-biological-artifact" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Artifact .

hedt:Periodic-discharge-absolute-amplitude a hed:HedTag ;
    rdfs:label "Periodic-discharge-absolute-amplitude" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Pink-color a hed:HedTag ;
    rdfs:label "Pink-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Quantitative-value a hed:HedTag ;
    rdfs:label "Quantitative-value" ;
    rdfs:comment "Something capable of being estimated or expressed with numeric values." ;
    hed:hasHedParent hedt:Data-value .

hedt:Relation a hed:HedTag ;
    rdfs:label "Relation" ;
    rdfs:comment "Concerns the way in which two or more people or things are connected." ;
    heda:extensionAllowed true .

hedt:Respiration-feature a hed:HedTag ;
    rdfs:label "Respiration-feature" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Respiration-channel-finding .

hedt:Size a hed:HedTag ;
    rdfs:label "Size" ;
    rdfs:comment "The physical magnitude of something." ;
    hed:hasHedParent hedt:Spatial-value .

hedt:Sleep-modulator a hed:HedTag ;
    rdfs:label "Sleep-modulator" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulator .

hedt:Sleep-related-episode a hed:HedTag ;
    rdfs:label "Sleep-related-episode" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Temporal-marker a hed:HedTag ;
    rdfs:label "Temporal-marker" ;
    rdfs:comment "An indicator placed at a particular time in the data." ;
    hed:hasHedParent hedt:Data-marker .

hedt:Temporal-relation a hed:HedTag ;
    rdfs:label "Temporal-relation" ;
    rdfs:comment "A relationship that includes a temporal or time-based component." ;
    hed:hasHedParent hedt:Relation .

hedt:Time-related-property a hed:HedTag ;
    rdfs:label "Time-related-property" ;
    rdfs:comment "Important to estimate how often an interictal abnormality is seen in the recording." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Torso a hed:HedTag ;
    rdfs:label "Torso" ;
    rdfs:comment "The body excluding the head and neck and limbs." ;
    hed:hasHedParent hedt:Body-part .

hedt:Upper-center-of a hed:HedTag ;
    rdfs:label "Upper-center-of" ;
    rdfs:comment "(A, (Upper-center-of, B)) means A is situated on the upper center part of B (due north). This relation is often used to specify qualitative information about screen position." ;
    heda:relatedTag hedt:Center-of,
        hedt:Lower-center-of,
        hedt:Lower-left-of,
        hedt:Lower-right-of,
        hedt:Upper-center-of,
        hedt:Upper-right-of ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Upper-extremity a hed:HedTag ;
    rdfs:label "Upper-extremity" ;
    rdfs:comment "Refers to the whole superior limb (shoulder, arm, elbow, wrist, hand)." ;
    hed:hasHedParent hedt:Body-part .

hedt:Agent a hed:HedTag ;
    rdfs:label "Agent" ;
    rdfs:comment "Someone or something that takes an active role or produces a specified effect.The role or effect may be implicit. Being alive or performing an activity such as a computation may qualify something to be an agent. An agent may also be something that simulates something else." ;
    heda:suggestedTag hedt:Agent-property .

hedt:Agent-physiological-state a hed:HedTag ;
    rdfs:label "Agent-physiological-state" ;
    rdfs:comment "Having to do with the mechanical, physical, or biochemical function of an agent." ;
    hed:hasHedParent hedt:Agent-state .

hedt:Agent-trait a hed:HedTag ;
    rdfs:label "Agent-trait" ;
    rdfs:comment "A genetically, environmentally, or socially determined characteristic of an agent." ;
    hed:hasHedParent hedt:Agent-property .

hedt:Background-activity-special-feature a hed:HedTag ;
    rdfs:label "Background-activity-special-feature" ;
    rdfs:comment "Special Features. Special features contains scoring options for the background activity of critically ill patients." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Background-activity .

hedt:Comparative-relation a hed:HedTag ;
    rdfs:label "Comparative-relation" ;
    rdfs:comment "Something considered in comparison to something else. The first entity is the focus." ;
    hed:hasHedParent hedt:Relation .

hedt:Data-property a hed:HedTag ;
    rdfs:label "Data-property" ;
    rdfs:comment "Something that pertains to data or information." ;
    heda:extensionAllowed true ;
    hed:hasHedParent hedt:Property .

hedt:Episode-property a hed:HedTag ;
    rdfs:label "Episode-property" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Event a hed:HedTag ;
    rdfs:label "Event" ;
    rdfs:comment "Something that happens at a given time and (typically) place. Elements of this tag subtree designate the general category in which an event falls." ;
    heda:suggestedTag hedt:Task-property .

hedt:Facilitating-factor a hed:HedTag ;
    rdfs:label "Facilitating-factor" ;
    rdfs:comment "Facilitating factors are defined as transient and sporadic endogenous or exogenous elements capable of augmenting seizure incidence (increasing the likelihood of seizure occurrence)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Finding-extent a hed:HedTag ;
    rdfs:label "Finding-extent" ;
    rdfs:comment "Percentage of occurrence during the recording (background activity and interictal finding)." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Finding-prevalence a hed:HedTag ;
    rdfs:label "Finding-prevalence" ;
    rdfs:comment "The percentage of the recording covered by the train/burst." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Location-property a hed:HedTag ;
    rdfs:label "Location-property" ;
    rdfs:comment "Location can be scored for findings. Semiologic finding can also be characterized by the somatotopic modifier (i.e. the part of the body where it occurs). In this respect, laterality (left, right, symmetric, asymmetric, left greater than right, right greater than left), body part (eyelid, face, arm, leg, trunk, visceral, hemi-) and centricity (axial, proximal limb, distal limb) can be scored." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Periodic-discharge-time-related-features a hed:HedTag ;
    rdfs:label "Periodic-discharge-time-related-features" ;
    rdfs:comment "Periodic discharges not further specified (PDs) time-relayed features tags." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Posterior-dominant-rhythm-property a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-property" ;
    rdfs:comment "Posterior dominant rhythm is the most often scored EEG feature in clinical practice. Therefore, there are specific terms that can be chosen for characterizing the PDR." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Property a hed:HedTag ;
    rdfs:label "Property" ;
    rdfs:comment "Something that pertains to a thing. A characteristic of some entity. A quality or feature regarded as a characteristic or inherent part of someone or something. HED attributes are adjectives or adverbs." ;
    heda:extensionAllowed true .

hedt:Rate-of-change a hed:HedTag ;
    rdfs:label "Rate-of-change" ;
    rdfs:comment "The amount of change accumulated per unit time." ;
    hed:hasHedParent hedt:Spatiotemporal-value .

hedt:Sensory-attribute a hed:HedTag ;
    rdfs:label "Sensory-attribute" ;
    rdfs:comment "A sensory characteristic associated with another entity." ;
    hed:hasHedParent hedt:Sensory-property .

hedt:Task-property a hed:HedTag ;
    rdfs:label "Task-property" ;
    rdfs:comment "Something that pertains to a task." ;
    heda:extensionAllowed true ;
    hed:hasHedParent hedt:Property .

hedu:frequencyUnits a hed:HedUnitClass ;
    rdfs:label "frequencyUnits" ;
    heda:defaultUnits "Hz" .

hedt:Breathe a hed:HedTag ;
    rdfs:label "Breathe" ;
    rdfs:comment "Inhale or exhale during respiration." ;
    hed:hasHedParent hedt:Move .

hedt:Communicate-vocally a hed:HedTag ;
    rdfs:label "Communicate-vocally" ;
    rdfs:comment "Communicate using mouth or vocal cords." ;
    hed:hasHedParent hedt:Communicate .

hedt:Cyan-color a hed:HedTag ;
    rdfs:label "Cyan-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Device a hed:HedTag ;
    rdfs:label "Device" ;
    rdfs:comment "An object contrived for a specific purpose." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:ECG-feature a hed:HedTag ;
    rdfs:label "ECG-feature" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:ECG-channel-finding .

hedt:Finding-property a hed:HedTag ;
    rdfs:label "Finding-property" ;
    rdfs:comment "Descriptive element similar to main HED /Property. Something that pertains to a thing. A characteristic of some entity. A quality or feature regarded as a characteristic or inherent part of someone or something. HED attributes are adjectives or adverbs." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Intermittent-photic-stimulation-effect a hed:HedTag ;
    rdfs:label "Intermittent-photic-stimulation-effect" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Modulator a hed:HedTag ;
    rdfs:label "Modulator" ;
    rdfs:comment "External stimuli / interventions or changes in the alertness level (sleep) that modify: the background activity, or how often a graphoelement is occurring, or change other features of the graphoelement (like intra-burst frequency). For each observed finding, there is an option of specifying how they are influenced by the modulators and procedures that were done during the recording." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Named-object-sound a hed:HedTag ;
    rdfs:label "Named-object-sound" ;
    rdfs:comment "A sound identifiable as coming from a particular type of object." ;
    hed:hasHedParent hedt:Sound .

hedt:Vehicle a hed:HedTag ;
    rdfs:label "Vehicle" ;
    rdfs:comment "A mobile machine which transports people or cargo." ;
    hed:hasHedParent hedt:Man-made-object .

hedt:Visual-presentation a hed:HedTag ;
    rdfs:label "Visual-presentation" ;
    rdfs:comment "The sense of sight used in the presentation to the user." ;
    hed:hasHedParent hedt:Sensory-presentation .

hedt:2D-shape a hed:HedTag ;
    rdfs:label "2D-shape" ;
    rdfs:comment "A planar, two-dimensional shape." ;
    hed:hasHedParent hedt:Geometric-object .

hedt:Agent-postural-state a hed:HedTag ;
    rdfs:label "Agent-postural-state" ;
    rdfs:comment "Pertaining to the position in which agent holds their body." ;
    hed:hasHedParent hedt:Agent-state .

hedt:Environmental-property a hed:HedTag ;
    rdfs:label "Environmental-property" ;
    rdfs:comment "Relating to or arising from the surroundings of an agent." ;
    hed:hasHedParent hedt:Property .

hedt:Face a hed:HedTag ;
    rdfs:label "Face" ;
    rdfs:comment "The anterior portion of the head extending from the forehead to the chin and ear to ear. The facial structures contain the eyes, nose and mouth, cheeks and jaws." ;
    hed:hasHedParent hedt:Head .

hedt:Finding-incidence a hed:HedTag ;
    rdfs:label "Finding-incidence" ;
    rdfs:comment "How often it occurs/time-epoch." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Man-made-object a hed:HedTag ;
    rdfs:label "Man-made-object" ;
    rdfs:comment "Something constructed by human means." ;
    hed:hasHedParent hedt:Object .

hedt:Metadata a hed:HedTag ;
    rdfs:label "Metadata" ;
    rdfs:comment "Data about data. Information that describes another set of data." ;
    hed:hasHedParent hedt:Informational-property .

hedt:Periodic-discharge-morphology a hed:HedTag ;
    rdfs:label "Periodic-discharge-morphology" ;
    rdfs:comment "Periodic discharges not further specified (PDs)." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Property-absence a hed:HedTag ;
    rdfs:label "Property-absence" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Property-exists a hed:HedTag ;
    rdfs:label "Property-exists" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Red-color a hed:HedTag ;
    rdfs:label "Red-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Task-event-role a hed:HedTag ;
    rdfs:label "Task-event-role" ;
    rdfs:comment "The purpose of an event with respect to the task." ;
    hed:hasHedParent hedt:Task-property .

hedt:Visualization a hed:HedTag ;
    rdfs:label "Visualization" ;
    rdfs:comment "An planned process that creates images, diagrams or animations from the input data." ;
    hed:hasHedParent hedt:Media .

hedt:Categorical-orientation-value a hed:HedTag ;
    rdfs:label "Categorical-orientation-value" ;
    rdfs:comment "Value indicating the orientation or direction of something." ;
    hed:hasHedParent hedt:Categorical-value .

hedt:Episode a hed:HedTag ;
    rdfs:label "Episode" ;
    rdfs:comment "Clinical episode or electrographic seizure." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Finding-amplitude-asymmetry a hed:HedTag ;
    rdfs:label "Finding-amplitude-asymmetry" ;
    rdfs:comment "For posterior dominant rhythm: a difference in amplitude between the homologous area on opposite sides of the head that consistently exceeds 50 percent. When symmetrical could be labeled with base schema Symmetrical tag. For sleep: Absence or consistently marked amplitude asymmetry (greater than 50 percent) of a normal sleep graphoelement." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Finding-stopped-by a hed:HedTag ;
    rdfs:label "Finding-stopped-by" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Finding-unmodified a hed:HedTag ;
    rdfs:label "Finding-unmodified" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Gray-color a hed:HedTag ;
    rdfs:label "Gray-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Named-animal-sound a hed:HedTag ;
    rdfs:label "Named-animal-sound" ;
    rdfs:comment "A sound recognizable as being associated with particular animals." ;
    hed:hasHedParent hedt:Sound .

hedt:Physiologic-pattern a hed:HedTag ;
    rdfs:label "Physiologic-pattern" ;
    rdfs:comment "EEG graphoelements or rhythms that are considered normal. They only should be scored if the physician considers that they have a specific clinical significance for the recording." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Semiology-sensory a hed:HedTag ;
    rdfs:label "Semiology-sensory" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Sensory-presentation a hed:HedTag ;
    rdfs:label "Sensory-presentation" ;
    rdfs:comment "The entity has a sensory manifestation." ;
    hed:hasHedParent hedt:Sensory-property .

hedt:Statistical-value a hed:HedTag ;
    rdfs:label "Statistical-value" ;
    rdfs:comment "A value based on or employing the principles of statistics." ;
    heda:extensionAllowed true ;
    hed:hasHedParent hedt:Data-value .

hedt:Task-attentional-demand a hed:HedTag ;
    rdfs:label "Task-attentional-demand" ;
    rdfs:comment "Strategy for allocating attention toward goal-relevant information." ;
    hed:hasHedParent hedt:Task-property .

hedt:Terrain a hed:HedTag ;
    rdfs:label "Terrain" ;
    rdfs:comment "Characterization of the physical features of a tract of land." ;
    hed:hasHedParent hedt:Environmental-property .

hedt:CSS-color a hed:HedTag ;
    rdfs:label "CSS-color" ;
    rdfs:comment "One of 140 colors supported by all browsers. For more details such as the color RGB or HEX values,  check:  https://www.w3schools.com/colors/colors_groups.asp." ;
    hed:hasHedParent hedt:Color .

hedt:Categorical-class-value a hed:HedTag ;
    rdfs:label "Categorical-class-value" ;
    rdfs:comment "Categorical values that fall into discrete classes such as true or false. The grouping is absolute in the sense that it is the same for all participants." ;
    hed:hasHedParent hedt:Categorical-value .

hedt:Episode-time-context-property a hed:HedTag ;
    rdfs:label "Episode-time-context-property" ;
    rdfs:comment "Additional clinically relevant features related to episodes can be scored under timing and context. If needed, episode duration can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Temporal-value/Duration." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Episode-property .

hedt:Language-item a hed:HedTag ;
    rdfs:label "Language-item" ;
    rdfs:comment "An entity related to a systematic means of communicating by the use of sounds, symbols, or gestures." ;
    heda:suggestedTag hedt:Sensory-presentation ;
    hed:hasHedParent hedt:Item .

hedt:Move-eyes a hed:HedTag ;
    rdfs:label "Move-eyes" ;
    rdfs:comment "Move eyes." ;
    hed:hasHedParent hedt:Move-body-part .

hedt:Move-lower-extremity a hed:HedTag ;
    rdfs:label "Move-lower-extremity" ;
    rdfs:comment "Move leg and/or foot." ;
    hed:hasHedParent hedt:Move-body-part .

hedt:Other-finding-property a hed:HedTag ;
    rdfs:label "Other-finding-property" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Perform a hed:HedTag ;
    rdfs:label "Perform" ;
    rdfs:comment "Carry out or accomplish an action, task, or function." ;
    hed:hasHedParent hedt:Action .

hedt:Semiology-autonomic a hed:HedTag ;
    rdfs:label "Semiology-autonomic" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-motor-automatisms a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-motor-manifestation .

hedt:Sleep-and-drowsiness a hed:HedTag ;
    rdfs:label "Sleep-and-drowsiness" ;
    rdfs:comment "The features of the ongoing activity during sleep are scored here. If abnormal graphoelements appear, disappear or change their morphology during sleep, that is not scored here but at the entry corresponding to that graphooelement (as a modulator)." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedt:Yellow-color a hed:HedTag ;
    rdfs:label "Yellow-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Episode-appearance a hed:HedTag ;
    rdfs:label "Episode-appearance" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-responsiveness a hed:HedTag ;
    rdfs:label "Episode-responsiveness" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Rhythmic-activity-morphology a hed:HedTag ;
    rdfs:label "Rhythmic-activity-morphology" ;
    rdfs:comment "EEG activity consisting of a sequence of waves approximately constant period." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Seizure-dynamics a hed:HedTag ;
    rdfs:label "Seizure-dynamics" ;
    rdfs:comment "Spatiotemporal dynamics can be scored (evolution in morphology; evolution in frequency; evolution in location)." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Task-action-type a hed:HedTag ;
    rdfs:label "Task-action-type" ;
    rdfs:comment "How an agent action should be interpreted in terms of the task specification." ;
    hed:hasHedParent hedt:Task-property .

hedt:Uncertain-significant-pattern a hed:HedTag ;
    rdfs:label "Uncertain-significant-pattern" ;
    rdfs:comment "EEG graphoelements or rhythms that resemble abnormal patterns but that are not necessarily associated with a pathology, and the physician does not consider them abnormal in the context of the scored recording (like normal variants and patterns)." ;
    heda:inLibrary "score" ;
    heda:requireChild true .

hedu:physicalLengthUnits a hed:HedUnitClass ;
    rdfs:label "physicalLengthUnits" ;
    heda:defaultUnits "m" .

hedt:Agent-cognitive-state a hed:HedTag ;
    rdfs:label "Agent-cognitive-state" ;
    rdfs:comment "The state of the cognitive processes or state of mind of the agent." ;
    hed:hasHedParent hedt:Agent-state .

hedt:Move-body a hed:HedTag ;
    rdfs:label "Move-body" ;
    rdfs:comment "Move entire body." ;
    hed:hasHedParent hedt:Move .

hedt:Move-face a hed:HedTag ;
    rdfs:label "Move-face" ;
    rdfs:comment "Move the face or jaw." ;
    hed:hasHedParent hedt:Move-body-part .

hedt:Organizational-property a hed:HedTag ;
    rdfs:label "Organizational-property" ;
    rdfs:comment "Relating to an organization or the action of organizing something." ;
    hed:hasHedParent hedt:Property .

hedt:Semiology-elementary-motor a hed:HedTag ;
    rdfs:label "Semiology-elementary-motor" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Semiology-motor-manifestation .

hedt:Biological-artifact a hed:HedTag ;
    rdfs:label "Biological-artifact" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Artifact .

hedt:Connective-relation a hed:HedTag ;
    rdfs:label "Connective-relation" ;
    rdfs:comment "Indicates two entities are related in some way. The first entity is the focus." ;
    hed:hasHedParent hedt:Relation .

hedu:timeUnits a hed:HedUnitClass ;
    rdfs:label "timeUnits" ;
    heda:defaultUnits "s" .

hedt:Blue-color a hed:HedTag ;
    rdfs:label "Blue-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Data-variability-attribute a hed:HedTag ;
    rdfs:label "Data-variability-attribute" ;
    rdfs:comment "An attribute describing how something changes or varies." ;
    hed:hasHedParent hedt:Data-property .

hedt:Postictal-semiology-manifestation a hed:HedTag ;
    rdfs:label "Postictal-semiology-manifestation" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-property .

hedt:Multifocal-finding a hed:HedTag ;
    rdfs:label "Multifocal-finding" ;
    rdfs:comment "When the same interictal graphoelement is observed bilaterally and at least in three independent locations, can score them using one entry, and choosing multifocal as a descriptor of the locations of the given interictal graphoelements, optionally emphasizing the involved, and the most active sites." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Location-property .

hedt:White-color a hed:HedTag ;
    rdfs:label "White-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Brown-color a hed:HedTag ;
    rdfs:label "Brown-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Communicate-gesturally a hed:HedTag ;
    rdfs:label "Communicate-gesturally" ;
    rdfs:comment "Communicate nonverbally using visible bodily actions, either in place of speech or together and in parallel with spoken words. Gestures include movement of the hands, face, or other parts of the body." ;
    heda:relatedTag hedt:Move-face,
        hedt:Move-upper-extremity ;
    hed:hasHedParent hedt:Communicate .

hedt:Modulators-property a hed:HedTag ;
    rdfs:label "Modulators-property" ;
    rdfs:comment "For each described graphoelement, the influence of the modulators can be scored. Only modulators present in the recording are scored." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedu:nameClass a hed:HedValueClass ;
    rdfs:label "nameClass" ;
    rdfs:comment "Value class designating values that have the characteristics of node names. The allowed characters are alphanumeric, hyphen, and underbar." ;
    heda:allowedCharacter "-",
        "_",
        "digits",
        "letters" .

hedt:Agent-emotional-state a hed:HedTag ;
    rdfs:label "Agent-emotional-state" ;
    rdfs:comment "The status of the general temperament and outlook of an agent." ;
    hed:hasHedParent hedt:Agent-state .

hedt:Purple-color a hed:HedTag ;
    rdfs:label "Purple-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Categorical-level-value a hed:HedTag ;
    rdfs:label "Categorical-level-value" ;
    rdfs:comment "Categorical values based on dividing a continuous variable into levels such as high and low." ;
    hed:hasHedParent hedt:Categorical-value .

hedt:Finding-frequency a hed:HedTag ;
    rdfs:label "Finding-frequency" ;
    rdfs:comment "Value in Hz (number) typed in." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Categorical-judgment-value a hed:HedTag ;
    rdfs:label "Categorical-judgment-value" ;
    rdfs:comment "Categorical values that are based on the judgment or perception of the participant such familiar and famous." ;
    hed:hasHedParent hedt:Categorical-value .

hedt:Motor-onset-seizure a hed:HedTag ;
    rdfs:label "Motor-onset-seizure" ;
    heda:deprecatedFrom "1.0.0" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Seizure-classification .

hedt:Think a hed:HedTag ;
    rdfs:label "Think" ;
    rdfs:comment "Direct the mind toward someone or something or use the mind actively to form connected ideas." ;
    hed:hasHedParent hedt:Action .

hedt:Green-color a hed:HedTag ;
    rdfs:label "Green-color" ;
    rdfs:comment "CSS color group." ;
    hed:hasHedParent hedt:CSS-color .

hedt:Source-analysis-brain-region a hed:HedTag ;
    rdfs:label "Source-analysis-brain-region" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Source-analysis-property .

hedt:Move-upper-extremity a hed:HedTag ;
    rdfs:label "Move-upper-extremity" ;
    rdfs:comment "Move arm, shoulder, and/or hand." ;
    hed:hasHedParent hedt:Move-body-part .

hedt:Task-stimulus-role a hed:HedTag ;
    rdfs:label "Task-stimulus-role" ;
    rdfs:comment "The role the stimulus plays in the task." ;
    hed:hasHedParent hedt:Task-property .

hedt:Artifact-significance-to-recording a hed:HedTag ;
    rdfs:label "Artifact-significance-to-recording" ;
    rdfs:comment "It is important to score the significance of the described artifacts: recording is not interpretable, recording of reduced diagnostic value, does not interfere with the interpretation of the recording." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Episode-awareness a hed:HedTag ;
    rdfs:label "Episode-awareness" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-postictal-phase a hed:HedTag ;
    rdfs:label "Episode-postictal-phase" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-prodrome a hed:HedTag ;
    rdfs:label "Episode-prodrome" ;
    rdfs:comment "Prodrome is a preictal phenomenon, and it is defined as a subjective or objective clinical alteration (e.g., ill-localized sensation or agitation) that heralds the onset of an epileptic seizure but does not form part of it (Blume et al., 2001). Therefore, prodrome should be distinguished from aura (which is an ictal phenomenon)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-tongue-biting a hed:HedTag ;
    rdfs:label "Episode-tongue-biting" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Signal-morphology-property a hed:HedTag ;
    rdfs:label "Signal-morphology-property" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Brain-centricity a hed:HedTag ;
    rdfs:label "Brain-centricity" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:State-episode-start a hed:HedTag ;
    rdfs:label "State-episode-start" ;
    rdfs:comment "State at the start of the episode." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-phase a hed:HedTag ;
    rdfs:label "Episode-phase" ;
    rdfs:comment "The electroclinical findings (i.e., the seizure semiology and the ictal EEG) are divided in three phases: onset, propagation, and postictal." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Ictal-EEG-patterns,
        hedt:Postictal-semiology-manifestation,
        hedt:Seizure-semiology-manifestation ;
    hed:hasHedParent hedt:Episode-property .

hedt:Clinical-EEG-temporal-relationship a hed:HedTag ;
    rdfs:label "Clinical-EEG-temporal-relationship" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-consciousness a hed:HedTag ;
    rdfs:label "Episode-consciousness" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Discharge-pattern a hed:HedTag ;
    rdfs:label "Discharge-pattern" ;
    rdfs:comment "Describes the organization of the EEG signal within the discharge (distinguish between single and repetitive discharges)" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Body-part-location a hed:HedTag ;
    rdfs:label "Body-part-location" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:Finding-significance-to-recording a hed:HedTag ;
    rdfs:label "Finding-significance-to-recording" ;
    rdfs:comment "Significance of finding. When normal/abnormal could be labeled with base schema Normal/Abnormal tags." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Appearance-mode a hed:HedTag ;
    rdfs:label "Appearance-mode" ;
    rdfs:comment "Describes how the non-ictal EEG pattern/graphoelement is distributed through the recording." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Property-not-possible-to-determine a hed:HedTag ;
    rdfs:label "Property-not-possible-to-determine" ;
    rdfs:comment "Not possible to determine." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Spatial-relation a hed:HedTag ;
    rdfs:label "Spatial-relation" ;
    rdfs:comment "Indicating a relationship about position between entities." ;
    hed:hasHedParent hedt:Relation .

hedt:Sensors a hed:HedTag ;
    rdfs:label "Sensors" ;
    rdfs:comment "Lists all corresponding sensors (electrodes/channels in montage). The sensor-group is selected from a list defined in the site-settings for each EEG-lab." ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:Brain-region a hed:HedTag ;
    rdfs:label "Brain-region" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedu:numericClass a hed:HedValueClass ;
    rdfs:label "numericClass" ;
    rdfs:comment "Value must be a valid numerical value." ;
    heda:allowedCharacter "+",
        "-",
        ".",
        "E",
        "digits",
        "e" .

hedt:Episode-event-count a hed:HedTag ;
    rdfs:label "Episode-event-count" ;
    rdfs:comment "Number of stereotypical episodes during the recording." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Brain-laterality a hed:HedTag ;
    rdfs:label "Brain-laterality" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedu:textClass a hed:HedValueClass ;
    rdfs:label "textClass" ;
    rdfs:comment "Value class designating values that have the characteristics of text such as in descriptions." ;
    heda:allowedCharacter "$",
        "%",
        "(",
        ")",
        "*",
        "+",
        "-",
        ".",
        "/",
        ":",
        ";",
        "?",
        "@",
        "blank",
        "digits",
        "letters" .

