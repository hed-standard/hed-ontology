hedt:Focal-to-bilateral-tonic-clonic-focal-onset-epileptic-seizure a hed:HedTag ;
    rdfs:label "Focal-to-bilateral-tonic-clonic-focal-onset-epileptic-seizure" ;
    rdfs:comment "A seizure type with focal onset, with awareness or impaired awareness, either motor or non-motor, progressing to bilateral tonic clonic activity. The prior term was seizure with partial onset with secondary generalization. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Seizure-dynamics,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Focal-onset-epileptic-seizure .

hedt:Forearm a hed:HedTag ;
    rdfs:label "Forearm" ;
    rdfs:comment "Lower part of the arm between the elbow and wrist." ;
    hed:hasHedParent hedt:Upper-extremity .

hedt:Foreground-view a hed:HedTag ;
    rdfs:label "Foreground-view" ;
    rdfs:comment "Parts of the view that are closest to the viewer and usually the most important part of the visual focus." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:Forehead a hed:HedTag ;
    rdfs:label "Forehead" ;
    rdfs:comment "The part of the face between the eyebrows and the normal hairline." ;
    hed:hasHedParent hedt:Face .

hedt:ForestGreen a hed:HedTag ;
    rdfs:label "ForestGreen" ;
    rdfs:comment "CSS-color 0x228B22." ;
    hed:hasHedParent hedt:Green-color .

hedt:Fourteen-six-Hz-positive-burst a hed:HedTag ;
    rdfs:label "Fourteen-six-Hz-positive-burst" ;
    rdfs:comment "Burst of arch-shaped waves at 13-17 Hz and/or 5-7-Hz but most commonly at 14 and or 6 Hz seen generally over the posterior temporal and adjacent areas of one or both sides of the head during sleep. The sharp peaks of its component waves are positive with respect to other regions. Amplitude varies but is generally below 75  micro V. Comments: (1) best demonstrated by referential recording using contralateral earlobe or other remote, reference electrodes. (2) This pattern has no established clinical significance." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Foveal-view a hed:HedTag ;
    rdfs:label "Foveal-view" ;
    rdfs:comment "Visual presentation directly on the fovea. A view projected on the small depression in the retina containing only cones and where vision is most acute." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:Fractal a hed:HedTag ;
    rdfs:label "Fractal" ;
    rdfs:comment "Having extremely irregular curves or shapes for which any suitably chosen part is similar in shape to a given larger or smaller part when magnified or reduced to the same size." ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Fraction-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
