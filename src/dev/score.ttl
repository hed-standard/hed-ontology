    hed:hasHedParent hedt:Agent-trait .

hedt:Alpha-activity-morphology a hed:HedTag ;
    rdfs:label "Alpha-activity-morphology" ;
    rdfs:comment "EEG rhythm in the alpha range (8-13 Hz) which is considered part of the background (ongoing) activity but does not fulfill the criteria of the posterior dominant rhythm (alpha rhythm)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-amplitude,
        hedt:Finding-frequency ;
    hed:hasHedParent hedt:Rhythmic-activity-morphology .

