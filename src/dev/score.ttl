    rdfs:comment "Frequency can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Rate-of-change/Frequency" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:ECG-feature .

hedt:ECG-ventricular-premature-depolarization a hed:HedTag ;
