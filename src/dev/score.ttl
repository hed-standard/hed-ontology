hedt:Thumb a hed:HedTag ;
    rdfs:label "Thumb" ;
    rdfs:comment "The thick and short hand digit which is next to the index finger in humans." ;
    hed:hasHedParent hedt:Finger .

hedt:Thumb-up a hed:HedTag ;
    rdfs:label "Thumb-up" ;
    rdfs:comment "Extend the thumb upward to indicate approval." ;
