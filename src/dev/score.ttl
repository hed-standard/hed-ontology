hedt:Cognitive-nonmotor-seizure a hed:HedTag ;
    rdfs:label "Cognitive-nonmotor-seizure" ;
    rdfs:comment "Pertaining to thinking and higher cortical functions, such as language, spatial perception, memory, and praxis. The previous term for similar usage as a seizure type was psychic. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Nonmotor-seizure .

hedt:Cognitive-task a hed:HedTag ;
    rdfs:label "Cognitive-task" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Modulator .

hedt:Cold a hed:HedTag ;
    rdfs:label "Cold" ;
    rdfs:comment "Having an absence of heat." ;
    heda:relatedTag hedt:Hot ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Collection a hed:HedTag ;
    rdfs:label "Collection" ;
    rdfs:comment "A tag designating a grouping of items such as in a set or list." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Complex a hed:HedTag ;
    rdfs:label "Complex" ;
    rdfs:comment "Hard, involved or complicated, elaborate, having many parts." ;
    heda:relatedTag hedt:Simple ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Computer-screen a hed:HedTag ;
    rdfs:label "Computer-screen" ;
    rdfs:comment "An electronic device designed as a display or a physical device designed to be a protective meshwork." ;
    hed:hasHedParent hedt:Display-device .

hedt:Condition-variable a hed:HedTag ;
    rdfs:label "Condition-variable" ;
    rdfs:comment "An aspect of the experiment or task that is to be varied during the experiment. Task-conditions are sometimes called independent variables or contrasts." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Congruent a hed:HedTag ;
    rdfs:label "Congruent" ;
    rdfs:comment "Concordance of multiple evidence lines. In agreement or harmony." ;
    heda:relatedTag hedt:Incongruent ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Constrained a hed:HedTag ;
    rdfs:label "Constrained" ;
    rdfs:comment "Keeping something within particular limits or bounds." ;
    heda:relatedTag hedt:Unconstrained ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Continuous-appearance-mode a hed:HedTag ;
    rdfs:label "Continuous-appearance-mode" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Appearance-mode .

hedt:Continuous-finding-prevalence a hed:HedTag ;
    rdfs:label "Continuous-finding-prevalence" ;
    rdfs:comment "Greater than 90 percent." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Finding-prevalence .

hedt:Control-variable a hed:HedTag ;
    rdfs:label "Control-variable" ;
    rdfs:comment "An aspect of the experiment that is fixed throughout the study and usually is explicitly controlled." ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Correct a hed:HedTag ;
    rdfs:label "Correct" ;
    rdfs:comment "Free from error. Especially conforming to fact or truth." ;
    heda:relatedTag hedt:Wrong ;
    hed:hasHedParent hedt:Categorical-class-value .

hedt:Covert-attention a hed:HedTag ;
    rdfs:label "Covert-attention" ;
    rdfs:comment "Paying attention without moving the eyes." ;
    heda:relatedTag hedt:Overt-attention ;
    hed:hasHedParent hedt:Task-attentional-demand .

hedt:Creation-date a hed:HedTag ;
    rdfs:label "Creation-date" ;
    rdfs:comment "The date on which data creation of this element began." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Metadata .

hedt:Data-maximum a hed:HedTag ;
    rdfs:label "Data-maximum" ;
    rdfs:comment "The largest possible quantity or degree." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Data-mean a hed:HedTag ;
    rdfs:label "Data-mean" ;
    rdfs:comment "The sum of a set of values divided by the number of values in the set." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Data-median a hed:HedTag ;
    rdfs:label "Data-median" ;
    rdfs:comment "The value which has an equal number of values greater and less than it." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Data-minimum a hed:HedTag ;
    rdfs:label "Data-minimum" ;
    rdfs:comment "The smallest possible quantity." ;
    hed:hasHedParent hedt:Statistical-value .

hedt:Decreasing a hed:HedTag ;
    rdfs:label "Decreasing" ;
    rdfs:comment "Becoming smaller or fewer in size, amount, intensity, or degree." ;
    heda:relatedTag hedt:Increasing ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Deep a hed:HedTag ;
    rdfs:label "Deep" ;
    rdfs:comment "Extending relatively far inward or downward." ;
    heda:relatedTag hedt:Shallow ;
    hed:hasHedParent hedt:Categorical-level-value .

hedt:Def a hed:HedTag ;
    rdfs:label "Def" ;
    rdfs:comment "A HED-specific utility tag used with a defined name to represent the tags associated with that definition." ;
    heda:requireChild true ;
    heda:reserved true ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Def-expand a hed:HedTag ;
    rdfs:label "Def-expand" ;
    rdfs:comment "A HED specific utility tag that is grouped with an expanded definition. The child value of the Def-expand is the name of the expanded definition." ;
    heda:requireChild true ;
    heda:reserved true ;
    heda:tagGroup true ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Definition a hed:HedTag ;
    rdfs:label "Definition" ;
    rdfs:comment "A HED-specific utility tag whose child value is the name of the concept and the tag group associated with the tag is an English language explanation of a concept." ;
    heda:requireChild true ;
    heda:reserved true ;
    heda:topLevelTagGroup true ;
    hed:hasHedParent hedt:Organizational-property .

hedt:Delta-activity-morphology a hed:HedTag ;
    rdfs:label "Delta-activity-morphology" ;
    rdfs:comment "EEG rhythm in the delta (under 4 Hz) range that does not belong to the posterior dominant rhythm (scored under other organized rhythms)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-amplitude,
        hedt:Finding-frequency ;
    hed:hasHedParent hedt:Rhythmic-activity-morphology .

hedt:Depth a hed:HedTag ;
    rdfs:label "Depth" ;
    rdfs:comment "The distance from the surface of something especially from the perspective of looking from the front." ;
    hed:hasHedParent hedt:Size .

hedt:Description a hed:HedTag ;
    rdfs:label "Description" ;
    rdfs:comment "An explanation of what the tag group it is in means. If the description is at the top-level of an event string, the description applies to the event." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Informational-property .

hedt:Discrete a hed:HedTag ;
    rdfs:label "Discrete" ;
    rdfs:comment "Constituting a separate entities or parts." ;
    heda:relatedTag hedt:Continuous,
        hedt:Discontinuous ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Disordered a hed:HedTag ;
    rdfs:label "Disordered" ;
    rdfs:comment "Not neatly arranged. Confused and untidy. A structural quality in which the parts of an object are non-rigid." ;
    heda:relatedTag hedt:Ordered ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Divided-attention a hed:HedTag ;
    rdfs:label "Divided-attention" ;
    rdfs:comment "Integrating parallel multiple stimuli. Behavior involving responding simultaneously to multiple tasks or multiple task demands." ;
    heda:relatedTag hedt:Focused-attention ;
    hed:hasHedParent hedt:Task-attentional-demand .

hedt:Done-indication a hed:HedTag ;
    rdfs:label "Done-indication" ;
    rdfs:comment "An action that indicates that the participant has completed this step in the task." ;
    heda:relatedTag hedt:Ready-indication ;
    hed:hasHedParent hedt:Task-action-type .

hedt:Drowsiness a hed:HedTag ;
    rdfs:label "Drowsiness" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Sleep-modulator .

hedt:ECG-QT-period a hed:HedTag ;
    rdfs:label "ECG-QT-period" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:ECG-channel-finding .

hedt:ECG-arrhythmia a hed:HedTag ;
    rdfs:label "ECG-arrhythmia" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:ECG-feature .

hedt:ECG-asystolia a hed:HedTag ;
