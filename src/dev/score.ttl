hedt:Truck a hed:HedTag ;
    rdfs:label "Truck" ;
    rdfs:comment "A motor vehicle which, as its primary funcion, transports cargo rather than human passangers." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Trunk-location-Placeholder a hed:HedPlaceholder ;
