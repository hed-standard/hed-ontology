hedt:Frontal-arousal-rhythm a hed:HedTag ;
    rdfs:label "Frontal-arousal-rhythm" ;
    rdfs:comment "Prolonged (up to 20s) rhythmical sharp or spiky activity over the frontal areas (maximum over the frontal midline) seen at arousal from sleep in children with minimal cerebral dysfunction." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Discharge-pattern ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

