    hed:hasHedParent hedt:Connective-relation .

hedt:Upper-arm a hed:HedTag ;
    rdfs:label "Upper-arm" ;
    rdfs:comment "Portion of arm between shoulder and elbow." ;
    hed:hasHedParent hedt:Upper-extremity .

hedt:Urban a hed:HedTag ;
    rdfs:label "Urban" ;
    rdfs:comment "Relating to, located in, or characteristic of a city or densely populated area." ;
    hed:hasHedParent hedt:Environmental-property .

hedt:Variable-appearance-mode-Placeholder a hed:HedPlaceholder ;
