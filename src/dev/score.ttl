    heda:deprecatedFrom "1.0.0" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Tool a hed:HedTag ;
    rdfs:label "Tool" ;
    rdfs:comment "A component that is not part of a device but is designed to support its assemby or operation." ;
    hed:hasHedParent hedt:Device .

hedt:Top-of a hed:HedTag ;
    rdfs:label "Top-of" ;
    rdfs:comment "(A, (Top-of, B)) means A is on the uppermost part, side, or surface of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Torso-back a hed:HedTag ;
    rdfs:label "Torso-back" ;
    rdfs:comment "The rear surface of the human body from the shoulders to the hips." ;
    hed:hasHedParent hedt:Torso .

hedt:Torso-chest a hed:HedTag ;
    rdfs:label "Torso-chest" ;
    rdfs:comment "The anterior side of the thorax from the neck to the abdomen." ;
    hed:hasHedParent hedt:Torso .

hedt:Touch a hed:HedTag ;
    rdfs:label "Touch" ;
    rdfs:comment "Come into or be in contact with." ;
    hed:hasHedParent hedt:Move-upper-extremity .

hedt:Touchscreen a hed:HedTag ;
