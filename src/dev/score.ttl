    hed:hasHedParent hedt:Communicate-gesturally .

hedt:Thumbs-down a hed:HedTag ;
    rdfs:label "Thumbs-down" ;
    rdfs:comment "Extend the thumb downward to indicate disapproval." ;
    heda:relatedTag hedt:Move-upper-extremity ;
    hed:hasHedParent hedt:Communicate-gesturally .

hedt:Timbre-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:valueClass hedu:nameClass ;
    hed:hasHedParent hedt:Timbre .

hedt:Time-block-Placeholder a hed:HedPlaceholder ;
