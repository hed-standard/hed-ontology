hedt:Semiology-autonomic-cardiovascular a hed:HedTag ;
    rdfs:label "Semiology-autonomic-cardiovascular" ;
    rdfs:comment "Modifications of heart rate (tachycardia, bradycardia), cardiac arrhythmias (such as sinus arrhythmia, sinus arrest, supraventricular tachycardia, atrial premature depolarizations, ventricular premature depolarizations, atrio-ventricular block, bundle branch block, atrioventricular nodal escape rhythm, asystole)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-gastrointestinal a hed:HedTag ;
    rdfs:label "Semiology-autonomic-gastrointestinal" ;
    rdfs:comment "Nausea, eructation, vomiting, retching, abdominal sensations, abdominal pain, flatulence, spitting, diarrhea." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-genital a hed:HedTag ;
    rdfs:label "Semiology-autonomic-genital" ;
    rdfs:comment "Sexual auras (erotic thoughts and feelings, sexual arousal and orgasm). Genital auras (unpleasant, sometimes painful, frightening or emotionally neutral somatosensory sensations in the genitals that can be accompanied by ictal orgasm). Sexual automatisms (hypermotor movements consisting of writhing, thrusting, rhythmic movements of the pelvis, arms and legs, sometimes associated with picking and rhythmic manipulation of the groin or genitalia, exhibitionism and masturbation)." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-hypersalivation a hed:HedTag ;
