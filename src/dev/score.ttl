hedt:Temporal-resolution-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Temporal-resolution .

hedt:Temporal-slowing-elderly a hed:HedTag ;
    rdfs:label "Temporal-slowing-elderly" ;
    rdfs:comment "Focal theta and/or delta activity over the temporal regions, especially the left, in persons over the age of 60. Amplitudes are low/similar to the background activity. Comment: focal temporal theta was found in 20 percent of people between the ages of 40-59 years, and 40 percent of people between 60 and 79 years. One third of people older than 60 years had focal temporal delta activity." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Textblock a hed:HedTag ;
    rdfs:label "Textblock" ;
    rdfs:comment "A block of text." ;
    hed:hasHedParent hedt:Language-item .

hedt:Theta-activity-morphology-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
