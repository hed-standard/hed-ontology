hedt:Fast-alpha-variant-rhythm a hed:HedTag ;
    rdfs:label "Fast-alpha-variant-rhythm" ;
    rdfs:comment "Characteristic rhythm at 14-20 Hz, detected most prominently over the posterior regions of the head. May alternate or be intermixed with alpha rhythm. Blocked or attenuated by attention, especially visual, and mental effort." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Discharge-pattern ;
    hed:hasHedParent hedt:Physiologic-pattern .

