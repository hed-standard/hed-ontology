    heda:takesValue true ;
    heda:unitClass hedu:physicalLengthUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Y-position .

hedt:Yawn a hed:HedTag ;
    rdfs:label "Yawn" ;
    rdfs:comment "Take a deep involuntary  inhalation with the mouth open often as a sign of drowsiness or boredom." ;
    hed:hasHedParent hedt:Move-face .

hedt:Yellow a hed:HedTag ;
    rdfs:label "Yellow" ;
    rdfs:comment "CSS-color 0xFFFF00." ;
    hed:hasHedParent hedt:Yellow-color .

hedt:YellowGreen a hed:HedTag ;
