    rdfs:comment "A drawing showing the head of a human being or animal as a circle and all other parts as straight lines." ;
    hed:hasHedParent hedt:Visualization .

hedt:Street-view a hed:HedTag ;
    rdfs:label "Street-view" ;
    rdfs:comment "A 360-degrees panoramic view from a position on the ground." ;
    hed:hasHedParent hedt:Map-view .

hedt:Stress a hed:HedTag ;
    rdfs:label "Stress" ;
    rdfs:comment "The negative mental, emotional, and physical reactions that occur when environmental stressors are perceived as exceeding the adaptive capacities of the individual." ;
    hed:hasHedParent hedt:Somatic-attribute .

hedt:Stressed a hed:HedTag ;
    rdfs:label "Stressed" ;
    rdfs:comment "Experiencing mental or emotional strain or tension." ;
    hed:hasHedParent hedt:Agent-emotional-state .

hedt:Stretch a hed:HedTag ;
    rdfs:label "Stretch" ;
    rdfs:comment "Straighten or extend body or a part of body to its full length, typically so as to tighten muscles or in order to reach something." ;
    hed:hasHedParent hedt:Move-body .

hedt:Stumble a hed:HedTag ;
    rdfs:label "Stumble" ;
    rdfs:comment "Trip or momentarily lose balance and almost fall." ;
    hed:hasHedParent hedt:Move-body .

hedt:Subclinical-rhythmic-EEG-discharge-adults a hed:HedTag ;
    rdfs:label "Subclinical-rhythmic-EEG-discharge-adults" ;
    rdfs:comment "Subclinical rhythmic EEG discharge of adults (SERDA). A rhythmic pattern seen in the adult age group, mainly in the waking state or drowsiness. It consists of a mixture of frequencies, often predominant in the theta range. The onset may be fairly abrupt with widespread sharp rhythmical theta and occasionally with delta activity. As to the spatial distribution, a maximum of this discharge is usually found over the centroparietal region and especially over the vertex. It may resemble a seizure discharge but is not accompanied by any clinical signs or symptoms." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Subject-identifier-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    hed:hasHedParent hedt:Subject-identifier .

hedt:Subtle-seizure a hed:HedTag ;
    rdfs:label "Subtle-seizure" ;
    rdfs:comment "Seizure type frequent in neonates, sometimes referred to as motor automatisms; they may include random and roving eye movements, sucking, chewing motions, tongue protrusion, rowing or swimming or boxing movements of the arms, pedaling and bicycling movements of the lower limbs; apneic seizures are relatively common. Although some subtle seizures are associated with rhythmic ictal EEG discharges, and are clearly epileptic, ictal EEG often does not show typical epileptic activity." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Episode .

hedt:Sucking-artifact a hed:HedTag ;
    rdfs:label "Sucking-artifact" ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Sudden-periodic-discharge-onset-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Sudden-periodic-discharge-onset .

hedt:Sustained-attention a hed:HedTag ;
    rdfs:label "Sustained-attention" ;
    rdfs:comment "Maintaining a consistent behavioral response during continuous and repetitive activity." ;
    hed:hasHedParent hedt:Task-attentional-demand .

hedt:Sweat-artifact a hed:HedTag ;
    rdfs:label "Sweat-artifact" ;
    rdfs:comment "Is a low amplitude undulating waveform that is usually greater than 2 seconds and may appear to be an unstable baseline." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Sweet a hed:HedTag ;
    rdfs:label "Sweet" ;
    rdfs:comment "Having or resembling the taste of sugar." ;
    hed:hasHedParent hedt:Gustatory-attribute .

hedt:Switch-attention a hed:HedTag ;
    rdfs:label "Switch-attention" ;
    rdfs:comment "Transfer attention from one focus to another." ;
    hed:hasHedParent hedt:Think .

hedt:Switched-attention a hed:HedTag ;
    rdfs:label "Switched-attention" ;
    rdfs:comment "Having to switch attention between two or more modalities of presentation." ;
    hed:hasHedParent hedt:Task-attentional-demand .

hedt:Syllable a hed:HedTag ;
    rdfs:label "Syllable" ;
    rdfs:comment "A unit of spoken language larger than a phoneme." ;
    hed:hasHedParent hedt:Language-item .

hedt:Synchronous-with a hed:HedTag ;
    rdfs:label "Synchronous-with" ;
    rdfs:comment "(A, (Synchronous-with, B)) means A happens at occurs at the same time or rate as B." ;
    hed:hasHedParent hedt:Temporal-relation .

hedt:Syncope a hed:HedTag ;
    rdfs:label "Syncope" ;
    rdfs:comment "Episode with loss of consciousness and muscle tone that is abrupt in onset, of short duration and followed by rapid recovery; it occurs in response to transient impairment of cerebral perfusion. Typical prodromal symptoms often herald onset of syncope and postictal symptoms are minimal. Syncopal convulsions resulting from cerebral anoxia are common but are not a form of epilepsy, nor are there any accompanying EEG ictal discharges." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Episode .

hedt:Tablet-computer a hed:HedTag ;
    rdfs:label "Tablet-computer" ;
    rdfs:comment "A small portable computer that accepts input directly on to its screen rather than via a keyboard or mouse." ;
    hed:hasHedParent hedt:Computing-device .

hedt:Tachypnea-respiration-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Tachypnea-respiration .

hedt:Tactile-presentation a hed:HedTag ;
    rdfs:label "Tactile-presentation" ;
    rdfs:comment "The sense of touch used in the presentation to the user." ;
    hed:hasHedParent hedt:Sensory-presentation .

hedt:Tactile-pressure a hed:HedTag ;
    rdfs:label "Tactile-pressure" ;
    rdfs:comment "Having a feeling of heaviness." ;
    hed:hasHedParent hedt:Tactile-attribute .

hedt:Tactile-temperature a hed:HedTag ;
    rdfs:label "Tactile-temperature" ;
    rdfs:comment "Having a feeling of hotness or coldness." ;
    hed:hasHedParent hedt:Tactile-attribute .

hedt:Tactile-texture a hed:HedTag ;
    rdfs:label "Tactile-texture" ;
    rdfs:comment "Having a feeling of roughness." ;
    hed:hasHedParent hedt:Tactile-attribute .

hedt:Tactile-vibration a hed:HedTag ;
    rdfs:label "Tactile-vibration" ;
    rdfs:comment "Having a feeling of mechanical oscillation." ;
    hed:hasHedParent hedt:Tactile-attribute .

hedt:Tan a hed:HedTag ;
    rdfs:label "Tan" ;
    rdfs:comment "CSS-color 0xD2B48C." ;
    hed:hasHedParent hedt:Brown-color .

hedt:Tape-recorder a hed:HedTag ;
    rdfs:label "Tape-recorder" ;
    rdfs:comment "A device for recording and reproduction usually using magnetic tape for storage that can be saved and played back." ;
    hed:hasHedParent hedt:Recording-device .

hedt:Task-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Optional label for the task block." ;
    heda:takesValue true ;
    heda:valueClass hedu:nameClass ;
    hed:hasHedParent hedt:Task .

hedt:Task-activity a hed:HedTag ;
    rdfs:label "Task-activity" ;
    rdfs:comment "Something that is part of the overall task or is necessary to the overall experiment but is not directly part of a stimulus-response cycle. Examples would be taking a survey or provided providing a silva sample." ;
    hed:hasHedParent hedt:Task-event-role .

hedt:Taste a hed:HedTag ;
    rdfs:label "Taste" ;
    rdfs:comment "Sense a flavor in the mouth and throat on contact with a substance." ;
    hed:hasHedParent hedt:Perceive .

hedt:Teal a hed:HedTag ;
    rdfs:label "Teal" ;
    rdfs:comment "CSS-color 0x008080." ;
    hed:hasHedParent hedt:Green-color .

hedt:Teeth a hed:HedTag ;
    rdfs:label "Teeth" ;
    rdfs:comment "The hard bonelike structures in the jaws. A collection of teeth arranged in some pattern in the mouth or other part of the body." ;
    hed:hasHedParent hedt:Face .

hedt:Temperature-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:temperatureUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Temperature .

hedt:Temporal-intermittent-rhythmic-delta-activity-morphology-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:inLibrary "score" ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Temporal-intermittent-rhythmic-delta-activity-morphology .

hedt:Temporal-rate-Placeholder a hed:HedPlaceholder ;
