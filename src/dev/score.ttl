    hed:hasHedParent hedt:IO-device .

hedt:Towards a hed:HedTag ;
    rdfs:label "Towards" ;
    rdfs:comment "(A, (Towards, B)) indicates that A is going to or has moved to B. The meaning depends on A and B." ;
    hed:hasHedParent hedt:Directional-relation .

hedt:Track a hed:HedTag ;
    rdfs:label "Track" ;
    rdfs:comment "Follow a person, animal, or object through space or time." ;
    hed:hasHedParent hedt:Think .

hedt:Tractor a hed:HedTag ;
    rdfs:label "Tractor" ;
    rdfs:comment "A mobile machine specifically designed to deliver a high tractive effort at slow speeds, and mainly used for the purposes of hauling a trailer or machinery used in agriculture or construction." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Train a hed:HedTag ;
    rdfs:label "Train" ;
    rdfs:comment "A connected line of railroad cars with or without a locomotive." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Triangle a hed:HedTag ;
    rdfs:label "Triangle" ;
    rdfs:comment "A three-sided polygon." ;
    hed:hasHedParent hedt:2D-shape .

hedt:Trot a hed:HedTag ;
    rdfs:label "Trot" ;
