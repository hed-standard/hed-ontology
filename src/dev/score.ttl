hedt:Sleep-periodic-limb-movement a hed:HedTag ;
    rdfs:label "Sleep-periodic-limb-movement" ;
    rdfs:comment "PLMS. Periodic limb movement in sleep. Episodes are characterized by brief (0.5- to 5.0-second) lower-extremity movements during sleep, which typically occur at 20- to 40-second intervals, most commonly during the first 3 hours of sleep. The affected individual is usually not aware of the movements or of the transient partial arousals." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Sleep-related-episode .

hedt:Sleep-related-arousal a hed:HedTag ;
    rdfs:label "Sleep-related-arousal" ;
    rdfs:comment "Normal." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Sleep-related-episode .

hedt:Sleep-spindles a hed:HedTag ;
    rdfs:label "Sleep-spindles" ;
    rdfs:comment "Burst at 11-15 Hz but mostly at 12-14 Hz generally diffuse but of higher voltage over the central regions of the head, occurring during sleep. Amplitude varies but is mostly below 50 microV in the adult." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-amplitude-asymmetry,
        hedt:Finding-significance-to-recording,
        hedt:Sensors ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

