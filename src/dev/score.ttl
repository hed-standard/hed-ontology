hedt:Episode-responsiveness-preserved a hed:HedTag ;
    rdfs:label "Episode-responsiveness-preserved" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Episode-responsiveness .

hedt:Episode-start-from-awake a hed:HedTag ;
    rdfs:label "Episode-start-from-awake" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:State-episode-start .

hedt:Episode-start-from-sleep a hed:HedTag ;
    rdfs:label "Episode-start-from-sleep" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:State-episode-start .

hedt:Event-stream a hed:HedTag ;
    rdfs:label "Event-stream" ;
