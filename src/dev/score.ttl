hedt:Apnea-hypopnea-index-respiration a hed:HedTag ;
    rdfs:label "Apnea-hypopnea-index-respiration" ;
    rdfs:comment "Events/h. Frequency can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Rate-of-change/Frequency" ;
    heda:inLibrary "score" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Respiration-feature .

hedt:Apnoe-respiration a hed:HedTag ;
    rdfs:label "Apnoe-respiration" ;
    rdfs:comment "Add duration (range in seconds) and comments in free text." ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Respiration-feature .

hedt:Appropriate-action a hed:HedTag ;
    rdfs:label "Appropriate-action" ;
    rdfs:comment "An action suitable or proper in the circumstances." ;
    heda:relatedTag hedt:Inappropriate-action ;
    hed:hasHedParent hedt:Task-action-type .

hedt:Area a hed:HedTag ;
    rdfs:label "Area" ;
    rdfs:comment "The extent of a 2-dimensional surface enclosed within a boundary." ;
    hed:hasHedParent hedt:Size .

hedt:Arm-location a hed:HedTag ;
    rdfs:label "Arm-location" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Arrhythmic-trains-or-bursts-discharge-pattern a hed:HedTag ;
    rdfs:label "Arrhythmic-trains-or-bursts-discharge-pattern" ;
    rdfs:comment "Applies to the intra-burst pattern: a non-ictal graphoelement that repeats itself without returning to the background activity between them. The graphoelements within this repetition occur at inconstant period." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-prevalence ;
    hed:hasHedParent hedt:Discharge-pattern .

hedt:Artifact-does-not-interfere-recording a hed:HedTag ;
    rdfs:label "Artifact-does-not-interfere-recording" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Artifact-significance-to-recording .

hedt:Asymmetrical a hed:HedTag ;
    rdfs:label "Asymmetrical" ;
    rdfs:comment "Lacking symmetry or having parts that fail to correspond to one another in shape, size, or arrangement." ;
    heda:relatedTag hedt:Symmetrical ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Atypical-absence-seizure a hed:HedTag ;
    rdfs:label "Atypical-absence-seizure" ;
    rdfs:comment "An absence seizure with changes in tone that are more pronounced than in typical absence or the onset and/or cessation is not abrupt, often associated with slow, irregular, generalized spike-wave activity. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Absence-seizure .

hedt:Audible a hed:HedTag ;
    rdfs:label "Audible" ;
    rdfs:comment "A sound that can be perceived by the participant." ;
    heda:relatedTag hedt:Inaudible ;
    hed:hasHedParent hedt:Categorical-judgment-value .

hedt:Auditory-stimulation a hed:HedTag ;
    rdfs:label "Auditory-stimulation" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Stimulation-modulator .

hedt:Automatism-motor-seizure a hed:HedTag ;
    rdfs:label "Automatism-motor-seizure" ;
    rdfs:comment "A more or less coordinated motor activity usually occurring when cognition is impaired and for which the subject is usually (but not always) amnesic afterward. This often resembles a voluntary movement and may consist of an inappropriate continuation of preictal motor activity. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Autonomic-nonmotor-seizure a hed:HedTag ;
    rdfs:label "Autonomic-nonmotor-seizure" ;
    rdfs:comment "A distinct alteration of autonomic nervous system function involving cardiovascular, pupillary, gastrointestinal, sudomotor, vasomotor, and thermoregulatory functions. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Nonmotor-seizure .

hedt:Awakening a hed:HedTag ;
    rdfs:label "Awakening" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Sleep-modulator .

hedt:Backward a hed:HedTag ;
    rdfs:label "Backward" ;
    rdfs:comment "Directed behind or to the rear." ;
    heda:relatedTag hedt:Forward ;
    hed:hasHedParent hedt:Categorical-orientation-value .

hedt:Beta-activity-morphology a hed:HedTag ;
    rdfs:label "Beta-activity-morphology" ;
    rdfs:comment "EEG rhythm between 14 and 40 Hz, which is considered part of the background (ongoing) activity but does not fulfill the criteria of the posterior dominant rhythm. Most characteristically: a rhythm from 14 to 40 Hz recorded over the fronto-central regions of the head during wakefulness. Amplitude of the beta rhythm varies but is mostly below 30 microV. Other beta rhythms are most prominent in other locations or are diffuse." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Finding-amplitude,
        hedt:Finding-frequency ;
    hed:hasHedParent hedt:Rhythmic-activity-morphology .

hedt:Blunt-periodic-discharge-sharpness a hed:HedTag ;
    rdfs:label "Blunt-periodic-discharge-sharpness" ;
    heda:inLibrary "score" ;
    hed:hasHedParent hedt:Periodic-discharge-sharpness .

hedt:Bottom-up-attention a hed:HedTag ;
