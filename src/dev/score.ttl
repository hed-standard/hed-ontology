    rdfs:label "Ivory" ;
    rdfs:comment "CSS-color 0xFFFFF0." ;
    hed:hasHedParent hedt:White-color .

hedt:Jactatio-capitis-nocturna a hed:HedTag ;
    rdfs:label "Jactatio-capitis-nocturna" ;
    rdfs:comment "Relatively common in normal children at the time of going to bed, especially during the first year of life, the rhythmic head movements persist during sleep. Usually, these phenomena disappear before 3 years of age." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Pediatric-episode .

hedt:Jealous a hed:HedTag ;
    rdfs:label "Jealous" ;
    rdfs:comment "Feeling threatened by a rival in a relationship with another individual, in particular an intimate partner, usually involves feelings of threat, fear, suspicion, distrust, anxiety, anger, betrayal, and rejection." ;
    hed:hasHedParent hedt:Agent-emotional-state .

hedt:Jerk a hed:HedTag ;
    rdfs:label "Jerk" ;
    rdfs:comment "Make a quick, sharp, sudden movement." ;
    hed:hasHedParent hedt:Move-body .

hedt:Jerk-rate-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:jerkUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Jerk-rate .

hedt:Jog a hed:HedTag ;
    rdfs:label "Jog" ;
    rdfs:comment "Run at a trot to exercise." ;
    hed:hasHedParent hedt:Move-lower-extremity .

hedt:Joyful a hed:HedTag ;
    rdfs:label "Joyful" ;
    rdfs:comment "Feeling delight or intense happiness." ;
    hed:hasHedParent hedt:Agent-emotional-state .

hedt:Joystick a hed:HedTag ;
    rdfs:label "Joystick" ;
    rdfs:comment "A control device that uses a movable handle to create two-axis input for a computer device." ;
    hed:hasHedParent hedt:Input-device .

hedt:Judge a hed:HedTag ;
    rdfs:label "Judge" ;
    rdfs:comment "Evaluate evidence to make a decision or form a belief." ;
    hed:hasHedParent hedt:Think .

hedt:Jump a hed:HedTag ;
    rdfs:label "Jump" ;
    rdfs:comment "Move off the ground or other surface through sudden muscular effort in the legs." ;
    hed:hasHedParent hedt:Move-lower-extremity .

hedt:K-complex a hed:HedTag ;
    rdfs:label "K-complex" ;
    rdfs:comment "A burst of somewhat variable appearance, consisting most commonly of a high voltage negative slow wave followed by a smaller positive slow wave frequently associated with a sleep spindle. Duration greater than 0.5 s. Amplitude is generally maximal in the frontal vertex. K complexes occur during nonREM sleep, apparently spontaneously, or in response to sudden sensory / auditory stimuli, and are not specific for any individual sensory modality." ;
    heda:inLibrary "score" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-amplitude-asymmetry,
        hedt:Finding-significance-to-recording,
        hedt:Sensors ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Ka-ching a hed:HedTag ;
    rdfs:label "Ka-ching" ;
    rdfs:comment "The sound made by a mechanical cash register, often to designate a reward." ;
    hed:hasHedParent hedt:Named-object-sound .

hedt:Keyboard-key-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Value of a keyboard key." ;
    heda:takesValue true ;
    hed:hasHedParent hedt:Keyboard-key .

hedt:Keypad-key-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Value of keypad key." ;
    heda:takesValue true ;
    hed:hasHedParent hedt:Keypad-key .

hedt:Khaki a hed:HedTag ;
    rdfs:label "Khaki" ;
    rdfs:comment "CSS-color 0xF0E68C." ;
    hed:hasHedParent hedt:Yellow-color .

hedt:Kick a hed:HedTag ;
    rdfs:label "Kick" ;
    rdfs:comment "Strike out or flail with the foot or feet.  Strike using the leg, in unison usually with an area of the knee or lower using the foot." ;
    hed:hasHedParent hedt:Move-lower-extremity .

hedt:Knee a hed:HedTag ;
    rdfs:label "Knee" ;
    rdfs:comment "A joint connecting the lower part of the femur with the upper part of the tibia." ;
    hed:hasHedParent hedt:Lower-extremity .

hedt:Kneeling a hed:HedTag ;
    rdfs:label "Kneeling" ;
    rdfs:comment "Positioned where one or both knees are on the ground." ;
    hed:hasHedParent hedt:Agent-postural-state .

hedt:Knuckles a hed:HedTag ;
    rdfs:label "Knuckles" ;
    rdfs:comment "A part of a finger at a joint where the bone is near the surface, especially where the finger joins the hand." ;
    hed:hasHedParent hedt:Hand .

hedt:LED-display a hed:HedTag ;
    rdfs:label "LED-display" ;
    rdfs:comment "A LED display is a flat panel display that uses an array of light-emitting diodes as pixels for a video display." ;
    hed:hasHedParent hedt:Display-device .

hedt:LED-pattern a hed:HedTag ;
    rdfs:label "LED-pattern" ;
    rdfs:comment "A pattern created by lighting selected members of a fixed light emitting diode array." ;
