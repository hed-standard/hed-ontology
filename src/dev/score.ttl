        hedt:Eyelid-myoclonia-absence-seizure,
        hedt:Myoclonic-absence-seizure,
        hedt:Myoclonic-atonic-motor-seizure,
        hedt:Myoclonic-motor-seizure,
        hedt:Myoclonic-tonic-clonic-motor-seizure,
        hedt:Seizure-dynamics,
        hedt:State-episode-start,
        hedt:Tonic-clonic-motor-seizure,
        hedt:Tonic-motor-seizure,
        hedt:Typical-absence-seizure ;
    hed:hasHedParent hedt:Epileptic-seizure .

