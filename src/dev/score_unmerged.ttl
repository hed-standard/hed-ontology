hedt:POSTS a hed:HedTag ;
    rdfs:label "POSTS" ;
    rdfs:comment "Positive occipital sharp transients of sleep. Sharp transient maximal over the occipital regions, positive relative to other areas, apparently occurring spontaneously during sleep. May be single or repetitive. Amplitude varies but is generally bellow 50 microV." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-amplitude-asymmetry,
        hedt:Finding-significance-to-recording,
        hedt:Sensors ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Paroxysmal-motor-event a hed:HedTag ;
    rdfs:label "Paroxysmal-motor-event" ;
    rdfs:comment "Paroxysmal phenomena during neonatal or childhood periods characterized by recurrent motor or behavioral signs or symptoms that must be distinguishes from epileptic disorders." ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Episode .

hedt:Pavor-nocturnus a hed:HedTag ;
    rdfs:label "Pavor-nocturnus" ;
    rdfs:comment "A nocturnal episode characterized by age of onset of less than five years (mean age 18 months, with peak prevalence at five to seven years), appearance of signs of panic two hours after falling asleep with crying, screams, a fearful expression, inability to recognize other people including parents (for a duration of 5-15 minutes), amnesia upon awakening. Pavor nocturnus occurs in patients almost every night for months or years (but the frequency is highly variable and may be as low as once a month) and is likely to disappear spontaneously at the age of six to eight years." ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Pediatric-episode .

hedt:Pediatric-stereotypical-behavior-episode a hed:HedTag ;
    rdfs:label "Pediatric-stereotypical-behavior-episode" ;
    rdfs:comment "Repetitive motor behavior in children, typically rhythmic and persistent; usually not paroxysmal and rarely suggest epilepsy. They include headbanging, head-rolling, jactatio capitis nocturna, body rocking, buccal or lingual movements, hand flapping and related mannerisms, repetitive hand-waving (to self-induce photosensitive seizures)." ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Pediatric-episode .

