hedt:Eye-blink-artifact a hed:HedTag ;
    rdfs:label "Eye-blink-artifact" ;
    rdfs:comment "Example for EEG: Fp1/Fp2 become electropositive with eye closure because the cornea is positively charged causing a negative deflection in Fp1/Fp2. If the eye blink is unilateral, consider prosthetic eye. If it is in F8 rather than Fp2 then the electrodes are plugged in wrong." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Eye-closure-sensitivity-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Eye-closure-sensitivity .

hedt:Eye-movement-horizontal-artifact a hed:HedTag ;
    rdfs:label "Eye-movement-horizontal-artifact" ;
    rdfs:comment "Example for EEG: There is an upward deflection in the Fp2-F8 derivation, when the eyes move to the right side. In this case F8 becomes more positive and therefore. When the eyes move to the left, F7 becomes more positive and there is an upward deflection in the Fp1-F7 derivation." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Eye-movement-vertical-artifact a hed:HedTag ;
    rdfs:label "Eye-movement-vertical-artifact" ;
    rdfs:comment "Example for EEG: The EEG shows positive potentials (50-100 micro V) with bi-frontal distribution, maximum at Fp1 and Fp2, when the eyeball rotated upward. The downward rotation of the eyeball was associated with the negative deflection. The time course of the deflections was similar to the time course of the eyeball movement." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Eye-opening-passive a hed:HedTag ;
    rdfs:label "Eye-opening-passive" ;
    rdfs:comment "Passive eye opening. Used with base schema Increasing/Decreasing." ;
    heda:suggestedTag hedt:Finding-stopped-by,
        hedt:Finding-triggered-by,
        hedt:Finding-unmodified,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Modulators-property .

