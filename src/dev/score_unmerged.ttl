hedt:Focal-to-bilateral-tonic-clonic-focal-onset-epileptic-seizure a hed:HedTag ;
    rdfs:label "Focal-to-bilateral-tonic-clonic-focal-onset-epileptic-seizure" ;
    rdfs:comment "A seizure type with focal onset, with awareness or impaired awareness, either motor or non-motor, progressing to bilateral tonic clonic activity. The prior term was seizure with partial onset with secondary generalization. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
