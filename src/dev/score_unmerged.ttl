hedt:Jactatio-capitis-nocturna a hed:HedTag ;
    rdfs:label "Jactatio-capitis-nocturna" ;
    rdfs:comment "Relatively common in normal children at the time of going to bed, especially during the first year of life, the rhythmic head movements persist during sleep. Usually, these phenomena disappear before 3 years of age." ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Pediatric-episode .

hedt:K-complex a hed:HedTag ;
    rdfs:label "K-complex" ;
    rdfs:comment "A burst of somewhat variable appearance, consisting most commonly of a high voltage negative slow wave followed by a smaller positive slow wave frequently associated with a sleep spindle. Duration greater than 0.5 s. Amplitude is generally maximal in the frontal vertex. K complexes occur during nonREM sleep, apparently spontaneously, or in response to sudden sensory / auditory stimuli, and are not specific for any individual sensory modality." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-amplitude-asymmetry,
        hedt:Finding-significance-to-recording,
        hedt:Sensors ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Lambda-wave a hed:HedTag ;
    rdfs:label "Lambda-wave" ;
    rdfs:comment "Diphasic sharp transient occurring over occipital regions of the head of waking subjects during visual exploration. The main component is positive relative to other areas. Time-locked to saccadic eye movement. Amplitude varies but is generally below 50 micro V." ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Physiologic-pattern .

