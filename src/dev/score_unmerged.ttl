        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-atonic a hed:HedTag ;
    rdfs:label "Semiology-motor-atonic" ;
    rdfs:comment "Sudden loss or diminution of muscle tone without apparent preceding myoclonic or tonic event lasting greater or equal to 1 to 2 s, involving head, trunk, jaw, or limb musculature." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-automatisms-dacrystic a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms-dacrystic" ;
