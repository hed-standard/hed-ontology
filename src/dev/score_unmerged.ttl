hedt:Postictal-semiology-anterograde-amnesia a hed:HedTag ;
    rdfs:label "Postictal-semiology-anterograde-amnesia" ;
    rdfs:comment "Impaired ability to remember new material." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-aphasia-or-dysphasia a hed:HedTag ;
    rdfs:label "Postictal-semiology-aphasia-or-dysphasia" ;
    rdfs:comment "Impaired communication involving language without dysfunction of relevant primary motor or sensory pathways, manifested as impaired comprehension, anomia, parahasic errors or a combination of these." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-behavioral-change a hed:HedTag ;
    rdfs:label "Postictal-semiology-behavioral-change" ;
    rdfs:comment "Occurring immediately after a aseizure. Including psychosis, hypomanina, obsessive-compulsive behavior." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-dysphoria a hed:HedTag ;
    rdfs:label "Postictal-semiology-dysphoria" ;
    rdfs:comment "Depression, irritability, euphoric mood, fear, anxiety." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-headache a hed:HedTag ;
    rdfs:label "Postictal-semiology-headache" ;
    rdfs:comment "Headache with features of tension-type or migraine headache that develops within 3 h following the seizure and resolves within 72 h after seizure." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-hemianopia a hed:HedTag ;
    rdfs:label "Postictal-semiology-hemianopia" ;
    rdfs:comment "Postictal visual loss in a a hemi field." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-impaired-cognition a hed:HedTag ;
    rdfs:label "Postictal-semiology-impaired-cognition" ;
    rdfs:comment "Decreased Cognitive performance involving one or more of perception, attention, emotion, memory, execution, praxis, speech." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

hedt:Postictal-semiology-nose-wiping a hed:HedTag ;
    rdfs:label "Postictal-semiology-nose-wiping" ;
    rdfs:comment "Noes-wiping usually within 60 sec of seizure offset, usually with the hand ipsilateral to the seizure onset." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Postictal-semiology-manifestation .

