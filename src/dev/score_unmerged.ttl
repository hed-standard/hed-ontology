hedt:Breach-rhythm a hed:HedTag ;
    rdfs:label "Breach-rhythm" ;
    rdfs:comment "Rhythmical activity recorded over cranial bone defects. Usually it is in the 6 to 11/sec range, does not respond to movements." ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Brief-periodic-discharge-duration-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Brief-periodic-discharge-duration .

hedt:Cataplexy a hed:HedTag ;
    rdfs:label "Cataplexy" ;
    rdfs:comment "A sudden decrement in muscle tone and loss of deep tendon reflexes, leading to muscle weakness, paralysis, or postural collapse. Cataplexy usually is precipitated by an outburst of emotional expression-notably laughter, anger, or startle. It is one of the tetrad of symptoms of narcolepsy. During cataplexy, respiration and voluntary eye movements are not compromised. Consciousness is preserved." ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Episode .

hedt:Chewing-artifact a hed:HedTag ;
    rdfs:label "Chewing-artifact" ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Ciganek-rhythm a hed:HedTag ;
    rdfs:label "Ciganek-rhythm" ;
    rdfs:comment "Midline theta rhythm (Ciganek rhythm) may be observed during wakefulness or drowsiness. The frequency is 4-7 Hz, and the location is midline (ie, vertex). The morphology is rhythmic, smooth, sinusoidal, arciform, spiky, or mu-like." ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Physiologic-pattern .

