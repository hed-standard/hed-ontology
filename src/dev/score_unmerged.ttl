hedt:Semiology-motor-astatic a hed:HedTag ;
    rdfs:label "Semiology-motor-astatic" ;
    rdfs:comment "Loss of erect posture that results from an atonic, myoclonic, or tonic mechanism. Synonym: drop attack." ;
