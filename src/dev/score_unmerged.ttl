hedt:Semiology-motor-versive a hed:HedTag ;
    rdfs:label "Semiology-motor-versive" ;
    rdfs:comment "A sustained, forced conjugate ocular, cephalic, and/or truncal rotation or lateral deviation from the midline." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-sensory-auditory a hed:HedTag ;
    rdfs:label "Semiology-sensory-auditory" ;
