hedt:Background-burst-suppression a hed:HedTag ;
    rdfs:label "Background-burst-suppression" ;
    rdfs:comment "EEG pattern consisting of bursts (activity appearing and disappearing abruptly) interrupted by periods of low amplitude (below 20 microV) and which occurs simultaneously over all head regions." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-extent,
        hedt:Sensors ;
    hed:hasHedParent hedt:Background-activity-special-feature .

hedt:Benign-sleep-myoclonus a hed:HedTag ;
    rdfs:label "Benign-sleep-myoclonus" ;
    rdfs:comment "A distinctive disorder of sleep characterized by a) neonatal onset, b) rhythmic myoclonic jerks only during sleep and c) abrupt and consistent cessation with arousal, d) absence of concomitant electrographic changes suggestive of seizures, and e) good outcome." ;
    heda:suggestedTag hedt:Clinical-EEG-temporal-relationship,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Finding-significance-to-recording,
        hedt:State-episode-start ;
    hed:hasHedParent hedt:Sleep-related-episode .

