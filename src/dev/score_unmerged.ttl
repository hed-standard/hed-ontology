        hedt:Episode-event-count,
        hedt:Episode-responsiveness ;
    hed:hasHedParent hedt:Semiology-motor-automatisms .

hedt:Semiology-motor-automatisms-mimetic a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms-mimetic" ;
    rdfs:comment "Facial expression suggesting an emotional state, often fear." ;
    heda:suggestedTag hedt:Episode-appearance,
        hedt:Episode-event-count,
        hedt:Episode-responsiveness ;
    hed:hasHedParent hedt:Semiology-motor-automatisms .

hedt:Semiology-motor-automatisms-oroalimentary a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms-oroalimentary" ;
    rdfs:comment "Lip smacking, lip pursing, chewing, licking, tooth grinding, or swallowing." ;
    heda:suggestedTag hedt:Episode-appearance,
        hedt:Episode-event-count,
        hedt:Episode-responsiveness ;
    hed:hasHedParent hedt:Semiology-motor-automatisms .

hedt:Semiology-motor-automatisms-pedal a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms-pedal" ;
    rdfs:comment "1. Indicates principally distal components, bilateral or unilateral. 2. Fumbling, tapping, manipulating movements." ;
    heda:suggestedTag hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-appearance,
        hedt:Episode-event-count,
