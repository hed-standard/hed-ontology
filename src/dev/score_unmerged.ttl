hedt:Variable-appearance-mode a hed:HedTag ;
    rdfs:label "Variable-appearance-mode" ;
    rdfs:comment "Occurrence of non-ictal EEG pattern / graphoelements, that is sometimes rhythmic or periodic, other times random, throughout the recording." ;
    hed:hasHedParent hedt:Appearance-mode .

hedt:Very-brief-periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Very-brief-periodic-discharge-duration" ;
    rdfs:comment "Less than 10 sec." ;
    hed:hasHedParent hedt:Periodic-discharge-duration .

hedt:Very-long-periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Very-long-periodic-discharge-duration" ;
    rdfs:comment "Greater than 1 hour." ;
    hed:hasHedParent hedt:Periodic-discharge-duration .

hedt:Visceral-location a hed:HedTag ;
    rdfs:label "Visceral-location" ;
    hed:hasHedParent hedt:Body-part-location .

hedt:Atonic-motor-seizure a hed:HedTag ;
    rdfs:label "Atonic-motor-seizure" ;
    rdfs:comment "Sudden loss or diminution of muscle tone without apparent preceding myoclonic or tonic event lasting  about 1 to 2 s, involving head, trunk, jaw, or limb musculature. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Behavior-arrest-nonmotor-seizure a hed:HedTag ;
    rdfs:label "Behavior-arrest-nonmotor-seizure" ;
    rdfs:comment "Arrest (pause) of activities, freezing, immobilization, as in behavior arrest seizure. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Nonmotor-seizure .

hedt:Clonic-motor-seizure a hed:HedTag ;
    rdfs:label "Clonic-motor-seizure" ;
    rdfs:comment "Jerking, either symmetric or asymmetric, that is regularly repetitive and involves the same muscle groups. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:DC-shift-morphology a hed:HedTag ;
    rdfs:label "DC-shift-morphology" ;
    rdfs:comment "Shift of negative polarity of the direct current recordings, during seizures." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Disappearance-of-ongoing-activity-morphology a hed:HedTag ;
    rdfs:label "Disappearance-of-ongoing-activity-morphology" ;
    rdfs:comment "Disappearance of the EEG activity that preceded the ictal event but still remnants of background activity (thus not enough to name it electrodecremental change)." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:ECG-channel-finding a hed:HedTag ;
    rdfs:label "ECG-channel-finding" ;
    rdfs:comment "Electrocardiography." ;
    heda:suggestedTag hedt:Finding-significance-to-recording ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:EMG-asymmetric-activation a hed:HedTag ;
    rdfs:label "EMG-asymmetric-activation" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:EMG-feature .

hedt:Electrodecremental-change-morphology a hed:HedTag ;
    rdfs:label "Electrodecremental-change-morphology" ;
    rdfs:comment "Sudden desynchronization of electrical activity." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Eye-modulator a hed:HedTag ;
    rdfs:label "Eye-modulator" ;
    hed:hasHedParent hedt:Modulator .

hedt:Fast-spike-activity-morphology a hed:HedTag ;
    rdfs:label "Fast-spike-activity-morphology" ;
    rdfs:comment "A burst consisting of a sequence of spikes. Duration greater than 1 s. Frequency at least in the alpha range." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Finding-propagation a hed:HedTag ;
    rdfs:label "Finding-propagation" ;
    rdfs:comment "When propagation within the graphoelement is observed, first the location of the onset region is scored. Then, the location of the propagation can be noted." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Property-absence,
        hedt:Property-exists,
        hedt:Sensors ;
    hed:hasHedParent hedt:Location-property .

hedt:Frontal-intermittent-rhythmic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Frontal-intermittent-rhythmic-delta-activity-morphology" ;
    rdfs:comment "Frontal intermittent rhythmic delta activity (FIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 1.5-2.5 Hz over the frontal areas of one or both sides of the head. Comment: most commonly associated with unspecified encephalopathy, in adults." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:High-frequency-oscillation-morphology a hed:HedTag ;
    rdfs:label "High-frequency-oscillation-morphology" ;
    rdfs:comment "HFO." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Hypsarrhythmia-classic-morphology a hed:HedTag ;
    rdfs:label "Hypsarrhythmia-classic-morphology" ;
    rdfs:comment "Abnormal interictal high amplitude waves and a background of irregular spikes." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Hypsarrhythmia-modified-morphology a hed:HedTag ;
    rdfs:label "Hypsarrhythmia-modified-morphology" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Interictal-special-patterns a hed:HedTag ;
    rdfs:label "Interictal-special-patterns" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Interictal-finding .

hedt:Irregular-delta-or-theta-activity-morphology a hed:HedTag ;
    rdfs:label "Irregular-delta-or-theta-activity-morphology" ;
    rdfs:comment "EEG activity consisting of repetitive waves of inconsistent wave-duration but in delta and/or theta rang (greater than 125 ms)." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Low-voltage-fast-activity-morphology a hed:HedTag ;
    rdfs:label "Low-voltage-fast-activity-morphology" ;
    rdfs:comment "Refers to the fast, and often recruiting activity which can be recorded at the onset of an ictal discharge, particularly in invasive EEG recording of a seizure." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Medication-modulator a hed:HedTag ;
    rdfs:label "Medication-modulator" ;
    hed:hasHedParent hedt:Modulator .

hedt:Myoclonic-motor-seizure a hed:HedTag ;
    rdfs:label "Myoclonic-motor-seizure" ;
    rdfs:comment "Sudden, brief ( lower than 100 msec) involuntary single or multiple contraction(s) of muscles(s) or muscle groups of variable topography (axial, proximal limb, distal). Myoclonus is less regularly repetitive and less sustained than is clonus. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Occipital-intermittent-rhythmic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Occipital-intermittent-rhythmic-delta-activity-morphology" ;
    rdfs:comment "Occipital intermittent rhythmic delta activity (OIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 2-3 Hz over the occipital or posterior head regions of one or both sides of the head. Frequently blocked or attenuated by opening the eyes. Comment: most commonly associated with unspecified encephalopathy, in children." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Periodic-discharge-onset a hed:HedTag ;
    rdfs:label "Periodic-discharge-onset" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-time-related-features .

hedt:Periodic-discharge-triphasic-morphology a hed:HedTag ;
    rdfs:label "Periodic-discharge-triphasic-morphology" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Polygraphic-channel-relation-to-episode a hed:HedTag ;
    rdfs:label "Polygraphic-channel-relation-to-episode" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-property .

hedt:Polymorphic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Polymorphic-delta-activity-morphology" ;
    rdfs:comment "EEG activity consisting of waves in the delta range (over 250 ms duration for each wave) but of different morphology." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Polysharp-waves-morphology a hed:HedTag ;
    rdfs:label "Polysharp-waves-morphology" ;
    rdfs:comment "A sequence of two or more sharp-waves." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Posterior-dominant-rhythm-frequency-asymmetry a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-frequency-asymmetry" ;
    rdfs:comment "When symmetrical could be labeled with base schema Symmetrical tag." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Provocative-factor a hed:HedTag ;
    rdfs:label "Provocative-factor" ;
    rdfs:comment "Provocative factors are defined as transient and sporadic endogenous or exogenous elements capable of evoking/triggering seizures immediately following the exposure to it." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Respiration-channel-finding a hed:HedTag ;
    rdfs:label "Respiration-channel-finding" ;
    heda:suggestedTag hedt:Finding-significance-to-recording ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:Runs-of-rapid-spikes-morphology a hed:HedTag ;
    rdfs:label "Runs-of-rapid-spikes-morphology" ;
    rdfs:comment "Bursts of spike discharges at a rate from 10 to 25/sec (in most cases somewhat irregular). The bursts last more than 2 seconds (usually 2 to 10 seconds) and it is typically seen in sleep. Synonyms: rhythmic spikes, generalized paroxysmal fast activity, fast paroxysmal rhythms, grand mal discharge, fast beta activity." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Semiology-experiential-mnemonic a hed:HedTag ;
    rdfs:label "Semiology-experiential-mnemonic" ;
    rdfs:comment "Components that reflect ictal dysmnesia such as feelings of familiarity (deja-vu) and unfamiliarity (jamais-vu)." ;
    hed:hasHedParent hedt:Semiology-experiential .

hedt:Sharp-wave-morphology a hed:HedTag ;
    rdfs:label "Sharp-wave-morphology" ;
    rdfs:comment "A transient clearly distinguished from background activity, with pointed peak at a conventional paper speed or time scale, and duration of 70-200 ms, i.e. over 1/4-1/5 s approximately. Main component is generally negative relative to other areas. Amplitude varies." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Sleep-architecture a hed:HedTag ;
    rdfs:label "Sleep-architecture" ;
    rdfs:comment "For longer recordings. Only to be scored if whole-night sleep is part of the recording. It is a global descriptor of the structure and pattern of sleep: estimation of the amount of time spent in REM and NREM sleep, sleep duration, NREM-REM cycle." ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:Slow-sharp-wave-morphology a hed:HedTag ;
    rdfs:label "Slow-sharp-wave-morphology" ;
    rdfs:comment "A transient that bears all the characteristics of a sharp-wave, but exceeds 200 ms. Synonym: blunted sharp wave." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Slow-wave-large-amplitude-morphology a hed:HedTag ;
    rdfs:label "Slow-wave-large-amplitude-morphology" ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Source-analysis-property a hed:HedTag ;
    rdfs:label "Source-analysis-property" ;
    rdfs:comment "How the current in the brain reaches the electrode sensors." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Spike-morphology a hed:HedTag ;
    rdfs:label "Spike-morphology" ;
    rdfs:comment "A transient, clearly distinguished from background activity, with pointed peak at a conventional paper speed or time scale and duration from 20 to under 70 ms, i.e. 1/50-1/15 s approximately. Main component is generally negative relative to other areas. Amplitude varies." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Temporal-intermittent-rhythmic-delta-activity-morphology a hed:HedTag ;
    rdfs:label "Temporal-intermittent-rhythmic-delta-activity-morphology" ;
    rdfs:comment "Temporal intermittent rhythmic delta activity (TIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at over the temporal areas of one side of the head. Comment: most commonly associated with temporal lobe epilepsy." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Tonic-clonic-motor-seizure a hed:HedTag ;
    rdfs:label "Tonic-clonic-motor-seizure" ;
    rdfs:comment "A sequence consisting of a tonic followed by a clonic phase. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Tonic-motor-seizure a hed:HedTag ;
    rdfs:label "Tonic-motor-seizure" ;
    rdfs:comment "A sustained increase in muscle contraction lasting a few seconds to minutes. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Artifact a hed:HedTag ;
    rdfs:label "Artifact" ;
    rdfs:comment "When relevant for the clinical interpretation, artifacts can be scored by specifying the type and the location." ;
    heda:requireChild true .

hedt:Critically-ill-patients-patterns a hed:HedTag ;
    rdfs:label "Critically-ill-patients-patterns" ;
    rdfs:comment "Rhythmic or periodic patterns in critically ill patients (RPPs) are scored according to the 2012 version of the American Clinical Neurophysiology Society Standardized Critical Care EEG Terminology (Hirsch et al., 2013)." ;
    heda:requireChild true .

hedt:EMG-channel-finding a hed:HedTag ;
    rdfs:label "EMG-channel-finding" ;
    rdfs:comment "electromyography" ;
    heda:suggestedTag hedt:Finding-significance-to-recording ;
    hed:hasHedParent hedt:Polygraphic-channel-finding .

hedt:EMG-muscle-side a hed:HedTag ;
    rdfs:label "EMG-muscle-side" ;
    hed:hasHedParent hedt:EMG-channel-finding .

hedt:Epileptic-spasm-episode a hed:HedTag ;
    rdfs:label "Epileptic-spasm-episode" ;
    rdfs:comment "A sudden flexion, extension, or mixed extension flexion of predominantly proximal and truncal muscles that is usually more sustained than a myoclonic movement but not as sustained as a tonic seizure. Limited forms may occur: Grimacing, head nodding, or subtle eye movements. Epileptic spasms frequently occur in clusters. Infantile spasms are the best known form, but spasms can occur at all ages. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Motor-onset-seizure .

hedt:Interictal-finding a hed:HedTag ;
    rdfs:label "Interictal-finding" ;
    rdfs:comment "EEG pattern / transient that is distinguished form the background activity, considered abnormal, but is not recorded during ictal period (seizure) or postictal period; the presence of an interictal finding does not necessarily imply that the patient has epilepsy." ;
    heda:requireChild true .

hedt:Modulators-effect a hed:HedTag ;
    rdfs:label "Modulators-effect" ;
    rdfs:comment "Tags for describing the influence of the modulators" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Periodic-discharge-dynamics a hed:HedTag ;
    rdfs:label "Periodic-discharge-dynamics" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-time-related-features .

hedt:Periodic-discharge-relative-amplitude a hed:HedTag ;
    rdfs:label "Periodic-discharge-relative-amplitude" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Periodic-discharge-superimposed-activity a hed:HedTag ;
    rdfs:label "Periodic-discharge-superimposed-activity" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Polyspike-and-slow-wave-morphology a hed:HedTag ;
    rdfs:label "Polyspike-and-slow-wave-morphology" ;
    rdfs:comment "Two or more consecutive spikes associated with one or more slow waves." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Polyspikes-morphology a hed:HedTag ;
    rdfs:label "Polyspikes-morphology" ;
    rdfs:comment "Two or more consecutive spikes." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Posterior-dominant-rhythm-amplitude-range a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-amplitude-range" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Posterior-dominant-rhythm-eye-opening-reactivity a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-eye-opening-reactivity" ;
    rdfs:comment "Change (disappearance or measurable decrease in amplitude) of a posterior dominant rhythm following eye-opening. Eye closure has the opposite effect." ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Posterior-dominant-rhythm-organization a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-organization" ;
    rdfs:comment "When normal could be labeled with base schema Normal tag." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Semiology-motor-manifestation a hed:HedTag ;
    rdfs:label "Semiology-motor-manifestation" ;
    hed:hasHedParent hedt:Seizure-semiology-manifestation .

hedt:Semiology-motor-tonic-clonic a hed:HedTag ;
    rdfs:label "Semiology-motor-tonic-clonic" ;
    rdfs:comment "A sequence consisting of a tonic followed by a clonic phase. Variants such as clonic-tonic-clonic may be seen. Asymmetry of limb posture during the tonic phase of a GTC: one arm is rigidly extended at the elbow (often with the fist clenched tightly and flexed at the wrist), whereas the opposite arm is flexed at the elbow." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Sharp-and-slow-wave-morphology a hed:HedTag ;
    rdfs:label "Sharp-and-slow-wave-morphology" ;
    rdfs:comment "A sequence of a sharp wave and a slow wave." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Spike-and-slow-wave-morphology a hed:HedTag ;
    rdfs:label "Spike-and-slow-wave-morphology" ;
    rdfs:comment "A pattern consisting of a spike followed by a slow wave." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Stimulation-modulator a hed:HedTag ;
    rdfs:label "Stimulation-modulator" ;
    hed:hasHedParent hedt:Modulator .

hedt:Absence-seizure a hed:HedTag ;
    rdfs:label "Absence-seizure" ;
    rdfs:comment "Absence seizures present with a sudden cessation of activity and awareness. Absence seizures tend to occur in younger age groups, have more sudden start and termination, and they usually display less complex automatisms than do focal seizures with impaired awareness, but the distinctions are not absolute. EEG information may be required for accurate classification. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Seizure-classification .

hedt:Background-activity a hed:HedTag ;
    rdfs:label "Background-activity" ;
    rdfs:comment "An EEG activity representing the setting in which a given normal or abnormal pattern appears and from which such pattern is distinguished." ;
    heda:requireChild true .

hedt:Epileptic-seizure a hed:HedTag ;
    rdfs:label "Epileptic-seizure" ;
    rdfs:comment "The ILAE presented a revised seizure classification that divides seizures into focal, generalized onset, or unknown onset." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Focal-onset-epileptic-seizure a hed:HedTag ;
    rdfs:label "Focal-onset-epileptic-seizure" ;
    rdfs:comment "Focal seizures can be divided into focal aware and impaired awareness seizures, with additional motor and nonmotor classifications." ;
    heda:suggestedTag hedt:Atonic-motor-seizure,
        hedt:Automatism-motor-seizure,
        hedt:Autonomic-nonmotor-seizure,
        hedt:Behavior-arrest-nonmotor-seizure,
        hedt:Clinical-EEG-temporal-relationship,
        hedt:Clonic-motor-seizure,
        hedt:Cognitive-nonmotor-seizure,
        hedt:Emotional-nonmotor-seizure,
        hedt:Epileptic-spasm-episode,
        hedt:Episode-awareness,
        hedt:Episode-consciousness,
        hedt:Episode-event-count,
        hedt:Episode-phase,
        hedt:Episode-postictal-phase,
        hedt:Episode-prodrome,
        hedt:Episode-tongue-biting,
        hedt:Hyperkinetic-motor-seizure,
        hedt:Myoclonic-motor-seizure,
        hedt:Seizure-dynamics,
        hedt:Sensory-nonmotor-seizure,
        hedt:State-episode-start,
        hedt:Tonic-motor-seizure ;
    hed:hasHedParent hedt:Epileptic-seizure .

hedt:Ictal-EEG-patterns a hed:HedTag ;
    rdfs:label "Ictal-EEG-patterns" ;
    hed:hasHedParent hedt:Episode-property .

hedt:Interictal-periodic-discharges a hed:HedTag ;
    rdfs:label "Interictal-periodic-discharges" ;
    rdfs:comment "Periodic discharge not further specified (PDs)." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Periodic-discharge-morphology,
        hedt:Periodic-discharge-time-related-features,
        hedt:Sensors ;
    hed:hasHedParent hedt:Interictal-special-patterns .

hedt:Pediatric-episode a hed:HedTag ;
    rdfs:label "Pediatric-episode" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Periodic-discharge-polarity a hed:HedTag ;
    rdfs:label "Periodic-discharge-polarity" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Quality-of-hyperventilation a hed:HedTag ;
    rdfs:label "Quality-of-hyperventilation" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Seizure-classification a hed:HedTag ;
    rdfs:label "Seizure-classification" ;
    rdfs:comment "Seizure classification refers to the grouping of seizures based on their clinical features, EEG patterns, and other characteristics. Epileptic seizures are named using the current ILAE seizure classification (Fisher et al., 2017, Beniczky et al., 2017)." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-property .

hedt:Seizure-semiology-manifestation a hed:HedTag ;
    rdfs:label "Seizure-semiology-manifestation" ;
    rdfs:comment "Seizure semiology refers to the clinical features or signs that are observed during a seizure, such as the type of movements or behaviors exhibited by the person having the seizure, the duration of the seizure, the level of consciousness, and any associated symptoms such as aura or postictal confusion. In other words, seizure semiology describes the physical manifestations of a seizure. Semiology is described according to the ILAE Glossary of Descriptive Terminology for Ictal Semiology (Blume et al., 2001). Besides the name, the semiologic finding can also be characterized by the somatotopic modifier, laterality, body part and centricity. Uses Location-property tags." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-property .

hedt:Sleep-stage-reached a hed:HedTag ;
    rdfs:label "Sleep-stage-reached" ;
    rdfs:comment "For normal sleep patterns the sleep stages reached during the recording can be specified" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Finding-significance-to-recording,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Sleep-and-drowsiness .

hedt:EMG-myoclonus a hed:HedTag ;
    rdfs:label "EMG-myoclonus" ;
    hed:hasHedParent hedt:EMG-feature .

hedt:Finding-triggered-by a hed:HedTag ;
    rdfs:label "Finding-triggered-by" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Nonmotor-seizure a hed:HedTag ;
    rdfs:label "Nonmotor-seizure" ;
    rdfs:comment "Focal or generalized seizure types in which motor activity is not prominent. Definition from ILAE 2017 Classification of Seizure Types Expanded Version" ;
    hed:hasHedParent hedt:Seizure-classification .

hedt:Number-of-periodic-discharge-phases a hed:HedTag ;
    rdfs:label "Number-of-periodic-discharge-phases" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Periodic-discharge-duration a hed:HedTag ;
    rdfs:label "Periodic-discharge-duration" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-time-related-features .

hedt:Periodic-discharge-sharpness a hed:HedTag ;
    rdfs:label "Periodic-discharge-sharpness" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Polygraphic-channel-finding a hed:HedTag ;
    rdfs:label "Polygraphic-channel-finding" ;
    rdfs:comment "Changes observed in polygraphic channels can be scored: EOG, Respiration, ECG, EMG, other polygraphic channel (+ free text), and their significance logged (normal, abnormal, no definite abnormality)." ;
    heda:requireChild true .

hedt:Posterior-dominant-rhythm-caveat a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-caveat" ;
    rdfs:comment "Caveat to the annotation of PDR." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:Semiology-experiential a hed:HedTag ;
    rdfs:label "Semiology-experiential" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-language-related a hed:HedTag ;
    rdfs:label "Semiology-language-related" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-non-motor-manifestation a hed:HedTag ;
    rdfs:label "Semiology-non-motor-manifestation" ;
    hed:hasHedParent hedt:Seizure-semiology-manifestation .

hedt:Absence-of-posterior-dominant-rhythm a hed:HedTag ;
    rdfs:label "Absence-of-posterior-dominant-rhythm" ;
    rdfs:comment "Reason for absence of PDR." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-property .

hedt:EMG-feature a hed:HedTag ;
    rdfs:label "EMG-feature" ;
    hed:hasHedParent hedt:EMG-channel-finding .

hedt:Finding-amplitude a hed:HedTag ;
    rdfs:label "Finding-amplitude" ;
    rdfs:comment "Value in microvolts (number) typed in." ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Non-biological-artifact a hed:HedTag ;
    rdfs:label "Non-biological-artifact" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Artifact .

hedt:Periodic-discharge-absolute-amplitude a hed:HedTag ;
    rdfs:label "Periodic-discharge-absolute-amplitude" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Periodic-discharge-morphology .

hedt:Respiration-feature a hed:HedTag ;
    rdfs:label "Respiration-feature" ;
    hed:hasHedParent hedt:Respiration-channel-finding .

hedt:Sleep-modulator a hed:HedTag ;
    rdfs:label "Sleep-modulator" ;
    hed:hasHedParent hedt:Modulator .

hedt:Sleep-related-episode a hed:HedTag ;
    rdfs:label "Sleep-related-episode" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode .

hedt:Time-related-property a hed:HedTag ;
    rdfs:label "Time-related-property" ;
    rdfs:comment "Important to estimate how often an interictal abnormality is seen in the recording." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Background-activity-special-feature a hed:HedTag ;
    rdfs:label "Background-activity-special-feature" ;
    rdfs:comment "Special Features. Special features contains scoring options for the background activity of critically ill patients." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Background-activity .

hedt:Episode-property a hed:HedTag ;
    rdfs:label "Episode-property" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Facilitating-factor a hed:HedTag ;
    rdfs:label "Facilitating-factor" ;
    rdfs:comment "Facilitating factors are defined as transient and sporadic endogenous or exogenous elements capable of augmenting seizure incidence (increasing the likelihood of seizure occurrence)." ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Finding-extent a hed:HedTag ;
    rdfs:label "Finding-extent" ;
    rdfs:comment "Percentage of occurrence during the recording (background activity and interictal finding)." ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Finding-prevalence a hed:HedTag ;
    rdfs:label "Finding-prevalence" ;
    rdfs:comment "The percentage of the recording covered by the train/burst." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Location-property a hed:HedTag ;
    rdfs:label "Location-property" ;
    rdfs:comment "Location can be scored for findings. Semiologic finding can also be characterized by the somatotopic modifier (i.e. the part of the body where it occurs). In this respect, laterality (left, right, symmetric, asymmetric, left greater than right, right greater than left), body part (eyelid, face, arm, leg, trunk, visceral, hemi-) and centricity (axial, proximal limb, distal limb) can be scored." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Periodic-discharge-time-related-features a hed:HedTag ;
    rdfs:label "Periodic-discharge-time-related-features" ;
    rdfs:comment "Periodic discharges not further specified (PDs) time-relayed features tags." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Posterior-dominant-rhythm-property a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-property" ;
    rdfs:comment "Posterior dominant rhythm is the most often scored EEG feature in clinical practice. Therefore, there are specific terms that can be chosen for characterizing the PDR." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:ECG-feature a hed:HedTag ;
    rdfs:label "ECG-feature" ;
    hed:hasHedParent hedt:ECG-channel-finding .

hedt:Finding-property a hed:HedTag ;
    rdfs:label "Finding-property" ;
    rdfs:comment "Descriptive element similar to main HED /Property. Something that pertains to a thing. A characteristic of some entity. A quality or feature regarded as a characteristic or inherent part of someone or something. HED attributes are adjectives or adverbs." ;
    heda:requireChild true .

hedt:Intermittent-photic-stimulation-effect a hed:HedTag ;
    rdfs:label "Intermittent-photic-stimulation-effect" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Modulators-property .

hedt:Modulator a hed:HedTag ;
    rdfs:label "Modulator" ;
    rdfs:comment "External stimuli / interventions or changes in the alertness level (sleep) that modify: the background activity, or how often a graphoelement is occurring, or change other features of the graphoelement (like intra-burst frequency). For each observed finding, there is an option of specifying how they are influenced by the modulators and procedures that were done during the recording." ;
    heda:requireChild true .

hedt:Finding-incidence a hed:HedTag ;
    rdfs:label "Finding-incidence" ;
    rdfs:comment "How often it occurs/time-epoch." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Periodic-discharge-morphology a hed:HedTag ;
    rdfs:label "Periodic-discharge-morphology" ;
    rdfs:comment "Periodic discharges not further specified (PDs)." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Property-absence a hed:HedTag ;
    rdfs:label "Property-absence" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Property-exists a hed:HedTag ;
    rdfs:label "Property-exists" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Episode a hed:HedTag ;
    rdfs:label "Episode" ;
    rdfs:comment "Clinical episode or electrographic seizure." ;
    heda:requireChild true .

hedt:Finding-amplitude-asymmetry a hed:HedTag ;
    rdfs:label "Finding-amplitude-asymmetry" ;
    rdfs:comment "For posterior dominant rhythm: a difference in amplitude between the homologous area on opposite sides of the head that consistently exceeds 50 percent. When symmetrical could be labeled with base schema Symmetrical tag. For sleep: Absence or consistently marked amplitude asymmetry (greater than 50 percent) of a normal sleep graphoelement." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Finding-stopped-by a hed:HedTag ;
    rdfs:label "Finding-stopped-by" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Finding-unmodified a hed:HedTag ;
    rdfs:label "Finding-unmodified" ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Physiologic-pattern a hed:HedTag ;
    rdfs:label "Physiologic-pattern" ;
    rdfs:comment "EEG graphoelements or rhythms that are considered normal. They only should be scored if the physician considers that they have a specific clinical significance for the recording." ;
    heda:requireChild true .

hedt:Semiology-sensory a hed:HedTag ;
    rdfs:label "Semiology-sensory" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Episode-time-context-property a hed:HedTag ;
    rdfs:label "Episode-time-context-property" ;
    rdfs:comment "Additional clinically relevant features related to episodes can be scored under timing and context. If needed, episode duration can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Temporal-value/Duration." ;
    hed:hasHedParent hedt:Episode-property .

hedt:Other-finding-property a hed:HedTag ;
    rdfs:label "Other-finding-property" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Semiology-autonomic a hed:HedTag ;
    rdfs:label "Semiology-autonomic" ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-motor-automatisms a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms" ;
    hed:hasHedParent hedt:Semiology-motor-manifestation .

hedt:Sleep-and-drowsiness a hed:HedTag ;
    rdfs:label "Sleep-and-drowsiness" ;
    rdfs:comment "The features of the ongoing activity during sleep are scored here. If abnormal graphoelements appear, disappear or change their morphology during sleep, that is not scored here but at the entry corresponding to that graphooelement (as a modulator)." ;
    heda:requireChild true .

hedt:Episode-appearance a hed:HedTag ;
    rdfs:label "Episode-appearance" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-responsiveness a hed:HedTag ;
    rdfs:label "Episode-responsiveness" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Rhythmic-activity-morphology a hed:HedTag ;
    rdfs:label "Rhythmic-activity-morphology" ;
    rdfs:comment "EEG activity consisting of a sequence of waves approximately constant period." ;
    hed:hasHedParent hedt:Signal-morphology-property .

hedt:Seizure-dynamics a hed:HedTag ;
    rdfs:label "Seizure-dynamics" ;
    rdfs:comment "Spatiotemporal dynamics can be scored (evolution in morphology; evolution in frequency; evolution in location)." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Uncertain-significant-pattern a hed:HedTag ;
    rdfs:label "Uncertain-significant-pattern" ;
    rdfs:comment "EEG graphoelements or rhythms that resemble abnormal patterns but that are not necessarily associated with a pathology, and the physician does not consider them abnormal in the context of the scored recording (like normal variants and patterns)." ;
    heda:requireChild true .

hedt:Semiology-elementary-motor a hed:HedTag ;
    rdfs:label "Semiology-elementary-motor" ;
    hed:hasHedParent hedt:Semiology-motor-manifestation .

hedt:Biological-artifact a hed:HedTag ;
    rdfs:label "Biological-artifact" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Artifact .

hedt:Postictal-semiology-manifestation a hed:HedTag ;
    rdfs:label "Postictal-semiology-manifestation" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Episode-property .

hedt:Multifocal-finding a hed:HedTag ;
    rdfs:label "Multifocal-finding" ;
    rdfs:comment "When the same interictal graphoelement is observed bilaterally and at least in three independent locations, can score them using one entry, and choosing multifocal as a descriptor of the locations of the given interictal graphoelements, optionally emphasizing the involved, and the most active sites." ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Location-property .

hedt:Modulators-property a hed:HedTag ;
    rdfs:label "Modulators-property" ;
    rdfs:comment "For each described graphoelement, the influence of the modulators can be scored. Only modulators present in the recording are scored." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Finding-frequency a hed:HedTag ;
    rdfs:label "Finding-frequency" ;
    rdfs:comment "Value in Hz (number) typed in." ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Motor-onset-seizure a hed:HedTag ;
    rdfs:label "Motor-onset-seizure" ;
    heda:deprecatedFrom "1.0.0" ;
    hed:hasHedParent hedt:Seizure-classification .

hedt:Source-analysis-brain-region a hed:HedTag ;
    rdfs:label "Source-analysis-brain-region" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Source-analysis-property .

hedt:Artifact-significance-to-recording a hed:HedTag ;
    rdfs:label "Artifact-significance-to-recording" ;
    rdfs:comment "It is important to score the significance of the described artifacts: recording is not interpretable, recording of reduced diagnostic value, does not interfere with the interpretation of the recording." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Episode-awareness a hed:HedTag ;
    rdfs:label "Episode-awareness" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists,
        hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-postictal-phase a hed:HedTag ;
    rdfs:label "Episode-postictal-phase" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-prodrome a hed:HedTag ;
    rdfs:label "Episode-prodrome" ;
    rdfs:comment "Prodrome is a preictal phenomenon, and it is defined as a subjective or objective clinical alteration (e.g., ill-localized sensation or agitation) that heralds the onset of an epileptic seizure but does not form part of it (Blume et al., 2001). Therefore, prodrome should be distinguished from aura (which is an ictal phenomenon)." ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-tongue-biting a hed:HedTag ;
    rdfs:label "Episode-tongue-biting" ;
    heda:suggestedTag hedt:Property-absence,
        hedt:Property-exists ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Signal-morphology-property a hed:HedTag ;
    rdfs:label "Signal-morphology-property" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Finding-property .

hedt:Brain-centricity a hed:HedTag ;
    rdfs:label "Brain-centricity" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:State-episode-start a hed:HedTag ;
    rdfs:label "State-episode-start" ;
    rdfs:comment "State at the start of the episode." ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-phase a hed:HedTag ;
    rdfs:label "Episode-phase" ;
    rdfs:comment "The electroclinical findings (i.e., the seizure semiology and the ictal EEG) are divided in three phases: onset, propagation, and postictal." ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Ictal-EEG-patterns,
        hedt:Postictal-semiology-manifestation,
        hedt:Seizure-semiology-manifestation ;
    hed:hasHedParent hedt:Episode-property .

hedt:Clinical-EEG-temporal-relationship a hed:HedTag ;
    rdfs:label "Clinical-EEG-temporal-relationship" ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Episode-consciousness a hed:HedTag ;
    rdfs:label "Episode-consciousness" ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Discharge-pattern a hed:HedTag ;
    rdfs:label "Discharge-pattern" ;
    rdfs:comment "Describes the organization of the EEG signal within the discharge (distinguish between single and repetitive discharges)" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Body-part-location a hed:HedTag ;
    rdfs:label "Body-part-location" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:Finding-significance-to-recording a hed:HedTag ;
    rdfs:label "Finding-significance-to-recording" ;
    rdfs:comment "Significance of finding. When normal/abnormal could be labeled with base schema Normal/Abnormal tags." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Appearance-mode a hed:HedTag ;
    rdfs:label "Appearance-mode" ;
    rdfs:comment "Describes how the non-ictal EEG pattern/graphoelement is distributed through the recording." ;
    heda:requireChild true ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Time-related-property .

hedt:Property-not-possible-to-determine a hed:HedTag ;
    rdfs:label "Property-not-possible-to-determine" ;
    rdfs:comment "Not possible to determine." ;
    hed:hasHedParent hedt:Other-finding-property .

hedt:Sensors a hed:HedTag ;
    rdfs:label "Sensors" ;
    rdfs:comment "Lists all corresponding sensors (electrodes/channels in montage). The sensor-group is selected from a list defined in the site-settings for each EEG-lab." ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:Brain-region a hed:HedTag ;
    rdfs:label "Brain-region" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

hedt:Episode-event-count a hed:HedTag ;
    rdfs:label "Episode-event-count" ;
    rdfs:comment "Number of stereotypical episodes during the recording." ;
    heda:suggestedTag hedt:Property-not-possible-to-determine ;
    hed:hasHedParent hedt:Episode-time-context-property .

hedt:Brain-laterality a hed:HedTag ;
    rdfs:label "Brain-laterality" ;
    heda:requireChild true ;
    hed:hasHedParent hedt:Location-property .

