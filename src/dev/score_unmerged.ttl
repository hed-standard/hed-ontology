        hedt:Episode-event-count,
        hedt:Episode-responsiveness ;
    hed:hasHedParent hedt:Semiology-motor-automatisms .

hedt:Semiology-motor-automatisms-dyspraxic a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms-dyspraxic" ;
    rdfs:comment "Inability to perform learned movements spontaneously or on command or imitation despite intact relevant motor and sensory systems and adequate comprehension and cooperation." ;
