hedt:Semiology-motor-automatisms-gelastic a hed:HedTag ;
    rdfs:label "Semiology-motor-automatisms-gelastic" ;
    rdfs:comment "Bursts of laughter or giggling, usually without an appropriate affective tone." ;
    heda:suggestedTag hedt:Episode-appearance,
        hedt:Episode-event-count,
