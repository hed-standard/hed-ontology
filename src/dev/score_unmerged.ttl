hedt:Respiration-artifact a hed:HedTag ;
    rdfs:label "Respiration-artifact" ;
    rdfs:comment "Respiration can produce 2 kinds of artifacts. One type is in the form of slow and rhythmic activity, synchronous with the body movements of respiration and mechanically affecting the impedance of (usually) one electrode. The other type can be slow or sharp waves that occur synchronously with inhalation or exhalation and involve those electrodes on which the patient is lying." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Respiration-oxygen-saturation-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Respiration-oxygen-saturation .

hedt:Rhythmic-activity-pattern a hed:HedTag ;
    rdfs:label "Rhythmic-activity-pattern" ;
    rdfs:comment "Not further specified." ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Rhythmic-activity-morphology,
        hedt:Sensors ;
    hed:hasHedParent hedt:Physiologic-pattern .

hedt:Rhythmic-delta-activity a hed:HedTag ;
    rdfs:label "Rhythmic-delta-activity" ;
    rdfs:comment "RDA" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Finding-frequency,
        hedt:Periodic-discharge-absolute-amplitude,
        hedt:Periodic-discharge-superimposed-activity,
        hedt:Periodic-discharge-time-related-features,
        hedt:Sensors ;
    hed:hasHedParent hedt:Critically-ill-patients-patterns .

hedt:Rhythmic-temporal-theta-burst-drowsiness a hed:HedTag ;
    rdfs:label "Rhythmic-temporal-theta-burst-drowsiness" ;
    rdfs:comment "Rhythmic temporal theta burst of drowsiness (RTTD). Characteristic burst of 4-7 Hz waves frequently notched by faster waves, occurring over the temporal regions of the head during drowsiness. Synonym: psychomotor variant pattern. Comment: this is a pattern of drowsiness that is of no clinical significance." ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Rhythmic-trains-or-bursts-discharge-pattern-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Rhythmic-trains-or-bursts-discharge-pattern .

hedt:Rocking-patting-artifact a hed:HedTag ;
    rdfs:label "Rocking-patting-artifact" ;
    rdfs:comment "Quasi-rhythmical artifacts in recordings from infants caused by rocking/patting." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

hedt:Rudimentary-spike-wave-complex a hed:HedTag ;
    rdfs:label "Rudimentary-spike-wave-complex" ;
    rdfs:comment "Synonym: Pseudo petit mal discharge. Paroxysmal discharge that consists of generalized or nearly generalized high voltage 3 to 4/sec waves with poorly developed spike in the positive trough between the slow waves, occurring in drowsiness only. It is found only in infancy and early childhood when marked hypnagogic rhythmical theta activity is paramount in the drowsy state." ;
    heda:suggestedTag hedt:Appearance-mode,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Discharge-pattern,
        hedt:Sensors ;
    hed:hasHedParent hedt:Uncertain-significant-pattern .

hedt:Runs-of-rapid-spikes-morphology-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Runs-of-rapid-spikes-morphology .

hedt:Salt-bridge-artifact a hed:HedTag ;
    rdfs:label "Salt-bridge-artifact" ;
    rdfs:comment "Typically occurs in 1 channel which may appear isoelectric. Only seen in bipolar montage." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording ;
    hed:hasHedParent hedt:Non-biological-artifact .

hedt:Saw-tooth-waves a hed:HedTag ;
    rdfs:label "Saw-tooth-waves" ;
    rdfs:comment "Vertex negative 2-5 Hz waves occuring in series during REM sleep" ;
    heda:suggestedTag hedt:Brain-laterality,
