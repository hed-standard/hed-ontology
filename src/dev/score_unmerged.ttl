hedt:Semiology-sensory-autonomic-sensation a hed:HedTag ;
    rdfs:label "Semiology-sensory-autonomic-sensation" ;
    rdfs:comment "A sensation consistent with involvement of the autonomic nervous system, including cardiovascular, gastrointestinal,  sudomotor, vasomotor, and thermoregulatory functions. (Thus autonomic aura; cf. autonomic events  3.0)." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-sensory .

hedt:Semiology-sensory-epigastric a hed:HedTag ;
    rdfs:label "Semiology-sensory-epigastric" ;
    rdfs:comment "Abdominal discomfort including nausea, emptiness, tightness, churning, butterflies, malaise, pain, and hunger; sensation may rise to chest or throat. Some phenomena may reflect ictal autonomic dysfunction." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-sensory .

hedt:Semiology-sensory-gustatory a hed:HedTag ;
