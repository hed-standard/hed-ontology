hedt:Semiology-motor-behavioral-arrest a hed:HedTag ;
    rdfs:label "Semiology-motor-behavioral-arrest" ;
    rdfs:comment "Interruption of ongoing motor activity or of ongoing behaviors with fixed gaze, without movement of the head or trunk (oro-alimentary and hand automatisms may continue)." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-motor-manifestation .

hedt:Semiology-motor-clonic a hed:HedTag ;
    rdfs:label "Semiology-motor-clonic" ;
    rdfs:comment "Myoclonus that is regularly repetitive, involves the same muscle groups, at a frequency of about 2 to 3 c/s, and is prolonged. Synonym: rhythmic myoclonus ." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-dystonic a hed:HedTag ;
    rdfs:label "Semiology-motor-dystonic" ;
    rdfs:comment "Sustained contractions of both agonist and antagonist muscles producing athetoid or twisting movements, which, when prolonged, may produce abnormal postures." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-epileptic-spasm a hed:HedTag ;
    rdfs:label "Semiology-motor-epileptic-spasm" ;
    rdfs:comment "A sudden flexion, extension, or mixed extension flexion of predominantly proximal and truncal muscles that is usually more sustained than a myoclonic movement but not so sustained as a tonic seizure (i.e., about 1 s). Limited forms may occur: grimacing, head nodding. Frequent occurrence in clusters." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-eye-blinking a hed:HedTag ;
    rdfs:label "Semiology-motor-eye-blinking" ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-jacksonian-march a hed:HedTag ;
    rdfs:label "Semiology-motor-jacksonian-march" ;
    rdfs:comment "Term indicating spread of clonic movements through contiguous body parts unilaterally." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-myoclonic a hed:HedTag ;
    rdfs:label "Semiology-motor-myoclonic" ;
    rdfs:comment "Characterized by myoclonus. MYOCLONUS : sudden, brief (lower than 100 ms) involuntary single or multiple contraction(s) of muscles(s) or muscle groups of variable topography (axial, proximal limb, distal)." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

hedt:Semiology-motor-negative-myoclonus a hed:HedTag ;
    rdfs:label "Semiology-motor-negative-myoclonus" ;
    rdfs:comment "Characterized by negative myoclonus. NEGATIVE MYOCLONUS: interruption of tonic muscular activity for lower than 500 ms without evidence of preceding myoclonia." ;
    heda:suggestedTag hedt:Body-part-location,
        hedt:Brain-centricity,
        hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-elementary-motor .

