hedt:EMG-artifact a hed:HedTag ;
    rdfs:label "EMG-artifact" ;
    rdfs:comment "Myogenic potentials are the most common artifacts. Frontalis and temporalis muscles (ex..: clenching of jaw muscles) are common causes. Generally, the potentials generated in the muscles are of shorter duration than those generated in the brain. The frequency components are usually beyond 30-50 Hz, and the bursts are arrhythmic." ;
    heda:suggestedTag hedt:Artifact-significance-to-recording,
        hedt:Brain-laterality,
        hedt:Brain-region,
        hedt:Multifocal-finding,
        hedt:Sensors ;
    hed:hasHedParent hedt:Biological-artifact .

