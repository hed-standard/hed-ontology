hedt:Electrocerebral-inactivity a hed:HedTag ;
    rdfs:label "Electrocerebral-inactivity" ;
    rdfs:comment "Absence of any ongoing cortical electric activities; in all leads EEG is isoelectric or only contains artifacts. Sensitivity has to be increased up to 2 microV/mm; recording time: at least 30 minutes." ;
    hed:hasHedParent hedt:Background-activity-special-feature .

hedt:Electrode-pops-artifact a hed:HedTag ;
