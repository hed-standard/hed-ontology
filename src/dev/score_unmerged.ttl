hedt:Semiology-autonomic-cardiovascular a hed:HedTag ;
    rdfs:label "Semiology-autonomic-cardiovascular" ;
    rdfs:comment "Modifications of heart rate (tachycardia, bradycardia), cardiac arrhythmias (such as sinus arrhythmia, sinus arrest, supraventricular tachycardia, atrial premature depolarizations, ventricular premature depolarizations, atrio-ventricular block, bundle branch block, atrioventricular nodal escape rhythm, asystole)." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-gastrointestinal a hed:HedTag ;
    rdfs:label "Semiology-autonomic-gastrointestinal" ;
    rdfs:comment "Nausea, eructation, vomiting, retching, abdominal sensations, abdominal pain, flatulence, spitting, diarrhea." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-genital a hed:HedTag ;
    rdfs:label "Semiology-autonomic-genital" ;
    rdfs:comment "Sexual auras (erotic thoughts and feelings, sexual arousal and orgasm). Genital auras (unpleasant, sometimes painful, frightening or emotionally neutral somatosensory sensations in the genitals that can be accompanied by ictal orgasm). Sexual automatisms (hypermotor movements consisting of writhing, thrusting, rhythmic movements of the pelvis, arms and legs, sometimes associated with picking and rhythmic manipulation of the groin or genitalia, exhibitionism and masturbation)." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-hypersalivation a hed:HedTag ;
    rdfs:label "Semiology-autonomic-hypersalivation" ;
    rdfs:comment "Increase in production of saliva leading to uncontrollable drooling" ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-other-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Semiology-autonomic-other .

hedt:Semiology-autonomic-pupillary a hed:HedTag ;
    rdfs:label "Semiology-autonomic-pupillary" ;
    rdfs:comment "Mydriasis, miosis (either bilateral or unilateral)." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-respiratory-apnoeic a hed:HedTag ;
    rdfs:label "Semiology-autonomic-respiratory-apnoeic" ;
    rdfs:comment "subjective shortness of breath, hyperventilation, stridor, coughing, choking, apnea, oxygen desaturation, neurogenic pulmonary edema." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-sudomotor a hed:HedTag ;
    rdfs:label "Semiology-autonomic-sudomotor" ;
    rdfs:comment "Sweating and piloerection (may be accompanied by feelings of warmth, cold and pain)." ;
    heda:suggestedTag hedt:Brain-laterality,
        hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-thermoregulatory a hed:HedTag ;
    rdfs:label "Semiology-autonomic-thermoregulatory" ;
    rdfs:comment "Hyperthermia, fever." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-urinary-incontinence a hed:HedTag ;
    rdfs:label "Semiology-autonomic-urinary-incontinence" ;
    rdfs:comment "urinary urge (intense urinary urge at the beginning of seizures), urinary incontinence, ictal urination (rare symptom of partial seizures without loss of consciousness)." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-autonomic-vasomotor a hed:HedTag ;
    rdfs:label "Semiology-autonomic-vasomotor" ;
    rdfs:comment "Flushing or pallor (may be accompanied by feelings of warmth, cold and pain)." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-autonomic .

hedt:Semiology-dyscognitive a hed:HedTag ;
    rdfs:label "Semiology-dyscognitive" ;
    rdfs:comment "The term describes events in which (1) disturbance of cognition is the predominant or most apparent feature, and (2a) two or more of the following components are involved, or (2b) involvement of such components remains undetermined. Otherwise, use the more specific term (e.g., mnemonic experiential seizure  or hallucinatory experiential seizure). Components of cognition: ++ perception: symbolic conception of sensory information ++ attention: appropriate selection of a principal perception or task ++ emotion: appropriate affective significance of a perception ++ memory: ability to store and retrieve percepts or concepts ++ executive function: anticipation, selection, monitoring of consequences, and initiation of motor activity including praxis, speech." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-non-motor-manifestation .

hedt:Semiology-experiential-affective-emotional a hed:HedTag ;
    rdfs:label "Semiology-experiential-affective-emotional" ;
    rdfs:comment "Components include fear, depression, joy, and (rarely) anger." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-experiential .

hedt:Semiology-experiential-hallucinatory a hed:HedTag ;
    rdfs:label "Semiology-experiential-hallucinatory" ;
    rdfs:comment "Composite perceptions without corresponding external stimuli involving visual, auditory, somatosensory, olfactory, and/or gustatory phenomena. Example: hearing  and seeing  people talking." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-experiential .

hedt:Semiology-experiential-illusory a hed:HedTag ;
    rdfs:label "Semiology-experiential-illusory" ;
    rdfs:comment "An alteration of actual percepts involving the visual, auditory, somatosensory, olfactory, or gustatory systems." ;
    heda:suggestedTag hedt:Episode-event-count ;
    hed:hasHedParent hedt:Semiology-experiential .

hedt:Semiology-experiential-mnemonic-Deja-vu a hed:HedTag ;
