hedt:Posterior-dominant-rhythm a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm" ;
    rdfs:comment "Rhythmic activity occurring during wakefulness over the posterior regions of the head, generally with maximum amplitudes over the occipital areas. Amplitude varies. Best seen with eyes closed and during physical relaxation and relative mental inactivity. Blocked or attenuated by attention, especially visual, and mental effort. In adults this is the alpha rhythm, and the frequency is 8 to 13 Hz. However the frequency can be higher or lower than this range (often a supra or sub harmonic of alpha frequency) and is called alpha variant rhythm (fast and slow alpha variant rhythm). In children, the normal range of the frequency of the posterior dominant rhythm is age-dependant." ;
    heda:suggestedTag hedt:Finding-amplitude-asymmetry,
        hedt:Finding-frequency,
        hedt:Finding-significance-to-recording,
        hedt:Posterior-dominant-rhythm-property ;
    hed:hasHedParent hedt:Background-activity .

hedt:Posterior-dominant-rhythm-caveat-drowsy-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    rdfs:comment "Free text." ;
    heda:takesValue true ;
    heda:valueClass hedu:textClass ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-caveat-drowsy .

hedt:Posterior-dominant-rhythm-caveat-only-following-hyperventilation a hed:HedTag ;
    rdfs:label "Posterior-dominant-rhythm-caveat-only-following-hyperventilation" ;
    hed:hasHedParent hedt:Posterior-dominant-rhythm-caveat .

hedt:Posterior-dominant-rhythm-caveat-only-open-eyes-during-the-recording-Placeholder a hed:HedPlaceholder ;
