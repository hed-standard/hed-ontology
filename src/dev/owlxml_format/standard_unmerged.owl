<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:hed="https://purl.org/hed#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Maroon">
    <rdfs:label>Maroon</rdfs:label>
    <rdfs:comment>CSS-color 0x800000.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Brown-color">
        <rdfs:label>Brown-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Item-count-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Item-count">
        <rdfs:label>Item-count</rdfs:label>
        <rdfs:comment>The integer count of something which is usually grouped with the entity it is counting. (Item-count/3, A) indicates that 3 of A have occurred up to this point.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Quantitative-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass>
      <hed:HedValueClass rdf:about="https://purl.org/hed/aux#numericClass">
        <rdfs:label>numericClass</rdfs:label>
        <rdfs:comment>Value must be a valid numerical value.</rdfs:comment>
        <hed:allowedCharacter>digits</hed:allowedCharacter>
        <hed:allowedCharacter>E</hed:allowedCharacter>
        <hed:allowedCharacter>e</hed:allowedCharacter>
        <hed:allowedCharacter>+</hed:allowedCharacter>
        <hed:allowedCharacter>-</hed:allowedCharacter>
        <hed:allowedCharacter>.</hed:allowedCharacter>
      </hed:HedValueClass>
    </hed:valueClass>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Recording-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Optional label for the recording.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Recording">
        <rdfs:label>Recording</rdfs:label>
        <rdfs:comment>A tag designating the data recording. Recording tags are usually have temporal scope which is the entire recording.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass>
      <hed:HedValueClass rdf:about="https://purl.org/hed/aux#nameClass">
        <rdfs:label>nameClass</rdfs:label>
        <rdfs:comment>Value class designating values that have the characteristics of node names. The allowed characters are alphanumeric, hyphen, and underbar.</rdfs:comment>
        <hed:allowedCharacter>letters</hed:allowedCharacter>
        <hed:allowedCharacter>digits</hed:allowedCharacter>
        <hed:allowedCharacter>_</hed:allowedCharacter>
        <hed:allowedCharacter>-</hed:allowedCharacter>
      </hed:HedValueClass>
    </hed:valueClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Penalty">
    <rdfs:label>Penalty</rdfs:label>
    <rdfs:comment>A disadvantage, loss, or hardship due to some action.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-stimulus-role">
        <rdfs:label>Task-stimulus-role</rdfs:label>
        <rdfs:comment>The role the stimulus plays in the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Not-equal-to">
    <rdfs:label>Not-equal-to</rdfs:label>
    <rdfs:comment>(A, (Not-equal-to, B)) indicates that the size or order of A is not the same as that of B.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Comparative-relation">
        <rdfs:label>Comparative-relation</rdfs:label>
        <rdfs:comment>Something considered in comparison to something else. The first entity is the focus.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ahead-of">
    <rdfs:label>Ahead-of</rdfs:label>
    <rdfs:comment>(A, (Ahead-of, B)) indicates that A is further forward in time or space in B.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Spatial-relation">
        <rdfs:label>Spatial-relation</rdfs:label>
        <rdfs:comment>Indicating a relationship about position between entities.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LavenderBlush">
    <rdfs:label>LavenderBlush</rdfs:label>
    <rdfs:comment>CSS-color 0xFFF0F5.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#White-color">
        <rdfs:label>White-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#peta">
    <rdfs:label>peta</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^15.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^15</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Close-eyes">
    <rdfs:label>Close-eyes</rdfs:label>
    <rdfs:comment>Lower and keep eyelids in a closed position.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-eyes">
        <rdfs:label>Move-eyes</rdfs:label>
        <rdfs:comment>Move eyes.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Memorize">
    <rdfs:label>Memorize</rdfs:label>
    <rdfs:comment>Adaptively change behavior as the result of experience.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Think">
        <rdfs:label>Think</rdfs:label>
        <rdfs:comment>Direct the mind toward someone or something or use the mind actively to form connected ideas.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Action"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#Volt">
    <rdfs:label>Volt</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#electricPotentialUnits">
        <rdfs:label>electricPotentialUnits</rdfs:label>
        <hed:defaultUnits>uv</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>0.000001</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stressed">
    <rdfs:label>Stressed</rdfs:label>
    <rdfs:comment>Experiencing mental or emotional strain or tension.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-emotional-state">
        <rdfs:label>Agent-emotional-state</rdfs:label>
        <rdfs:comment>The status of the general temperament and outlook of an agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-state"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cough">
    <rdfs:label>Cough</rdfs:label>
    <rdfs:comment>Suddenly and audibly expel air from the lungs through a partially closed glottis, preceded by inhalation.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Breathe">
        <rdfs:label>Breathe</rdfs:label>
        <rdfs:comment>Inhale or exhale during respiration.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Index-finger">
    <rdfs:label>Index-finger</rdfs:label>
    <rdfs:comment>The second finger from the radial side of the hand, next to the thumb.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Finger">
        <rdfs:label>Finger</rdfs:label>
        <rdfs:comment>Any of the digits of the hand.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Hand"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#G">
    <rdfs:label>G</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^9.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^9</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Incidental">
    <rdfs:label>Incidental</rdfs:label>
    <rdfs:comment>A sensory or other type of event that is unrelated to the task or experiment.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-event-role">
        <rdfs:label>Task-event-role</rdfs:label>
        <rdfs:comment>The purpose of an event with respect to the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Red">
    <rdfs:label>Red</rdfs:label>
    <rdfs:comment>CSS-color 0xFF0000.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Red-color">
        <rdfs:label>Red-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Big-toe">
    <rdfs:label>Big-toe</rdfs:label>
    <rdfs:comment>The largest toe on the inner side of the foot.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Foot">
        <rdfs:label>Foot</rdfs:label>
        <rdfs:comment>The structure found below the ankle joint required for locomotion.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Lower-extremity"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#unitPrefix">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnit"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unitPrefix</rdfs:label>
    <rdfs:comment>A schema attribute applied specifically to unit elements to designate that the unit indicator is a prefix (e.g., dollar sign in the currency units).</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:unitProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Measurement-event">
    <rdfs:label>Measurement-event</rdfs:label>
    <rdfs:comment>A discrete measure returned by an instrument.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Event">
        <rdfs:label>Event</rdfs:label>
        <rdfs:comment>Something that happens at a given time and (typically) place. Elements of this tag subtree designate the general category in which an event falls.</rdfs:comment>
        <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-property">
        <rdfs:label>Data-property</rdfs:label>
        <rdfs:comment>Something that pertains to data or information.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Property"/>
        <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
      </hed:HedTag>
    </hed:suggestedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Forehead">
    <rdfs:label>Forehead</rdfs:label>
    <rdfs:comment>The part of the face between the eyebrows and the normal hairline.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Face">
        <rdfs:label>Face</rdfs:label>
        <rdfs:comment>The anterior portion of the head extending from the forehead to the chin and ear to ear. The facial structures contain the eyes, nose and mouth, cheeks and jaws.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Head"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Collection-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the collection.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Collection">
        <rdfs:label>Collection</rdfs:label>
        <rdfs:comment>A tag designating a grouping of items such as in a set or list.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkCyan">
    <rdfs:label>DarkCyan</rdfs:label>
    <rdfs:comment>CSS-color 0x008B8B.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Green-color">
        <rdfs:label>Green-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#deci">
    <rdfs:label>deci</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-1.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>0.1</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Keypad-key-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Value of keypad key.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Keypad-key">
        <rdfs:label>Keypad-key</rdfs:label>
        <rdfs:comment>A key on a separate section of a computer keyboard that groups together numeric keys and those for mathematical or other special functions in an arrangement like that of a calculator.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Keypad"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clause">
    <rdfs:label>Clause</rdfs:label>
    <rdfs:comment>A  unit of grammatical organization next below the sentence in rank, usually consisting of a subject and predicate.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Language-item">
        <rdfs:label>Language-item</rdfs:label>
        <rdfs:comment>An entity related to a systematic means of communicating by the use of sounds, symbols, or gestures.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Item"/>
        <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Room">
    <rdfs:label>Room</rdfs:label>
    <rdfs:comment>An area within a building enclosed by walls and floor and ceiling.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Building">
        <rdfs:label>Building</rdfs:label>
        <rdfs:comment>A structure that has a roof and walls and stands more or less permanently in one place.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Performed-by">
    <rdfs:label>Performed-by</rdfs:label>
    <rdfs:comment>(A, (Performed-by, B)) indicates that the action or procedure A was carried out by agent B.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Connective-relation">
        <rdfs:label>Connective-relation</rdfs:label>
        <rdfs:comment>Indicates two entities are related in some way. The first entity is the focus.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#In-front-of">
    <rdfs:label>In-front-of</rdfs:label>
    <rdfs:comment>(A, (In-front-of, B)) means A is in a position just ahead or at the front part of B, potentially partially blocking B from view.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Yellow">
    <rdfs:label>Yellow</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFF00.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Yellow-color">
        <rdfs:label>Yellow-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Chartreuse">
    <rdfs:label>Chartreuse</rdfs:label>
    <rdfs:comment>CSS-color 0x7FFF00.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sensory-event">
    <rdfs:label>Sensory-event</rdfs:label>
    <rdfs:comment>Something perceivable by the participant. An event meant to be an experimental stimulus should include the tag Task-property/Task-event-role/Experimental-stimulus.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
    <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
    <hed:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sensory-presentation">
        <rdfs:label>Sensory-presentation</rdfs:label>
        <rdfs:comment>The entity has a sensory manifestation.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-property"/>
      </hed:HedTag>
    </hed:suggestedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Jog">
    <rdfs:label>Jog</rdfs:label>
    <rdfs:comment>Run at a trot to exercise.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-lower-extremity">
        <rdfs:label>Move-lower-extremity</rdfs:label>
        <rdfs:comment>Move leg and/or foot.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Chin">
    <rdfs:label>Chin</rdfs:label>
    <rdfs:comment>The part of the face below the lower lip and including the protruding part of the lower jaw.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Time-interval-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Time-interval">
        <rdfs:label>Time-interval</rdfs:label>
        <rdfs:comment>The period of time separating two instances, events, or occurrences.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#timeUnits">
        <rdfs:label>timeUnits</rdfs:label>
        <hed:defaultUnits>s</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Turn-head">
    <rdfs:label>Turn-head</rdfs:label>
    <rdfs:comment>Rotate head horizontally to look in a different direction.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-head">
        <rdfs:label>Move-head</rdfs:label>
        <rdfs:comment>Move head.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sour">
    <rdfs:label>Sour</rdfs:label>
    <rdfs:comment>Having a sharp, acidic taste.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Gustatory-attribute">
        <rdfs:label>Gustatory-attribute</rdfs:label>
        <rdfs:comment>Pertaining to the sense of taste.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Barking">
    <rdfs:label>Barking</rdfs:label>
    <rdfs:comment>Sharp explosive cries like sounds made by certain animals, especially a dog, fox, or seal.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Named-animal-sound">
        <rdfs:label>Named-animal-sound</rdfs:label>
        <rdfs:comment>A sound recognizable as being associated with particular animals.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Fearful">
    <rdfs:label>Fearful</rdfs:label>
    <rdfs:comment>Feeling apprehension that one may be in danger.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grassy-terrain">
    <rdfs:label>Grassy-terrain</rdfs:label>
    <rdfs:comment>Tracts of land covered by grass.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Terrain">
        <rdfs:label>Terrain</rdfs:label>
        <rdfs:comment>Characterization of the physical features of a tract of land.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Wrist">
    <rdfs:label>Wrist</rdfs:label>
    <rdfs:comment>A joint between the distal end of the radius and the proximal row of carpal bones.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Upper-extremity">
        <rdfs:label>Upper-extremity</rdfs:label>
        <rdfs:comment>Refers to the whole superior limb (shoulder, arm, elbow, wrist, hand).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#z">
    <rdfs:label>z</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-21.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-21</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Male">
    <rdfs:label>Male</rdfs:label>
    <rdfs:comment>Biological sex of an individual with male sexual organs producing sperm.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sex">
        <rdfs:label>Sex</rdfs:label>
        <rdfs:comment>Physical properties or qualities by which male is distinguished from female.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Hue-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Angular value between 0 and 360.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Hue">
        <rdfs:label>Hue</rdfs:label>
        <rdfs:comment>Attribute of a visual sensation according to which an area appears to be similar to one of the perceived colors.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#HSV-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumSpringGreen">
    <rdfs:label>MediumSpringGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x00FA9A.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#foot">
    <rdfs:label>foot</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#physicalLengthUnits">
        <rdfs:label>physicalLengthUnits</rdfs:label>
        <hed:defaultUnits>m</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:conversionFactor>0.3048</hed:conversionFactor>
  </hed:HedUnit>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#unitClassProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unitClassProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute is meant to be applied to unit classes.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m_3">
    <rdfs:label>m^3</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#volumeUnits">
        <rdfs:label>volumeUnits</rdfs:label>
        <hed:defaultUnits>m^3</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Aroused">
    <rdfs:label>Aroused</rdfs:label>
    <rdfs:comment>In a state reactive to stimuli leading to increased heart rate and blood pressure, sensory alertness, mobility and readiness to respond.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Creation-date-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Creation-date">
        <rdfs:label>Creation-date</rdfs:label>
        <rdfs:comment>The date on which data creation of this element began.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
        <hed:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:requireChild>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass>
      <hed:HedValueClass rdf:about="https://purl.org/hed/aux#dateTimeClass">
        <rdfs:label>dateTimeClass</rdfs:label>
        <rdfs:comment>Date-times should conform to ISO8601 date-time format YYYY-MM-DDThh:mm:ss. Any variation on the full form is allowed.</rdfs:comment>
        <hed:allowedCharacter>digits</hed:allowedCharacter>
        <hed:allowedCharacter>T</hed:allowedCharacter>
        <hed:allowedCharacter>-</hed:allowedCharacter>
        <hed:allowedCharacter>:</hed:allowedCharacter>
      </hed:HedValueClass>
    </hed:valueClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Repetitive">
    <rdfs:label>Repetitive</rdfs:label>
    <rdfs:comment>A recurring action that is often non-purposeful.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-variability-attribute">
        <rdfs:label>Data-variability-attribute</rdfs:label>
        <rdfs:comment>An attribute describing how something changes or varies.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Refresh-rate-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Refresh-rate">
        <rdfs:label>Refresh-rate</rdfs:label>
        <rdfs:comment>The frequency with which the image on a computer monitor or similar electronic display screen is refreshed, usually expressed in hertz.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cornsilk">
    <rdfs:label>Cornsilk</rdfs:label>
    <rdfs:comment>CSS-color 0xFFF8DC.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Write">
    <rdfs:label>Write</rdfs:label>
    <rdfs:comment>Communicate or express by means of letters or symbols written or imprinted on a surface.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Perform">
        <rdfs:label>Perform</rdfs:label>
        <rdfs:comment>Carry out or accomplish an action, task, or function.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Action"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Across-from">
    <rdfs:label>Across-from</rdfs:label>
    <rdfs:comment>(A, (Across-from, B)) means A is on the opposite side of something from B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shoulder">
    <rdfs:label>Shoulder</rdfs:label>
    <rdfs:comment>Joint attaching upper arm to trunk.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#YellowGreen">
    <rdfs:label>YellowGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x9ACD32.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <owl:ObjectProperty rdf:about="https://purl.org/hed#suggestedTag">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:label>suggestedTag</rdfs:label>
    <rdfs:comment>A schema attribute that indicates another tag  that is often associated with this tag. This attribute is used by tagging tools to provide tagging suggestions.</rdfs:comment>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
    <hed:isInheritedProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:isInheritedProperty>
  </owl:ObjectProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Muddy-terrain">
    <rdfs:label>Muddy-terrain</rdfs:label>
    <rdfs:comment>Tracts of land covered by a liquid or semi-liquid mixture of water and some combination of soil, silt, and clay.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkKhaki">
    <rdfs:label>DarkKhaki</rdfs:label>
    <rdfs:comment>CSS-color 0xBDB76B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ivory">
    <rdfs:label>Ivory</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFFF0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LimeGreen">
    <rdfs:label>LimeGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x32CD32.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Resting">
    <rdfs:label>Resting</rdfs:label>
    <rdfs:comment>A state in which the agent is not exhibiting any physical exertion.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-cognitive-state">
        <rdfs:label>Agent-cognitive-state</rdfs:label>
        <rdfs:comment>The state of the cognitive processes or state of mind of the agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-state"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Fall-down">
    <rdfs:label>Fall-down</rdfs:label>
    <rdfs:comment>Lose balance and collapse.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-body">
        <rdfs:label>Move-body</rdfs:label>
        <rdfs:comment>Move entire body.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Warning">
    <rdfs:label>Warning</rdfs:label>
    <rdfs:comment>Something that should warn the participant that the parameters of the task have been or are about to be exceeded such as a warning message about getting too close to the shoulder of the road in a driving task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sing">
    <rdfs:label>Sing</rdfs:label>
    <rdfs:comment>Produce musical tones by means of the voice.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Communicate-musically">
        <rdfs:label>Communicate-musically</rdfs:label>
        <rdfs:comment>Communicate using music.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ambidextrous">
    <rdfs:label>Ambidextrous</rdfs:label>
    <rdfs:comment>Having no overall dominance in the use of right or left hand or foot in the performance of tasks that require one hand or foot.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Handedness">
        <rdfs:label>Handedness</rdfs:label>
        <rdfs:comment>Individual preference for use of a hand, known as the dominant hand.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Instructional">
    <rdfs:label>Instructional</rdfs:label>
    <rdfs:comment>Usually associated with a sensory event intended to give instructions to the participant about the task or behavior.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#h">
    <rdfs:label>h</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^2.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>100.0</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Greater-than">
    <rdfs:label>Greater-than</rdfs:label>
    <rdfs:comment>(A, (Greater-than, B)) indicates that the relative size or order of A is bigger than that of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sneeze">
    <rdfs:label>Sneeze</rdfs:label>
    <rdfs:comment>Suddenly and violently expel breath through the nose and mouth.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Saccade">
    <rdfs:label>Saccade</rdfs:label>
    <rdfs:comment>Move eyes rapidly between fixation points.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Learn">
    <rdfs:label>Learn</rdfs:label>
    <rdfs:comment>Adaptively change behavior as the result of experience.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Wave">
    <rdfs:label>Wave</rdfs:label>
    <rdfs:comment>Raise hand and move left and right, as a greeting or sign of departure.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Communicate-gesturally">
        <rdfs:label>Communicate-gesturally</rdfs:label>
        <rdfs:comment>Communicate nonverbally using visible bodily actions, either in place of speech or together and in parallel with spoken words. Gestures include movement of the hands, face, or other parts of the body.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-upper-extremity">
        <rdfs:label>Move-upper-extremity</rdfs:label>
        <rdfs:comment>Move arm, shoulder, and/or hand.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sound-envelope-attack-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-envelope-attack">
        <rdfs:label>Sound-envelope-attack</rdfs:label>
        <rdfs:comment>The time taken for initial run-up of level from nil to peak usually beginning when the key on a musical instrument is pressed.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound-envelope"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#k">
    <rdfs:label>k</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^3.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>1000.0</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Distracted">
    <rdfs:label>Distracted</rdfs:label>
    <rdfs:comment>Lacking in concentration because of being preoccupied.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experimenter">
    <rdfs:label>Experimenter</rdfs:label>
    <rdfs:comment>Person who is the owner of the experiment and has its responsibility.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-task-role">
        <rdfs:label>Agent-task-role</rdfs:label>
        <rdfs:comment>The function or part that is ascribed to an agent in performing the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#conversionFactor">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnit"/>
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnitModifier"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>conversionFactor</rdfs:label>
    <rdfs:comment>The multiplicative factor to multiply these units to convert to default units.</rdfs:comment>
    <hed:unitProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitProperty>
    <hed:unitModifierProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitModifierProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pyramid">
    <rdfs:label>Pyramid</rdfs:label>
    <rdfs:comment>A polyhedron of which one face is a polygon of any number of sides, and the other faces are triangles with a common vertex.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#3D-shape">
        <rdfs:label>3D-shape</rdfs:label>
        <rdfs:comment>A geometric three-dimensional shape.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Geometric-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Spectral-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Spectral-resolution">
        <rdfs:label>Spectral-resolution</rdfs:label>
        <rdfs:comment>Measures the ability of a sensor to  resolve features in the electromagnetic spectrum.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#ForestGreen">
    <rdfs:label>ForestGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x228B22.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Correction">
    <rdfs:label>Correction</rdfs:label>
    <rdfs:comment>An action offering an improvement to replace a mistake or error.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-action-type">
        <rdfs:label>Task-action-type</rdfs:label>
        <rdfs:comment>How an agent action should be interpreted in terms of the task specification.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sad">
    <rdfs:label>Sad</rdfs:label>
    <rdfs:comment>Feeling grief or unhappiness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-procedure">
    <rdfs:label>Experiment-procedure</rdfs:label>
    <rdfs:comment>An event indicating an experimental procedure, as in performing a saliva swab during the experiment or administering a survey.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#zetta">
    <rdfs:label>zetta</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^21.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^21</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Glass">
    <rdfs:label>Glass</rdfs:label>
    <rdfs:comment>A brittle transparent solid with irregular atomic structure.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Manufactured-material">
        <rdfs:label>Manufactured-material</rdfs:label>
        <rdfs:comment>Substances created or extracted from raw materials.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Data-mean-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-mean">
        <rdfs:label>Data-mean</rdfs:label>
        <rdfs:comment>The sum of a set of values divided by the number of values in the set.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <owl:ObjectProperty rdf:about="https://purl.org/hed#defaultUnits">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnitClass"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedUnit"/>
    <rdfs:label>defaultUnits</rdfs:label>
    <rdfs:comment>A schema attribute of unit classes specifying the default units to use if the placeholder has a unit class but the substituted value has no units.</rdfs:comment>
    <hed:unitClassProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitClassProperty>
  </owl:ObjectProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkRed">
    <rdfs:label>DarkRed</rdfs:label>
    <rdfs:comment>CSS-color 0x8B0000.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MintCream">
    <rdfs:label>MintCream</rdfs:label>
    <rdfs:comment>CSS-color 0xF5FFFA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Omitted-action">
    <rdfs:label>Omitted-action</rdfs:label>
    <rdfs:comment>An expected response was skipped.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hear">
    <rdfs:label>Hear</rdfs:label>
    <rdfs:comment>Give attention to a sound.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Perceive">
        <rdfs:label>Perceive</rdfs:label>
        <rdfs:comment>Produce an internal, conscious image through stimulating a sensory system.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Action"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Loudspeaker">
    <rdfs:label>Loudspeaker</rdfs:label>
    <rdfs:comment>A device designed to convert electrical signals to sounds that can be heard.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Auditory-device">
        <rdfs:label>Auditory-device</rdfs:label>
        <rdfs:comment>A device designed to produce sound.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Output-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Imagine">
    <rdfs:label>Imagine</rdfs:label>
    <rdfs:comment>Form a mental image or concept of something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Torso-back">
    <rdfs:label>Torso-back</rdfs:label>
    <rdfs:comment>The rear surface of the human body from the shoulders to the hips.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Torso">
        <rdfs:label>Torso</rdfs:label>
        <rdfs:comment>The body excluding the head and neck and limbs.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Character">
    <rdfs:label>Character</rdfs:label>
    <rdfs:comment>A mark or symbol used in writing.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightSteelBlue">
    <rdfs:label>LightSteelBlue</rdfs:label>
    <rdfs:comment>CSS-color 0xB0C4DE.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Blue-color">
        <rdfs:label>Blue-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#oC">
    <rdfs:label>oC</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#temperatureUnits">
        <rdfs:label>temperatureUnits</rdfs:label>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m">
    <rdfs:label>m</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Timed">
    <rdfs:label>Timed</rdfs:label>
    <rdfs:comment>Something planned or scheduled to be done at a particular time or lasting for a specified amount of time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pink">
    <rdfs:label>Pink</rdfs:label>
    <rdfs:comment>CSS-color 0xFFC0CB.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Pink-color">
        <rdfs:label>Pink-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Purring">
    <rdfs:label>Purring</rdfs:label>
    <rdfs:comment>Low continuous vibratory sound such as those made by cats. The sound expresses contentment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Statistical-precision-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Statistical-precision">
        <rdfs:label>Statistical-precision</rdfs:label>
        <rdfs:comment>A quantitative representation of the degree of accuracy necessary for or associated with a particular action.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Participant-response">
    <rdfs:label>Participant-response</rdfs:label>
    <rdfs:comment>Something related to a participant actions in performing the task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Human-agent">
    <rdfs:label>Human-agent</rdfs:label>
    <rdfs:comment>A person who takes an active role or produces a specified effect.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent">
        <rdfs:label>Agent</rdfs:label>
        <rdfs:comment>Someone or something that takes an active role or produces a specified effect.The role or effect may be implicit. Being alive or performing an activity such as a computation may qualify something to be an agent. An agent may also be something that simulates something else.</rdfs:comment>
        <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Agent-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Pitch-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Pitch">
        <rdfs:label>Pitch</rdfs:label>
        <rdfs:comment>A perceptual property that allows the user to order sounds on a frequency scale.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#frequencyUnits">
        <rdfs:label>frequencyUnits</rdfs:label>
        <hed:defaultUnits>Hz</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-action">
    <rdfs:label>Agent-action</rdfs:label>
    <rdfs:comment>Any action engaged in by an agent (see the Agent subtree for agent categories). A participant response to an experiment stimulus should include the tag Agent-property/Agent-task-role/Experiment-participant.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
    <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
    <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Agent"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Before">
    <rdfs:label>Before</rdfs:label>
    <rdfs:comment>(A, (Before B)) means A happens at a time earlier in time or order than B.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-relation">
        <rdfs:label>Temporal-relation</rdfs:label>
        <rdfs:comment>A relationship that includes a temporal or time-based component.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Spatial-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Spatial-resolution">
        <rdfs:label>Spatial-resolution</rdfs:label>
        <rdfs:comment>Linear spacing of a spatial measurement.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#ID-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#ID">
        <rdfs:label>ID</rdfs:label>
        <rdfs:comment>An alphanumeric name that identifies either a unique object or a unique class of objects. Here the object or class may be an idea, physical countable object (or class), or physical uncountable substance (or class).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Informational-property"/>
        <hed:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:requireChild>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass>
      <hed:HedValueClass rdf:about="https://purl.org/hed/aux#textClass">
        <rdfs:label>textClass</rdfs:label>
        <rdfs:comment>Value class designating values that have the characteristics of text such as in descriptions.</rdfs:comment>
        <hed:allowedCharacter>letters</hed:allowedCharacter>
        <hed:allowedCharacter>digits</hed:allowedCharacter>
        <hed:allowedCharacter>blank</hed:allowedCharacter>
        <hed:allowedCharacter>+</hed:allowedCharacter>
        <hed:allowedCharacter>-</hed:allowedCharacter>
        <hed:allowedCharacter>:</hed:allowedCharacter>
        <hed:allowedCharacter>;</hed:allowedCharacter>
        <hed:allowedCharacter>.</hed:allowedCharacter>
        <hed:allowedCharacter>/</hed:allowedCharacter>
        <hed:allowedCharacter>(</hed:allowedCharacter>
        <hed:allowedCharacter>)</hed:allowedCharacter>
        <hed:allowedCharacter>?</hed:allowedCharacter>
        <hed:allowedCharacter>*</hed:allowedCharacter>
        <hed:allowedCharacter>%</hed:allowedCharacter>
        <hed:allowedCharacter>$</hed:allowedCharacter>
        <hed:allowedCharacter>@</hed:allowedCharacter>
      </hed:HedValueClass>
    </hed:valueClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightCoral">
    <rdfs:label>LightCoral</rdfs:label>
    <rdfs:comment>CSS-color 0xF08080.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grimace">
    <rdfs:label>Grimace</rdfs:label>
    <rdfs:comment>Make a twisted expression, typically expressing disgust, pain, or wry amusement.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-face">
        <rdfs:label>Move-face</rdfs:label>
        <rdfs:comment>Move the face or jaw.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cube">
    <rdfs:label>Cube</rdfs:label>
    <rdfs:comment>A solid or semi-solid in the shape of a three dimensional square.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Box">
        <rdfs:label>Box</rdfs:label>
        <rdfs:comment>A square or rectangular vessel, usually made of cardboard or plastic.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#3D-shape"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Snow">
    <rdfs:label>Snow</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFAFA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Single-point">
    <rdfs:label>Single-point</rdfs:label>
    <rdfs:comment>A point is a geometric entity that is located in a zero-dimensional spatial region and whose position is defined by its coordinates in some coordinate system.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#2D-shape">
        <rdfs:label>2D-shape</rdfs:label>
        <rdfs:comment>A planar, two-dimensional shape.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Geometric-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkOrchid">
    <rdfs:label>DarkOrchid</rdfs:label>
    <rdfs:comment>CSS-color 0x9932CC.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Purple-color">
        <rdfs:label>Purple-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Meowing">
    <rdfs:label>Meowing</rdfs:label>
    <rdfs:comment>Vocalizations like those made by as those cats. These sounds have diverse tones and are sometimes chattered, murmured or whispered. The purpose can be assertive.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#HSV-value-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#HSV-value">
        <rdfs:label>HSV-value</rdfs:label>
        <rdfs:comment>An attribute of a visual sensation according to which an area appears to emit more or less light.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#HSV-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Distance-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Distance">
        <rdfs:label>Distance</rdfs:label>
        <rdfs:comment>A measure of the space separating two objects or points.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Query">
    <rdfs:label>Query</rdfs:label>
    <rdfs:comment>A sentence of inquiry that asks for a reply.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Outline-visualization">
    <rdfs:label>Outline-visualization</rdfs:label>
    <rdfs:comment>A visualization consisting of a line or set of lines enclosing or indicating the shape of an object in a sketch or diagram.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Visualization">
        <rdfs:label>Visualization</rdfs:label>
        <rdfs:comment>An planned process that creates images, diagrams or animations from the input data.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Media"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#During">
    <rdfs:label>During</rdfs:label>
    <rdfs:comment>(A, (During, B)) means A happens at some point in a given period of time in which B is ongoing.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#OBO-identifier-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#OBO-identifier">
        <rdfs:label>OBO-identifier</rdfs:label>
        <rdfs:comment>The identifier of a term in some Open Biology Ontology (OBO) ontology.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Glasses">
    <rdfs:label>Glasses</rdfs:label>
    <rdfs:comment>Frames with lenses worn in front of the eye for vision correction, eye protection, or protection from UV rays.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Assistive-device">
        <rdfs:label>Assistive-device</rdfs:label>
        <rdfs:comment>A device that help an individual accomplish a task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Within">
    <rdfs:label>Within</rdfs:label>
    <rdfs:comment>(A, (Within, B)) means A is on the inside of or contained in B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#valueClassProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>valueClassProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute is meant to be applied to value classes.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Jealous">
    <rdfs:label>Jealous</rdfs:label>
    <rdfs:comment>Feeling threatened by a rival in a relationship with another individual, in particular an intimate partner, usually involves feelings of threat, fear, suspicion, distrust, anxiety, anger, betrayal, and rejection.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Trot">
    <rdfs:label>Trot</rdfs:label>
    <rdfs:comment>Run at a moderate pace, typically with short steps.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stress">
    <rdfs:label>Stress</rdfs:label>
    <rdfs:comment>The negative mental, emotional, and physical reactions that occur when environmental stressors are perceived as exceeding the adaptive capacities of the individual.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Somatic-attribute">
        <rdfs:label>Somatic-attribute</rdfs:label>
        <rdfs:comment>Pertaining to the feelings in the body or of the nervous system.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DodgerBlue">
    <rdfs:label>DodgerBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x1E90FF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Includes">
    <rdfs:label>Includes</rdfs:label>
    <rdfs:comment>(A, (Includes, B)) indicates that A has B as a member or part.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gulp">
    <rdfs:label>Gulp</rdfs:label>
    <rdfs:comment>Swallow quickly or in large mouthfuls, often audibly, sometimes to indicate apprehension.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Swallow">
        <rdfs:label>Swallow</rdfs:label>
        <rdfs:comment>Cause or allow something, especially food or drink to pass down the throat.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-face"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Indigo">
    <rdfs:label>Indigo</rdfs:label>
    <rdfs:comment>CSS-color 0x4B0082.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Related-to">
    <rdfs:label>Related-to</rdfs:label>
    <rdfs:comment>(A, (Related-to, B)) indicates A has some relationship to B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Laptop-computer">
    <rdfs:label>Laptop-computer</rdfs:label>
    <rdfs:comment>A computer that is portable and suitable for use while traveling.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Computing-device">
        <rdfs:label>Computing-device</rdfs:label>
        <rdfs:comment>An electronic device which take inputs and processes results from the inputs.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Software-agent">
    <rdfs:label>Software-agent</rdfs:label>
    <rdfs:comment>An agent computer program.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mountain">
    <rdfs:label>Mountain</rdfs:label>
    <rdfs:comment>A landform that extends above the surrounding terrain in a limited area.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Natural-feature">
        <rdfs:label>Natural-feature</rdfs:label>
        <rdfs:comment>A feature that occurs in nature. A prominent or identifiable aspect, region, or site of interest.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Natural-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ring-finger">
    <rdfs:label>Ring-finger</rdfs:label>
    <rdfs:comment>The fourth finger from the radial side of the hand.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finger"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Push-button">
    <rdfs:label>Push-button</rdfs:label>
    <rdfs:comment>A switch designed to be operated by pressing a button.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Input-device">
        <rdfs:label>Input-device</rdfs:label>
        <rdfs:comment>A piece of equipment used to provide data and control signals to an information processing system such as a computer or information appliance.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#IO-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-activity">
    <rdfs:label>Task-activity</rdfs:label>
    <rdfs:comment>Something that is part of the overall task or is necessary to the overall experiment but is not directly part of a stimulus-response cycle. Examples would be taking a survey or provided providing a silva sample.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#f">
    <rdfs:label>f</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-15.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-15</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sniff">
    <rdfs:label>Sniff</rdfs:label>
    <rdfs:comment>Draw in air audibly through the nose to detect a smell, to stop it from running, or to express contempt.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Phoneme">
    <rdfs:label>Phoneme</rdfs:label>
    <rdfs:comment>A speech sound that is distinguished by the speakers of a particular language.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shrug">
    <rdfs:label>Shrug</rdfs:label>
    <rdfs:comment>Lift shoulders up towards head to indicate a lack of knowledge about a particular topic.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-torso">
        <rdfs:label>Move-torso</rdfs:label>
        <rdfs:comment>Move body trunk.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Printer-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Printer-resolution">
        <rdfs:label>Printer-resolution</rdfs:label>
        <rdfs:comment>Resolution of a printer, usually expressed as the number of dots-per-inch for a printer.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gender">
    <rdfs:label>Gender</rdfs:label>
    <rdfs:comment>Characteristics that are socially constructed, including norms, behaviors, and roles based on sex.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-trait">
        <rdfs:label>Agent-trait</rdfs:label>
        <rdfs:comment>A genetically, environmentally, or socially determined characteristic of an agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Magenta">
    <rdfs:label>Magenta</rdfs:label>
    <rdfs:comment>CSS-color 0xFF00FF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Avatar-agent">
    <rdfs:label>Avatar-agent</rdfs:label>
    <rdfs:comment>An agent associated with an icon or avatar representing another agent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ankle">
    <rdfs:label>Ankle</rdfs:label>
    <rdfs:comment>A gliding joint between the distal ends of the tibia and fibula and the proximal end of the talus.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Lower-extremity">
        <rdfs:label>Lower-extremity</rdfs:label>
        <rdfs:comment>Refers to the whole inferior limb (leg and/or foot).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Painting">
    <rdfs:label>Painting</rdfs:label>
    <rdfs:comment>A work produced through the art of painting.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Image">
        <rdfs:label>Image</rdfs:label>
        <rdfs:comment>Any record of an imaging event whether physical or electronic.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Data-minimum-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-minimum">
        <rdfs:label>Data-minimum</rdfs:label>
        <rdfs:comment>The smallest possible quantity.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Waist">
    <rdfs:label>Waist</rdfs:label>
    <rdfs:comment>The abdominal circumference at the navel.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Torso"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Def-expand-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Def-expand">
        <rdfs:label>Def-expand</rdfs:label>
        <rdfs:comment>A HED specific utility tag that is grouped with an expanded definition. The child value of the Def-expand is the name of the expanded definition.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
        <hed:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:requireChild>
        <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
        <hed:tagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:tagGroup>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#c">
    <rdfs:label>c</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-2.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>0.01</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Spread-hands">
    <rdfs:label>Spread-hands</rdfs:label>
    <rdfs:comment>Spread hands apart to indicate ignorance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Library-name-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Library-name">
        <rdfs:label>Library-name</rdfs:label>
        <rdfs:comment>Official name of a HED library.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Comatose">
    <rdfs:label>Comatose</rdfs:label>
    <rdfs:comment>In a state of profound unconsciousness associated with markedly depressed cerebral activity.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shake-fist">
    <rdfs:label>Shake-fist</rdfs:label>
    <rdfs:comment>Clench hand into a fist and shake to demonstrate anger.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Less-than">
    <rdfs:label>Less-than</rdfs:label>
    <rdfs:comment>(A, (Less-than, B)) indicates that A is smaller than B. Here A and B could refer to sizes, orders, positions or other quantities.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experimental-stimulus">
    <rdfs:label>Experimental-stimulus</rdfs:label>
    <rdfs:comment>Part of something designed to elicit a response in the experiment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#g">
    <rdfs:label>g</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#weightUnits">
        <rdfs:label>weightUnits</rdfs:label>
        <hed:defaultUnits>g</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#u">
    <rdfs:label>u</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-6.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-6</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Whisper">
    <rdfs:label>Whisper</rdfs:label>
    <rdfs:comment>Speak very softly using breath without vocal cords.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Communicate-vocally">
        <rdfs:label>Communicate-vocally</rdfs:label>
        <rdfs:comment>Communicate using mouth or vocal cords.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Unrelated-to">
    <rdfs:label>Unrelated-to</rdfs:label>
    <rdfs:comment>(A, (Unrelated-to, B)) indicates that A is not related to B.  For example, A is not related to Task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PowderBlue">
    <rdfs:label>PowderBlue</rdfs:label>
    <rdfs:comment>CSS-color 0xB0E0E6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#RGB-blue-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>B value of RGB between 0 and 1.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#RGB-blue">
        <rdfs:label>RGB-blue</rdfs:label>
        <rdfs:comment>The blue component.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#RGB-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Roaring">
    <rdfs:label>Roaring</rdfs:label>
    <rdfs:comment>Loud, deep, or harsh prolonged sounds such as those made by big cats and bears for long-distance communication and intimidation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Headphones">
    <rdfs:label>Headphones</rdfs:label>
    <rdfs:comment>An instrument that consists of a pair of small loudspeakers, or less commonly a single speaker, held close to ears and connected to a signal source such as an audio amplifier, radio, CD player or portable media player.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Moccasin">
    <rdfs:label>Moccasin</rdfs:label>
    <rdfs:comment>CSS-color 0xFFE4B5.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Detect">
    <rdfs:label>Detect</rdfs:label>
    <rdfs:comment>Discover or identify the presence or existence of something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lip">
    <rdfs:label>Lip</rdfs:label>
    <rdfs:comment>Fleshy fold which surrounds the opening of the mouth.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkViolet">
    <rdfs:label>DarkViolet</rdfs:label>
    <rdfs:comment>CSS-color 0x9400D3.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#candela">
    <rdfs:label>candela</rdfs:label>
    <rdfs:comment>Units used to express light intensity.</rdfs:comment>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#intensityUnits">
        <rdfs:label>intensityUnits</rdfs:label>
        <hed:defaultUnits>dB</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lift-head">
    <rdfs:label>Lift-head</rdfs:label>
    <rdfs:comment>Tilt head back lifting chin.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Below">
    <rdfs:label>Below</rdfs:label>
    <rdfs:comment>(A, (Below, B)) means A is in a place or position that is lower than the position of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Nod-head">
    <rdfs:label>Nod-head</rdfs:label>
    <rdfs:comment>Tilt head in alternating up and down arcs along the sagittal plane. It is most commonly, but not universally, used to indicate agreement, acceptance, or acknowledgement.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ding">
    <rdfs:label>Ding</rdfs:label>
    <rdfs:comment>A short ringing sound such as that made by a bell, often to indicate a correct response or the expiration of time.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Named-object-sound">
        <rdfs:label>Named-object-sound</rdfs:label>
        <rdfs:comment>A sound identifiable as coming from a particular type of object.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LED-display">
    <rdfs:label>LED-display</rdfs:label>
    <rdfs:comment>A LED display is a flat panel display that uses an array of light-emitting diodes as pixels for a video display.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Display-device">
        <rdfs:label>Display-device</rdfs:label>
        <rdfs:comment>An output device for presentation of information in visual or tactile form the latter used for example in tactile electronic displays for blind people.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Output-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Collide-with">
    <rdfs:label>Collide-with</rdfs:label>
    <rdfs:comment>Hit with force when moving.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#radian">
    <rdfs:label>radian</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#angleUnits">
        <rdfs:label>angleUnits</rdfs:label>
        <hed:defaultUnits>radian</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Around">
    <rdfs:label>Around</rdfs:label>
    <rdfs:comment>(A, (Around, B)) means A is in or near the present place or situation of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Alarm-sound">
    <rdfs:label>Alarm-sound</rdfs:label>
    <rdfs:comment>A loud signal often loud continuous ringing to alert people to a problem or condition that requires urgent attention.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Grayscale-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>White intensity between 0 and 1.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Grayscale">
        <rdfs:label>Grayscale</rdfs:label>
        <rdfs:comment>Using a color map composed of shades of gray, varying from black at the weakest intensity to white at the strongest.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Play-instrument">
    <rdfs:label>Play-instrument</rdfs:label>
    <rdfs:comment>Make musical sounds using an instrument.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stand-up">
    <rdfs:label>Stand-up</rdfs:label>
    <rdfs:comment>Move from a sitting to a standing position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#CadetBlue">
    <rdfs:label>CadetBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x5F9EA0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Smile">
    <rdfs:label>Smile</rdfs:label>
    <rdfs:comment>Form facial features into a pleased, kind, or amused expression, typically with the corners of the mouth turned up and the front teeth exposed.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Upper-arm">
    <rdfs:label>Upper-arm</rdfs:label>
    <rdfs:comment>Portion of arm between shoulder and elbow.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SlateGray">
    <rdfs:label>SlateGray</rdfs:label>
    <rdfs:comment>CSS-color 0x708090.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Gray-color">
        <rdfs:label>Gray-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#extensionAllowed">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>extensionAllowed</rdfs:label>
    <rdfs:comment>A schema attribute indicating that users can add unlimited levels of child nodes under this tag. This tag is propagated to child nodes with the exception of the hashtag placeholders.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
    <hed:isInheritedProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:isInheritedProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clothing">
    <rdfs:label>Clothing</rdfs:label>
    <rdfs:comment>A covering designed to be worn on the body.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Man-made-object">
        <rdfs:label>Man-made-object</rdfs:label>
        <rdfs:comment>Something constructed by human means.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mineral">
    <rdfs:label>Mineral</rdfs:label>
    <rdfs:comment>A solid, homogeneous, inorganic substance occurring in nature and having a definite chemical composition.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Natural-object">
        <rdfs:label>Natural-object</rdfs:label>
        <rdfs:comment>Something that exists in or is produced by nature, and is not artificial or man-made.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#dB">
    <rdfs:label>dB</rdfs:label>
    <rdfs:comment>Intensity expressed as ratio to a threshold. May be used for sound intensity.</rdfs:comment>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#intensityUnits"/>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Weight-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Weight">
        <rdfs:label>Weight</rdfs:label>
        <rdfs:comment>The relative mass or the quantity of matter contained by something.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Physical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#weightUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lower-right-of">
    <rdfs:label>Lower-right-of</rdfs:label>
    <rdfs:comment>(A, (Lower-right-of, B)) means A is situated on the lower right part of B. This relation is often used to specify qualitative information about screen position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Center-of">
        <rdfs:label>Center-of</rdfs:label>
        <rdfs:comment>(A, (Center-of, B)) means A is at a point or or in an area that is approximately central within B.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Lower-center-of">
        <rdfs:label>Lower-center-of</rdfs:label>
        <rdfs:comment>(A, (Lower-center-of, B)) means A is situated on the lower center part of B (due south). This relation is often used to specify qualitative information about screen position.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-left-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-right-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-right-of"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Lower-left-of">
        <rdfs:label>Lower-left-of</rdfs:label>
        <rdfs:comment>(A, (Lower-left-of, B)) means A is situated on the lower left part of B. This relation is often used to specify qualitative information about screen position.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-right-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-left-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-right-of"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Upper-left-of">
        <rdfs:label>Upper-left-of</rdfs:label>
        <rdfs:comment>(A, (Upper-left-of, B)) means A is situated on the upper left part of B. This relation is often used to specify qualitative information about screen position.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-left-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-right-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-right-of"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Upper-center-of">
        <rdfs:label>Upper-center-of</rdfs:label>
        <rdfs:comment>(A, (Upper-center-of, B)) means A is situated on the upper center part of B (due north). This relation is often used to specify qualitative information about screen position.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-left-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-right-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-center-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-right-of"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-right-of"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Abrupt">
    <rdfs:label>Abrupt</rdfs:label>
    <rdfs:comment>Marked by sudden change.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#SIUnit">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnit"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>SIUnit</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this unit element is an SI unit and can be modified by multiple and submultiple names. Note that some units such as byte are designated as SI units although they are not part of the standard.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:unitProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Synchronous-with">
    <rdfs:label>Synchronous-with</rdfs:label>
    <rdfs:comment>(A, (Synchronous-with, B)) means A happens at occurs at the same time or rate as B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Groan">
    <rdfs:label>Groan</rdfs:label>
    <rdfs:comment>Make a deep inarticulate sound in response to pain or despair.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Curl-toes">
    <rdfs:label>Curl-toes</rdfs:label>
    <rdfs:comment>Bend toes sometimes to grip.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Plan">
    <rdfs:label>Plan</rdfs:label>
    <rdfs:comment>Think about the activities required to achieve a desired goal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Speed-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Speed">
        <rdfs:label>Speed</rdfs:label>
        <rdfs:comment>A scalar measure of the rate of movement of the object expressed either as the distance travelled divided by the time taken (average speed) or the rate of change of position with respect to time at a particular point (instantaneous speed). The direction of change should be given separately.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#speedUnits">
        <rdfs:label>speedUnits</rdfs:label>
        <hed:defaultUnits>m-per-s</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sentence">
    <rdfs:label>Sentence</rdfs:label>
    <rdfs:comment>A set of words that is complete in itself, conveying a statement, question, exclamation, or command and typically containing an explicit or implied subject and a predicate containing a finite verb.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Close">
    <rdfs:label>Close</rdfs:label>
    <rdfs:comment>Act as to blocked against entry or passage.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sitting">
    <rdfs:label>Sitting</rdfs:label>
    <rdfs:comment>In a seated position.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-postural-state">
        <rdfs:label>Agent-postural-state</rdfs:label>
        <rdfs:comment>Pertaining to the position in which agent holds their body.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-state"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Attentive">
    <rdfs:label>Attentive</rdfs:label>
    <rdfs:comment>Concentrating and focusing mental energy on the task or surroundings.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Palm">
    <rdfs:label>Palm</rdfs:label>
    <rdfs:comment>The part of the inner surface of the hand that extends from the wrist to the bases of the fingers.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Hand">
        <rdfs:label>Hand</rdfs:label>
        <rdfs:comment>The distal portion of the upper extremity. It consists of the carpus, metacarpus, and digits.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Upper-extremity"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Oblique">
    <rdfs:label>Oblique</rdfs:label>
    <rdfs:comment>Slanting or inclined in direction, course, or position that is neither parallel nor perpendicular nor right-angular.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Categorical-orientation-value">
        <rdfs:label>Categorical-orientation-value</rdfs:label>
        <rdfs:comment>Value indicating the orientation or direction of something.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Rotated">
        <rdfs:label>Rotated</rdfs:label>
        <rdfs:comment>Positioned offset around an axis or center.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Olfactory-presentation">
    <rdfs:label>Olfactory-presentation</rdfs:label>
    <rdfs:comment>The sense of smell used in the presentation to the user.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#RosyBrown">
    <rdfs:label>RosyBrown</rdfs:label>
    <rdfs:comment>CSS-color 0xBC8F8F.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#p">
    <rdfs:label>p</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-12.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-12</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#HoneyDew">
    <rdfs:label>HoneyDew</rdfs:label>
    <rdfs:comment>CSS-color 0xF0FFF0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MEG-recorder">
    <rdfs:label>MEG-recorder</rdfs:label>
    <rdfs:comment>A device for measuring the magnetic fields produced by electrical activity in the brain, usually conducted externally.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Recording-device">
        <rdfs:label>Recording-device</rdfs:label>
        <rdfs:comment>A device that copies information in a signal into a persistent information bearer.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#IO-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Control-variable-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the control variable.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Control-variable">
        <rdfs:label>Control-variable</rdfs:label>
        <rdfs:comment>An aspect of the experiment that is fixed throughout the study and usually is explicitly controlled.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Virtual-world">
    <rdfs:label>Virtual-world</rdfs:label>
    <rdfs:comment>Using technology that creates immersive, computer-generated experiences that a person can interact with and navigate through. The digital content is generally delivered to the user through some type of headset and responds to changes in head position or through interaction with other types of sensors. Existing in a virtual setting such as a simulation or game environment.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Environmental-property">
        <rdfs:label>Environmental-property</rdfs:label>
        <rdfs:comment>Relating to or arising from the surroundings of an agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Whistle">
    <rdfs:label>Whistle</rdfs:label>
    <rdfs:comment>Produce a shrill clear sound by forcing breath out or air in through the puckered lips.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sound-volume-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-volume">
        <rdfs:label>Sound-volume</rdfs:label>
        <rdfs:comment>The sound pressure level (SPL) usually the ratio to a reference signal estimated as the lower bound of hearing.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#intensityUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tablet-computer">
    <rdfs:label>Tablet-computer</rdfs:label>
    <rdfs:comment>A small portable computer that accepts input directly on to its screen rather than via a keyboard or mouse.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Computing-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Siren">
    <rdfs:label>Siren</rdfs:label>
    <rdfs:comment>A loud, continuous sound often varying in frequency designed to indicate an emergency.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Event-context">
    <rdfs:label>Event-context</rdfs:label>
    <rdfs:comment>A special HED tag inserted as part of a top-level tag group to contain information about the interrelated conditions under which the event occurs. The event context includes information about other events that are ongoing when this event happens.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Organizational-property">
        <rdfs:label>Organizational-property</rdfs:label>
        <rdfs:comment>Relating to an organization or the action of organizing something.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
    <hed:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:topLevelTagGroup>
    <hed:unique rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unique>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lime">
    <rdfs:label>Lime</rdfs:label>
    <rdfs:comment>CSS-color 0x00FF00.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Growling">
    <rdfs:label>Growling</rdfs:label>
    <rdfs:comment>Low guttural sounds like those that made in the throat by a hostile dog or other animal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Computed-prediction">
    <rdfs:label>Computed-prediction</rdfs:label>
    <rdfs:comment>A computed extrapolation of known data.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-source-type">
        <rdfs:label>Data-source-type</rdfs:label>
        <rdfs:comment>The type of place, person, or thing from which the data comes or can be obtained.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Nose">
    <rdfs:label>Nose</rdfs:label>
    <rdfs:comment>A structure of special sense serving as an organ of the sense of smell and as an entrance to the respiratory tract.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Satellite-view">
    <rdfs:label>Satellite-view</rdfs:label>
    <rdfs:comment>A representation as captured by technology such as a satellite.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Map-view">
        <rdfs:label>Map-view</rdfs:label>
        <rdfs:comment>A diagrammatic representation of an area of land or sea showing physical features, cities, roads.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#takesValue">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>takesValue</rdfs:label>
    <rdfs:comment>A schema attribute indicating the tag is a hashtag placeholder that is expected to be replaced with a user-defined value.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clear-throat">
    <rdfs:label>Clear-throat</rdfs:label>
    <rdfs:comment>Cough slightly so as to speak more clearly, attract attention, or to express hesitancy before saying something awkward.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Not-meaningful">
    <rdfs:label>Not-meaningful</rdfs:label>
    <rdfs:comment>Not having a serious, important, or useful quality or purpose.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PaleTurquoise">
    <rdfs:label>PaleTurquoise</rdfs:label>
    <rdfs:comment>CSS-color 0xAFEEEE.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Cyan-color">
        <rdfs:label>Cyan-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Flickering">
    <rdfs:label>Flickering</rdfs:label>
    <rdfs:comment>Moving irregularly or unsteadily or burning or shining fitfully or with a fluctuating light.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#After">
    <rdfs:label>After</rdfs:label>
    <rdfs:comment>(A, (After B)) means A happens at a time subsequent to a reference time related to B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-relation"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#boolProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>boolProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute represents something that is either true or false and does not have a value. Attributes without this value are assumed to have string values.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Condition-variable-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the condition variable.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Condition-variable">
        <rdfs:label>Condition-variable</rdfs:label>
        <rdfs:comment>An aspect of the experiment or task that is to be varied during the experiment. Task-conditions are sometimes called independent variables or contrasts.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#RGB-red-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>R value of RGB between 0 and 1.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#RGB-red">
        <rdfs:label>RGB-red</rdfs:label>
        <rdfs:comment>The red component.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#RGB-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#White">
    <rdfs:label>White</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFFFF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Taste">
    <rdfs:label>Taste</rdfs:label>
    <rdfs:comment>Sense a flavor in the mouth and throat on contact with a substance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perceive"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Scratch">
    <rdfs:label>Scratch</rdfs:label>
    <rdfs:comment>Drag claws or nails over a surface or on skin.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Augmented-reality">
    <rdfs:label>Augmented-reality</rdfs:label>
    <rdfs:comment>Using technology that enhances real-world experiences with computer-derived digital overlays to change some aspects of perception of the natural environment. The digital content is shown to the user through a smart device or glasses and responds to changes in the environment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Navy">
    <rdfs:label>Navy</rdfs:label>
    <rdfs:comment>CSS-color 0x000080.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Switched-attention">
    <rdfs:label>Switched-attention</rdfs:label>
    <rdfs:comment>Having to switch attention between two or more modalities of presentation.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-attentional-demand">
        <rdfs:label>Task-attentional-demand</rdfs:label>
        <rdfs:comment>Strategy for allocating attention toward goal-relevant information.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Boundary-of">
    <rdfs:label>Boundary-of</rdfs:label>
    <rdfs:comment>(A, (Boundary-of, B)) means A is on or part of the edge or boundary of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#y">
    <rdfs:label>y</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-24.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-24</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sigh">
    <rdfs:label>Sigh</rdfs:label>
    <rdfs:comment>Emit a long, deep, audible breath expressing sadness, relief, tiredness, or a similar feeling.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Reach">
    <rdfs:label>Reach</rdfs:label>
    <rdfs:comment>Stretch out your arm in order to get or touch something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Statistical-recall-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Statistical-recall">
        <rdfs:label>Statistical-recall</rdfs:label>
        <rdfs:comment>Sensitivity is a measurement datum qualifying a binary classification test and is computed by substracting the false negative rate to the integral numeral 1.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bicycle">
    <rdfs:label>Bicycle</rdfs:label>
    <rdfs:comment>A human-powered, pedal-driven, single-track vehicle, having two wheels attached to a frame, one behind the other.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Vehicle">
        <rdfs:label>Vehicle</rdfs:label>
        <rdfs:comment>A mobile machine which transports people or cargo.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sloped-terrain">
    <rdfs:label>Sloped-terrain</rdfs:label>
    <rdfs:comment>Tracts of land arranged in a sloping  or inclined position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SlateBlue">
    <rdfs:label>SlateBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x6A5ACD.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Recall">
    <rdfs:label>Recall</rdfs:label>
    <rdfs:comment>Remember information by mental effort.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#T">
    <rdfs:label>T</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#magneticFieldUnits">
        <rdfs:label>magneticFieldUnits</rdfs:label>
        <rdfs:comment>Units used to magnetic field intensity.</rdfs:comment>
        <hed:defaultUnits>fT</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>10^-15</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Chew">
    <rdfs:label>Chew</rdfs:label>
    <rdfs:comment>Repeatedly grinding, tearing, and or crushing with teeth or jaws.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Plant">
    <rdfs:label>Plant</rdfs:label>
    <rdfs:comment>Any living organism that typically synthesizes its food from inorganic substances and possesses cellulose cell walls.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Organism">
        <rdfs:label>Organism</rdfs:label>
        <rdfs:comment>A living entity, more specifically a biological entity that consists of one or more cells and is capable of genomic replication (independently or not).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Biological-item"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Age-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Age">
        <rdfs:label>Age</rdfs:label>
        <rdfs:comment>Length of time elapsed time since birth of the agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <owl:ObjectProperty rdf:about="https://purl.org/hed#relatedTag">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:label>relatedTag</rdfs:label>
    <rdfs:comment>A schema attribute suggesting HED tags that are closely related to this tag. This attribute is used by tagging tools.</rdfs:comment>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
    <hed:isInheritedProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:isInheritedProperty>
  </owl:ObjectProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#OrangeRed">
    <rdfs:label>OrangeRed</rdfs:label>
    <rdfs:comment>CSS-color 0xFF4500.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Orange-color">
        <rdfs:label>Orange-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gurgle">
    <rdfs:label>Gurgle</rdfs:label>
    <rdfs:comment>Make a hollow bubbling sound like that made by water running out of a bottle.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#second">
    <rdfs:label>second</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#File-storage">
    <rdfs:label>File-storage</rdfs:label>
    <rdfs:comment>A device for recording digital information to a permanent media.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Recording-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Instep">
    <rdfs:label>Instep</rdfs:label>
    <rdfs:comment>The part of the foot between the ball and the heel on the inner side.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Foot"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Square">
    <rdfs:label>Square</rdfs:label>
    <rdfs:comment>A square is a special rectangle with four equal sides.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Rectangle">
        <rdfs:label>Rectangle</rdfs:label>
        <rdfs:comment>A parallelogram with four right angles.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Dash">
    <rdfs:label>Dash</rdfs:label>
    <rdfs:comment>A horizontal stroke in writing or printing to mark a pause or break in sense or to represent omitted letters or words.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#SIUnitSymbolModifier">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnitModifier"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>SIUnitSymbolModifier</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a unit symbol rather than a base symbol.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:unitModifierProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitModifierProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Paragraph">
    <rdfs:label>Paragraph</rdfs:label>
    <rdfs:comment>A distinct section of a piece of writing, usually dealing with a single theme.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Alert">
    <rdfs:label>Alert</rdfs:label>
    <rdfs:comment>Condition of heightened watchfulness or preparation for action.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightGray">
    <rdfs:label>LightGray</rdfs:label>
    <rdfs:comment>CSS-color 0xD3D3D3.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mishap">
    <rdfs:label>Mishap</rdfs:label>
    <rdfs:comment>Unplanned disruption such as an equipment or experiment control abnormality or experimenter error.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sense-by-touch">
    <rdfs:label>Sense-by-touch</rdfs:label>
    <rdfs:comment>Sense something through receptors in the skin.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perceive"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Parameter-label-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Parameter-label">
        <rdfs:label>Parameter-label</rdfs:label>
        <rdfs:comment>The name of the parameter.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Parameter"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Aerial-view">
    <rdfs:label>Aerial-view</rdfs:label>
    <rdfs:comment>Elevated view of an object from above, with a perspective as though the observer were a bird.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Map-view"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#micro">
    <rdfs:label>micro</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-6.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-6</hed:conversionFactor>
  </hed:HedUnitModifier>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#unique">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unique</rdfs:label>
    <rdfs:comment>A schema attribute indicating that only one of this tag or its descendants can be used  in the event-level HED string.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gold">
    <rdfs:label>Gold</rdfs:label>
    <rdfs:comment>CSS-color 0xFFD700.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Point-light-visualization">
    <rdfs:label>Point-light-visualization</rdfs:label>
    <rdfs:comment>A display in which action is depicted using a few points of light, often generated from discrete sensors in motion capture.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Video-clip">
    <rdfs:label>Video-clip</rdfs:label>
    <rdfs:comment>A short segment of video.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Media-clip">
        <rdfs:label>Media-clip</rdfs:label>
        <rdfs:comment>A short segment of media.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Media"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hold-breath">
    <rdfs:label>Hold-breath</rdfs:label>
    <rdfs:comment>Interrupt normal breathing by ceasing to inhale or exhale.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Length-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Length">
        <rdfs:label>Length</rdfs:label>
        <rdfs:comment>The linear extent in space from one end of something to the other end, or the extent of something from beginning to end.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Size"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Orange">
    <rdfs:label>Orange</rdfs:label>
    <rdfs:comment>CSS-color 0xFFA500.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Orange-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bend">
    <rdfs:label>Bend</rdfs:label>
    <rdfs:comment>Move body in a bowed or curved manner.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ka-ching">
    <rdfs:label>Ka-ching</rdfs:label>
    <rdfs:comment>The sound made by a mechanical cash register, often to designate a reward.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#X-position-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#X-position">
        <rdfs:label>X-position</rdfs:label>
        <rdfs:comment>The position along the x-axis of the frame of reference.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Position"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Background-view">
    <rdfs:label>Background-view</rdfs:label>
    <rdfs:comment>Parts of the view that are farthest from the viewer and usually the not part of the visual focus.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Visual-presentation">
        <rdfs:label>Visual-presentation</rdfs:label>
        <rdfs:comment>The sense of sight used in the presentation to the user.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#deca">
    <rdfs:label>deca</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^1.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10.0</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Torso-chest">
    <rdfs:label>Torso-chest</rdfs:label>
    <rdfs:comment>The anterior side of the thorax from the neck to the abdomen.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Torso"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#point">
    <rdfs:label>point</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#currencyUnits">
        <rdfs:label>currencyUnits</rdfs:label>
        <rdfs:comment>Units indicating the worth of something.</rdfs:comment>
        <hed:defaultUnits>$</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Middle-finger">
    <rdfs:label>Middle-finger</rdfs:label>
    <rdfs:comment>The middle or third finger from the radial side of the hand.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finger"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Between">
    <rdfs:label>Between</rdfs:label>
    <rdfs:comment>(A, (Between, (B, C))) means A is in the space or interval separating B and C.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Data-median-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-median">
        <rdfs:label>Data-median</rdfs:label>
        <rdfs:comment>The value which has an equal number of values greater and less than it.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mooing">
    <rdfs:label>Mooing</rdfs:label>
    <rdfs:comment>Deep vocal sounds like those made by a cow.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#$">
    <rdfs:label>$</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#currencyUnits"/>
    <hed:unitPrefix rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitPrefix>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Blink">
    <rdfs:label>Blink</rdfs:label>
    <rdfs:comment>Shut and open the eyes quickly.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Width-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Width">
        <rdfs:label>Width</rdfs:label>
        <rdfs:comment>The extent or measurement of something from side to side.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Size"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hair">
    <rdfs:label>Hair</rdfs:label>
    <rdfs:comment>The filamentous outgrowth of the epidermis.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Head">
        <rdfs:label>Head</rdfs:label>
        <rdfs:comment>The upper part of the human body, or the front or upper part of the body of an animal, typically separated from the rest of the body by a neck, and containing the brain, mouth, and sense organs.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Def-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the definition.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Def">
        <rdfs:label>Def</rdfs:label>
        <rdfs:comment>A HED-specific utility tag used with a defined name to represent the tags associated with that definition.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
        <hed:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:requireChild>
        <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#byte">
    <rdfs:label>byte</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#memorySizeUnits">
        <rdfs:label>memorySizeUnits</rdfs:label>
        <hed:defaultUnits>B</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Aircraft">
    <rdfs:label>Aircraft</rdfs:label>
    <rdfs:comment>A vehicle which is able to travel through air in an atmosphere.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Non-informative">
    <rdfs:label>Non-informative</rdfs:label>
    <rdfs:comment>Something that is not useful in forming an opinion or judging an outcome.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Walk">
    <rdfs:label>Walk</rdfs:label>
    <rdfs:comment>Move at a regular pace by lifting and setting down each foot in turn never having both feet off the ground at once.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkGoldenRod">
    <rdfs:label>DarkGoldenRod</rdfs:label>
    <rdfs:comment>CSS-color 0xB8860B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Depth-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Depth">
        <rdfs:label>Depth</rdfs:label>
        <rdfs:comment>The distance from the surface of something especially from the perspective of looking from the front.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Size"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Squint">
    <rdfs:label>Squint</rdfs:label>
    <rdfs:comment>Squeeze one or both eyes partly closed in an attempt to see more clearly or as a reaction to strong light.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Urban">
    <rdfs:label>Urban</rdfs:label>
    <rdfs:comment>Relating to, located in, or characteristic of a city or densely populated area.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkMagenta">
    <rdfs:label>DarkMagenta</rdfs:label>
    <rdfs:comment>CSS-color 0x8B008B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Jerk-rate-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Jerk-rate">
        <rdfs:label>Jerk-rate</rdfs:label>
        <rdfs:comment>Magnitude of the rate at which the acceleration of an object changes with respect to time. The direction of change should be given separately.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#jerkUnits">
        <rdfs:label>jerkUnits</rdfs:label>
        <hed:defaultUnits>m-per-s^3</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Toes">
    <rdfs:label>Toes</rdfs:label>
    <rdfs:comment>The terminal digits of the foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Foot"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Crimson">
    <rdfs:label>Crimson</rdfs:label>
    <rdfs:comment>CSS-color 0xDC143C.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Toe-off">
    <rdfs:label>Toe-off</rdfs:label>
    <rdfs:comment>Push with toe as part of a stride.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Step">
        <rdfs:label>Step</rdfs:label>
        <rdfs:comment>Put one leg in front of the other and shift weight onto it.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Y-position-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Y-position">
        <rdfs:label>Y-position</rdfs:label>
        <rdfs:comment>The position along the y-axis of the frame of reference.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Position"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cartoon">
    <rdfs:label>Cartoon</rdfs:label>
    <rdfs:comment>A type of illustration, sometimes animated, typically in a non-realistic or semi-realistic style. The specific meaning has evolved over time, but the modern usage usually refers to either an image or series of images intended for satire, caricature, or humor. A motion picture that relies on a sequence of illustrations for its animation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Image"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m-per-s">
    <rdfs:label>m-per-s</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#speedUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Peripheral-view">
    <rdfs:label>Peripheral-view</rdfs:label>
    <rdfs:comment>Indirect vision as it occurs outside the point of fixation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hill">
    <rdfs:label>Hill</rdfs:label>
    <rdfs:comment>A rounded elevation of limited extent rising above the surrounding land with local relief of less than 300m.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Natural-feature"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Touch">
    <rdfs:label>Touch</rdfs:label>
    <rdfs:comment>Come into or be in contact with.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m-per-s_3">
    <rdfs:label>m-per-s^3</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#jerkUnits"/>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Time-block-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Optional label for the task block.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Time-block">
        <rdfs:label>Time-block</rdfs:label>
        <rdfs:comment>A tag used to indicate a contiguous time block in the experiment during which something is fixed or noted.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mouth">
    <rdfs:label>Mouth</rdfs:label>
    <rdfs:comment>The proximal portion of the digestive tract, containing the oral cavity and bounded by the oral opening.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Savory">
    <rdfs:label>Savory</rdfs:label>
    <rdfs:comment>Belonging to a taste that is salty or spicy rather than sweet.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gustatory-attribute"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Standard-deviation-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Standard-deviation">
        <rdfs:label>Standard-deviation</rdfs:label>
        <rdfs:comment>A measure of the range of values in a set of numbers. Standard deviation is a statistic used as a measure of the dispersion or variation in a distribution, equal to the square root of the arithmetic mean of the squares of the deviations from the arithmetic mean.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Dark-shade">
    <rdfs:label>Dark-shade</rdfs:label>
    <rdfs:comment>A color tone not reflecting much light.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Color-shade">
        <rdfs:label>Color-shade</rdfs:label>
        <rdfs:comment>A slight degree of difference between colors, especially with regard to how light or dark it is or as distinguished from one nearly like it.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Robot">
    <rdfs:label>Robot</rdfs:label>
    <rdfs:comment>A mechanical device that sometimes resembles a living animal and is capable of performing a variety of often complex human tasks on command or by being programmed in advance.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Device">
        <rdfs:label>Device</rdfs:label>
        <rdfs:comment>An object contrived for a specific purpose.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#Hz">
    <rdfs:label>Hz</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#frequencyUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#BurlyWood">
    <rdfs:label>BurlyWood</rdfs:label>
    <rdfs:comment>CSS-color 0xDEB887.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#unitModifierProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unitModifierProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute is meant to be applied to unit modifier classes.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gray">
    <rdfs:label>Gray</rdfs:label>
    <rdfs:comment>CSS-color 0x808080.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Intersex">
    <rdfs:label>Intersex</rdfs:label>
    <rdfs:comment>Having genitalia and/or secondary sexual characteristics of indeterminate sex.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sex"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumPurple">
    <rdfs:label>MediumPurple</rdfs:label>
    <rdfs:comment>CSS-color 0x9370DB.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Scroll-wheel">
    <rdfs:label>Scroll-wheel</rdfs:label>
    <rdfs:comment>A scroll wheel or mouse wheel is a wheel used for scrolling made of hard plastic with a rubbery surface usually located between the left and right mouse buttons and is positioned perpendicular to the mouse surface.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Computer-mouse">
        <rdfs:label>Computer-mouse</rdfs:label>
        <rdfs:comment>A hand-held pointing device that detects two-dimensional motion relative to a surface.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Input-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Outside-of">
    <rdfs:label>Outside-of</rdfs:label>
    <rdfs:comment>(A, (Outside-of, B)) means A is located in the space around but not including B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Experimental-note-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Experimental-note">
        <rdfs:label>Experimental-note</rdfs:label>
        <rdfs:comment>A brief written record about the experiment.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clockface">
    <rdfs:label>Clockface</rdfs:label>
    <rdfs:comment>The dial face of a clock. A location identifier based on clockface numbering or anatomic subregion.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Motion-capture">
    <rdfs:label>Motion-capture</rdfs:label>
    <rdfs:comment>A device for recording the movement of objects or people.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Recording-device"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#CogAtlas-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#CogAtlas">
        <rdfs:label>CogAtlas</rdfs:label>
        <rdfs:comment>The Cognitive Atlas ID number of something.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Plum">
    <rdfs:label>Plum</rdfs:label>
    <rdfs:comment>CSS-color 0xDDA0DD.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Meaningful">
    <rdfs:label>Meaningful</rdfs:label>
    <rdfs:comment>Conveying significant or relevant information.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vestibular-attribute">
    <rdfs:label>Vestibular-attribute</rdfs:label>
    <rdfs:comment>Pertaining to the sense of balance or body position.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sensory-attribute">
        <rdfs:label>Sensory-attribute</rdfs:label>
        <rdfs:comment>A sensory characteristic associated with another entity.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ceramic">
    <rdfs:label>Ceramic</rdfs:label>
    <rdfs:comment>A hard, brittle, heat-resistant and corrosion-resistant material made by shaping and then firing a nonmetallic mineral, such as clay, at a high temperature.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Manufactured-material"/>
  </hed:HedTag>
  <owl:ObjectProperty rdf:about="https://purl.org/hed#unitClass">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedUnitClass"/>
    <rdfs:label>unitClass</rdfs:label>
    <rdfs:comment>A schema attribute specifying which unit class this value tag belongs to.</rdfs:comment>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:ObjectProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Empathetic">
    <rdfs:label>Empathetic</rdfs:label>
    <rdfs:comment>Understanding and sharing the feelings of another. Being aware of, being sensitive to, and vicariously experiencing the feelings, thoughts, and experience of another.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shake-head">
    <rdfs:label>Shake-head</rdfs:label>
    <rdfs:comment>Turn head from side to side as a way of showing disagreement or refusal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ingestible-object">
    <rdfs:label>Ingestible-object</rdfs:label>
    <rdfs:comment>Something that can be taken into the body by the mouth for digestion or absorption.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Object">
        <rdfs:label>Object</rdfs:label>
        <rdfs:comment>Something perceptible by one or more of the senses, especially by vision or touch. A material thing.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Item"/>
        <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pump-fist">
    <rdfs:label>Pump-fist</rdfs:label>
    <rdfs:comment>Raise with fist clenched in triumph or affirmation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Book">
    <rdfs:label>Book</rdfs:label>
    <rdfs:comment>A volume made up of pages fastened along one edge and enclosed between protective covers.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Document">
        <rdfs:label>Document</rdfs:label>
        <rdfs:comment>A physical object, or electronic counterpart, that is characterized by containing writing which is meant to be human-readable.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Buzz">
    <rdfs:label>Buzz</rdfs:label>
    <rdfs:comment>A persistent vibratory sound often made by a buzzer device and used to indicate something incorrect.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Saturation-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>B value of RGB between 0 and 1.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Saturation">
        <rdfs:label>Saturation</rdfs:label>
        <rdfs:comment>Colorfulness of a stimulus relative to its own brightness.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#HSV-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grab">
    <rdfs:label>Grab</rdfs:label>
    <rdfs:comment>Seize suddenly or quickly. Snatch or clutch.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#euro">
    <rdfs:label>euro</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#currencyUnits"/>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Part-of">
    <rdfs:label>Part-of</rdfs:label>
    <rdfs:comment>(A, (Part-of, B)) indicates A is a part of the whole B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-controller">
    <rdfs:label>Experiment-controller</rdfs:label>
    <rdfs:comment>An agent exerting control over some aspect of the experiment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-task-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cart">
    <rdfs:label>Cart</rdfs:label>
    <rdfs:comment>A cart is a vehicle which has two wheels and is designed to transport human passengers or cargo.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Ratio-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Ratio">
        <rdfs:label>Ratio</rdfs:label>
        <rdfs:comment>A quotient of quantities of the same kind for different components within the same system.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Quantitative-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Right-handed">
    <rdfs:label>Right-handed</rdfs:label>
    <rdfs:comment>Preference for using the right hand or foot for tasks requiring the use of a single hand or foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Handedness"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rural">
    <rdfs:label>Rural</rdfs:label>
    <rdfs:comment>Of or pertaining to the country as opposed to the city.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Press-foot">
    <rdfs:label>Press-foot</rdfs:label>
    <rdfs:comment>Move by pressing foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Respond">
    <rdfs:label>Respond</rdfs:label>
    <rdfs:comment>React to something such as a treatment or a stimulus.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#nano">
    <rdfs:label>nano</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-9.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-9</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shudder">
    <rdfs:label>Shudder</rdfs:label>
    <rdfs:comment>Tremble convulsively, sometimes as a result of fear or revulsion.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Foveal-view">
    <rdfs:label>Foveal-view</rdfs:label>
    <rdfs:comment>Visual presentation directly on the fovea. A view projected on the small depression in the retina containing only cones and where vision is most acute.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Event-stream-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the event stream.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Event-stream">
        <rdfs:label>Event-stream</rdfs:label>
        <rdfs:comment>A special HED tag indicating that this event is a member of an ordered succession of events.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Towards">
    <rdfs:label>Towards</rdfs:label>
    <rdfs:comment>(A, (Towards, B)) indicates that A is going to or has moved to B. The meaning depends on A and B.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Directional-relation">
        <rdfs:label>Directional-relation</rdfs:label>
        <rdfs:comment>A relationship indicating direction of change of one entity relative to another. The first entity is the focus.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Linen">
    <rdfs:label>Linen</rdfs:label>
    <rdfs:comment>CSS-color 0xFAF0E6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Snap-fingers">
    <rdfs:label>Snap-fingers</rdfs:label>
    <rdfs:comment>Make a noise by pushing second finger hard against thumb and then releasing it suddenly so that it hits the base of the thumb.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#atto">
    <rdfs:label>atto</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-18.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-18</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Silent">
    <rdfs:label>Silent</rdfs:label>
    <rdfs:comment>The absence of ambient audible sound or the state of having ceased to produce sounds.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Auditory-presentation">
        <rdfs:label>Auditory-presentation</rdfs:label>
        <rdfs:comment>The sense of hearing is used in the presentation to the user.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#yocto">
    <rdfs:label>yocto</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-24.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-24</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Raise-eyebrows">
    <rdfs:label>Raise-eyebrows</rdfs:label>
    <rdfs:comment>Move eyebrows upward.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Acceleration-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Acceleration">
        <rdfs:label>Acceleration</rdfs:label>
        <rdfs:comment>Magnitude of the rate of change in either speed or direction. The direction of change should be given separately.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#accelerationUnits">
        <rdfs:label>accelerationUnits</rdfs:label>
        <hed:defaultUnits>m-per-s^2</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
  </hed:HedPlaceholder>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#isInheritedProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>isInheritedProperty</rdfs:label>
    <rdfs:comment>Indicates that this attribute is inherited by child nodes. This property only applies to schema attributes for nodes.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Human">
    <rdfs:label>Human</rdfs:label>
    <rdfs:comment>The bipedal primate mammal Homo sapiens.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organism"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cheek">
    <rdfs:label>Cheek</rdfs:label>
    <rdfs:comment>The fleshy part of the face bounded by the eyes, nose, ear, and jaw line.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Task-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Optional label for the task block.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task">
        <rdfs:label>Task</rdfs:label>
        <rdfs:comment>An assigned piece of work, usually with a time allotment. A tag used to indicate a linkage the structured activities performed as part of the experiment.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tomato">
    <rdfs:label>Tomato</rdfs:label>
    <rdfs:comment>CSS-color 0xFF6347.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Orange-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Fractal">
    <rdfs:label>Fractal</rdfs:label>
    <rdfs:comment>Having extremely irregular curves or shapes for which any suitably chosen part is similar in shape to a given larger or smaller part when magnified or reduced to the same size.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightPink">
    <rdfs:label>LightPink</rdfs:label>
    <rdfs:comment>CSS-color 0xFFB6C1.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Pink-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Violet">
    <rdfs:label>Violet</rdfs:label>
    <rdfs:comment>CSS-color 0xEE82EE.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#AntiqueWhite">
    <rdfs:label>AntiqueWhite</rdfs:label>
    <rdfs:comment>CSS-color 0xFAEBD7.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Uneven-terrain">
    <rdfs:label>Uneven-terrain</rdfs:label>
    <rdfs:comment>Tracts of land that are not level, smooth, or regular.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#degree_Celsius">
    <rdfs:label>degree Celsius</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#temperatureUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bilateral-to">
    <rdfs:label>Bilateral-to</rdfs:label>
    <rdfs:comment>(A, (Bilateral, B)) means A is on both sides of B or affects both sides of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Compassionate">
    <rdfs:label>Compassionate</rdfs:label>
    <rdfs:comment>Feeling or showing sympathy and concern for others often evoked for a person who is in distress and associated with altruistic motivation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#2D-view">
    <rdfs:label>2D-view</rdfs:label>
    <rdfs:comment>A view showing only two dimensions.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cue">
    <rdfs:label>Cue</rdfs:label>
    <rdfs:comment>A signal for an action, a pattern of stimuli indicating a particular response.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#meter">
    <rdfs:label>meter</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Beige">
    <rdfs:label>Beige</rdfs:label>
    <rdfs:comment>CSS-color 0xF5F5DC.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#And">
    <rdfs:label>And</rdfs:label>
    <rdfs:comment>(A, (And, B)) means A and B are both in effect.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Logical-relation">
        <rdfs:label>Logical-relation</rdfs:label>
        <rdfs:comment>Indicating a logical relationship between entities. The first entity is usually the focus.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Duration-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Duration">
        <rdfs:label>Duration</rdfs:label>
        <rdfs:comment>The period of time during which an event occurs. This tag defines the end time of an event of temporal extent and may be used with the Delay tag.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-value"/>
        <hed:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:topLevelTagGroup>
        <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Delay"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Generate">
    <rdfs:label>Generate</rdfs:label>
    <rdfs:comment>Cause something, especially an emotion or situation to arise or come about.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#inch">
    <rdfs:label>inch</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
    <hed:conversionFactor>0.0254</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Fixate">
    <rdfs:label>Fixate</rdfs:label>
    <rdfs:comment>Direct eyes to a specific point or target.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-feature">
    <rdfs:label>Data-feature</rdfs:label>
    <rdfs:comment>An event marking the occurrence of a data feature such as an interictal spike or alpha burst that is often added post hoc to the data record.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
    <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Data-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Light-shade">
    <rdfs:label>Light-shade</rdfs:label>
    <rdfs:comment>A color tone reflecting more light.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Color-shade"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Intended-effect">
    <rdfs:label>Intended-effect</rdfs:label>
    <rdfs:comment>A phenomenon that is intended to follow and be caused by some previous phenomenon.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-effect-evidence">
        <rdfs:label>Task-effect-evidence</rdfs:label>
        <rdfs:comment>The evidence supporting the conclusion that the event had the specified effect.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Screen-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Screen-resolution">
        <rdfs:label>Screen-resolution</rdfs:label>
        <rdfs:comment>Resolution of a screen, usually expressed as the of pixels in a dimension for a digital display device.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Controller-agent">
    <rdfs:label>Controller-agent</rdfs:label>
    <rdfs:comment>An agent experiment control software or hardware.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shhh">
    <rdfs:label>Shhh</rdfs:label>
    <rdfs:comment>Place finger over lips and possibly uttering the syllable shhh to indicate the need to be quiet.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Dirt-terrain">
    <rdfs:label>Dirt-terrain</rdfs:label>
    <rdfs:comment>Tracts of land characterized by a soil surface and lack of vegetation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Non-target">
    <rdfs:label>Non-target</rdfs:label>
    <rdfs:comment>Something other than that done or looked for. Also tag Expected if the Non-target is frequent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Target">
        <rdfs:label>Target</rdfs:label>
        <rdfs:comment>Something fixed as a goal, destination, or point of examination.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Timbre-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Timbre">
        <rdfs:label>Timbre</rdfs:label>
        <rdfs:comment>The perceived sound quality of a singing voice or musical instrument.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pause">
    <rdfs:label>Pause</rdfs:label>
    <rdfs:comment>Indicates the temporary interruption of  the operation a process and subsequently wait for a signal to continue.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-marker">
        <rdfs:label>Temporal-marker</rdfs:label>
        <rdfs:comment>An indicator placed at a particular time in the data.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-marker"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Elbow">
    <rdfs:label>Elbow</rdfs:label>
    <rdfs:comment>A type of hinge joint located between the forearm and upper arm.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Upper-extremity"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#B">
    <rdfs:label>B</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#memorySizeUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Calf">
    <rdfs:label>Calf</rdfs:label>
    <rdfs:comment>The fleshy part at the back of the leg below the knee.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Attic">
    <rdfs:label>Attic</rdfs:label>
    <rdfs:comment>A room or a space immediately below the roof of a building.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Building"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Statistical-uncertainty-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Statistical-uncertainty">
        <rdfs:label>Statistical-uncertainty</rdfs:label>
        <rdfs:comment>A measure of the inherent variability of repeated observation measurements of a quantity including quantities evaluated by statistical methods and by other means.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cellphone">
    <rdfs:label>Cellphone</rdfs:label>
    <rdfs:comment>A telephone with access to a cellular radio system so it can be used over a wide area, without a physical connection to a network.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Computing-device"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sampling-rate-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sampling-rate">
        <rdfs:label>Sampling-rate</rdfs:label>
        <rdfs:comment>The number of digital samples taken or recorded per unit of time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#frequencyUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Behind">
    <rdfs:label>Behind</rdfs:label>
    <rdfs:comment>(A, (Behind, B)) means A is at or to the far side of B, typically so as to be hidden by it.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Deny">
    <rdfs:label>Deny</rdfs:label>
    <rdfs:comment>Refuse to give or grant something requested or desired by someone.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Drowsy">
    <rdfs:label>Drowsy</rdfs:label>
    <rdfs:comment>In a state of near-sleep, a strong desire for sleep, or sleeping for unusually long periods.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pain">
    <rdfs:label>Pain</rdfs:label>
    <rdfs:comment>The sensation of discomfort, distress, or agony, resulting from the stimulation of specialized nerve endings.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Somatic-attribute"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m-per-s_2">
    <rdfs:label>m-per-s^2</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#accelerationUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Standing">
    <rdfs:label>Standing</rdfs:label>
    <rdfs:comment>Assuming or maintaining an erect upright position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Syllable">
    <rdfs:label>Syllable</rdfs:label>
    <rdfs:comment>A unit of spoken language larger than a phoneme.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Percentage-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Percentage">
        <rdfs:label>Percentage</rdfs:label>
        <rdfs:comment>A fraction or ratio with 100 understood as the denominator.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Quantitative-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#pound">
    <rdfs:label>pound</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#weightUnits"/>
    <hed:conversionFactor>453.592</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Plastic">
    <rdfs:label>Plastic</rdfs:label>
    <rdfs:comment>Various high-molecular-weight thermoplastic or thermosetting polymers that are capable of being molded, extruded, drawn, or otherwise shaped and then hardened into a form.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Manufactured-material"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#inLibrary">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedElement"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>inLibrary</rdfs:label>
    <rdfs:comment>Indicates this schema element came from the named library schema, not the standard schema. This attribute is added by tools when a library schema is merged into its partnered standard schema.</rdfs:comment>
    <hed:elementProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:elementProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#HotPink">
    <rdfs:label>HotPink</rdfs:label>
    <rdfs:comment>CSS-color 0xFF69B4.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Pink-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Or">
    <rdfs:label>Or</rdfs:label>
    <rdfs:comment>(A, (Or, B)) means at least one of A and B are in effect.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Logical-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Time-sync">
    <rdfs:label>Time-sync</rdfs:label>
    <rdfs:comment>A synchronization signal whose purpose to help synchronize different signals or processes. Often used to indicate a marker inserted into the recorded data to allow post hoc synchronization of concurrently recorded data streams.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-marker"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Loving">
    <rdfs:label>Loving</rdfs:label>
    <rdfs:comment>Feeling a strong positive emotion of affection and attraction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#recommended">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>recommended</rdfs:label>
    <rdfs:comment>A schema attribute indicating that the event-level HED string should include this tag.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Threat">
    <rdfs:label>Threat</rdfs:label>
    <rdfs:comment>An indicator that signifies hostility and predicts an increased probability of attack.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PaleGreen">
    <rdfs:label>PaleGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x98FB98.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Content">
    <rdfs:label>Content</rdfs:label>
    <rdfs:comment>Feeling  satisfaction with things as they are.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-structure">
    <rdfs:label>Experiment-structure</rdfs:label>
    <rdfs:comment>An event specifying a change-point of the structure of experiment. This event is typically used to indicate a change in experimental conditions or tasks.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sound-envelope-release-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-envelope-release">
        <rdfs:label>Sound-envelope-release</rdfs:label>
        <rdfs:comment>The time taken for the level to decay from the sustain level to zero after the key is released.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound-envelope"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#yotta">
    <rdfs:label>yotta</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^24.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^24</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Encode">
    <rdfs:label>Encode</rdfs:label>
    <rdfs:comment>Convert information or an instruction into a particular form.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Thumb">
    <rdfs:label>Thumb</rdfs:label>
    <rdfs:comment>The thick and short hand digit which is next to the index finger in humans.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finger"/>
  </hed:HedTag>
  <owl:ObjectProperty rdf:about="https://purl.org/hed#rooted">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:label>rooted</rdfs:label>
    <rdfs:comment>Indicates a top-level library schema node is identical to a node of the same name in the partnered standard schema. This attribute can only appear in nodes that have the inLibrary schema attribute.</rdfs:comment>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:ObjectProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Thigh">
    <rdfs:label>Thigh</rdfs:label>
    <rdfs:comment>Upper part of the leg between hip and knee.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Lower-extremity"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#mph">
    <rdfs:label>mph</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#speedUnits"/>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>0.44704</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#3D-view">
    <rdfs:label>3D-view</rdfs:label>
    <rdfs:comment>A view showing three dimensions.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Temporal-rate-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-rate">
        <rdfs:label>Temporal-rate</rdfs:label>
        <rdfs:comment>The number of items per unit of time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#frequencyUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Extraneous">
    <rdfs:label>Extraneous</rdfs:label>
    <rdfs:comment>Irrelevant or unrelated to the subject being dealt with.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Away-from">
    <rdfs:label>Away-from</rdfs:label>
    <rdfs:comment>(A, (Away-from, B)) indicates that A is going or has moved away from B. The meaning depends on A and B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Directional-relation"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#elementProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>elementProperty</rdfs:label>
    <rdfs:comment>Indicates this schema attribute can apply to any type of element(tag term, unit class, etc).</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Little-toe">
    <rdfs:label>Little-toe</rdfs:label>
    <rdfs:comment>The smallest toe located on the outer side of the foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Foot"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#femto">
    <rdfs:label>femto</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-15.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-15</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Squawking">
    <rdfs:label>Squawking</rdfs:label>
    <rdfs:comment>Loud, harsh noises such as those made by geese.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-control">
    <rdfs:label>Experiment-control</rdfs:label>
    <rdfs:comment>An event pertaining to the physical control of the experiment during its operation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tan">
    <rdfs:label>Tan</rdfs:label>
    <rdfs:comment>CSS-color 0xD2B48C.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Described-by">
    <rdfs:label>Described-by</rdfs:label>
    <rdfs:comment>(A, (Described-by, B)) indicates that B provides information about A.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tractor">
    <rdfs:label>Tractor</rdfs:label>
    <rdfs:comment>A mobile machine specifically designed to deliver a high tractive effort at slow speeds, and mainly used for the purposes of hauling a trailer or machinery used in agriculture or construction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#minute">
    <rdfs:label>minute</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <hed:conversionFactor>60</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Seated-with-chin-rest">
    <rdfs:label>Seated-with-chin-rest</rdfs:label>
    <rdfs:comment>Using a device that supports the chin and head.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Top-of">
    <rdfs:label>Top-of</rdfs:label>
    <rdfs:comment>(A, (Top-of, B)) means A is on the uppermost part, side, or surface of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Statistical-accuracy-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Statistical-accuracy">
        <rdfs:label>Statistical-accuracy</rdfs:label>
        <rdfs:comment>A measure of closeness to true value expressed as a number between 0 and 1.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Contained-in">
    <rdfs:label>Contained-in</rdfs:label>
    <rdfs:comment>(A, (Contained-in, B)) indicates that A is completely inside of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vocalized-sound">
    <rdfs:label>Vocalized-sound</rdfs:label>
    <rdfs:comment>Musical sound produced by vocal cords in a biological agent.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Musical-sound">
        <rdfs:label>Musical-sound</rdfs:label>
        <rdfs:comment>Sound produced by continuous and regular vibrations, as opposed to noise.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Paved-terrain">
    <rdfs:label>Paved-terrain</rdfs:label>
    <rdfs:comment>Tracts of land covered  with concrete, asphalt, stones, or bricks.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <owl:ObjectProperty rdf:about="https://purl.org/hed#valueClass">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedValueClass"/>
    <rdfs:label>valueClass</rdfs:label>
    <rdfs:comment>A schema attribute specifying which value class this value tag belongs to.</rdfs:comment>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:ObjectProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Run">
    <rdfs:label>Run</rdfs:label>
    <rdfs:comment>Travel on foot at a fast pace.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Open">
    <rdfs:label>Open</rdfs:label>
    <rdfs:comment>Widen an aperture, door, or gap, especially one allowing access to something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DimGray">
    <rdfs:label>DimGray</rdfs:label>
    <rdfs:comment>CSS-color 0x696969.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Eyebrow">
    <rdfs:label>Eyebrow</rdfs:label>
    <rdfs:comment>The arched strip of hair on the bony ridge above each eye socket.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LED-pattern">
    <rdfs:label>LED-pattern</rdfs:label>
    <rdfs:comment>A pattern created by lighting selected members of a fixed light emitting diode array.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Pattern">
        <rdfs:label>Pattern</rdfs:label>
        <rdfs:comment>An arrangement of objects, facts, behaviors, or other things which have scientific, mathematical, geometric, statistical, or other meaning.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Geometric-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Eyes-closed">
    <rdfs:label>Eyes-closed</rdfs:label>
    <rdfs:comment>Keeping eyes closed with no blinking.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Asynchronous-with">
    <rdfs:label>Asynchronous-with</rdfs:label>
    <rdfs:comment>(A, (Asynchronous-with, B)) means A happens at times not occurring at the same time or having the same period or phase as B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Intoxicated">
    <rdfs:label>Intoxicated</rdfs:label>
    <rdfs:comment>In a state with disturbed psychophysiological functions and responses as a result of administration or ingestion of a psychoactive substance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#deprecatedFrom">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedElement"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>deprecatedFrom</rdfs:label>
    <rdfs:comment>Indicates that this element is deprecated. The value of the attribute is the latest schema version in which the element appeared in undeprecated form.</rdfs:comment>
    <hed:elementProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:elementProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Monophonic">
    <rdfs:label>Monophonic</rdfs:label>
    <rdfs:comment>Relating to sound transmission, recording, or reproduction involving a single transmission path.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Chirping">
    <rdfs:label>Chirping</rdfs:label>
    <rdfs:comment>Short, sharp, high-pitched noises like sounds made by small birds or an insects.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Discriminate">
    <rdfs:label>Discriminate</rdfs:label>
    <rdfs:comment>Recognize a distinction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Switch-attention">
    <rdfs:label>Switch-attention</rdfs:label>
    <rdfs:comment>Transfer attention from one focus to another.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Item-interval-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Item-interval">
        <rdfs:label>Item-interval</rdfs:label>
        <rdfs:comment>An integer indicating how many items or entities have passed since the last one of these. An item interval of 0 indicates the current item.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Quantitative-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#required">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>required</rdfs:label>
    <rdfs:comment>A schema attribute indicating that every event-level HED string should include this tag.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lie-down">
    <rdfs:label>Lie-down</rdfs:label>
    <rdfs:comment>Move to a horizontal or resting position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#s">
    <rdfs:label>s</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Burp">
    <rdfs:label>Burp</rdfs:label>
    <rdfs:comment>Noisily release air from the stomach through the mouth. Belch.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m_2">
    <rdfs:label>m^2</rdfs:label>
    <hed:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#areaUnits">
        <rdfs:label>areaUnits</rdfs:label>
        <hed:defaultUnits>m^2</hed:defaultUnits>
      </hed:HedUnitClass>
    </hed:unitClass>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Label-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Label">
        <rdfs:label>Label</rdfs:label>
        <rdfs:comment>A string of 20 or fewer characters identifying something. Labels usually refer to general classes of things while IDs refer to specific instances. A term that is associated with some entity. A brief description given for purposes of identification. An identifying or descriptive marker that is attached to an object.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Informational-property"/>
        <hed:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:requireChild>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Computed-feature">
    <rdfs:label>Computed-feature</rdfs:label>
    <rdfs:comment>A feature computed from the data by a tool. This tag should be grouped with a label of the form Toolname_propertyName.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-source-type"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Delay-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Delay">
        <rdfs:label>Delay</rdfs:label>
        <rdfs:comment>The time at which an event start time is delayed from the current onset time. This tag defines the start time of an event of temporal extent and may be used with the Duration tag.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-value"/>
        <hed:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:topLevelTagGroup>
        <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Duration"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Expert-annotation">
    <rdfs:label>Expert-annotation</rdfs:label>
    <rdfs:comment>An explanatory or critical comment or other in-context information provided by an authority.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-source-type"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Teeth">
    <rdfs:label>Teeth</rdfs:label>
    <rdfs:comment>The hard bonelike structures in the jaws. A collection of teeth arranged in some pattern in the mouth or other part of the body.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Waterfall">
    <rdfs:label>Waterfall</rdfs:label>
    <rdfs:comment>A sudden descent of water over a step or ledge in the bed of a river.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Natural-feature"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Animal-agent">
    <rdfs:label>Animal-agent</rdfs:label>
    <rdfs:comment>An agent that is an animal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Experimental-trial-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Optional label for the trial (often a numerical string).</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Experimental-trial">
        <rdfs:label>Experimental-trial</rdfs:label>
        <rdfs:comment>Designates a run or execution of an activity, for example, one execution of a script. A tag used to indicate a particular organizational part in the experimental design often containing a stimulus-response pair or stimulus-response-feedback triad.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Laugh">
    <rdfs:label>Laugh</rdfs:label>
    <rdfs:comment>Make the spontaneous sounds and movements of the face and body that are the instinctive expressions of lively amusement and sometimes also of contempt or derision.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#v">
    <rdfs:label>v</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#electricPotentialUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>0.000001</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Implied-by">
    <rdfs:label>Implied-by</rdfs:label>
    <rdfs:comment>(A, (Implied-by, B)) indicates B is suggested by A.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tone">
    <rdfs:label>Tone</rdfs:label>
    <rdfs:comment>A musical note, warble, or other sound used as a particular signal on a telephone or answering machine.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Musical-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Star">
    <rdfs:label>Star</rdfs:label>
    <rdfs:comment>A conventional or stylized representation of a star, typically one having five or more points.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tactile-vibration">
    <rdfs:label>Tactile-vibration</rdfs:label>
    <rdfs:comment>Having a feeling of mechanical oscillation.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Tactile-attribute">
        <rdfs:label>Tactile-attribute</rdfs:label>
        <rdfs:comment>Pertaining to the sense of touch.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#FireBrick">
    <rdfs:label>FireBrick</rdfs:label>
    <rdfs:comment>CSS-color 0xB22222.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Crowing">
    <rdfs:label>Crowing</rdfs:label>
    <rdfs:comment>Loud shrill sounds characteristic of roosters.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#Z">
    <rdfs:label>Z</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^21.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^21</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Predict">
    <rdfs:label>Predict</rdfs:label>
    <rdfs:comment>Say or estimate that something will happen or will be a consequence of something without having exact informaton.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#See">
    <rdfs:label>See</rdfs:label>
    <rdfs:comment>Direct gaze toward someone or something or in a specified direction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perceive"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Roof">
    <rdfs:label>Roof</rdfs:label>
    <rdfs:comment>A roof is the covering on the uppermost part of a building which provides protection from animals and weather, notably rain, but also heat, wind and sunlight.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Building"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#hecto">
    <rdfs:label>hecto</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^2.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>100.0</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Foreground-view">
    <rdfs:label>Foreground-view</rdfs:label>
    <rdfs:comment>Parts of the view that are closest to the viewer and usually the most important part of the visual focus.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#RGB-green-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>G value of RGB between 0 and 1.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#RGB-green">
        <rdfs:label>RGB-green</rdfs:label>
        <rdfs:comment>The green component.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#RGB-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#topLevelTagGroup">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>topLevelTagGroup</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this tag (or its descendants) can only appear in a top-level tag group. A tag group can have at most one tag with this attribute.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Far-from">
    <rdfs:label>Far-from</rdfs:label>
    <rdfs:comment>(A, (Far-from, B)) means A is at a large distance from or is not located near in space to B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightBlue">
    <rdfs:label>LightBlue</rdfs:label>
    <rdfs:comment>CSS-color 0xADD8E6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#River">
    <rdfs:label>River</rdfs:label>
    <rdfs:comment>A natural freshwater surface stream of considerable volume and a permanent or seasonal flow, moving in a definite channel toward a sea, lake, or another river.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Natural-feature"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#metre">
    <rdfs:label>metre</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Fuchsia">
    <rdfs:label>Fuchsia</rdfs:label>
    <rdfs:comment>CSS-color 0xFF00FF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Olive">
    <rdfs:label>Olive</rdfs:label>
    <rdfs:comment>CSS-color 0x808000.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#milli">
    <rdfs:label>milli</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-3.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>0.001</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Desktop-computer">
    <rdfs:label>Desktop-computer</rdfs:label>
    <rdfs:comment>A computer suitable for use at an ordinary desk.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Computing-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Frown">
    <rdfs:label>Frown</rdfs:label>
    <rdfs:comment>Express disapproval, displeasure, or concentration, typically by turning down the corners of the mouth.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SandyBrown">
    <rdfs:label>SandyBrown</rdfs:label>
    <rdfs:comment>CSS-color 0xF4A460.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Paper">
    <rdfs:label>Paper</rdfs:label>
    <rdfs:comment>A thin sheet material produced by mechanically or chemically processing cellulose fibres derived from wood, rags, grasses or other vegetable sources in water.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Manufactured-material"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#unitSymbol">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnit"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unitSymbol</rdfs:label>
    <rdfs:comment>A schema attribute indicating this tag is an abbreviation or symbol representing a type of unit. Unit symbols represent both the singular and the plural and thus cannot be pluralized.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:unitProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitProperty>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#SIUnitModifier">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnitModifier"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>SIUnitModifier</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a base unit rather than a unit symbol.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:unitModifierProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitModifierProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Signal-noise">
    <rdfs:label>Signal-noise</rdfs:label>
    <rdfs:comment>Any part of a signal that is not the true or original signal but is introduced by the communication mechanism.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Environmental-sound">
        <rdfs:label>Environmental-sound</rdfs:label>
        <rdfs:comment>Sounds occuring in the environment. An accumulation of noise pollution that occurs outside. This noise can be caused by transport, industrial, and recreational activities.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#lb">
    <rdfs:label>lb</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#weightUnits"/>
    <hed:conversionFactor>453.592</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#cd">
    <rdfs:label>cd</rdfs:label>
    <rdfs:comment>Units used to express light intensity.</rdfs:comment>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#intensityUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
  </hed:HedUnit>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#rad">
    <rdfs:label>rad</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#angleUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gentalia">
