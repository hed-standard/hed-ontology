    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Area">
        <rdfs:label>Area</rdfs:label>
        <rdfs:comment>The extent of a 2-dimensional surface enclosed within a boundary.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Size"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#areaUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Indoors">
    <rdfs:label>Indoors</rdfs:label>
    <rdfs:comment>Located inside a building or enclosure.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkOrange">
    <rdfs:label>DarkOrange</rdfs:label>
    <rdfs:comment>CSS-color 0xFF8C00.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Orange-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Temporal-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-resolution">
        <rdfs:label>Temporal-resolution</rdfs:label>
        <rdfs:comment>Measures the ability of a sensor to  resolve features in time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Audio-clip">
    <rdfs:label>Audio-clip</rdfs:label>
    <rdfs:comment>A short segment of audio.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Media-clip"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightSeaGreen">
    <rdfs:label>LightSeaGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x20B2AA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Retract">
    <rdfs:label>Retract</rdfs:label>
    <rdfs:comment>Draw or pull back.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#requireChild">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>requireChild</rdfs:label>
    <rdfs:comment>A schema attribute indicating that one of the node elements descendants must be included when using this tag.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bitter">
    <rdfs:label>Bitter</rdfs:label>
    <rdfs:comment>Having a sharp, pungent taste.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gustatory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightGoldenRodYellow">
    <rdfs:label>LightGoldenRodYellow</rdfs:label>
    <rdfs:comment>CSS-color 0xFAFAD2.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Read">
    <rdfs:label>Read</rdfs:label>
    <rdfs:comment>Interpret something that is written or printed.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Photograph">
    <rdfs:label>Photograph</rdfs:label>
    <rdfs:comment>An image recorded by a camera.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Image"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Animation">
    <rdfs:label>Animation</rdfs:label>
    <rdfs:comment>A form of graphical illustration that changes with time to give a sense of motion or represent dynamic changes in the portrayal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Luminance">
    <rdfs:label>Luminance</rdfs:label>
    <rdfs:comment>A quality that exists by virtue of the luminous intensity per unit area projected in a given direction.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Visual-attribute">
        <rdfs:label>Visual-attribute</rdfs:label>
        <rdfs:comment>Pertaining to the sense of sight.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#allowedCharacter">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedValueClass"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>allowedCharacter</rdfs:label>
    <rdfs:comment>A schema attribute of value classes specifying a special character that is allowed in expressing the value of a placeholder. Normally the allowed characters are listed individually. However, the word letters designates the upper and lower case alphabetic characters and the word digits designates the digits 0-9. The word blank designates the blank character.</rdfs:comment>
    <hed:valueClassProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:valueClassProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Leaf-covered-terrain">
    <rdfs:label>Leaf-covered-terrain</rdfs:label>
    <rdfs:comment>Tracts of land covered by leaves and composited organic material.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Kick">
    <rdfs:label>Kick</rdfs:label>
    <rdfs:comment>Strike out or flail with the foot or feet.  Strike using the leg, in unison usually with an area of the knee or lower using the foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Keyboard-key-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Value of a keyboard key.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Keyboard-key">
        <rdfs:label>Keyboard-key</rdfs:label>
        <rdfs:comment>A button on a keyboard usually representing letters, numbers, functions, or symbols.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Keyboard"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Field">
    <rdfs:label>Field</rdfs:label>
    <rdfs:comment>An unbroken expanse as of ice or grassland.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Natural-feature"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#AliceBlue">
    <rdfs:label>AliceBlue</rdfs:label>
    <rdfs:comment>CSS-color 0xF0F8FF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Thumb-up">
    <rdfs:label>Thumb-up</rdfs:label>
    <rdfs:comment>Extend the thumb upward to indicate approval.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Awed">
    <rdfs:label>Awed</rdfs:label>
    <rdfs:comment>Filled with wonder. Feeling grand, sublime or powerful emotions characterized by a combination of joy, fear, admiration, reverence, and/or respect.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Jerk">
    <rdfs:label>Jerk</rdfs:label>
    <rdfs:comment>Make a quick, sharp, sudden movement.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Female">
    <rdfs:label>Female</rdfs:label>
    <rdfs:comment>Biological sex of an individual with female sexual organs such ova.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sex"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Basement">
    <rdfs:label>Basement</rdfs:label>
    <rdfs:comment>The part of a building that is wholly or partly below ground level.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Building"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Khaki">
    <rdfs:label>Khaki</rdfs:label>
    <rdfs:comment>CSS-color 0xF0E68C.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Textblock">
    <rdfs:label>Textblock</rdfs:label>
    <rdfs:comment>A block of text.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Opacity">
    <rdfs:label>Opacity</rdfs:label>
    <rdfs:comment>A measure of impenetrability to light.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Behavioral-evidence">
    <rdfs:label>Behavioral-evidence</rdfs:label>
    <rdfs:comment>An indication or conclusion based on the behavior of an agent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-effect-evidence"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Wink">
    <rdfs:label>Wink</rdfs:label>
    <rdfs:comment>Close and open one eye quickly, typically to indicate that something is a joke or a secret or as a signal of affection or greeting.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Furnishing">
    <rdfs:label>Furnishing</rdfs:label>
    <rdfs:comment>Furniture, fittings, and other decorative accessories, such as curtains and carpets, for a house or room.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Experimental-intertrial-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Optional label for the intertrial block.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Experimental-intertrial">
        <rdfs:label>Experimental-intertrial</rdfs:label>
        <rdfs:comment>A tag used to indicate a part of the experiment between trials usually where nothing is happening.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Pathname-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Pathname">
        <rdfs:label>Pathname</rdfs:label>
        <rdfs:comment>The specification of a node (file or directory) in a hierarchical file system, usually specified by listing the nodes top-down.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Thistle">
    <rdfs:label>Thistle</rdfs:label>
    <rdfs:comment>CSS-color 0xD8BFD8.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hop">
    <rdfs:label>Hop</rdfs:label>
    <rdfs:comment>Jump on one foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stick-figure-visualization">
    <rdfs:label>Stick-figure-visualization</rdfs:label>
    <rdfs:comment>A drawing showing the head of a human being or animal as a circle and all other parts as straight lines.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Version-identifier-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Usually is a semantic version.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Version-identifier">
        <rdfs:label>Version-identifier</rdfs:label>
        <rdfs:comment>An alphanumeric character string that identifies a form or variant of a type or original.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Belongs-to">
    <rdfs:label>Belongs-to</rdfs:label>
    <rdfs:comment>(A, (Belongs-to, B)) indicates that A is a member of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#GoldenRod">
    <rdfs:label>GoldenRod</rdfs:label>
    <rdfs:comment>CSS-color 0xDAA520.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Click">
    <rdfs:label>Click</rdfs:label>
    <rdfs:comment>The sound made by a mechanical cash register, often to designate a reward.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Probability-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Probability">
        <rdfs:label>Probability</rdfs:label>
        <rdfs:comment>A measure of the expectation of the occurrence of a particular event.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#GreenYellow">
    <rdfs:label>GreenYellow</rdfs:label>
    <rdfs:comment>CSS-color 0xADFF2F.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HeaderMember rdf:about="https://purl.org/hed#Version">
    <rdfs:label>version</rdfs:label>
    <hed:HeaderAttribute>8.2.0</hed:HeaderAttribute>
  </hed:HeaderMember>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Adjacent-to">
    <rdfs:label>Adjacent-to</rdfs:label>
    <rdfs:comment>(A, (Adjacent-to, B)) indicates that A is next to B in time or space.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumBlue">
    <rdfs:label>MediumBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x0000CD.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SeaGreen">
    <rdfs:label>SeaGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x2E8B57.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Flex">
    <rdfs:label>Flex</rdfs:label>
    <rdfs:comment>Cause a muscle to stand out by contracting or tensing it. Bend a limb or joint.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-actor">
    <rdfs:label>Experiment-actor</rdfs:label>
    <rdfs:comment>An agent who plays a predetermined role to create the experiment scenario.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-task-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Inhibit-blinks">
    <rdfs:label>Inhibit-blinks</rdfs:label>
    <rdfs:comment>Purposely prevent blinking.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#day">
    <rdfs:label>day</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <hed:conversionFactor>86400</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Time-out">
    <rdfs:label>Time-out</rdfs:label>
    <rdfs:comment>A cancellation or cessation that automatically occurs when a predefined interval of time has passed without a certain event occurring.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-marker"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Blue">
    <rdfs:label>Blue</rdfs:label>
    <rdfs:comment>CSS-color 0x0000FF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stereophonic">
    <rdfs:label>Stereophonic</rdfs:label>
    <rdfs:comment>Relating to, or constituting sound reproduction involving the use of separated microphones and two transmission channels to achieve the sound separation of a live hearing.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pen">
    <rdfs:label>Pen</rdfs:label>
    <rdfs:comment>A common writing instrument used to apply ink to a surface for writing or drawing.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Writing-device">
        <rdfs:label>Writing-device</rdfs:label>
        <rdfs:comment>A device used for writing.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Assistive-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Point">
    <rdfs:label>Point</rdfs:label>
    <rdfs:comment>Draw attention to something by extending a finger or arm.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Count">
    <rdfs:label>Count</rdfs:label>
    <rdfs:comment>Tally items either silently or aloud.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gustatory-presentation">
    <rdfs:label>Gustatory-presentation</rdfs:label>
    <rdfs:comment>The sense of taste used in the presentation to the user.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Indicator-variable-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the indicator variable.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Indicator-variable">
        <rdfs:label>Indicator-variable</rdfs:label>
        <rdfs:comment>An aspect of the experiment or task that is measured as task conditions are varied during the experiment. Experiment indicators are sometimes called dependent variables.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#reserved">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>reserved</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this tag has special meaning and requires special handling by tools.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Passive">
    <rdfs:label>Passive</rdfs:label>
    <rdfs:comment>Not responding or initiating an action in response to a stimulus.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#M">
    <rdfs:label>M</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^6.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^6</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Angry">
    <rdfs:label>Angry</rdfs:label>
    <rdfs:comment>Experiencing emotions characterized by marked annoyance or hostility.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Above">
    <rdfs:label>Above</rdfs:label>
    <rdfs:comment>(A, (Above, B)) means A is in a place or position that is higher than B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Allow">
    <rdfs:label>Allow</rdfs:label>
    <rdfs:comment>Allow access to something such as allowing a car to pass.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed#tagGroup">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>tagGroup</rdfs:label>
    <rdfs:comment>A schema attribute indicating the tag can only appear inside a tag group.</rdfs:comment>
    <hed:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:boolProperty>
    <hed:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Gravel-terrain">
    <rdfs:label>Gravel-terrain</rdfs:label>
    <rdfs:comment>Tracts of land covered by a surface consisting a loose aggregation of small water-worn or pounded stones.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Track">
    <rdfs:label>Track</rdfs:label>
    <rdfs:comment>Follow a person, animal, or object through space or time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#n">
    <rdfs:label>n</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-9.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-9</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Attend-to">
    <rdfs:label>Attend-to</rdfs:label>
    <rdfs:comment>Focus mental experience on specific targets.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#exa">
    <rdfs:label>exa</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^18.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^18</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mouse-button">
    <rdfs:label>Mouse-button</rdfs:label>
    <rdfs:comment>An electric switch on a computer mouse which can be pressed or clicked to select or interact with an element of a graphical user interface.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Computer-mouse"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Glyph">
    <rdfs:label>Glyph</rdfs:label>
    <rdfs:comment>A hieroglyphic character, symbol, or pictograph.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkGreen">
    <rdfs:label>DarkGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x006400.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumAquaMarine">
    <rdfs:label>MediumAquaMarine</rdfs:label>
    <rdfs:comment>CSS-color 0x66CDAA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stare">
    <rdfs:label>Stare</rdfs:label>
    <rdfs:comment>Look fixedly or vacantly at someone or something with eyes wide open.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PaleGoldenRod">
    <rdfs:label>PaleGoldenRod</rdfs:label>
    <rdfs:comment>CSS-color 0xEEE8AA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Robotic-agent">
    <rdfs:label>Robotic-agent</rdfs:label>
    <rdfs:comment>An agent mechanical device capable of performing a variety of often complex tasks on command or by being programmed in advance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Frequency-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Frequency">
        <rdfs:label>Frequency</rdfs:label>
        <rdfs:comment>Frequency is the number of occurrences of a repeating event per unit time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#frequencyUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightYellow">
    <rdfs:label>LightYellow</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFFE0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Salmon">
    <rdfs:label>Salmon</rdfs:label>
    <rdfs:comment>CSS-color 0xFA8072.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bite">
    <rdfs:label>Bite</rdfs:label>
    <rdfs:comment>Seize with teeth or jaws an object or organism so as to grip or break the surface covering.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Halt">
    <rdfs:label>Halt</rdfs:label>
    <rdfs:comment>Bring or come to an abrupt stop.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Repeat">
    <rdfs:label>Repeat</rdfs:label>
    <rdfs:comment>Make do or perform again.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cone">
    <rdfs:label>Cone</rdfs:label>
    <rdfs:comment>A shape whose base is a circle and whose sides taper up to a point.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#3D-shape"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Knee">
    <rdfs:label>Knee</rdfs:label>
    <rdfs:comment>A joint connecting the lower part of the femur with the upper part of the tibia.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Lower-extremity"/>
  </hed:HedTag>
  <hed:HedElement rdf:about="https://purl.org/hed#Prologue">
    <rdfs:label>epilogue</rdfs:label>
    <hed:elementValue>The HED standard schema is a hierarchically-organized vocabulary for annotating events and experimental structure. HED annotations consist of comma-separated tags drawn from this vocabulary. This vocabulary can be augmented by terms drawn from specialized library schema. 

Each term in this vocabulary has a human-readable description and may include additional attributes that give additional properties or that specify how tools should treat the tag during analysis. The meaning of these attributes is described in the Additional schema properties section.

</hed:elementValue>
  </hed:HedElement>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumSlateBlue">
    <rdfs:label>MediumSlateBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x7B68EE.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Distractor">
    <rdfs:label>Distractor</rdfs:label>
    <rdfs:comment>A person or thing that distracts or a plausible but incorrect option in a multiple-choice question. In pyschological studies this is sometimes referred to as a foil.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tactile-pressure">
    <rdfs:label>Tactile-pressure</rdfs:label>
    <rdfs:comment>Having a feeling of heaviness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Tactile-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Salty">
    <rdfs:label>Salty</rdfs:label>
    <rdfs:comment>Tasting of or like salt.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gustatory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Machine">
    <rdfs:label>Machine</rdfs:label>
    <rdfs:comment>A human-made device that uses power to apply forces and control movement to perform an action.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sound-envelope-sustain-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-envelope-sustain">
        <rdfs:label>Sound-envelope-sustain</rdfs:label>
        <rdfs:comment>The time taken for the main sequence of the sound duration, until the key is released.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound-envelope"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Evade">
    <rdfs:label>Evade</rdfs:label>
    <rdfs:comment>Escape or avoid, especially by cleverness or trickery.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hip">
    <rdfs:label>Hip</rdfs:label>
    <rdfs:comment>The lateral prominence of the pelvis from the waist to the thigh.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Torso"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Art-installation">
    <rdfs:label>Art-installation</rdfs:label>
    <rdfs:comment>A large-scale, mixed-media constructions, often designed for a specific place or for a temporary period of time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Widen-eyes">
    <rdfs:label>Widen-eyes</rdfs:label>
    <rdfs:comment>Open eyes and possibly with eyebrows lifted especially to express surprise or fear.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#hour">
    <rdfs:label>hour</rdfs:label>
    <rdfs:comment>Should be in 24-hour format.</rdfs:comment>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <hed:conversionFactor>3600</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vestibular-presentation">
    <rdfs:label>Vestibular-presentation</rdfs:label>
    <rdfs:comment>The sense balance used in the presentation to the user.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#a">
    <rdfs:label>a</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-18.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^-18</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cry">
    <rdfs:label>Cry</rdfs:label>
    <rdfs:comment>Shed tears associated with emotions, usually sadness but also joy or frustration.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lift">
    <rdfs:label>Lift</rdfs:label>
    <rdfs:comment>Raising something to higher position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Release">
    <rdfs:label>Release</rdfs:label>
    <rdfs:comment>Make available or set free.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Nonword">
    <rdfs:label>Nonword</rdfs:label>
    <rdfs:comment>A group of letters or speech sounds that looks or sounds like a word but that is not accepted as such by native speakers.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DeepPink">
    <rdfs:label>DeepPink</rdfs:label>
    <rdfs:comment>CSS-color 0xFF1493.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Pink-color"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#da">
    <rdfs:label>da</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^1.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10.0</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Teal">
    <rdfs:label>Teal</rdfs:label>
    <rdfs:comment>CSS-color 0x008080.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Olfactory-attribute">
    <rdfs:label>Olfactory-attribute</rdfs:label>
    <rdfs:comment>Having a smell.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#EEG-recorder">
    <rdfs:label>EEG-recorder</rdfs:label>
    <rdfs:comment>A device for recording electric currents in the brain using electrodes applied to the scalp, to the surface of the brain, or placed within the substance of the brain.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Recording-device"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#kph">
    <rdfs:label>kph</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#speedUnits"/>
    <hed:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:unitSymbol>
    <hed:conversionFactor>0.277778</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#m">
    <rdfs:label>m</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-3.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>0.001</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Group-of">
    <rdfs:label>Group-of</rdfs:label>
    <rdfs:comment>(A, (Group-of, B)) indicates A is a group of items of type B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkGray">
    <rdfs:label>DarkGray</rdfs:label>
    <rdfs:comment>CSS-color 0xA9A9A9.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumSeaGreen">
    <rdfs:label>MediumSeaGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x3CB371.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Parameter-value-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Parameter-value">
        <rdfs:label>Parameter-value</rdfs:label>
        <rdfs:comment>The value of the parameter.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Parameter"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#d">
    <rdfs:label>d</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-1.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>0.1</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-participant">
    <rdfs:label>Experiment-participant</rdfs:label>
    <rdfs:comment>Someone who takes part in an activity related to an experiment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-task-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vocalize">
    <rdfs:label>Vocalize</rdfs:label>
    <rdfs:comment>Utter vocal sounds.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Interacts-with">
    <rdfs:label>Interacts-with</rdfs:label>
    <rdfs:comment>(A, (Interacts-with, B)) indicates A and B interact, possibly reciprocally.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Selective-attention">
    <rdfs:label>Selective-attention</rdfs:label>
    <rdfs:comment>Maintaining a behavioral or cognitive set in the face of distracting or competing stimuli. Ability to pay attention to a limited array of all available sensory information.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Thumbs-down">
    <rdfs:label>Thumbs-down</rdfs:label>
    <rdfs:comment>Extend the thumb downward to indicate disapproval.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rest">
    <rdfs:label>Rest</rdfs:label>
    <rdfs:comment>Be inactive in order to regain strength, health, or energy.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Race">
    <rdfs:label>Race</rdfs:label>
    <rdfs:comment>Belonging to a group sharing physical or social qualities as defined within a specified society. Use with Label to avoid extension.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cyan">
    <rdfs:label>Cyan</rdfs:label>
    <rdfs:comment>CSS-color 0x00FFFF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#gram">
    <rdfs:label>gram</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#weightUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Azure">
    <rdfs:label>Azure</rdfs:label>
    <rdfs:comment>CSS-color 0xF0FFFF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Primary-subtask">
    <rdfs:label>Primary-subtask</rdfs:label>
    <rdfs:comment>A part of the task which should be the primary focus of the participant.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-relationship">
        <rdfs:label>Task-relationship</rdfs:label>
        <rdfs:comment>Specifying organizational importance of sub-tasks.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkSalmon">
    <rdfs:label>DarkSalmon</rdfs:label>
    <rdfs:comment>CSS-color 0xE9967A.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bleating">
    <rdfs:label>Bleating</rdfs:label>
    <rdfs:comment>Wavering cries like sounds made by a sheep, goat, or calf.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-animal-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Screen-window">
    <rdfs:label>Screen-window</rdfs:label>
    <rdfs:comment>A part of a computer screen that contains a display different from the rest of the screen. A window is a graphical control element consisting of a visual area containing some of the graphical user interface of the program it belongs to and is framed by a window decoration.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Computer-screen">
        <rdfs:label>Computer-screen</rdfs:label>
        <rdfs:comment>An electronic device designed as a display or a physical device designed to be a protective meshwork.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Display-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Icon">
    <rdfs:label>Icon</rdfs:label>
    <rdfs:comment>A sign (such as a word or graphic symbol) whose form suggests its meaning.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Image"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cross">
    <rdfs:label>Cross</rdfs:label>
    <rdfs:comment>A figure or mark formed by two intersecting lines crossing at their midpoints.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Somatic-presentation">
    <rdfs:label>Somatic-presentation</rdfs:label>
    <rdfs:comment>The nervous system is used in the presentation to the user.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#CogPo-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#CogPo">
        <rdfs:label>CogPo</rdfs:label>
        <rdfs:comment>The CogPO ID number of something.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Loudness-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Loudness">
        <rdfs:label>Loudness</rdfs:label>
        <rdfs:comment>Perceived intensity of a sound.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Novel">
    <rdfs:label>Novel</rdfs:label>
    <rdfs:comment>Having no previous example or precedent or parallel.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Left-handed">
    <rdfs:label>Left-handed</rdfs:label>
    <rdfs:comment>Preference for using the left hand or foot for tasks requiring the use of a single hand or foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Handedness"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#P">
    <rdfs:label>P</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^15.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^15</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PaleVioletRed">
    <rdfs:label>PaleVioletRed</rdfs:label>
    <rdfs:comment>CSS-color 0xDB7093.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Pink-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grieving">
    <rdfs:label>Grieving</rdfs:label>
    <rdfs:comment>Feeling sorrow in response to loss, whether physical or abstract.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Drop">
    <rdfs:label>Drop</rdfs:label>
    <rdfs:comment>Let or cause to fall vertically.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Open-eyes">
    <rdfs:label>Open-eyes</rdfs:label>
    <rdfs:comment>Raise eyelids to expose pupil.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Member-of">
    <rdfs:label>Member-of</rdfs:label>
    <rdfs:comment>(A, (Member-of, B)) indicates A is a member of group B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Underneath">
    <rdfs:label>Underneath</rdfs:label>
    <rdfs:comment>(A, (Underneath, B)) means A is situated directly below and may be concealed by B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Entrance">
    <rdfs:label>Entrance</rdfs:label>
    <rdfs:comment>The means or place of entry.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Building"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Connected-to">
    <rdfs:label>Connected-to</rdfs:label>
    <rdfs:comment>(A, (Connected-to, B)) indicates that A is related to B in some respect, usually through a direct link.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Exhale">
    <rdfs:label>Exhale</rdfs:label>
    <rdfs:comment>Blow out or expel breath.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Performed-using">
    <rdfs:label>Performed-using</rdfs:label>
    <rdfs:comment>(A, (Performed-using, B)) indicates that the action or procedure A was accomplished using B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumTurquoise">
    <rdfs:label>MediumTurquoise</rdfs:label>
    <rdfs:comment>CSS-color 0x48D1CC.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Loudspeaker-separation">
    <rdfs:label>Loudspeaker-separation</rdfs:label>
    <rdfs:comment>The distance between two loudspeakers. Grouped with the Distance tag.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-presentation"/>
    <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Distance"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LawnGreen">
    <rdfs:label>LawnGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x7CFC00.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Joyful">
    <rdfs:label>Joyful</rdfs:label>
    <rdfs:comment>Feeling delight or intense happiness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Street-view">
    <rdfs:label>Street-view</rdfs:label>
    <rdfs:comment>A 360-degrees panoramic view from a position on the ground.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Map-view"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pedal">
    <rdfs:label>Pedal</rdfs:label>
    <rdfs:comment>Move by working the pedals of a bicycle or other machine.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#kilo">
    <rdfs:label>kilo</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^3.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>1000.0</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Excited">
    <rdfs:label>Excited</rdfs:label>
    <rdfs:comment>Feeling great enthusiasm and eagerness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Happy">
    <rdfs:label>Happy</rdfs:label>
    <rdfs:comment>Feeling pleased and content.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Drawing">
    <rdfs:label>Drawing</rdfs:label>
    <rdfs:comment>A representation of an object or outlining a figure, plan, or sketch by means of lines.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Image"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Questionnaire">
    <rdfs:label>Questionnaire</rdfs:label>
    <rdfs:comment>A document consisting of questions and possibly responses, depending on whether it has been filled out.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Document"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sit-down">
    <rdfs:label>Sit-down</rdfs:label>
    <rdfs:comment>Move from a standing to a sitting position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#hertz">
    <rdfs:label>hertz</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#frequencyUnits"/>
    <hed:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnit>
    <hed:conversionFactor>1.0</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#mega">
    <rdfs:label>mega</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^6.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^6</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Varying">
    <rdfs:label>Varying</rdfs:label>
    <rdfs:comment>Differing in size, amount, degree, or nature.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#BlanchedAlmond">
    <rdfs:label>BlanchedAlmond</rdfs:label>
    <rdfs:comment>CSS-color 0xFFEBCD.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SpringGreen">
    <rdfs:label>SpringGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x00FF7F.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Modify">
    <rdfs:label>Modify</rdfs:label>
    <rdfs:comment>Change something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Green">
    <rdfs:label>Green</rdfs:label>
    <rdfs:comment>CSS-color 0x008000.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hum">
    <rdfs:label>Hum</rdfs:label>
    <rdfs:comment>Make a low, steady continuous sound like that of a bee. Sing with the lips closed and without uttering speech.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clap-hands">
    <rdfs:label>Clap-hands</rdfs:label>
    <rdfs:comment>Strike the palms of against one another resoundingly, and usually repeatedly, especially to express approval.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Word">
    <rdfs:label>Word</rdfs:label>
    <rdfs:comment>A word is the smallest free form (an item that may be expressed in isolation with semantic or pragmatic content) in a language.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Orienting-attention">
    <rdfs:label>Orienting-attention</rdfs:label>
    <rdfs:comment>Directing attention to a target stimulus.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Time-value-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Time-value">
        <rdfs:label>Time-value</rdfs:label>
        <rdfs:comment>A value with units of time. Usually grouped with tags identifying what the value represents.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightGreen">
    <rdfs:label>LightGreen</rdfs:label>
    <rdfs:comment>CSS-color 0x90EE90.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Approximately-equal-to">
    <rdfs:label>Approximately-equal-to</rdfs:label>
    <rdfs:comment>(A, (Approximately-equal-to, B)) indicates that A and B have almost the same value. Here A and B could refer to sizes, orders, positions or other quantities.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PeachPuff">
    <rdfs:label>PeachPuff</rdfs:label>
    <rdfs:comment>CSS-color 0xFFDAB9.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Speak">
    <rdfs:label>Speak</rdfs:label>
    <rdfs:comment>Communicate using spoken language.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lower-head">
    <rdfs:label>Lower-head</rdfs:label>
    <rdfs:comment>Move head downward so that eyes are in a lower position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#NavajoWhite">
    <rdfs:label>NavajoWhite</rdfs:label>
    <rdfs:comment>CSS-color 0xFFDEAD.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Relieved">
    <rdfs:label>Relieved</rdfs:label>
    <rdfs:comment>No longer feeling pain, distress,  anxiety, or reassured.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SteelBlue">
    <rdfs:label>SteelBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x4682B4.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Background-subtask">
    <rdfs:label>Background-subtask</rdfs:label>
    <rdfs:comment>A part of the task which should be performed in the background as for example inhibiting blinks due to instruction while performing the primary task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-relationship"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Turn">
    <rdfs:label>Turn</rdfs:label>
    <rdfs:comment>Change or cause to change direction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#T">
    <rdfs:label>T</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^12.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^12</hed:conversionFactor>
  </hed:HedUnitModifier>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#unitProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unitProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute is meant to be applied to units within a unit class.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Angle-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Angle">
        <rdfs:label>Angle</rdfs:label>
        <rdfs:comment>The amount of inclination of one line to another or the plane of one object to another.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#angleUnits"/>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Kneeling">
    <rdfs:label>Kneeling</rdfs:label>
    <rdfs:comment>Positioned where one or both knees are on the ground.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Eye">
    <rdfs:label>Eye</rdfs:label>
    <rdfs:comment>The organ of sight or vision.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#FloralWhite">
    <rdfs:label>FloralWhite</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFAF0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Subject-identifier-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Subject-identifier">
        <rdfs:label>Subject-identifier</rdfs:label>
        <rdfs:comment>A sequence of characters used to identify, name, or characterize a trial or study subject.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Metadata"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Waiting-for">
    <rdfs:label>Waiting-for</rdfs:label>
    <rdfs:comment>(A, (Waiting-for, B)) means A pauses for something to happen in B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MidnightBlue">
    <rdfs:label>MidnightBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x191970.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Jump">
    <rdfs:label>Jump</rdfs:label>
    <rdfs:comment>Move off the ground or other surface through sudden muscular effort in the legs.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Greater-than-or-equal-to">
    <rdfs:label>Greater-than-or-equal-to</rdfs:label>
    <rdfs:comment>(A, (Greater-than-or-equal-to, B)) indicates that the relative size or order of A is bigger than or the same as that of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Item-index-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Item-index">
        <rdfs:label>Item-index</rdfs:label>
        <rdfs:comment>The index of an item in a collection, sequence or other structure. (A (Item-index/3, B)) means that A is item number 3 in B.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Quantitative-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sit-up">
    <rdfs:label>Sit-up</rdfs:label>
    <rdfs:comment>Move from lying down to a sitting position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Volume-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Volume">
        <rdfs:label>Volume</rdfs:label>
        <rdfs:comment>The amount of three dimensional space occupied by an object or the capacity of a space or container.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Size"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#volumeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkSlateBlue">
    <rdfs:label>DarkSlateBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x483D8B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Path">
    <rdfs:label>Path</rdfs:label>
    <rdfs:comment>A trodden way. A way or track laid down for walking or made by continual treading.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Navigational-object">
        <rdfs:label>Navigational-object</rdfs:label>
        <rdfs:comment>An object whose purpose is to assist directed movement from one location to another.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hiccup">
    <rdfs:label>Hiccup</rdfs:label>
    <rdfs:comment>Involuntarily spasm  the diaphragm and respiratory organs, with a sudden closure of the glottis and a characteristic sound like that of a cough.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#OldLace">
    <rdfs:label>OldLace</rdfs:label>
    <rdfs:comment>CSS-color 0xFDF5E6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Feedback">
    <rdfs:label>Feedback</rdfs:label>
    <rdfs:comment>An evaluative response to an inquiry, process, event, or activity.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Letter">
    <rdfs:label>Letter</rdfs:label>
    <rdfs:comment>A written message addressed to a person or organization.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Document"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Aquamarine">
    <rdfs:label>Aquamarine</rdfs:label>
    <rdfs:comment>CSS-color 0x7FFFD4.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Locked-in">
    <rdfs:label>Locked-in</rdfs:label>
    <rdfs:comment>In a state of complete paralysis of all voluntary muscles except for the ones that control the movements of the eyes.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tactile-temperature">
    <rdfs:label>Tactile-temperature</rdfs:label>
    <rdfs:comment>Having a feeling of hotness or coldness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Tactile-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Dance">
    <rdfs:label>Dance</rdfs:label>
    <rdfs:comment>Perform a purposefully selected sequences of human movement often with aesthetic or symbolic value. Move rhythmically to music, typically following a set sequence of steps.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightCyan">
    <rdfs:label>LightCyan</rdfs:label>
    <rdfs:comment>CSS-color 0xE0FFFF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Crowd-sound">
    <rdfs:label>Crowd-sound</rdfs:label>
    <rdfs:comment>Noise produced by a mixture of sounds from a large group of people.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#From-to">
    <rdfs:label>From-to</rdfs:label>
    <rdfs:comment>(A, (From-to, B)) indicates a directional relation from A to B. A is considered the source.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Microphone">
    <rdfs:label>Microphone</rdfs:label>
    <rdfs:comment>A device designed to convert sound to an electrical signal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Input-device"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Description-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Description">
        <rdfs:label>Description</rdfs:label>
        <rdfs:comment>An explanation of what the tag group it is in means. If the description is at the top-level of an event string, the description applies to the event.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Informational-property"/>
        <hed:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:requireChild>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Braille">
    <rdfs:label>Braille</rdfs:label>
    <rdfs:comment>A display using a system of raised dots that can be read with the fingers by people who are blind.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Crouching">
    <rdfs:label>Crouching</rdfs:label>
    <rdfs:comment>Adopting a position where the knees are bent and the upper body is brought forward and down, sometimes to avoid detection or to defend oneself.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Reward">
    <rdfs:label>Reward</rdfs:label>
    <rdfs:comment>A positive reinforcement for a desired action, behavior or response.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Inhale">
    <rdfs:label>Inhale</rdfs:label>
    <rdfs:comment>Draw in with the breath through the nose or mouth.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Purple">
    <rdfs:label>Purple</rdfs:label>
    <rdfs:comment>CSS-color 0x800080.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sensory-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sensory-resolution">
        <rdfs:label>Sensory-resolution</rdfs:label>
        <rdfs:comment>Resolution of measurements by a sensing device.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Over">
    <rdfs:label>Over</rdfs:label>
    <rdfs:comment>(A, (Over, B)) means A above is above B so as to cover or protect or A extends over the a general area as from a from a vantage point.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sound-envelope-decay-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-envelope-decay">
        <rdfs:label>Sound-envelope-decay</rdfs:label>
        <rdfs:comment>The time taken for the subsequent run down from the attack level to the designated sustain level.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound-envelope"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Real-world">
    <rdfs:label>Real-world</rdfs:label>
    <rdfs:comment>Located in a place that exists in real space and time under realistic conditions.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Less-than-or-equal-to">
    <rdfs:label>Less-than-or-equal-to</rdfs:label>
    <rdfs:comment>(A, (Less-than-or-equal-to, B)) indicates that the relative size or order of A is smaller than or equal to B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Phrase">
    <rdfs:label>Phrase</rdfs:label>
    <rdfs:comment>A phrase is a group of words functioning as a single unit in the syntax of a sentence.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Z-position-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Z-position">
        <rdfs:label>Z-position</rdfs:label>
        <rdfs:comment>The position along the z-axis of the frame of reference.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Position"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#RoyalBlue">
    <rdfs:label>RoyalBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x4169E1.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Fraction-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Fraction">
        <rdfs:label>Fraction</rdfs:label>
        <rdfs:comment>A numerical value between 0 and 1.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Quantitative-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tape-recorder">
    <rdfs:label>Tape-recorder</rdfs:label>
    <rdfs:comment>A device for recording and reproduction usually using magnetic tape for storage that can be saved and played back.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Recording-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightSlateGray">
    <rdfs:label>LightSlateGray</rdfs:label>
    <rdfs:comment>CSS-color 0x778899.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Dots">
    <rdfs:label>Dots</rdfs:label>
    <rdfs:comment>A small round mark or spot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Pattern"/>
  </hed:HedTag>
  <hed:HedElement rdf:about="https://purl.org/hed#Epilogue">
    <rdfs:label>epilogue</rdfs:label>
    <hed:elementValue>This schema is released under the Creative Commons Attribution 4.0 International and is a product of the HED Working Group. The DOI for the latest version of the HED standard schema is 10.5281/zenodo.7876037.
</hed:elementValue>
  </hed:HedElement>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tool">
    <rdfs:label>Tool</rdfs:label>
    <rdfs:comment>A component that is not part of a device but is designed to support its assemby or operation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Brain-dead">
    <rdfs:label>Brain-dead</rdfs:label>
    <rdfs:comment>Characterized by the irreversible absence of cortical and brain stem functioning.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Instrument-sound">
    <rdfs:label>Instrument-sound</rdfs:label>
    <rdfs:comment>Sound produced by a musical instrument.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Musical-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Eyes-open">
    <rdfs:label>Eyes-open</rdfs:label>
    <rdfs:comment>Keeping eyes open with occasional blinking.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bisque">
    <rdfs:label>Bisque</rdfs:label>
    <rdfs:comment>CSS-color 0xFFE4C4.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Imagined-action">
    <rdfs:label>Imagined-action</rdfs:label>
    <rdfs:comment>Form a mental image or concept of something. This is used to identity something that only happened in the imagination of the participant as in imagined movements in motor imagery paradigms.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Aqua">
    <rdfs:label>Aqua</rdfs:label>
    <rdfs:comment>CSS-color 0x00FFFF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#pico">
    <rdfs:label>pico</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-12.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-12</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Composite-terrain">
    <rdfs:label>Composite-terrain</rdfs:label>
    <rdfs:comment>Tracts of land characterized by a mixure of physical features.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Terrain"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Awake">
    <rdfs:label>Awake</rdfs:label>
    <rdfs:comment>In a non sleeping state.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ethnicity">
    <rdfs:label>Ethnicity</rdfs:label>
    <rdfs:comment>Belong to a social group that has a common national or cultural tradition. Use with Label to avoid extension.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkBlue">
    <rdfs:label>DarkBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x00008B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Audiovisual-clip">
    <rdfs:label>Audiovisual-clip</rdfs:label>
    <rdfs:comment>A short media segment containing both audio and video.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Media-clip"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#On-treadmill">
    <rdfs:label>On-treadmill</rdfs:label>
    <rdfs:comment>Ambulation on an exercise apparatus with an endless moving belt to support moving in place.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Exact-value">
    <rdfs:label>Exact-value</rdfs:label>
    <rdfs:comment>A value that is viewed to the true value according to some standard.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cylinder">
    <rdfs:label>Cylinder</rdfs:label>
    <rdfs:comment>A surface formed by circles of a given radius that are contained in a plane perpendicular to a given axis, whose centers align on the axis.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#3D-shape"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#E">
    <rdfs:label>E</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^18.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^18</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lane">
    <rdfs:label>Lane</rdfs:label>
    <rdfs:comment>A defined path with physical dimensions through which an object or substance may traverse.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Road">
        <rdfs:label>Road</rdfs:label>
        <rdfs:comment>An open way for the passage of vehicles, persons, or animals on land.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Navigational-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#degree">
    <rdfs:label>degree</rdfs:label>
    <hed:unitClass rdf:resource="https://purl.org/hed/aux#angleUnits"/>
    <hed:conversionFactor>0.0174533</hed:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DeepSkyBlue">
    <rdfs:label>DeepSkyBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x00BFFF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shin">
    <rdfs:label>Shin</rdfs:label>
    <rdfs:comment>Front part of the leg below the knee.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Lower-extremity"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#Y">
    <rdfs:label>Y</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^24.</rdfs:comment>
    <hed:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitSymbolModifier>
    <hed:conversionFactor>10^24</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Judge">
    <rdfs:label>Judge</rdfs:label>
    <rdfs:comment>Evaluate evidence to make a decision or form a belief.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PapayaWhip">
    <rdfs:label>PapayaWhip</rdfs:label>
    <rdfs:comment>CSS-color 0xFFEFD5.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Buttocks">
    <rdfs:label>Buttocks</rdfs:label>
    <rdfs:comment>The round fleshy parts that form the lower rear area of a human trunk.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Torso"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkTurquoise">
    <rdfs:label>DarkTurquoise</rdfs:label>
    <rdfs:comment>CSS-color 0x00CED1.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bistable-view">
    <rdfs:label>Bistable-view</rdfs:label>
    <rdfs:comment>Something having two stable visual forms that have two distinguishable stable forms as in optical illusions.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#GhostWhite">
    <rdfs:label>GhostWhite</rdfs:label>
    <rdfs:comment>CSS-color 0xF8F8FF.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Beep">
    <rdfs:label>Beep</rdfs:label>
    <rdfs:comment>A short, single tone, that is typically high-pitched and generally made by a computer or other machine.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Lavender">
    <rdfs:label>Lavender</rdfs:label>
    <rdfs:comment>CSS-color 0xE6E6FA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sculpture">
    <rdfs:label>Sculpture</rdfs:label>
    <rdfs:comment>A two- or three-dimensional representative or abstract forms, especially by carving stone or wood or by casting metal or plaster.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#OliveDrab">
    <rdfs:label>OliveDrab</rdfs:label>
    <rdfs:comment>CSS-color 0x6B8E23.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Green-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Horn-blow">
    <rdfs:label>Horn-blow</rdfs:label>
    <rdfs:comment>A loud sound made by forcing air through a sound device that funnels air to create the sound, often used to sound an alert.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Priming">
    <rdfs:label>Priming</rdfs:label>
    <rdfs:comment>An implicit memory effect in which exposure to a stimulus influences response to a later stimulus.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightSkyBlue">
    <rdfs:label>LightSkyBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x87CEFA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HeaderMember rdf:about="https://purl.org/hed#XSI">
    <rdfs:label>xmlns:xsi</rdfs:label>
    <hed:HeaderAttribute>http://www.w3.org/2001/XMLSchema-instance</hed:HeaderAttribute>
  </hed:HeaderMember>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Runway">
    <rdfs:label>Runway</rdfs:label>
    <rdfs:comment>A paved strip of ground on a landing field for the landing and takeoff of aircraft.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Navigational-object"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Brown">
    <rdfs:label>Brown</rdfs:label>
    <rdfs:comment>CSS-color 0xA52A2A.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ear">
    <rdfs:label>Ear</rdfs:label>
    <rdfs:comment>A sense organ needed for the detection of sound and for establishing balance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Head"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SaddleBrown">
    <rdfs:label>SaddleBrown</rdfs:label>
    <rdfs:comment>CSS-color 0x8B4513.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedValueClass rdf:about="https://purl.org/hed/aux#posixPath">
    <rdfs:label>posixPath</rdfs:label>
    <rdfs:comment>Posix path specification.</rdfs:comment>
    <hed:allowedCharacter>digits</hed:allowedCharacter>
    <hed:allowedCharacter>letters</hed:allowedCharacter>
    <hed:allowedCharacter>/</hed:allowedCharacter>
    <hed:allowedCharacter>:</hed:allowedCharacter>
  </hed:HedValueClass>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Outdoors">
    <rdfs:label>Outdoors</rdfs:label>
    <rdfs:comment>Any area outside a building or shelter.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Little-finger">
    <rdfs:label>Little-finger</rdfs:label>
    <rdfs:comment>The fifth and smallest finger from the radial side of the hand.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finger"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Equal-to">
    <rdfs:label>Equal-to</rdfs:label>
    <rdfs:comment>(A, (Equal-to, B)) indicates that the size or order of A is the same as that of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Computational-evidence">
    <rdfs:label>Computational-evidence</rdfs:label>
    <rdfs:comment>A type of evidence in which data are produced, and/or generated, and/or analyzed on a computer.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-effect-evidence"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Scream">
    <rdfs:label>Scream</rdfs:label>
    <rdfs:comment>Make loud, vociferous cries or yells to express pain, excitement, or fear.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stumble">
    <rdfs:label>Stumble</rdfs:label>
    <rdfs:comment>Trip or momentarily lose balance and almost fall.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clock-face">
    <rdfs:label>Clock-face</rdfs:label>
    <rdfs:comment>A location identifier based on clockface numbering or anatomic subregion.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Clock">
        <rdfs:label>Clock</rdfs:label>
        <rdfs:comment>A device designed to indicate the time of day or to measure the time duration of an event or action.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Measurement-device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vegetative">
    <rdfs:label>Vegetative</rdfs:label>
    <rdfs:comment>A state of wakefulness and conscience, but (in contrast to coma) with involuntary opening of the eyes and movements (such as teeth grinding, yawning, or thrashing of the extremities).</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Play">
    <rdfs:label>Play</rdfs:label>
    <rdfs:comment>Engage in activity for enjoyment and recreation rather than a serious or practical purpose.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Chocolate">
    <rdfs:label>Chocolate</rdfs:label>
    <rdfs:comment>CSS-color 0xD2691E.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkSlateGray">
    <rdfs:label>DarkSlateGray</rdfs:label>
    <rdfs:comment>CSS-color 0x2F4F4F.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Orchid">
    <rdfs:label>Orchid</rdfs:label>
    <rdfs:comment>CSS-color 0xDA70D6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Data-maximum-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-maximum">
        <rdfs:label>Data-maximum</rdfs:label>
        <rdfs:comment>The largest possible quantity or degree.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:takesValue>
    <hed:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Circle">
    <rdfs:label>Circle</rdfs:label>
    <rdfs:comment>A ring-shaped structure with every point equidistant from the center.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Ellipse">
        <rdfs:label>Ellipse</rdfs:label>
        <rdfs:comment>A closed plane curve resulting from the intersection of a circular cone and a plane cutting completely through it, especially a plane not parallel to the base.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Car">
    <rdfs:label>Car</rdfs:label>
    <rdfs:comment>A wheeled motor vehicle used primarily for the transportation of human passengers.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Anesthetized">
    <rdfs:label>Anesthetized</rdfs:label>
    <rdfs:comment>Having lost sensation to pain or having senses dulled due to the effects of an anesthetic.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Train">
    <rdfs:label>Train</rdfs:label>
    <rdfs:comment>A connected line of railroad cars with or without a locomotive.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Boat">
    <rdfs:label>Boat</rdfs:label>
    <rdfs:comment>A watercraft of any size which is able to float or plane on water.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sienna">
    <rdfs:label>Sienna</rdfs:label>
    <rdfs:comment>CSS-color 0xA0522D.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stretch">
    <rdfs:label>Stretch</rdfs:label>
    <rdfs:comment>Straighten or extend body or a part of body to its full length, typically so as to tighten muscles or in order to reach something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#IndianRed">
    <rdfs:label>IndianRed</rdfs:label>
    <rdfs:comment>CSS-color 0xCD5C5C.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Observation">
    <rdfs:label>Observation</rdfs:label>
    <rdfs:comment>Active acquisition of information from a primary source. Should be grouped with a label of the form AgentID_featureName.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-source-type"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Asleep">
    <rdfs:label>Asleep</rdfs:label>
    <rdfs:comment>Having entered a periodic, readily reversible state of reduced awareness and metabolic activity, usually accompanied by physical relaxation and brain activity.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#WhiteSmoke">
    <rdfs:label>WhiteSmoke</rdfs:label>
    <rdfs:comment>CSS-color 0xF5F5F5.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Instrument-measurement">
    <rdfs:label>Instrument-measurement</rdfs:label>
    <rdfs:comment>Information obtained from a device that is used to measure material properties or make other observations.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-source-type"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sweet">
    <rdfs:label>Sweet</rdfs:label>
    <rdfs:comment>Having or resembling the taste of sugar.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gustatory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sustained-attention">
    <rdfs:label>Sustained-attention</rdfs:label>
    <rdfs:comment>Maintaining a consistent behavioral response during continuous and repetitive activity.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sphere">
    <rdfs:label>Sphere</rdfs:label>
    <rdfs:comment>A solid or hollow three-dimensional object bounded by a closed surface such that every point on the surface is equidistant from the center.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Ellipsoid">
        <rdfs:label>Ellipsoid</rdfs:label>
        <rdfs:comment>A closed plane curve resulting from the intersection of a circular cone and a plane cutting completely through it, especially a plane not parallel to the base.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#3D-shape"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#zepto">
    <rdfs:label>zepto</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-21.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^-21</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Wheat">
    <rdfs:label>Wheat</rdfs:label>
    <rdfs:comment>CSS-color 0xF5DEB3.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MistyRose">
    <rdfs:label>MistyRose</rdfs:label>
    <rdfs:comment>CSS-color 0xFFE4E1.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Steel">
    <rdfs:label>Steel</rdfs:label>
    <rdfs:comment>An alloy made up of iron with typically a few tenths of a percent of carbon to improve its strength and fracture resistance compared to iron.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Manufactured-material"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Recover-balance">
    <rdfs:label>Recover-balance</rdfs:label>
    <rdfs:comment>Return to a stable, upright body position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Note">
    <rdfs:label>Note</rdfs:label>
    <rdfs:comment>A brief written record.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Document"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pencil">
    <rdfs:label>Pencil</rdfs:label>
    <rdfs:comment>An implement for writing or drawing that is constructed of a narrow solid pigment core in a protective casing that prevents the core from being broken or marking the hand.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Writing-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Heel-strike">
    <rdfs:label>Heel-strike</rdfs:label>
    <rdfs:comment>Strike the ground with the heel during a step.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Step"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Frustrated">
    <rdfs:label>Frustrated</rdfs:label>
    <rdfs:comment>Feeling annoyed as a result of being blocked, thwarted, disappointed or defeated.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed#nodeProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>nodeProperty</rdfs:label>
    <rdfs:comment>Indicates this schema attribute applies to node (tag-term) elements. This was added to allow for an attribute to apply to multiple elements.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Recognize">
    <rdfs:label>Recognize</rdfs:label>
    <rdfs:comment>Identify someone or something from having encountered them before.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tactile-presentation">
    <rdfs:label>Tactile-presentation</rdfs:label>
    <rdfs:comment>The sense of touch used in the presentation to the user.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-presentation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Coral">
    <rdfs:label>Coral</rdfs:label>
    <rdfs:comment>CSS-color 0xFF7F50.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Orange-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Head-mounted-display">
    <rdfs:label>Head-mounted-display</rdfs:label>
    <rdfs:comment>An instrument that functions as a display device, worn on the head or as part of a helmet, that has a small display optic in front of one (monocular HMD) or each eye (binocular HMD).</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Display-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#RebeccaPurple">
    <rdfs:label>RebeccaPurple</rdfs:label>
    <rdfs:comment>CSS-color 0x663399.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SeaShell">
    <rdfs:label>SeaShell</rdfs:label>
    <rdfs:comment>CSS-color 0xFFF5EE.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightSalmon">
    <rdfs:label>LightSalmon</rdfs:label>
    <rdfs:comment>CSS-color 0xFFA07A.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Red-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#To-left-of">
    <rdfs:label>To-left-of</rdfs:label>
    <rdfs:comment>(A, (To-left-of, B)) means A is located on or directed toward the side to the west of B when B is facing north. This term is used when A is not part of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Turquoise">
    <rdfs:label>Turquoise</rdfs:label>
    <rdfs:comment>CSS-color 0x40E0D0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Knuckles">
    <rdfs:label>Knuckles</rdfs:label>
    <rdfs:comment>A part of a finger at a joint where the bone is near the surface, especially where the finger joins the hand.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Hand"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Close-to">
    <rdfs:label>Close-to</rdfs:label>
    <rdfs:comment>(A, (Close-to, B)) means A is at a small distance from or is located near in space to B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Emotionally-neutral">
    <rdfs:label>Emotionally-neutral</rdfs:label>
    <rdfs:comment>Feeling neither satisfied nor dissatisfied.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Touchscreen">
    <rdfs:label>Touchscreen</rdfs:label>
    <rdfs:comment>A control component that operates an electronic device by pressing the display on the screen.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#IO-device">
        <rdfs:label>IO-device</rdfs:label>
        <rdfs:comment>Hardware used by a human (or other system) to communicate with a computer.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Arrow">
    <rdfs:label>Arrow</rdfs:label>
    <rdfs:comment>A shape with a pointed end indicating direction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#To-right-of">
    <rdfs:label>To-right-of</rdfs:label>
    <rdfs:comment>(A, (To-right-of, B)) means A is located on or directed toward the side to the east of B when B is facing north. This term is used when A is not part of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grasp">
    <rdfs:label>Grasp</rdfs:label>
    <rdfs:comment>Seize and hold firmly.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Disgusted">
    <rdfs:label>Disgusted</rdfs:label>
    <rdfs:comment>Feeling revulsion or profound disapproval aroused by something unpleasant or offensive.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Joystick">
    <rdfs:label>Joystick</rdfs:label>
    <rdfs:comment>A control device that uses a movable handle to create two-axis input for a computer device.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Input-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Identify">
    <rdfs:label>Identify</rdfs:label>
    <rdfs:comment>Establish or indicate who or what someone or something is.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HeaderMember rdf:about="https://purl.org/hed#XSINoNamespaceSchemaLocation">
    <rdfs:label>xsi:noNamespaceSchemaLocation</rdfs:label>
    <hed:HeaderAttribute>https://github.com/hed-standard/hed-specification/raw/master/hedxml/HED8.0.0.xsd</hed:HeaderAttribute>
  </hed:HeaderMember>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#giga">
    <rdfs:label>giga</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^9.</rdfs:comment>
    <hed:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:SIUnitModifier>
    <hed:conversionFactor>10^9</hed:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Constant">
    <rdfs:label>Constant</rdfs:label>
    <rdfs:comment>Continually recurring or continuing without interruption. Not changing in time or space.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Famous">
    <rdfs:label>Famous</rdfs:label>
    <rdfs:comment>A person who has a high degree of recognition by the general population for his or her success or accomplishments. A famous person.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Categorical-judgment-value">
        <rdfs:label>Categorical-judgment-value</rdfs:label>
        <rdfs:comment>Categorical values that are based on the judgment or perception of the participant such familiar and famous.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Familiar">
        <rdfs:label>Familiar</rdfs:label>
        <rdfs:comment>Recognized, familiar, or within the scope of knowledge.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Unfamiliar"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Famous"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Unfamiliar">
        <rdfs:label>Unfamiliar</rdfs:label>
        <rdfs:comment>Not having knowledge or experience of.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Familiar"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Famous"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Decreasing">
    <rdfs:label>Decreasing</rdfs:label>
    <rdfs:comment>Becoming smaller or fewer in size, amount, intensity, or degree.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Increasing">
        <rdfs:label>Increasing</rdfs:label>
        <rdfs:comment>Becoming greater in size, amount, or degree.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Decreasing"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Inappropriate-action">
    <rdfs:label>Inappropriate-action</rdfs:label>
    <rdfs:comment>An action not in keeping with what is correct or proper for the task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Appropriate-action">
        <rdfs:label>Appropriate-action</rdfs:label>
        <rdfs:comment>An action suitable or proper in the circumstances.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Inappropriate-action"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Novice-level">
    <rdfs:label>Novice-level</rdfs:label>
    <rdfs:comment>Being inexperienced in a field or situation related to the task.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-experience-level">
        <rdfs:label>Agent-experience-level</rdfs:label>
        <rdfs:comment>Amount of skill or knowledge that the agent has as pertains to the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Expert-level">
        <rdfs:label>Expert-level</rdfs:label>
        <rdfs:comment>Having comprehensive and authoritative knowledge of or skill in a particular area related to the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-experience-level"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Intermediate-experience-level"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Novice-level"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Intermediate-experience-level">
        <rdfs:label>Intermediate-experience-level</rdfs:label>
        <rdfs:comment>Having a moderate amount of knowledge or skill related to the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-experience-level"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Expert-level"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Novice-level"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Covert-attention">
    <rdfs:label>Covert-attention</rdfs:label>
    <rdfs:comment>Paying attention without moving the eyes.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Overt-attention">
        <rdfs:label>Overt-attention</rdfs:label>
        <rdfs:comment>Selectively processing one location over others by moving the eyes to point at that location.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Covert-attention"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Congruent">
    <rdfs:label>Congruent</rdfs:label>
    <rdfs:comment>Concordance of multiple evidence lines. In agreement or harmony.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Incongruent">
        <rdfs:label>Incongruent</rdfs:label>
        <rdfs:comment>Not in agreement or harmony.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Congruent"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Downward">
    <rdfs:label>Downward</rdfs:label>
    <rdfs:comment>Moving or leading toward a lower place or level.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Leftward">
        <rdfs:label>Leftward</rdfs:label>
        <rdfs:comment>Going toward or facing the left.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Downward"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Rightward"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upward"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Rightward">
        <rdfs:label>Rightward</rdfs:label>
        <rdfs:comment>Going toward or situated on the right.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Downward"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Leftward"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upward"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Upward">
        <rdfs:label>Upward</rdfs:label>
        <rdfs:comment>Moving, pointing, or leading to a higher place, point, or level.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Downward"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Leftward"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Rightward"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Top-down-attention">
    <rdfs:label>Top-down-attention</rdfs:label>
    <rdfs:comment>Voluntary allocation of attention to certain features. Sometimes this is referred to goal-oriented attention.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Bottom-up-attention">
        <rdfs:label>Bottom-up-attention</rdfs:label>
        <rdfs:comment>Attentional guidance purely by externally driven factors to stimuli that are salient because of their inherent properties relative to the background. Sometimes this is referred to as stimulus driven.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Top-down-attention"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Keypad">
    <rdfs:label>Keypad</rdfs:label>
    <rdfs:comment>A device consisting of keys, usually in a block arrangement, that provides limited input to a system.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Input-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Push">
    <rdfs:label>Push</rdfs:label>
    <rdfs:comment>Apply force in order to move something away. Use Press to indicate a key press or mouse click.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Press">
        <rdfs:label>Press</rdfs:label>
        <rdfs:comment>Apply pressure to something to flatten, shape, smooth or depress it. This action tag should be used to indicate key presses and mouse clicks.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Push"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rate-of-change">
    <rdfs:label>Rate-of-change</rdfs:label>
    <rdfs:comment>The amount of change accumulated per unit time.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Spatiotemporal-value">
        <rdfs:label>Spatiotemporal-value</rdfs:label>
        <rdfs:comment>A property relating to space and/or time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Position">
    <rdfs:label>Position</rdfs:label>
    <rdfs:comment>A reference to the alignment of an object, a particular situation or view of a situation, or the location of an object. Coordinates with respect a specified frame of reference or the default Screen-frame if no frame is given.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Spatial-value">
        <rdfs:label>Spatial-value</rdfs:label>
        <rdfs:comment>Value of an item involving space.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatiotemporal-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Categorical-class-value">
    <rdfs:label>Categorical-class-value</rdfs:label>
    <rdfs:comment>Categorical values that fall into discrete classes such as true or false. The grouping is absolute in the sense that it is the same for all participants.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Categorical-value">
        <rdfs:label>Categorical-value</rdfs:label>
        <rdfs:comment>Indicates that something can take on a limited and usually fixed number of possible values.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Discrete">
    <rdfs:label>Discrete</rdfs:label>
    <rdfs:comment>Constituting a separate entities or parts.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Continuous">
        <rdfs:label>Continuous</rdfs:label>
        <rdfs:comment>Uninterrupted in time, sequence, substance, or extent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Discrete"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Discontinuous"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Discontinuous">
        <rdfs:label>Discontinuous</rdfs:label>
        <rdfs:comment>Having a gap in time, sequence, substance, or extent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Continuous"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Liminal">
    <rdfs:label>Liminal</rdfs:label>
    <rdfs:comment>Situated at a sensory threshold that is barely perceptible or capable of eliciting a response.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Categorical-level-value">
        <rdfs:label>Categorical-level-value</rdfs:label>
        <rdfs:comment>Categorical values based on dividing a continuous variable into levels such as high and low.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Subliminal">
        <rdfs:label>Subliminal</rdfs:label>
        <rdfs:comment>Situated below a sensory threshold that is imperceptible or not capable of eliciting a response.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Liminal"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Supraliminal"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Supraliminal">
        <rdfs:label>Supraliminal</rdfs:label>
        <rdfs:comment>Situated above a sensory threshold that is perceptible or capable of eliciting a response.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Liminal"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Subliminal"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sensory-property">
    <rdfs:label>Sensory-property</rdfs:label>
    <rdfs:comment>Relating to sensation or the physical senses.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Property">
        <rdfs:label>Property</rdfs:label>
        <rdfs:comment>Something that pertains to a thing. A characteristic of some entity. A quality or feature regarded as a characteristic or inherent part of someone or something. HED attributes are adjectives or adverbs.</rdfs:comment>
        <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Inset">
    <rdfs:label>Inset</rdfs:label>
    <rdfs:comment>Marks an intermediate point in an ongoing event of temporal extent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-marker"/>
    <hed:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:topLevelTagGroup>
    <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Onset">
        <rdfs:label>Onset</rdfs:label>
        <rdfs:comment>Marks the start of an ongoing event of temporal extent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-marker"/>
        <hed:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:topLevelTagGroup>
        <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Inset"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Offset"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Offset">
        <rdfs:label>Offset</rdfs:label>
        <rdfs:comment>Marks the end of an event of temporal extent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-marker"/>
        <hed:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:topLevelTagGroup>
        <hed:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:reserved>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Onset"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Inset"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Low">
    <rdfs:label>Low</rdfs:label>
    <rdfs:comment>Less than normal in degree, intensity or amount.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#High">
        <rdfs:label>High</rdfs:label>
        <rdfs:comment>Having a greater than normal degree, intensity, or amount.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Low"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Medium"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-value">
    <rdfs:label>Data-value</rdfs:label>
    <rdfs:comment>Designation of the type of a data item.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Focused-attention">
    <rdfs:label>Focused-attention</rdfs:label>
    <rdfs:comment>Responding discretely to specific visual, auditory, or tactile stimuli.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Divided-attention">
        <rdfs:label>Divided-attention</rdfs:label>
        <rdfs:comment>Integrating parallel multiple stimuli. Behavior involving responding simultaneously to multiple tasks or multiple task demands.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-attentional-demand"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Focused-attention"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Relation">
    <rdfs:label>Relation</rdfs:label>
    <rdfs:comment>Concerns the way in which two or more people or things are connected.</rdfs:comment>
    <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Voluntary">
    <rdfs:label>Voluntary</rdfs:label>
    <rdfs:comment>Using free will or design; not forced or compelled; controlled by individual volition.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Involuntary">
        <rdfs:label>Involuntary</rdfs:label>
        <rdfs:comment>An action that is not made by choice. In the body, involuntary actions (such as blushing) occur automatically, and cannot be controlled by choice.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Voluntary"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hungry">
    <rdfs:label>Hungry</rdfs:label>
    <rdfs:comment>Being in a state of craving or desiring food.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-physiological-state">
        <rdfs:label>Agent-physiological-state</rdfs:label>
        <rdfs:comment>Having to do with the mechanical, physical, or biochemical function of an agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-state"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sated">
        <rdfs:label>Sated</rdfs:label>
        <rdfs:comment>Feeling full.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-physiological-state"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Hungry"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Thirsty">
        <rdfs:label>Thirsty</rdfs:label>
        <rdfs:comment>Feeling a need to drink.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-physiological-state"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Hungry"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Deep">
    <rdfs:label>Deep</rdfs:label>
    <rdfs:comment>Extending relatively far inward or downward.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Shallow">
        <rdfs:label>Shallow</rdfs:label>
        <rdfs:comment>Having a depth which is relatively low.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Deep"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Large">
    <rdfs:label>Large</rdfs:label>
    <rdfs:comment>Having a great extent such as in physical dimensions, period of time, amplitude or frequency.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Small">
        <rdfs:label>Small</rdfs:label>
        <rdfs:comment>Having a small extent such as in physical dimensions, period of time, amplitude or frequency.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Large"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bottom-edge-of">
    <rdfs:label>Bottom-edge-of</rdfs:label>
    <rdfs:comment>(A, (Bottom-edge-of, B)) means A is on the bottom most part or or near the boundary of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Left-edge-of">
        <rdfs:label>Left-edge-of</rdfs:label>
        <rdfs:comment>(A, (Left-edge-of, B)) means A is located on the left side of B on or near the boundary of B.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Bottom-edge-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Right-edge-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Top-edge-of"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Right-edge-of">
        <rdfs:label>Right-edge-of</rdfs:label>
        <rdfs:comment>(A, (Right-edge-of, B)) means A is located on the right side of B on or near the boundary of B.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Bottom-edge-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Left-edge-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Top-edge-of"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Top-edge-of">
        <rdfs:label>Top-edge-of</rdfs:label>
        <rdfs:comment>(A, (Top-edge-of, B)) means A is on the uppermost part or or near the boundary of B.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Left-edge-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Right-edge-of"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Bottom-edge-of"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hot">
    <rdfs:label>Hot</rdfs:label>
    <rdfs:comment>Having an excess of heat.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Cold">
        <rdfs:label>Cold</rdfs:label>
        <rdfs:comment>Having an absence of heat.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Hot"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Valid">
    <rdfs:label>Valid</rdfs:label>
    <rdfs:comment>Allowable, usable, or acceptable.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Invalid">
        <rdfs:label>Invalid</rdfs:label>
        <rdfs:comment>Not allowed or not conforming to the correct format or specifications.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Valid"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Normal">
    <rdfs:label>Normal</rdfs:label>
    <rdfs:comment>Being approximately average or within certain limits. Conforming with or constituting a norm or standard or level or type or social norm.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Abnormal">
        <rdfs:label>Abnormal</rdfs:label>
        <rdfs:comment>Deviating in any way from the state, position, structure, condition, behavior, or rule which is considered a norm.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Normal"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Size">
    <rdfs:label>Size</rdfs:label>
    <rdfs:comment>The physical magnitude of something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-value"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Informational-property">
    <rdfs:label>Informational-property</rdfs:label>
    <rdfs:comment>Something that pertains to a task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Property"/>
    <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Smooth">
    <rdfs:label>Smooth</rdfs:label>
    <rdfs:comment>Having a surface free from bumps, ridges, or irregularities.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Rough">
        <rdfs:label>Rough</rdfs:label>
        <rdfs:comment>Having a surface with perceptible bumps, ridges, or irregularities.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Smooth"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Auditory-attribute">
    <rdfs:label>Auditory-attribute</rdfs:label>
    <rdfs:comment>Pertaining to the sense of hearing.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-state">
    <rdfs:label>Agent-state</rdfs:label>
    <rdfs:comment>The state of the agent.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-property">
        <rdfs:label>Agent-property</rdfs:label>
        <rdfs:comment>Something that pertains to an agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Property"/>
        <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Symmetrical">
    <rdfs:label>Symmetrical</rdfs:label>
    <rdfs:comment>Made up of exactly similar parts facing each other or around an axis. Showing aspects of symmetry.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Asymmetrical">
        <rdfs:label>Asymmetrical</rdfs:label>
        <rdfs:comment>Lacking symmetry or having parts that fail to correspond to one another in shape, size, or arrangement.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Symmetrical"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Upper-right-of">
    <rdfs:label>Upper-right-of</rdfs:label>
    <rdfs:comment>(A, (Upper-right-of, B)) means A is situated on the upper right part of B. This relation is often used to specify qualitative information about screen position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Center-of"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-center-of"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-left-of"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-left-of"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Upper-center-of"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Lower-right-of"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#All">
    <rdfs:label>All</rdfs:label>
    <rdfs:comment>To a complete degree or to the full or entire extent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Some">
        <rdfs:label>Some</rdfs:label>
        <rdfs:comment>At least a small amount or number of, but not a large amount of, or often.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#All"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#None"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#None">
        <rdfs:label>None</rdfs:label>
        <rdfs:comment>No person or thing, nobody, not any.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#All"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Some"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ordered">
    <rdfs:label>Ordered</rdfs:label>
    <rdfs:comment>Conforming to a logical or comprehensible arrangement of separate elements.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Disordered">
        <rdfs:label>Disordered</rdfs:label>
        <rdfs:comment>Not neatly arranged. Confused and untidy. A structural quality in which the parts of an object are non-rigid.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Ordered"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Expected">
    <rdfs:label>Expected</rdfs:label>
    <rdfs:comment>Considered likely, probable or anticipated. Something of low information value as in frequent non-targets in an RSVP paradigm.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Unexpected"/>
    <hed:suggestedTag rdf:resource="https://purl.org/hed/tag#Target"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Incorrect-action">
    <rdfs:label>Incorrect-action</rdfs:label>
    <rdfs:comment>An action considered wrong or incorrect in the context of the task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Correct-action">
        <rdfs:label>Correct-action</rdfs:label>
        <rdfs:comment>An action that was a correct response in the context of the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Incorrect-action"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Indeterminate-action"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Indeterminate-action">
        <rdfs:label>Indeterminate-action</rdfs:label>
        <rdfs:comment>An action that cannot be distinguished between two or more possibibities in the current context. This tag might be applied when an outside evaluator or a classification algorithm cannot determine a definitive result.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Correct-action"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Incorrect-action"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Miss"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Near-miss"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ready-indication">
    <rdfs:label>Ready-indication</rdfs:label>
    <rdfs:comment>An action that indicates that the participant is ready to perform the next step in the task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Done-indication">
        <rdfs:label>Done-indication</rdfs:label>
        <rdfs:comment>An action that indicates that the participant has completed this step in the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Ready-indication"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Correct">
    <rdfs:label>Correct</rdfs:label>
    <rdfs:comment>Free from error. Especially conforming to fact or truth.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Wrong">
        <rdfs:label>Wrong</rdfs:label>
        <rdfs:comment>Inaccurate or not correct.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Correct"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#CSS-color">
    <rdfs:label>CSS-color</rdfs:label>
    <rdfs:comment>One of 140 colors supported by all browsers. For more details such as the color RGB or HEX values,  check:  https://www.w3schools.com/colors/colors_groups.asp.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Color">
        <rdfs:label>Color</rdfs:label>
        <rdfs:comment>The appearance of objects (or light sources) described in terms of perception of their hue and lightness (or brightness) and saturation.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Simple">
    <rdfs:label>Simple</rdfs:label>
    <rdfs:comment>Easily understood or presenting no difficulties.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Complex">
        <rdfs:label>Complex</rdfs:label>
        <rdfs:comment>Hard, involved or complicated, elaborate, having many parts.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Simple"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Right-side-of">
    <rdfs:label>Right-side-of</rdfs:label>
    <rdfs:comment>(A, (Right-side-of, B)) means A is located on the right side of B usually as part of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Left-side-of">
        <rdfs:label>Left-side-of</rdfs:label>
        <rdfs:comment>(A, (Left-side-of, B)) means A is located on the left side of B usually as part of B.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Right-side-of"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Unconstrained">
    <rdfs:label>Unconstrained</rdfs:label>
    <rdfs:comment>Moving without restriction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Constrained">
        <rdfs:label>Constrained</rdfs:label>
        <rdfs:comment>Keeping something within particular limits or bounds.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Unconstrained"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Go-signal">
    <rdfs:label>Go-signal</rdfs:label>
    <rdfs:comment>An indicator to proceed with a planned action.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Stop-signal">
        <rdfs:label>Stop-signal</rdfs:label>
        <rdfs:comment>An indicator that the agent should stop the current activity.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Go-signal"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Measurement-device">
    <rdfs:label>Measurement-device</rdfs:label>
    <rdfs:comment>A device in which a measure function inheres.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Medium">
    <rdfs:label>Medium</rdfs:label>
    <rdfs:comment>Mid-way between small and large in number, quantity, magnitude or extent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Low"/>
    <hed:relatedTag rdf:resource="https://purl.org/hed/tag#High"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Parameter">
    <rdfs:label>Parameter</rdfs:label>
    <rdfs:comment>Something user-defined for this experiment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Informational-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Deterministic">
    <rdfs:label>Deterministic</rdfs:label>
    <rdfs:comment>No randomness is involved in the development of the future states of the element.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Random">
        <rdfs:label>Random</rdfs:label>
        <rdfs:comment>Governed by or depending on chance. Lacking any definite plan or order or purpose.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Deterministic"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Stochastic"/>
      </hed:HedTag>
    </hed:relatedTag>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Stochastic">
        <rdfs:label>Stochastic</rdfs:label>
        <rdfs:comment>Uses  a random probability distribution or pattern that may be analysed statistically but may not be predicted precisely to determine future states.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Deterministic"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Random"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Near-miss">
    <rdfs:label>Near-miss</rdfs:label>
    <rdfs:comment>An action barely satisfied the requirements of the task. In a driving experiment for example this could pertain to a narrowly avoided collision or other accident.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Miss">
        <rdfs:label>Miss</rdfs:label>
        <rdfs:comment>An action considered to be a failure in the context of the task. For example, if the agent is supposed to try to hit a target and misses.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Near-miss"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rested">
    <rdfs:label>Rested</rdfs:label>
    <rdfs:comment>Feeling refreshed and relaxed.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-physiological-state"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Tired">
        <rdfs:label>Tired</rdfs:label>
        <rdfs:comment>Feeling in need of sleep or rest.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-physiological-state"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Rested"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#HSV-color">
    <rdfs:label>HSV-color</rdfs:label>
    <rdfs:comment>A color representation that models how colors appear under light.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Statistical-value">
    <rdfs:label>Statistical-value</rdfs:label>
    <rdfs:comment>A value based on or employing the principles of statistics.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-value"/>
    <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Positive">
    <rdfs:label>Positive</rdfs:label>
    <rdfs:comment>Involving advantage or good.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Negative">
        <rdfs:label>Negative</rdfs:label>
        <rdfs:comment>Involving disadvantage or harm.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Positive"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Thick">
    <rdfs:label>Thick</rdfs:label>
    <rdfs:comment>Wide in width, extent or cross-section.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Thin">
        <rdfs:label>Thin</rdfs:label>
        <rdfs:comment>Narrow in width, extent or cross-section.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Thick"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Implicit">
    <rdfs:label>Implicit</rdfs:label>
    <rdfs:comment>Implied though not plainly expressed.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Explicit">
        <rdfs:label>Explicit</rdfs:label>
        <rdfs:comment>Stated clearly and in detail, leaving no room for confusion or doubt.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Implicit"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Audible">
    <rdfs:label>Audible</rdfs:label>
    <rdfs:comment>A sound that can be perceived by the participant.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Inaudible">
        <rdfs:label>Inaudible</rdfs:label>
        <rdfs:comment>A sound below the threshold of perception of the participant.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Audible"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Quiet">
    <rdfs:label>Quiet</rdfs:label>
    <rdfs:comment>Characterizing a perceived low intensity of sound.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Loud">
        <rdfs:label>Loud</rdfs:label>
        <rdfs:comment>Having a perceived high intensity of sound.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-level-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Quiet"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Unmasked">
    <rdfs:label>Unmasked</rdfs:label>
    <rdfs:comment>Information is revealed.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Masked">
        <rdfs:label>Masked</rdfs:label>
        <rdfs:comment>Information exists but is not provided or is partially obscured due to security,  privacy, or other concerns.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-judgment-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Unmasked"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Quantitative-value">
    <rdfs:label>Quantitative-value</rdfs:label>
    <rdfs:comment>Something capable of being estimated or expressed with numeric values.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-value"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Body-part">
    <rdfs:label>Body-part</rdfs:label>
    <rdfs:comment>Any part of an organism.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Anatomical-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Forward">
    <rdfs:label>Forward</rdfs:label>
    <rdfs:comment>At or near or directed toward the front.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Backward">
        <rdfs:label>Backward</rdfs:label>
        <rdfs:comment>Directed behind or to the rear.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Forward"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-envelope">
    <rdfs:label>Sound-envelope</rdfs:label>
    <rdfs:comment>Description of how a sound changes over time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Auditory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-property">
    <rdfs:label>Task-property</rdfs:label>
    <rdfs:comment>Something that pertains to a task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Property"/>
    <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound">
    <rdfs:label>Sound</rdfs:label>
    <rdfs:comment>Mechanical vibrations transmitted by an elastic medium. Something that can be heard.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Item">
        <rdfs:label>Item</rdfs:label>
        <rdfs:comment>An independently existing thing (living or nonliving).</rdfs:comment>
        <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Unplanned">
    <rdfs:label>Unplanned</rdfs:label>
    <rdfs:comment>Something that has not been planned as part of the task.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Planned">
        <rdfs:label>Planned</rdfs:label>
        <rdfs:comment>Something that was decided on or arranged in advance.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Unplanned"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#True">
    <rdfs:label>True</rdfs:label>
    <rdfs:comment>Conforming to facts, reality or definitive criteria.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#False">
        <rdfs:label>False</rdfs:label>
        <rdfs:comment>Not in accordance with facts, reality or definitive criteria.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-class-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#True"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#RGB-color">
    <rdfs:label>RGB-color</rdfs:label>
    <rdfs:comment>A color from the RGB schema.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vertically-oriented">
    <rdfs:label>Vertically-oriented</rdfs:label>
    <rdfs:comment>Oriented perpendicular to the plane of the horizon.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Horizontally-oriented">
        <rdfs:label>Horizontally-oriented</rdfs:label>
        <rdfs:comment>Oriented parallel to or in the plane of the horizon.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Categorical-orientation-value"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Vertically-oriented"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-resolution">
    <rdfs:label>Data-resolution</rdfs:label>
    <rdfs:comment>Smallest change in a quality being measured by an sensor that causes a perceptible change.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-body-part">
    <rdfs:label>Move-body-part</rdfs:label>
    <rdfs:comment>Move one part of a body.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move">
        <rdfs:label>Move</rdfs:label>
        <rdfs:comment>Move in a specified direction or manner. Change position or posture.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Action"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Communicate">
    <rdfs:label>Communicate</rdfs:label>
    <rdfs:comment>Convey knowledge of or information about something.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Action">
        <rdfs:label>Action</rdfs:label>
        <rdfs:comment>Do something.</rdfs:comment>
        <hed:extensionAllowed rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hed:extensionAllowed>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Biological-item">
    <rdfs:label>Biological-item</rdfs:label>
    <rdfs:comment>An entity that is biological, that is related to living organisms.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-value">
    <rdfs:label>Temporal-value</rdfs:label>
    <rdfs:comment>A characteristic of or relating to time or limited by time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatiotemporal-value"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Geometric-object">
    <rdfs:label>Geometric-object</rdfs:label>
    <rdfs:comment>An object or a representation that has structure and topology in space.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Object"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Keyboard">
    <rdfs:label>Keyboard</rdfs:label>
    <rdfs:comment>A device consisting of mechanical keys that are pressed to create input to a computer.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Input-device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sick">
    <rdfs:label>Sick</rdfs:label>
    <rdfs:comment>Being in a state of ill health, bodily malfunction, or discomfort.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-physiological-state"/>
    <hed:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Healthy">
        <rdfs:label>Healthy</rdfs:label>
        <rdfs:comment>Having no significant health-related issues.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-physiological-state"/>
        <hed:relatedTag rdf:resource="https://purl.org/hed/tag#Sick"/>
      </hed:HedTag>
    </hed:relatedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Metadata">
    <rdfs:label>Metadata</rdfs:label>
    <rdfs:comment>Data about data. Information that describes another set of data.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Informational-property"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Physical-value">
    <rdfs:label>Physical-value</rdfs:label>
    <rdfs:comment>The value of some physical property of something.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-value"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Media">
    <rdfs:label>Media</rdfs:label>
    <rdfs:comment>Media are audo/visual/audiovisual modes of communicating information for mass consumption.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Output-device">
    <rdfs:label>Output-device</rdfs:label>
    <rdfs:comment>Any piece of computer hardware equipment which converts information into human understandable form.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#IO-device"/>
  </hed:HedTag>
</rdf:RDF>
