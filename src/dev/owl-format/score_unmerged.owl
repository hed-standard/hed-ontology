  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hypnagogic-hypersynchrony">
    <rdfs:label>Hypnagogic-hypersynchrony</rdfs:label>
    <rdfs:comment>Bursts of bilateral, synchronous delta or theta activity of large amplitude, occasionally with superimposed faster components, occurring during falling asleep or during awakening, in children.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-and-drowsiness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-significance-to-recording"/>
