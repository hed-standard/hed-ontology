  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Occipital-intermittent-rhythmic-delta-activity-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Occipital-intermittent-rhythmic-delta-activity-morphology">
        <rdfs:label>Occipital-intermittent-rhythmic-delta-activity-morphology</rdfs:label>
        <rdfs:comment>Occipital intermittent rhythmic delta activity (OIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 2-3 Hz over the occipital or posterior head regions of one or both sides of the head. Frequently blocked or attenuated by opening the eyes. Comment: most commonly associated with unspecified encephalopathy, in children.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Signal-morphology-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
  </hed:HedPlaceholder>
