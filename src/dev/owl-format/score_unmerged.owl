    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Modulators-reactivity">
        <rdfs:label>Modulators-reactivity</rdfs:label>
        <rdfs:comment>Susceptibility of individual rhythms or the EEG as a whole to change following sensory stimulation or other physiologic actions.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Modulators-property"/>
