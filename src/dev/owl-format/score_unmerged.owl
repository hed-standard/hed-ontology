  <hed:HedTag rdf:about="https://purl.org/hed/tag#Eye-movement-vertical-artifact">
    <rdfs:label>Eye-movement-vertical-artifact</rdfs:label>
    <rdfs:comment>Example for EEG: The EEG shows positive potentials (50-100 micro V) with bi-frontal distribution, maximum at Fp1 and Fp2, when the eyeball rotated upward. The downward rotation of the eyeball was associated with the negative deflection. The time course of the deflections was similar to the time course of the eyeball movement.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Biological-artifact">
        <rdfs:label>Biological-artifact</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Artifact"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Multifocal-finding"/>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Artifact-significance-to-recording">
        <rdfs:label>Artifact-significance-to-recording</rdfs:label>
        <rdfs:comment>It is important to score the significance of the described artifacts: recording is not interpretable, recording of reduced diagnostic value, does not interfere with the interpretation of the recording.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Other-finding-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
      </hed:HedTag>
    </heda:suggestedTag>
  </hed:HedTag>
