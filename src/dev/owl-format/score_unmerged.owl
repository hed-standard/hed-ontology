  <hed:HedTag rdf:about="https://purl.org/hed/tag#Movement-artifact">
    <rdfs:label>Movement-artifact</rdfs:label>
    <rdfs:comment>Example for EEG: Large amplitude artifact, with irregular morphology (usually resembling a slow-wave or a wave with complex morphology) seen in one or several channels, due to movement. If the causing movement is repetitive, the artifact might resemble a rhythmic EEG activity.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Biological-artifact"/>
