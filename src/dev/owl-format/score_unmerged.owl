        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-absence"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rhythmic-delta-activity">
    <rdfs:label>Rhythmic-delta-activity</rdfs:label>
    <rdfs:comment>RDA</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Critically-ill-patients-patterns"/>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Periodic-discharge-superimposed-activity">
