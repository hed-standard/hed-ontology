  <hed:HedTag rdf:about="https://purl.org/hed/tag#Arousal-pattern">
    <rdfs:label>Arousal-pattern</rdfs:label>
    <rdfs:comment>Arousal pattern in children. Prolonged, marked high voltage 4-6/s activity in all leads with some intermixed slower frequencies, in children.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-and-drowsiness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Electrode-pops-artifact">
    <rdfs:label>Electrode-pops-artifact</rdfs:label>
    <rdfs:comment>Are brief discharges with a very steep upslope and shallow fall that occur in all leads which include that electrode.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Non-biological-artifact"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Artifact-significance-to-recording"/>
  </hed:HedTag>
