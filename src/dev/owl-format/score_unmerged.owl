  <hed:HedTag rdf:about="https://purl.org/hed/tag#Slow-alpha-variant-rhythm">
    <rdfs:label>Slow-alpha-variant-rhythm</rdfs:label>
    <rdfs:comment>Characteristic rhythms mostly at 4-5 Hz, recorded most prominently over the posterior regions of the head. Generally alternate, or are intermixed, with alpha rhythm to which they often are harmonically related. Amplitude varies but is frequently close to 50 micro V. Blocked or attenuated by attention, especially visual, and mental effort. Comment: slow alpha variant rhythms should be distinguished from posterior slow waves characteristic of children and adolescents and occasionally seen in young adults.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Physiologic-pattern"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
  </hed:HedTag>
