  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pulse-artifact">
    <rdfs:label>Pulse-artifact</rdfs:label>
    <rdfs:comment>Example for EEG: Occurs when an EEG electrode is placed over a pulsating vessel. The pulsation can cause slow waves that may simulate EEG activity. A direct relationship exists between ECG and the pulse waves (200-300 millisecond delay after ECG equals QRS complex).</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Biological-artifact"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
