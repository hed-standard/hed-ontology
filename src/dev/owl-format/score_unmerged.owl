  <hed:HedTag rdf:about="https://purl.org/hed/tag#Frontal-arousal-rhythm">
    <rdfs:label>Frontal-arousal-rhythm</rdfs:label>
    <rdfs:comment>Prolonged (up to 20s) rhythmical sharp or spiky activity over the frontal areas (maximum over the frontal midline) seen at arousal from sleep in children with minimal cerebral dysfunction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-and-drowsiness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
  </hed:HedTag>
