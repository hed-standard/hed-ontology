    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Low-voltage-fast-activity-morphology"/>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
