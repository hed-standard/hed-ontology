  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Random-appearance-mode-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Random-appearance-mode">
        <rdfs:label>Random-appearance-mode</rdfs:label>
        <rdfs:comment>Occurrence of the non-ictal EEG pattern / graphoelement without any rhythmicity / periodicity.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Myoclonic-atonic-motor-onset-seizure">
    <rdfs:label>Myoclonic-atonic-motor-onset-seizure</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Motor-onset-seizure"/>
    <heda:deprecatedFrom>1.0.0</heda:deprecatedFrom>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Medication-reduction-effect-EEG">
    <rdfs:label>Medication-reduction-effect-EEG</rdfs:label>
    <rdfs:comment>Medications reduction or withdrawal effect on EEG. Used with base schema Increasing/Decreasing.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Modulators-property">
        <rdfs:label>Modulators-property</rdfs:label>
        <rdfs:comment>For each described graphoelement, the influence of the modulators can be scored. Only modulators present in the recording are scored.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finding-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Property-not-possible-to-determine">
        <rdfs:label>Property-not-possible-to-determine</rdfs:label>
        <rdfs:comment>Not possible to determine.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Other-finding-property"/>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-stopped-by"/>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Finding-unmodified">
        <rdfs:label>Finding-unmodified</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Other-finding-property"/>
      </hed:HedTag>
    </heda:suggestedTag>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-motor-clonic">
    <rdfs:label>Semiology-motor-clonic</rdfs:label>
    <rdfs:comment>Myoclonus that is regularly repetitive, involves the same muscle groups, at a frequency of about 2 to 3 c/s, and is prolonged. Synonym: rhythmic myoclonus .</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-elementary-motor"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Body-part-location"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-centricity"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Semiology-sensory-other-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-sensory-other">
        <rdfs:label>Semiology-sensory-other</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-sensory"/>
