  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-motor-negative-myoclonus">
    <rdfs:label>Semiology-motor-negative-myoclonus</rdfs:label>
    <rdfs:comment>Characterized by negative myoclonus. NEGATIVE MYOCLONUS: interruption of tonic muscular activity for lower than 500 ms without evidence of preceding myoclonia.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-elementary-motor"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Body-part-location"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-centricity"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Postictal-semiology-behavioral-change">
    <rdfs:label>Postictal-semiology-behavioral-change</rdfs:label>
    <rdfs:comment>Occurring immediately after a aseizure. Including psychosis, hypomanina, obsessive-compulsive behavior.</rdfs:comment>
