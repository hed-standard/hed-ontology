  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Data-median-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Data-median">
        <rdfs:label>Data-median</rdfs:label>
        <rdfs:comment>The value which has an equal number of values greater and less than it.</rdfs:comment>
