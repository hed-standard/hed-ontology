    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Theta-activity-morphology">
        <rdfs:label>Theta-activity-morphology</rdfs:label>
        <rdfs:comment>EEG rhythm in the theta (4-8 Hz) range that does not belong to the posterior dominant rhythm (scored under other organized rhythm).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rhythmic-activity-morphology"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-frequency"/>
