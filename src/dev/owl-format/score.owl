    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LED-pattern">
    <rdfs:label>LED-pattern</rdfs:label>
    <rdfs:comment>A pattern created by lighting selected members of a fixed light emitting diode array.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Pattern"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sleep-walking">
    <rdfs:label>Sleep-walking</rdfs:label>
    <rdfs:comment>Episodes characterized by ambulation during sleep; the patient is difficult to arouse during an episode, and is usually amnesic following the episode. Episodes usually occur in the first third of the night during slow wave sleep. Polysomnographic recordings demonstrate 2 abnormalities during the first sleep cycle: frequent, brief, non-behavioral EEG-defined arousals prior to the somnambulistic episode and abnormally low gamma (0.75-2.0 Hz) EEG power on spectral analysis, correlating with high-voltage (hyper-synchronic gamma) waves lasting 10 to 15 s occurring just prior to the movement. This is followed by stage I NREM sleep, and there is no evidence of complete awakening.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-related-episode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-phase"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-significance-to-recording"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-consciousness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-awareness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Clinical-EEG-temporal-relationship"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#State-episode-start"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-postictal-phase"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-prodrome"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-tongue-biting"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedValueClass rdf:about="https://purl.org/hed/aux#posixPath">
    <rdfs:label>posixPath</rdfs:label>
