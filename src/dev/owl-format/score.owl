        <rdfs:comment>An attribute of a visual sensation according to which an area appears to emit more or less light.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#HSV-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-autonomic-hypersalivation">
    <rdfs:label>Semiology-autonomic-hypersalivation</rdfs:label>
    <rdfs:comment>Increase in production of saliva leading to uncontrollable drooling</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-autonomic"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-language-related-aphasia">
    <rdfs:label>Semiology-language-related-aphasia</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-language-related">
        <rdfs:label>Semiology-language-related</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-non-motor-manifestation"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-activity">
    <rdfs:label>Task-activity</rdfs:label>
    <rdfs:comment>Something that is part of the overall task or is necessary to the overall experiment but is not directly part of a stimulus-response cycle. Examples would be taking a survey or provided providing a silva sample.</rdfs:comment>
