  <hed:HedTag rdf:about="https://purl.org/hed/tag#Painting">
    <rdfs:label>Painting</rdfs:label>
    <rdfs:comment>A work produced through the art of painting.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Image"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Exact-value">
    <rdfs:label>Exact-value</rdfs:label>
    <rdfs:comment>A value that is viewed to the true value according to some standard.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-variability-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Syllable">
    <rdfs:label>Syllable</rdfs:label>
    <rdfs:comment>A unit of spoken language larger than a phoneme.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Black">
    <rdfs:label>Black</rdfs:label>
    <rdfs:comment>CSS-color 0x000000.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gray-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Instep">
    <rdfs:label>Instep</rdfs:label>
    <rdfs:comment>The part of the foot between the ball and the heel on the inner side.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Foot"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Animation">
    <rdfs:label>Animation</rdfs:label>
    <rdfs:comment>A form of graphical illustration that changes with time to give a sense of motion or represent dynamic changes in the portrayal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed/attributes/#boolProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>boolProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute represents something that is either true or false and does not have a value. Attributes without this value are assumed to have string values.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Tool">
    <rdfs:label>Tool</rdfs:label>
    <rdfs:comment>A component that is not part of a device but is designed to support its assemby or operation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Device"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightGoldenRodYellow">
    <rdfs:label>LightGoldenRodYellow</rdfs:label>
    <rdfs:comment>CSS-color 0xFAFAD2.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sitting">
    <rdfs:label>Sitting</rdfs:label>
    <rdfs:comment>In a seated position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Distance-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Distance"/>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Incidental">
    <rdfs:label>Incidental</rdfs:label>
    <rdfs:comment>A sensory or other type of event that is unrelated to the task or experiment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#inch">
    <rdfs:label>inch</rdfs:label>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
    <heda:conversionFactor>0.0254</heda:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sphere">
    <rdfs:label>Sphere</rdfs:label>
    <rdfs:comment>A solid or hollow three-dimensional object bounded by a closed surface such that every point on the surface is equidistant from the center.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Ellipsoid">
        <rdfs:label>Ellipsoid</rdfs:label>
        <rdfs:comment>A closed plane curve resulting from the intersection of a circular cone and a plane cutting completely through it, especially a plane not parallel to the base.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#3D-shape"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Car">
    <rdfs:label>Car</rdfs:label>
    <rdfs:comment>A wheeled motor vehicle used primarily for the transportation of human passengers.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Connected-to">
    <rdfs:label>Connected-to</rdfs:label>
    <rdfs:comment>(A, (Connected-to, B)) indicates that A is related to B in some respect, usually through a direct link.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clothing">
    <rdfs:label>Clothing</rdfs:label>
    <rdfs:comment>A covering designed to be worn on the body.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rhythmic-temporal-theta-burst-drowsiness">
    <rdfs:label>Rhythmic-temporal-theta-burst-drowsiness</rdfs:label>
    <rdfs:comment>Rhythmic temporal theta burst of drowsiness (RTTD). Characteristic burst of 4-7 Hz waves frequently notched by faster waves, occurring over the temporal regions of the head during drowsiness. Synonym: psychomotor variant pattern. Comment: this is a pattern of drowsiness that is of no clinical significance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Uncertain-significant-pattern"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Occasional-finding-incidence-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Occasional-finding-incidence">
        <rdfs:label>Occasional-finding-incidence</rdfs:label>
        <rdfs:comment>1/min to 1/5min.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finding-incidence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Brain-laterality-left-Placeholder">
    <rdfs:label>#</rdfs:label>
