    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#2-periodic-discharge-phases">
        <rdfs:label>2-periodic-discharge-phases</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Number-of-periodic-discharge-phases"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Syncope">
    <rdfs:label>Syncope</rdfs:label>
    <rdfs:comment>Episode with loss of consciousness and muscle tone that is abrupt in onset, of short duration and followed by rapid recovery; it occurs in response to transient impairment of cerebral perfusion. Typical prodromal symptoms often herald onset of syncope and postictal symptoms are minimal. Syncopal convulsions resulting from cerebral anoxia are common but are not a form of epilepsy, nor are there any accompanying EEG ictal discharges.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-phase"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-significance-to-recording"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-consciousness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-awareness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Clinical-EEG-temporal-relationship"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#State-episode-start"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-postictal-phase"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-prodrome"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-tongue-biting"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#metre">
    <rdfs:label>metre</rdfs:label>
    <heda:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#physicalLengthUnits">
        <rdfs:label>physicalLengthUnits</rdfs:label>
        <heda:defaultUnits>m</heda:defaultUnits>
      </hed:HedUnitClass>
    </heda:unitClass>
    <heda:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnit>
    <heda:conversionFactor>1.0</heda:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Furnishing">
    <rdfs:label>Furnishing</rdfs:label>
    <rdfs:comment>Furniture, fittings, and other decorative accessories, such as curtains and carpets, for a house or room.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Man-made-object">
        <rdfs:label>Man-made-object</rdfs:label>
        <rdfs:comment>Something constructed by human means.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Spike-and-slow-wave-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Spike-and-slow-wave-morphology">
        <rdfs:label>Spike-and-slow-wave-morphology</rdfs:label>
        <rdfs:comment>A pattern consisting of a spike followed by a slow wave.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Signal-morphology-property"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Pain">
    <rdfs:label>Pain</rdfs:label>
    <rdfs:comment>The sensation of discomfort, distress, or agony, resulting from the stimulation of specialized nerve endings.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Somatic-attribute">
        <rdfs:label>Somatic-attribute</rdfs:label>
        <rdfs:comment>Pertaining to the feelings in the body or of the nervous system.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sensory-attribute"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Nociceptive-stimulation-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Nociceptive-stimulation">
