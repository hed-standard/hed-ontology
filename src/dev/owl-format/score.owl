    <heda:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitSymbolModifier>
    <heda:conversionFactor>1000.0</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Long-periodic-discharge-duration-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Long-periodic-discharge-duration">
