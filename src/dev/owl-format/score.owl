  <hed:HedTag rdf:about="https://purl.org/hed/tag#Fourteen-six-Hz-positive-burst">
    <rdfs:label>Fourteen-six-Hz-positive-burst</rdfs:label>
    <rdfs:comment>Burst of arch-shaped waves at 13-17 Hz and/or 5-7-Hz but most commonly at 14 and or 6 Hz seen generally over the posterior temporal and adjacent areas of one or both sides of the head during sleep. The sharp peaks of its component waves are positive with respect to other regions. Amplitude varies but is generally below 75  micro V. Comments: (1) best demonstrated by referential recording using contralateral earlobe or other remote, reference electrodes. (2) This pattern has no established clinical significance.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Uncertain-significant-pattern"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Toes">
    <rdfs:label>Toes</rdfs:label>
    <rdfs:comment>The terminal digits of the foot.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Foot"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Attentive">
    <rdfs:label>Attentive</rdfs:label>
    <rdfs:comment>Concentrating and focusing mental energy on the task or surroundings.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Awakening-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Awakening">
        <rdfs:label>Awakening</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-modulator"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkKhaki">
    <rdfs:label>DarkKhaki</rdfs:label>
    <rdfs:comment>CSS-color 0xBDB76B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Group-of">
    <rdfs:label>Group-of</rdfs:label>
    <rdfs:comment>(A, (Group-of, B)) indicates A is a group of items of type B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MediumPurple">
    <rdfs:label>MediumPurple</rdfs:label>
    <rdfs:comment>CSS-color 0x9370DB.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Power-supply-artifact">
    <rdfs:label>Power-supply-artifact</rdfs:label>
    <rdfs:comment>50-60 Hz artifact. Monomorphic waveform due to 50 or 60 Hz A/C power supply.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Non-biological-artifact"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Artifact-significance-to-recording"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Source-analysis-frontal-perisylvian-superior-surface">
    <rdfs:label>Source-analysis-frontal-perisylvian-superior-surface</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Source-analysis-brain-region"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Trot">
    <rdfs:label>Trot</rdfs:label>
    <rdfs:comment>Run at a moderate pace, typically with short steps.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Aerial-view">
    <rdfs:label>Aerial-view</rdfs:label>
    <rdfs:comment>Elevated view of an object from above, with a perspective as though the observer were a bird.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Map-view"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed/attributes/#unitClassProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>unitClassProperty</rdfs:label>
    <rdfs:comment>Indicates that the schema attribute is meant to be applied to unit classes.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Resting">
    <rdfs:label>Resting</rdfs:label>
    <rdfs:comment>A state in which the agent is not exhibiting any physical exertion.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-cognitive-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Note">
    <rdfs:label>Note</rdfs:label>
    <rdfs:comment>A brief written record.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Document"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Medium-periodic-discharge-absolute-amplitude-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Medium-periodic-discharge-absolute-amplitude">
        <rdfs:label>Medium-periodic-discharge-absolute-amplitude</rdfs:label>
        <rdfs:comment>50 to 199 microV.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Periodic-discharge-absolute-amplitude"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Yawn">
    <rdfs:label>Yawn</rdfs:label>
    <rdfs:comment>Take a deep involuntary  inhalation with the mouth open often as a sign of drowsiness or boredom.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Make-fist">
    <rdfs:label>Make-fist</rdfs:label>
    <rdfs:comment>Close hand tightly with the fingers bent against the palm.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Outside-of">
    <rdfs:label>Outside-of</rdfs:label>
    <rdfs:comment>(A, (Outside-of, B)) means A is located in the space around but not including B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Jealous">
    <rdfs:label>Jealous</rdfs:label>
    <rdfs:comment>Feeling threatened by a rival in a relationship with another individual, in particular an intimate partner, usually involves feelings of threat, fear, suspicion, distrust, anxiety, anger, betrayal, and rejection.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-experiential-mnemonic-Jamais-vu">
    <rdfs:label>Semiology-experiential-mnemonic-Jamais-vu</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-experiential-mnemonic">
        <rdfs:label>Semiology-experiential-mnemonic</rdfs:label>
        <rdfs:comment>Components that reflect ictal dysmnesia such as feelings of familiarity (deja-vu) and unfamiliarity (jamais-vu).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-experiential"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Medication-administered-during-recording-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Medication-administered-during-recording">
        <rdfs:label>Medication-administered-during-recording</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Medication-modulator"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LemonChiffon">
    <rdfs:label>LemonChiffon</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFACD.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Yellow-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stand-up">
    <rdfs:label>Stand-up</rdfs:label>
    <rdfs:comment>Move from a sitting to a standing position.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Vocalize">
    <rdfs:label>Vocalize</rdfs:label>
    <rdfs:comment>Utter vocal sounds.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Eye-opening-passive">
    <rdfs:label>Eye-opening-passive</rdfs:label>
    <rdfs:comment>Passive eye opening. Used with base schema Increasing/Decreasing.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Modulators-property"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-stopped-by"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-unmodified"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-triggered-by"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sculpture">
    <rdfs:label>Sculpture</rdfs:label>
    <rdfs:comment>A two- or three-dimensional representative or abstract forms, especially by carving stone or wood or by casting metal or plaster.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#SaddleBrown">
    <rdfs:label>SaddleBrown</rdfs:label>
    <rdfs:comment>CSS-color 0x8B4513.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brown-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PaleTurquoise">
    <rdfs:label>PaleTurquoise</rdfs:label>
    <rdfs:comment>CSS-color 0xAFEEEE.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Cyan-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Automatism-motor-onset-seizure">
    <rdfs:label>Automatism-motor-onset-seizure</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Motor-onset-seizure"/>
    <heda:deprecatedFrom>1.0.0</heda:deprecatedFrom>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grieving">
    <rdfs:label>Grieving</rdfs:label>
    <rdfs:comment>Feeling sorrow in response to loss, whether physical or abstract.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Brain-region-parietal-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Brain-region-parietal">
        <rdfs:label>Brain-region-parietal</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Brain-region"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experimental-stimulus">
    <rdfs:label>Experimental-stimulus</rdfs:label>
    <rdfs:comment>Part of something designed to elicit a response in the experiment.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <owl:AnnotationProperty rdf:about="https://purl.org/hed/attributes/#nodeProperty">
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>nodeProperty</rdfs:label>
    <rdfs:comment>Indicates this schema attribute applies to node (tag-term) elements. This was added to allow for an attribute to apply to multiple elements.</rdfs:comment>
  </owl:AnnotationProperty>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#a">
    <rdfs:label>a</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-18.</rdfs:comment>
    <heda:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitSymbolModifier>
    <heda:conversionFactor>10^-18</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Cough">
    <rdfs:label>Cough</rdfs:label>
    <rdfs:comment>Suddenly and audibly expel air from the lungs through a partially closed glottis, preceded by inhalation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Less-than">
    <rdfs:label>Less-than</rdfs:label>
    <rdfs:comment>(A, (Less-than, B)) indicates that A is smaller than B. Here A and B could refer to sizes, orders, positions or other quantities.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Path">
    <rdfs:label>Path</rdfs:label>
    <rdfs:comment>A trodden way. A way or track laid down for walking or made by continual treading.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Navigational-object">
        <rdfs:label>Navigational-object</rdfs:label>
        <rdfs:comment>An object whose purpose is to assist directed movement from one location to another.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Man-made-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Forehead">
    <rdfs:label>Forehead</rdfs:label>
    <rdfs:comment>The part of the face between the eyebrows and the normal hairline.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Face"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stick-figure-visualization">
    <rdfs:label>Stick-figure-visualization</rdfs:label>
    <rdfs:comment>A drawing showing the head of a human being or animal as a circle and all other parts as straight lines.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Kneeling">
    <rdfs:label>Kneeling</rdfs:label>
    <rdfs:comment>Positioned where one or both knees are on the ground.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Atonic-motor-onset-seizure">
    <rdfs:label>Atonic-motor-onset-seizure</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Motor-onset-seizure"/>
    <heda:deprecatedFrom>1.0.0</heda:deprecatedFrom>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkSlateBlue">
    <rdfs:label>DarkSlateBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x483D8B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Spike-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spike-morphology"/>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-motor-tonic">
    <rdfs:label>Semiology-motor-tonic</rdfs:label>
    <rdfs:comment>A sustained increase in muscle contraction lasting a few seconds to minutes.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-elementary-motor"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Body-part-location"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-centricity"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Arrow">
    <rdfs:label>Arrow</rdfs:label>
    <rdfs:comment>A shape with a pointed end indicating direction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Calf">
    <rdfs:label>Calf</rdfs:label>
    <rdfs:comment>The fleshy part at the back of the leg below the knee.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Lower-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Source-analysis-central-sulcus-posterior-surface">
    <rdfs:label>Source-analysis-central-sulcus-posterior-surface</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Source-analysis-brain-region"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Rare-finding-incidence-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Rare-finding-incidence">
        <rdfs:label>Rare-finding-incidence</rdfs:label>
        <rdfs:comment>less than 1/h</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finding-incidence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Khaki">
    <rdfs:label>Khaki</rdfs:label>
