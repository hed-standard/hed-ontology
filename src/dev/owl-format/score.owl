    <heda:conversionFactor>0.001</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Distractor">
    <rdfs:label>Distractor</rdfs:label>
    <rdfs:comment>A person or thing that distracts or a plausible but incorrect option in a multiple-choice question. In pyschological studies this is sometimes referred to as a foil.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#AliceBlue">
    <rdfs:label>AliceBlue</rdfs:label>
