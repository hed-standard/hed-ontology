        <rdfs:comment>An indicator placed to mark something.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Correction">
    <rdfs:label>Correction</rdfs:label>
    <rdfs:comment>An action offering an improvement to replace a mistake or error.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-action-type"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Grab">
    <rdfs:label>Grab</rdfs:label>
    <rdfs:comment>Seize suddenly or quickly. Snatch or clutch.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#day">
    <rdfs:label>day</rdfs:label>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <heda:conversionFactor>86400</heda:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Word">
    <rdfs:label>Word</rdfs:label>
    <rdfs:comment>A word is the smallest free form (an item that may be expressed in isolation with semantic or pragmatic content) in a language.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Scroll-wheel">
    <rdfs:label>Scroll-wheel</rdfs:label>
    <rdfs:comment>A scroll wheel or mouse wheel is a wheel used for scrolling made of hard plastic with a rubbery surface usually located between the left and right mouse buttons and is positioned perpendicular to the mouse surface.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Computer-mouse"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Intermittent-appearance-mode-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Intermittent-appearance-mode">
        <rdfs:label>Intermittent-appearance-mode</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sour">
    <rdfs:label>Sour</rdfs:label>
    <rdfs:comment>Having a sharp, acidic taste.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gustatory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Saw-tooth-waves">
    <rdfs:label>Saw-tooth-waves</rdfs:label>
    <rdfs:comment>Vertex negative 2-5 Hz waves occuring in series during REM sleep</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-and-drowsiness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-significance-to-recording"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-amplitude-asymmetry"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#yocto">
    <rdfs:label>yocto</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-24.</rdfs:comment>
    <heda:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitModifier>
    <heda:conversionFactor>10^-24</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ethnicity">
    <rdfs:label>Ethnicity</rdfs:label>
    <rdfs:comment>Belong to a social group that has a common national or cultural tradition. Use with Label to avoid extension.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-trait">
        <rdfs:label>Agent-trait</rdfs:label>
        <rdfs:comment>A genetically, environmentally, or socially determined characteristic of an agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Stress">
    <rdfs:label>Stress</rdfs:label>
    <rdfs:comment>The negative mental, emotional, and physical reactions that occur when environmental stressors are perceived as exceeding the adaptive capacities of the individual.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Somatic-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Play">
    <rdfs:label>Play</rdfs:label>
    <rdfs:comment>Engage in activity for enjoyment and recreation rather than a serious or practical purpose.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-motor-myoclonic">
    <rdfs:label>Semiology-motor-myoclonic</rdfs:label>
    <rdfs:comment>Characterized by myoclonus. MYOCLONUS : sudden, brief (lower than 100 ms) involuntary single or multiple contraction(s) of muscles(s) or muscle groups of variable topography (axial, proximal limb, distal).</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-elementary-motor"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Body-part-location"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-centricity"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Groan">
    <rdfs:label>Groan</rdfs:label>
    <rdfs:comment>Make a deep inarticulate sound in response to pain or despair.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-vocally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clap-hands">
    <rdfs:label>Clap-hands</rdfs:label>
    <rdfs:comment>Strike the palms of against one another resoundingly, and usually repeatedly, especially to express approval.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#RoyalBlue">
    <rdfs:label>RoyalBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x4169E1.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#K-complex">
    <rdfs:label>K-complex</rdfs:label>
    <rdfs:comment>A burst of somewhat variable appearance, consisting most commonly of a high voltage negative slow wave followed by a smaller positive slow wave frequently associated with a sleep spindle. Duration greater than 0.5 s. Amplitude is generally maximal in the frontal vertex. K complexes occur during nonREM sleep, apparently spontaneously, or in response to sudden sensory / auditory stimuli, and are not specific for any individual sensory modality.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sleep-and-drowsiness"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-significance-to-recording"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-amplitude-asymmetry"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Race">
    <rdfs:label>Race</rdfs:label>
    <rdfs:comment>Belonging to a group sharing physical or social qualities as defined within a specified society. Use with Label to avoid extension.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Top-of">
    <rdfs:label>Top-of</rdfs:label>
    <rdfs:comment>(A, (Top-of, B)) means A is on the uppermost part, side, or surface of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Crouching">
    <rdfs:label>Crouching</rdfs:label>
    <rdfs:comment>Adopting a position where the knees are bent and the upper body is brought forward and down, sometimes to avoid detection or to defend oneself.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-postural-state"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Hyperventilation-good-effort-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Hyperventilation-good-effort">
