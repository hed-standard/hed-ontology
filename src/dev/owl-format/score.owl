  <hed:HedUnit rdf:about="https://purl.org/hed/aux#m-per-s_2">
    <rdfs:label>m-per-s^2</rdfs:label>
    <heda:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#accelerationUnits">
