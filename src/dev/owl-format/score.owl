  <owl:DatatypeProperty rdf:about="https://purl.org/hed/attributes/#topLevelTagGroup">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>topLevelTagGroup</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this tag (or its descendants) can only appear in a top-level tag group. A tag group can have at most one tag with this attribute.</rdfs:comment>
    <heda:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:boolProperty>
    <heda:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Tachypnea-respiration-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Tachypnea-respiration">
        <rdfs:label>Tachypnea-respiration</rdfs:label>
        <rdfs:comment>Cycles/min. Frequency can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Rate-of-change/Frequency</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Respiration-feature"/>
