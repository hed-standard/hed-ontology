    <heda:conversionFactor>10.0</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkSlateGray">
    <rdfs:label>DarkSlateGray</rdfs:label>
