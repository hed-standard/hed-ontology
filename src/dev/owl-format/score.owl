  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mouse-button">
    <rdfs:label>Mouse-button</rdfs:label>
    <rdfs:comment>An electric switch on a computer mouse which can be pressed or clicked to select or interact with an element of a graphical user interface.</rdfs:comment>
