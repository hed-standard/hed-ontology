    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-sensory"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Source-analysis-central-mesial">
    <rdfs:label>Source-analysis-central-mesial</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Source-analysis-brain-region"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#E">
    <rdfs:label>E</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^18.</rdfs:comment>
    <heda:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitSymbolModifier>
    <heda:conversionFactor>10^18</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Behavioral-evidence">
    <rdfs:label>Behavioral-evidence</rdfs:label>
    <rdfs:comment>An indication or conclusion based on the behavior of an agent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-effect-evidence"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Glyph">
    <rdfs:label>Glyph</rdfs:label>
    <rdfs:comment>A hieroglyphic character, symbol, or pictograph.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Below">
    <rdfs:label>Below</rdfs:label>
    <rdfs:comment>(A, (Below, B)) means A is in a place or position that is lower than the position of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Irregular-delta-or-theta-activity-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Irregular-delta-or-theta-activity-morphology"/>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#M">
    <rdfs:label>M</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^6.</rdfs:comment>
    <heda:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitSymbolModifier>
    <heda:conversionFactor>10^6</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MidnightBlue">
    <rdfs:label>MidnightBlue</rdfs:label>
    <rdfs:comment>CSS-color 0x191970.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Underneath">
    <rdfs:label>Underneath</rdfs:label>
    <rdfs:comment>(A, (Underneath, B)) means A is situated directly below and may be concealed by B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Phoneme">
