    <rdfs:comment>CSS-color 0xFFF5EE.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#External-evidence">
