    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Media-clip"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Postictal-semiology-quick-recovery-of-consciousness">
    <rdfs:label>Postictal-semiology-quick-recovery-of-consciousness</rdfs:label>
    <rdfs:comment>Quick recovery of awareness and responsiveness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Postictal-semiology-manifestation"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Belongs-to">
    <rdfs:label>Belongs-to</rdfs:label>
    <rdfs:comment>(A, (Belongs-to, B)) indicates that A is a member of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Temporal-intermittent-rhythmic-delta-activity-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-intermittent-rhythmic-delta-activity-morphology">
        <rdfs:label>Temporal-intermittent-rhythmic-delta-activity-morphology</rdfs:label>
        <rdfs:comment>Temporal intermittent rhythmic delta activity (TIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at over the temporal areas of one side of the head. Comment: most commonly associated with temporal lobe epilepsy.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Signal-morphology-property"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Low-voltage-fast-activity-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Low-voltage-fast-activity-morphology">
        <rdfs:label>Low-voltage-fast-activity-morphology</rdfs:label>
        <rdfs:comment>Refers to the fast, and often recruiting activity which can be recorded at the onset of an ictal discharge, particularly in invasive EEG recording of a seizure.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Signal-morphology-property"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#ECG-arrhythmia-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#ECG-arrhythmia">
        <rdfs:label>ECG-arrhythmia</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#ECG-feature"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
