  <hed:HedTag rdf:about="https://purl.org/hed/tag#Instructional">
    <rdfs:label>Instructional</rdfs:label>
    <rdfs:comment>Usually associated with a sensory event intended to give instructions to the participant about the task or behavior.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-event-role"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#atto">
