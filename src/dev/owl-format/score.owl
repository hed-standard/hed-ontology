    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Electrocerebral-inactivity">
    <rdfs:label>Electrocerebral-inactivity</rdfs:label>
    <rdfs:comment>Absence of any ongoing cortical electric activities; in all leads EEG is isoelectric or only contains artifacts. Sensitivity has to be increased up to 2 microV/mm; recording time: at least 30 minutes.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Background-activity-special-feature"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
