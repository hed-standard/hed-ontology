    <rdfs:label>Semiology-motor-astatic</rdfs:label>
    <rdfs:comment>Loss of erect posture that results from an atonic, myoclonic, or tonic mechanism. Synonym: drop attack.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-elementary-motor"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
