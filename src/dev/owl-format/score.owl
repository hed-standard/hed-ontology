    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed/attributes/#takesValue">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>takesValue</rdfs:label>
    <rdfs:comment>A schema attribute indicating the tag is a hashtag placeholder that is expected to be replaced with a user-defined value.</rdfs:comment>
    <heda:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:boolProperty>
    <heda:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Orienting-attention">
    <rdfs:label>Orienting-attention</rdfs:label>
    <rdfs:comment>Directing attention to a target stimulus.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-attentional-demand">
        <rdfs:label>Task-attentional-demand</rdfs:label>
        <rdfs:comment>Strategy for allocating attention toward goal-relevant information.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#FloralWhite">
    <rdfs:label>FloralWhite</rdfs:label>
    <rdfs:comment>CSS-color 0xFFFAF0.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ding">
    <rdfs:label>Ding</rdfs:label>
    <rdfs:comment>A short ringing sound such as that made by a bell, often to indicate a correct response or the expiration of time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Named-object-sound"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Point">
    <rdfs:label>Point</rdfs:label>
    <rdfs:comment>Draw attention to something by extending a finger or arm.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#MintCream">
    <rdfs:label>MintCream</rdfs:label>
    <rdfs:comment>CSS-color 0xF5FFFA.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#White-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Non-target">
    <rdfs:label>Non-target</rdfs:label>
    <rdfs:comment>Something other than that done or looked for. Also tag Expected if the Non-target is frequent.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
    <heda:relatedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Target">
        <rdfs:label>Target</rdfs:label>
        <rdfs:comment>Something fixed as a goal, destination, or point of examination.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-stimulus-role"/>
      </hed:HedTag>
    </heda:relatedTag>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Control-variable-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Name of the control variable.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Control-variable">
        <rdfs:label>Control-variable</rdfs:label>
        <rdfs:comment>An aspect of the experiment that is fixed throughout the study and usually is explicitly controlled.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Organizational-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#nameClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Textblock">
    <rdfs:label>Textblock</rdfs:label>
    <rdfs:comment>A block of text.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Language-item"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-motor-postural">
    <rdfs:label>Semiology-motor-postural</rdfs:label>
    <rdfs:comment>Adoption of a posture that may be bilaterally symmetric or asymmetric (as in a fencing posture).</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-elementary-motor"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Body-part-location"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-centricity"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Jerk-rate-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Jerk-rate">
        <rdfs:label>Jerk-rate</rdfs:label>
        <rdfs:comment>Magnitude of the rate at which the acceleration of an object changes with respect to time. The direction of change should be given separately.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <heda:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#jerkUnits">
        <rdfs:label>jerkUnits</rdfs:label>
        <heda:defaultUnits>m-per-s^3</heda:defaultUnits>
      </hed:HedUnitClass>
    </heda:unitClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sweat-artifact">
    <rdfs:label>Sweat-artifact</rdfs:label>
    <rdfs:comment>Is a low amplitude undulating waveform that is usually greater than 2 seconds and may appear to be an unstable baseline.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Biological-artifact"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Multifocal-finding"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Artifact-significance-to-recording"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-sensory-headache">
    <rdfs:label>Semiology-sensory-headache</rdfs:label>
    <rdfs:comment>Headache occurring in close temporal proximity to the seizure or as the sole seizure manifestation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-sensory"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#DarkOrchid">
    <rdfs:label>DarkOrchid</rdfs:label>
    <rdfs:comment>CSS-color 0x9932CC.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#BurlyWood">
    <rdfs:label>BurlyWood</rdfs:label>
