        <rdfs:comment>Events/h. Frequency can be tagged with base schema /Property/Data-property/Data-value/Spatiotemporal-value/Rate-of-change/Frequency</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Respiration-feature"/>
