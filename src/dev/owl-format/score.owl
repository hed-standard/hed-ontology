<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:heda="https://purl.org/hed/attributes/#"
  xmlns:hed="https://purl.org/hed#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Blunt-periodic-discharge-sharpness-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Blunt-periodic-discharge-sharpness">
        <rdfs:label>Blunt-periodic-discharge-sharpness</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Periodic-discharge-sharpness"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass>
      <hed:HedValueClass rdf:about="https://purl.org/hed/aux#textClass">
        <rdfs:label>textClass</rdfs:label>
        <rdfs:comment>Value class designating values that have the characteristics of text such as in descriptions.</rdfs:comment>
        <heda:allowedCharacter>letters</heda:allowedCharacter>
        <heda:allowedCharacter>digits</heda:allowedCharacter>
        <heda:allowedCharacter>blank</heda:allowedCharacter>
        <heda:allowedCharacter>+</heda:allowedCharacter>
        <heda:allowedCharacter>-</heda:allowedCharacter>
        <heda:allowedCharacter>:</heda:allowedCharacter>
        <heda:allowedCharacter>;</heda:allowedCharacter>
        <heda:allowedCharacter>.</heda:allowedCharacter>
        <heda:allowedCharacter>/</heda:allowedCharacter>
        <heda:allowedCharacter>(</heda:allowedCharacter>
        <heda:allowedCharacter>)</heda:allowedCharacter>
        <heda:allowedCharacter>?</heda:allowedCharacter>
        <heda:allowedCharacter>*</heda:allowedCharacter>
        <heda:allowedCharacter>%</heda:allowedCharacter>
        <heda:allowedCharacter>$</heda:allowedCharacter>
        <heda:allowedCharacter>@</heda:allowedCharacter>
      </hed:HedValueClass>
    </heda:valueClass>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#$">
    <rdfs:label>$</rdfs:label>
    <heda:unitClass>
      <hed:HedUnitClass rdf:about="https://purl.org/hed/aux#currencyUnits">
        <rdfs:label>currencyUnits</rdfs:label>
        <rdfs:comment>Units indicating the worth of something.</rdfs:comment>
        <heda:defaultUnits>$</heda:defaultUnits>
      </hed:HedUnitClass>
    </heda:unitClass>
    <heda:unitPrefix rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:unitPrefix>
    <heda:unitSymbol rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:unitSymbol>
    <heda:conversionFactor>1.0</heda:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Ankle">
    <rdfs:label>Ankle</rdfs:label>
    <rdfs:comment>A gliding joint between the distal ends of the tibia and fibula and the proximal end of the talus.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Lower-extremity">
        <rdfs:label>Lower-extremity</rdfs:label>
        <rdfs:comment>Refers to the whole inferior limb (leg and/or foot).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Postictal-semiology-nose-wiping">
    <rdfs:label>Postictal-semiology-nose-wiping</rdfs:label>
    <rdfs:comment>Noes-wiping usually within 60 sec of seizure offset, usually with the hand ipsilateral to the seizure onset.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Postictal-semiology-manifestation">
        <rdfs:label>Postictal-semiology-manifestation</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Brain-laterality">
        <rdfs:label>Brain-laterality</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Location-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-event-count">
        <rdfs:label>Episode-event-count</rdfs:label>
        <rdfs:comment>Number of stereotypical episodes during the recording.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Slow-sharp-wave-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Slow-sharp-wave-morphology">
        <rdfs:label>Slow-sharp-wave-morphology</rdfs:label>
        <rdfs:comment>A transient that bears all the characteristics of a sharp-wave, but exceeds 200 ms. Synonym: blunted sharp wave.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Signal-morphology-property"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Detect">
    <rdfs:label>Detect</rdfs:label>
    <rdfs:comment>Discover or identify the presence or existence of something.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Think">
        <rdfs:label>Think</rdfs:label>
        <rdfs:comment>Direct the mind toward someone or something or use the mind actively to form connected ideas.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Action"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Orchid">
    <rdfs:label>Orchid</rdfs:label>
    <rdfs:comment>CSS-color 0xDA70D6.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Purple-color">
        <rdfs:label>Purple-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Statistical-uncertainty-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Statistical-uncertainty">
        <rdfs:label>Statistical-uncertainty</rdfs:label>
        <rdfs:comment>A measure of the inherent variability of repeated observation measurements of a quantity including quantities evaluated by statistical methods and by other means.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Statistical-value"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass>
      <hed:HedValueClass rdf:about="https://purl.org/hed/aux#numericClass">
        <rdfs:label>numericClass</rdfs:label>
        <rdfs:comment>Value must be a valid numerical value.</rdfs:comment>
        <heda:allowedCharacter>digits</heda:allowedCharacter>
        <heda:allowedCharacter>E</heda:allowedCharacter>
        <heda:allowedCharacter>e</heda:allowedCharacter>
        <heda:allowedCharacter>+</heda:allowedCharacter>
        <heda:allowedCharacter>-</heda:allowedCharacter>
        <heda:allowedCharacter>.</heda:allowedCharacter>
      </hed:HedValueClass>
    </heda:valueClass>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Switch-attention">
    <rdfs:label>Switch-attention</rdfs:label>
    <rdfs:comment>Transfer attention from one focus to another.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Think"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Uncommon-finding-incidence-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Uncommon-finding-incidence">
        <rdfs:label>Uncommon-finding-incidence</rdfs:label>
        <rdfs:comment>1/5 min to 1/h.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finding-incidence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Saccade">
    <rdfs:label>Saccade</rdfs:label>
    <rdfs:comment>Move eyes rapidly between fixation points.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Move-eyes">
        <rdfs:label>Move-eyes</rdfs:label>
        <rdfs:comment>Move eyes.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-body-part"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Single-discharge-pattern-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Single-discharge-pattern">
        <rdfs:label>Single-discharge-pattern</rdfs:label>
        <rdfs:comment>Applies to the intra-burst pattern: a graphoelement that is not repetitive; before and after the graphoelement one can distinguish the background activity.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-incidence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Other-polygraphic-channel-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Other-polygraphic-channel">
        <rdfs:label>Other-polygraphic-channel</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Polygraphic-channel-finding"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Six-Hz-spike-slow-wave">
    <rdfs:label>Six-Hz-spike-slow-wave</rdfs:label>
    <rdfs:comment>Spike and slow wave complexes at 4-7Hz, but mostly at 6 Hz occurring generally in brief bursts bilaterally and synchronously, symmetrically or asymmetrically, and either confined to or of larger amplitude over the posterior or anterior regions of the head. The spike has a strong positive component. Amplitude varies but is generally smaller than that of spike-and slow-wave complexes repeating at slower rates. Comment: this pattern should be distinguished from epileptiform discharges. Synonym: wave and spike phantom.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Uncertain-significant-pattern">
        <rdfs:label>Uncertain-significant-pattern</rdfs:label>
        <rdfs:comment>EEG graphoelements or rhythms that resemble abnormal patterns but that are not necessarily associated with a pathology, and the physician does not consider them abnormal in the context of the scored recording (like normal variants and patterns).</rdfs:comment>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Brain-region">
        <rdfs:label>Brain-region</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Location-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sensors">
        <rdfs:label>Sensors</rdfs:label>
        <rdfs:comment>Lists all corresponding sensors (electrodes/channels in montage). The sensor-group is selected from a list defined in the site-settings for each EEG-lab.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Location-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Appearance-mode">
        <rdfs:label>Appearance-mode</rdfs:label>
        <rdfs:comment>Describes how the non-ictal EEG pattern/graphoelement is distributed through the recording.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Time-related-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Discharge-pattern">
        <rdfs:label>Discharge-pattern</rdfs:label>
        <rdfs:comment>Describes the organization of the EEG signal within the discharge (distinguish between single and repetitive discharges)</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Time-related-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Postictal-semiology-sleep">
    <rdfs:label>Postictal-semiology-sleep</rdfs:label>
    <rdfs:comment>Invincible need to sleep after a seizure.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Postictal-semiology-manifestation"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Photomyogenic-response">
    <rdfs:label>Photomyogenic-response</rdfs:label>
    <rdfs:comment>A response to intermittent photic stimulation characterized by the appearance in the record of brief, repetitive muscular artifacts (spikes) over the anterior regions of the head. These often increase gradually in amplitude as stimuli are continued and cease promptly when the stimulus is withdrawn. Comment: this response is frequently associated with flutter of the eyelids and vertical oscillations of the eyeballs and sometimes with discrete jerking mostly involving the musculature of the face and head. (Preferred to synonym: photo-myoclonic response).</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Physiologic-pattern">
        <rdfs:label>Physiologic-pattern</rdfs:label>
        <rdfs:comment>EEG graphoelements or rhythms that are considered normal. They only should be scored if the physician considers that they have a specific clinical significance for the recording.</rdfs:comment>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Non-informative">
    <rdfs:label>Non-informative</rdfs:label>
    <rdfs:comment>Something that is not useful in forming an opinion or judging an outcome.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Task-stimulus-role">
        <rdfs:label>Task-stimulus-role</rdfs:label>
        <rdfs:comment>The role the stimulus plays in the task.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-property"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hill">
    <rdfs:label>Hill</rdfs:label>
    <rdfs:comment>A rounded elevation of limited extent rising above the surrounding land with local relief of less than 300m.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Natural-feature">
        <rdfs:label>Natural-feature</rdfs:label>
        <rdfs:comment>A feature that occurs in nature. A prominent or identifiable aspect, region, or site of interest.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Natural-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Episode-tongue-biting-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-tongue-biting">
        <rdfs:label>Episode-tongue-biting</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-exists"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-absence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Apnoe-respiration-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Apnoe-respiration">
        <rdfs:label>Apnoe-respiration</rdfs:label>
        <rdfs:comment>Add duration (range in seconds) and comments in free text.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Respiration-feature"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed/attributes/#deprecatedFrom">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedElement"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>deprecatedFrom</rdfs:label>
    <rdfs:comment>Indicates that this element is deprecated. The value of the attribute is the latest schema version in which the element appeared in undeprecated form.</rdfs:comment>
    <heda:elementProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:elementProperty>
  </owl:DatatypeProperty>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#giga">
    <rdfs:label>giga</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^9.</rdfs:comment>
    <heda:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitModifier>
    <heda:conversionFactor>10^9</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Expert-annotation">
    <rdfs:label>Expert-annotation</rdfs:label>
    <rdfs:comment>An explanatory or critical comment or other in-context information provided by an authority.</rdfs:comment>
    <hed:hasHedParent>
