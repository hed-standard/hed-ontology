    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Source-analysis-temporal-lateral-posterior">
    <rdfs:label>Source-analysis-temporal-lateral-posterior</rdfs:label>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Source-analysis-brain-region"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Sound-envelope-decay-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sound-envelope-decay">
        <rdfs:label>Sound-envelope-decay</rdfs:label>
        <rdfs:comment>The time taken for the subsequent run down from the attack level to the designated sustain level.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Sound-envelope"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Ictal-EEG-patterns-obscured-by-artifacts-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Ictal-EEG-patterns-obscured-by-artifacts">
        <rdfs:label>Ictal-EEG-patterns-obscured-by-artifacts</rdfs:label>
        <rdfs:comment>The interpretation of the EEG is not possible due to artifacts.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Ictal-EEG-patterns"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Performed-by">
    <rdfs:label>Performed-by</rdfs:label>
    <rdfs:comment>(A, (Performed-by, B)) indicates that the action or procedure A was carried out by agent B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Brain-laterality-diffuse-asynchronous-Placeholder">
    <rdfs:label>#</rdfs:label>
