    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Printer-resolution">
        <rdfs:label>Printer-resolution</rdfs:label>
        <rdfs:comment>Resolution of a printer, usually expressed as the number of dots-per-inch for a printer.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
