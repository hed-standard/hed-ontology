    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Includes">
    <rdfs:label>Includes</rdfs:label>
    <rdfs:comment>(A, (Includes, B)) indicates that A has B as a member or part.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Connective-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Posterior-dominant-rhythm-eye-opening-reactivity-reduced-right-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>free text</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Posterior-dominant-rhythm-eye-opening-reactivity-reduced-right">
        <rdfs:label>Posterior-dominant-rhythm-eye-opening-reactivity-reduced-right</rdfs:label>
