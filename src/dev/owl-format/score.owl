      <hed:HedTag rdf:about="https://purl.org/hed/tag#Directional-relation">
        <rdfs:label>Directional-relation</rdfs:label>
        <rdfs:comment>A relationship indicating direction of change of one entity relative to another. The first entity is the focus.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Sleep-related-arousal">
    <rdfs:label>Sleep-related-arousal</rdfs:label>
    <rdfs:comment>Normal.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Sleep-related-episode">
        <rdfs:label>Sleep-related-episode</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-phase">
        <rdfs:label>Episode-phase</rdfs:label>
        <rdfs:comment>The electroclinical findings (i.e., the seizure semiology and the ictal EEG) are divided in three phases: onset, propagation, and postictal.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Seizure-semiology-manifestation"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Postictal-semiology-manifestation"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Ictal-EEG-patterns"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Finding-significance-to-recording">
        <rdfs:label>Finding-significance-to-recording</rdfs:label>
        <rdfs:comment>Significance of finding. When normal/abnormal could be labeled with base schema Normal/Abnormal tags.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Other-finding-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-consciousness">
        <rdfs:label>Episode-consciousness</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-awareness">
        <rdfs:label>Episode-awareness</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-exists"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-absence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Clinical-EEG-temporal-relationship">
        <rdfs:label>Clinical-EEG-temporal-relationship</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#State-episode-start">
        <rdfs:label>State-episode-start</rdfs:label>
        <rdfs:comment>State at the start of the episode.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-postictal-phase">
        <rdfs:label>Episode-postictal-phase</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-not-possible-to-determine"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-prodrome">
        <rdfs:label>Episode-prodrome</rdfs:label>
        <rdfs:comment>Prodrome is a preictal phenomenon, and it is defined as a subjective or objective clinical alteration (e.g., ill-localized sensation or agitation) that heralds the onset of an epileptic seizure but does not form part of it (Blume et al., 2001). Therefore, prodrome should be distinguished from aura (which is an ictal phenomenon).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-time-context-property"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-exists"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Property-absence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </heda:suggestedTag>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-tongue-biting"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
