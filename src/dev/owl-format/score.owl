        <rdfs:comment>Reduced left side reactivity.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Posterior-dominant-rhythm-eye-opening-reactivity"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Shake-head">
    <rdfs:label>Shake-head</rdfs:label>
    <rdfs:comment>Turn head from side to side as a way of showing disagreement or refusal.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#RGB-blue-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>B value of RGB between 0 and 1.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#RGB-blue">
        <rdfs:label>RGB-blue</rdfs:label>
        <rdfs:comment>The blue component.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#RGB-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hum">
    <rdfs:label>Hum</rdfs:label>
    <rdfs:comment>Make a low, steady continuous sound like that of a bee. Sing with the lips closed and without uttering speech.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Wave">
    <rdfs:label>Wave</rdfs:label>
    <rdfs:comment>Raise hand and move left and right, as a greeting or sign of departure.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Move-upper-extremity"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Hyperventilation-provoked-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Hyperventilation-provoked">
        <rdfs:label>Hyperventilation-provoked</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Provocative-factor"/>
