    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Task-effect-evidence"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Indigo">
    <rdfs:label>Indigo</rdfs:label>
    <rdfs:comment>CSS-color 0x4B0082.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Salty">
    <rdfs:label>Salty</rdfs:label>
    <rdfs:comment>Tasting of or like salt.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Gustatory-attribute"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Indoors">
    <rdfs:label>Indoors</rdfs:label>
    <rdfs:comment>Located inside a building or enclosure.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Environmental-property"/>
