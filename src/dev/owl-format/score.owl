    <heda:suggestedTag>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Irregular-delta-or-theta-activity-morphology">
        <rdfs:label>Irregular-delta-or-theta-activity-morphology</rdfs:label>
        <rdfs:comment>EEG activity consisting of repetitive waves of inconsistent wave-duration but in delta and/or theta rang (greater than 125 ms).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Signal-morphology-property"/>
