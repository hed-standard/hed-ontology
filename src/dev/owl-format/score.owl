      <hed:HedTag rdf:about="https://purl.org/hed/tag#Step">
        <rdfs:label>Step</rdfs:label>
        <rdfs:comment>Put one leg in front of the other and shift weight onto it.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Move-lower-extremity"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Luminance">
    <rdfs:label>Luminance</rdfs:label>
    <rdfs:comment>A quality that exists by virtue of the luminous intensity per unit area projected in a given direction.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visual-attribute"/>
