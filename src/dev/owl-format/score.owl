  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Abundant-finding-incidence-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Abundant-finding-incidence">
        <rdfs:label>Abundant-finding-incidence</rdfs:label>
        <rdfs:comment>Greater than 1/10 s).</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Finding-incidence"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#tera">
    <rdfs:label>tera</rdfs:label>
    <rdfs:comment>SI unit multiple representing 10^12.</rdfs:comment>
    <heda:SIUnitModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitModifier>
    <heda:conversionFactor>10^12</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Clear-throat">
    <rdfs:label>Clear-throat</rdfs:label>
    <rdfs:comment>Cough slightly so as to speak more clearly, attract attention, or to express hesitancy before saying something awkward.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
    <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Move-head"/>
  </hed:HedTag>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#m">
    <rdfs:label>m</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-3.</rdfs:comment>
