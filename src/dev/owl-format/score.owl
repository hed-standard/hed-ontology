    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#ECG-sinus-rhythm-Placeholder">
    <rdfs:label>#</rdfs:label>
