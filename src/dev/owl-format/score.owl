  <owl:ObjectProperty rdf:about="https://purl.org/hed/attributes/#relatedTag">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:label>relatedTag</rdfs:label>
    <rdfs:comment>A schema attribute suggesting HED tags that are closely related to this tag. This attribute is used by tagging tools.</rdfs:comment>
    <heda:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:nodeProperty>
    <heda:isInheritedProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:isInheritedProperty>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed/attributes/#requireChild">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedTag"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>requireChild</rdfs:label>
    <rdfs:comment>A schema attribute indicating that one of the node elements descendants must be included when using this tag.</rdfs:comment>
    <heda:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:boolProperty>
    <heda:nodeProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:nodeProperty>
  </owl:DatatypeProperty>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Loudness-Placeholder">
