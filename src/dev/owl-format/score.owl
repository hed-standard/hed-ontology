        <rdfs:comment>A parallelogram with four right angles.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#2D-shape"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Apnea-hypopnea-index-respiration-Placeholder">
