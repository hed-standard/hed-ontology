    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Purple-color"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Very-brief-periodic-discharge-duration-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Very-brief-periodic-discharge-duration">
        <rdfs:label>Very-brief-periodic-discharge-duration</rdfs:label>
        <rdfs:comment>Less than 10 sec.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Periodic-discharge-duration"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedUnitModifier rdf:about="https://purl.org/hed/aux/unit_modifier#p">
    <rdfs:label>p</rdfs:label>
    <rdfs:comment>SI unit submultiple representing 10^-12.</rdfs:comment>
    <heda:SIUnitSymbolModifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnitSymbolModifier>
    <heda:conversionFactor>10^-12</heda:conversionFactor>
  </hed:HedUnitModifier>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Postictal-semiology-impaired-cognition">
    <rdfs:label>Postictal-semiology-impaired-cognition</rdfs:label>
    <rdfs:comment>Decreased Cognitive performance involving one or more of perception, attention, emotion, memory, execution, praxis, speech.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Postictal-semiology-manifestation"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Dots">
    <rdfs:label>Dots</rdfs:label>
    <rdfs:comment>A small round mark or spot.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Pattern">
        <rdfs:label>Pattern</rdfs:label>
        <rdfs:comment>An arrangement of objects, facts, behaviors, or other things which have scientific, mathematical, geometric, statistical, or other meaning.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Geometric-object"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#PowderBlue">
    <rdfs:label>PowderBlue</rdfs:label>
    <rdfs:comment>CSS-color 0xB0E0E6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Joyful">
    <rdfs:label>Joyful</rdfs:label>
    <rdfs:comment>Feeling delight or intense happiness.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#LightBlue">
    <rdfs:label>LightBlue</rdfs:label>
    <rdfs:comment>CSS-color 0xADD8E6.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Blue-color"/>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed/attributes/#allowedCharacter">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedValueClass"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>allowedCharacter</rdfs:label>
    <rdfs:comment>A schema attribute of value classes specifying a special character that is allowed in expressing the value of a placeholder. Normally the allowed characters are listed individually. However, the word letters designates the upper and lower case alphabetic characters and the word digits designates the digits 0-9. The word blank designates the blank character.</rdfs:comment>
    <heda:valueClassProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:valueClassProperty>
  </owl:DatatypeProperty>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Delay-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Delay">
        <rdfs:label>Delay</rdfs:label>
        <rdfs:comment>The time at which an event start time is delayed from the current onset time. This tag defines the start time of an event of temporal extent and may be used with the Duration tag.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Temporal-value"/>
        <heda:topLevelTagGroup rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:topLevelTagGroup>
        <heda:reserved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:reserved>
        <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Duration"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Age-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Age">
        <rdfs:label>Age</rdfs:label>
        <rdfs:comment>Length of time elapsed time since birth of the agent.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-trait"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Write">
    <rdfs:label>Write</rdfs:label>
    <rdfs:comment>Communicate or express by means of letters or symbols written or imprinted on a surface.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Perform"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Prone">
    <rdfs:label>Prone</rdfs:label>
    <rdfs:comment>Positioned in a recumbent body position whereby the person lies on its stomach and faces downward.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Agent-postural-state">
        <rdfs:label>Agent-postural-state</rdfs:label>
        <rdfs:comment>Pertaining to the position in which agent holds their body.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-state"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Mu-rhythm">
    <rdfs:label>Mu-rhythm</rdfs:label>
    <rdfs:comment>EEG rhythm at 7-11 Hz composed of arch-shaped waves occurring over the central or centro-parietal regions of the scalp during wakefulness. Amplitudes varies but is mostly below 50 microV. Blocked or attenuated most clearly by contralateral movement, thought of movement, readiness to move or tactile stimulation.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Background-activity"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-frequency"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-significance-to-recording"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Temporal-resolution-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-resolution">
        <rdfs:label>Temporal-resolution</rdfs:label>
        <rdfs:comment>Measures the ability of a sensor to  resolve features in time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Data-resolution"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-autonomic-cardiovascular">
    <rdfs:label>Semiology-autonomic-cardiovascular</rdfs:label>
    <rdfs:comment>Modifications of heart rate (tachycardia, bradycardia), cardiac arrhythmias (such as sinus arrhythmia, sinus arrest, supraventricular tachycardia, atrial premature depolarizations, ventricular premature depolarizations, atrio-ventricular block, bundle branch block, atrioventricular nodal escape rhythm, asystole).</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-autonomic"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Episode-event-count"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Temporal-rate-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Temporal-rate">
        <rdfs:label>Temporal-rate</rdfs:label>
        <rdfs:comment>The number of items per unit of time.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Rate-of-change"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#frequencyUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Bicycle">
    <rdfs:label>Bicycle</rdfs:label>
    <rdfs:comment>A human-powered, pedal-driven, single-track vehicle, having two wheels attached to a frame, one behind the other.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Vehicle"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#IndianRed">
    <rdfs:label>IndianRed</rdfs:label>
    <rdfs:comment>CSS-color 0xCD5C5C.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Red-color">
        <rdfs:label>Red-color</rdfs:label>
        <rdfs:comment>CSS color group.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#CSS-color"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Play-instrument">
    <rdfs:label>Play-instrument</rdfs:label>
    <rdfs:comment>Make musical sounds using an instrument.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-musically"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Greater-than">
    <rdfs:label>Greater-than</rdfs:label>
    <rdfs:comment>(A, (Greater-than, B)) indicates that the relative size or order of A is bigger than that of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Comparative-relation"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Wink">
    <rdfs:label>Wink</rdfs:label>
    <rdfs:comment>Close and open one eye quickly, typically to indicate that something is a joke or a secret or as a signal of affection or greeting.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Communicate-gesturally"/>
    <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Move-face"/>
    <heda:relatedTag rdf:resource="https://purl.org/hed/tag#Move-eyes"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Or">
    <rdfs:label>Or</rdfs:label>
    <rdfs:comment>(A, (Or, B)) means at least one of A and B are in effect.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Logical-relation">
        <rdfs:label>Logical-relation</rdfs:label>
        <rdfs:comment>Indicating a logical relationship between entities. The first entity is usually the focus.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Relation"/>
      </hed:HedTag>
    </hed:hasHedParent>
  </hed:HedTag>
  <owl:DatatypeProperty rdf:about="https://purl.org/hed/attributes/#SIUnitModifier">
    <rdfs:domain rdf:resource="https://purl.org/hed#HedUnitModifier"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/hed#schemaAttributeDatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label>SIUnitModifier</rdfs:label>
    <rdfs:comment>A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a base unit rather than a unit symbol.</rdfs:comment>
    <heda:boolProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:boolProperty>
    <heda:unitModifierProperty rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:unitModifierProperty>
  </owl:DatatypeProperty>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Runs-of-rapid-spikes-morphology-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Runs-of-rapid-spikes-morphology"/>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Experiment-procedure">
    <rdfs:label>Experiment-procedure</rdfs:label>
    <rdfs:comment>An event indicating an experimental procedure, as in performing a saliva swab during the experiment or administering a survey.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Event"/>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#second">
    <rdfs:label>second</rdfs:label>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#timeUnits"/>
    <heda:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnit>
    <heda:conversionFactor>1.0</heda:conversionFactor>
  </hed:HedUnit>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Rudimentary-spike-wave-complex">
    <rdfs:label>Rudimentary-spike-wave-complex</rdfs:label>
    <rdfs:comment>Synonym: Pseudo petit mal discharge. Paroxysmal discharge that consists of generalized or nearly generalized high voltage 3 to 4/sec waves with poorly developed spike in the positive trough between the slow waves, occurring in drowsiness only. It is found only in infancy and early childhood when marked hypnagogic rhythmical theta activity is paramount in the drowsy state.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Uncertain-significant-pattern"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Art-installation">
    <rdfs:label>Art-installation</rdfs:label>
    <rdfs:comment>A large-scale, mixed-media constructions, often designed for a specific place or for a temporary period of time.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Visualization"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Content">
    <rdfs:label>Content</rdfs:label>
    <rdfs:comment>Feeling  satisfaction with things as they are.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Agent-emotional-state"/>
  </hed:HedTag>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Around">
    <rdfs:label>Around</rdfs:label>
    <rdfs:comment>(A, (Around, B)) means A is in or near the present place or situation of B.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Spatial-relation"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Generalized-photoparoxysmal-intermittent-photic-stimulation-response-limited-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Generalized-photoparoxysmal-intermittent-photic-stimulation-response-limited">
        <rdfs:label>Generalized-photoparoxysmal-intermittent-photic-stimulation-response-limited</rdfs:label>
        <rdfs:comment>Limited to the stimulus-train.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Intermittent-photic-stimulation-effect"/>
        <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Finding-frequency"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Semiology-language-related-other-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Semiology-language-related-other">
        <rdfs:label>Semiology-language-related-other</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Semiology-language-related"/>
        <heda:requireChild rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:requireChild>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Episode-consciousness-not-tested-Placeholder">
    <rdfs:label>#</rdfs:label>
    <rdfs:comment>Free text.</rdfs:comment>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Episode-consciousness-not-tested">
        <rdfs:label>Episode-consciousness-not-tested</rdfs:label>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Episode-consciousness"/>
        <heda:inLibrary>score</heda:inLibrary>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#textClass"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Hiccup">
    <rdfs:label>Hiccup</rdfs:label>
    <rdfs:comment>Involuntarily spasm  the diaphragm and respiratory organs, with a sudden closure of the glottis and a characteristic sound like that of a cough.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Breathe"/>
  </hed:HedTag>
  <hed:HedPlaceholder rdf:about="https://purl.org/hed/tag#Depth-Placeholder">
    <rdfs:label>#</rdfs:label>
    <hed:hasHedParent>
      <hed:HedTag rdf:about="https://purl.org/hed/tag#Depth">
        <rdfs:label>Depth</rdfs:label>
        <rdfs:comment>The distance from the surface of something especially from the perspective of looking from the front.</rdfs:comment>
        <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Size"/>
      </hed:HedTag>
    </hed:hasHedParent>
    <heda:takesValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:takesValue>
    <heda:valueClass rdf:resource="https://purl.org/hed/aux#numericClass"/>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#physicalLengthUnits"/>
  </hed:HedPlaceholder>
  <hed:HedTag rdf:about="https://purl.org/hed/tag#Needle-like-occipital-spikes-blind">
    <rdfs:label>Needle-like-occipital-spikes-blind</rdfs:label>
    <rdfs:comment>Spike discharges of a particularly fast and needle-like character develop over the occipital region in most congenitally blind children. Completely disappear during childhood or adolescence.</rdfs:comment>
    <hed:hasHedParent rdf:resource="https://purl.org/hed/tag#Uncertain-significant-pattern"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-laterality"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Brain-region"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Sensors"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Appearance-mode"/>
    <heda:suggestedTag rdf:resource="https://purl.org/hed/tag#Discharge-pattern"/>
    <heda:inLibrary>score</heda:inLibrary>
  </hed:HedTag>
  <hed:HedUnit rdf:about="https://purl.org/hed/aux#cd">
    <rdfs:label>cd</rdfs:label>
    <rdfs:comment>Units used to express light intensity.</rdfs:comment>
    <heda:unitClass rdf:resource="https://purl.org/hed/aux#intensityUnits"/>
    <heda:SIUnit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</heda:SIUnit>
