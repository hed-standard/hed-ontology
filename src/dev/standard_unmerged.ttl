@prefix hed: <https://purl.org/hed/core#> .
@prefix heda: <https://purl.org/hed/attributes/#> .
@prefix hedt: <https://purl.org/hed/tag#> .
@prefix hedu: <https://purl.org/hed/aux#> .
@prefix hedum: <https://purl.org/hed/aux/unit_modifier#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

heda:SIUnit a owl:DatatypeProperty ;
    rdfs:label "SIUnit" ;
    rdfs:comment "A schema attribute indicating that this unit element is an SI unit and can be modified by multiple and submultiple names. Note that some units such as byte are designated as SI units although they are not part of the standard." ;
    rdfs:domain hed:HedUnit ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitProperty true .

heda:SIUnitModifier a owl:DatatypeProperty ;
    rdfs:label "SIUnitModifier" ;
    rdfs:comment "A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a base unit rather than a unit symbol." ;
    rdfs:domain hed:HedUnitModifier ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitModifierProperty true .

heda:SIUnitSymbolModifier a owl:DatatypeProperty ;
    rdfs:label "SIUnitSymbolModifier" ;
    rdfs:comment "A schema attribute indicating that this SI unit modifier represents a multiple or submultiple of a unit symbol rather than a base symbol." ;
    rdfs:domain hed:HedUnitModifier ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitModifierProperty true .

heda:allowedCharacter a owl:DatatypeProperty ;
    rdfs:label "allowedCharacter" ;
    rdfs:comment "A schema attribute of value classes specifying a special character that is allowed in expressing the value of a placeholder. Normally the allowed characters are listed individually. However, the word letters designates the upper and lower case alphabetic characters and the word digits designates the digits 0-9. The word blank designates the blank character." ;
    rdfs:domain hed:HedValueClass ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:valueClassProperty true .

heda:boolProperty a owl:AnnotationProperty ;
    rdfs:label "boolProperty" ;
    rdfs:comment "Indicates that the schema attribute represents something that is either true or false and does not have a value. Attributes without this value are assumed to have string values." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:conversionFactor a owl:DatatypeProperty ;
    rdfs:label "conversionFactor" ;
    rdfs:comment "The multiplicative factor to multiply these units to convert to default units." ;
    rdfs:domain hed:HedUnit,
        hed:HedUnitModifier ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:unitModifierProperty true ;
    heda:unitProperty true .

heda:defaultUnits a owl:ObjectProperty ;
    rdfs:label "defaultUnits" ;
    rdfs:comment "A schema attribute of unit classes specifying the default units to use if the placeholder has a unit class but the substituted value has no units." ;
    rdfs:domain hed:HedUnitClass ;
    rdfs:range hed:HedUnit ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:unitClassProperty true .

heda:deprecatedFrom a owl:DatatypeProperty ;
    rdfs:label "deprecatedFrom" ;
    rdfs:comment "Indicates that this element is deprecated. The value of the attribute is the latest schema version in which the element appeared in undeprecated form." ;
    rdfs:domain hed:HedElement ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:elementProperty true .

heda:elementProperty a owl:AnnotationProperty ;
    rdfs:label "elementProperty" ;
    rdfs:comment "Indicates this schema attribute can apply to any type of element(tag term, unit class, etc)." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:extensionAllowed a owl:DatatypeProperty ;
    rdfs:label "extensionAllowed" ;
    rdfs:comment "A schema attribute indicating that users can add unlimited levels of child nodes under this tag. This tag is propagated to child nodes with the exception of the hashtag placeholders." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:isInheritedProperty true ;
    heda:nodeProperty true .

heda:inLibrary a owl:DatatypeProperty ;
    rdfs:label "inLibrary" ;
    rdfs:comment "Indicates this schema element came from the named library schema, not the standard schema. This attribute is added by tools when a library schema is merged into its partnered standard schema." ;
    rdfs:domain hed:HedElement ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:elementProperty true .

heda:isInheritedProperty a owl:AnnotationProperty ;
    rdfs:label "isInheritedProperty" ;
    rdfs:comment "Indicates that this attribute is inherited by child nodes. This property only applies to schema attributes for nodes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:nodeProperty a owl:AnnotationProperty ;
    rdfs:label "nodeProperty" ;
    rdfs:comment "Indicates this schema attribute applies to node (tag-term) elements. This was added to allow for an attribute to apply to multiple elements." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:recommended a owl:DatatypeProperty ;
    rdfs:label "recommended" ;
    rdfs:comment "A schema attribute indicating that the event-level HED string should include this tag." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:relatedTag a owl:ObjectProperty ;
    rdfs:label "relatedTag" ;
    rdfs:comment "A schema attribute suggesting HED tags that are closely related to this tag. This attribute is used by tagging tools." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedTag ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:isInheritedProperty true ;
    heda:nodeProperty true .

heda:requireChild a owl:DatatypeProperty ;
    rdfs:label "requireChild" ;
    rdfs:comment "A schema attribute indicating that one of the node elements descendants must be included when using this tag." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:required a owl:DatatypeProperty ;
    rdfs:label "required" ;
    rdfs:comment "A schema attribute indicating that every event-level HED string should include this tag." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:reserved a owl:DatatypeProperty ;
    rdfs:label "reserved" ;
    rdfs:comment "A schema attribute indicating that this tag has special meaning and requires special handling by tools." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:rooted a owl:ObjectProperty ;
    rdfs:label "rooted" ;
    rdfs:comment "Indicates a top-level library schema node is identical to a node of the same name in the partnered standard schema. This attribute can only appear in nodes that have the inLibrary schema attribute." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedTag ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:nodeProperty true .

heda:suggestedTag a owl:ObjectProperty ;
    rdfs:label "suggestedTag" ;
    rdfs:comment "A schema attribute that indicates another tag  that is often associated with this tag. This attribute is used by tagging tools to provide tagging suggestions." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedTag ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:isInheritedProperty true ;
    heda:nodeProperty true .

heda:tagGroup a owl:DatatypeProperty ;
    rdfs:label "tagGroup" ;
    rdfs:comment "A schema attribute indicating the tag can only appear inside a tag group." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:takesValue a owl:DatatypeProperty ;
    rdfs:label "takesValue" ;
    rdfs:comment "A schema attribute indicating the tag is a hashtag placeholder that is expected to be replaced with a user-defined value." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:topLevelTagGroup a owl:DatatypeProperty ;
    rdfs:label "topLevelTagGroup" ;
    rdfs:comment "A schema attribute indicating that this tag (or its descendants) can only appear in a top-level tag group. A tag group can have at most one tag with this attribute." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:unique a owl:DatatypeProperty ;
    rdfs:label "unique" ;
    rdfs:comment "A schema attribute indicating that only one of this tag or its descendants can be used  in the event-level HED string." ;
    rdfs:domain hed:HedTag ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:nodeProperty true .

heda:unitClass a owl:ObjectProperty ;
    rdfs:label "unitClass" ;
    rdfs:comment "A schema attribute specifying which unit class this value tag belongs to." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedUnitClass ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:nodeProperty true .

heda:unitClassProperty a owl:AnnotationProperty ;
    rdfs:label "unitClassProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to unit classes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:unitModifierProperty a owl:AnnotationProperty ;
    rdfs:label "unitModifierProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to unit modifier classes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:unitPrefix a owl:DatatypeProperty ;
    rdfs:label "unitPrefix" ;
    rdfs:comment "A schema attribute applied specifically to unit elements to designate that the unit indicator is a prefix (e.g., dollar sign in the currency units)." ;
    rdfs:domain hed:HedUnit ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitProperty true .

heda:unitProperty a owl:AnnotationProperty ;
    rdfs:label "unitProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to units within a unit class." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

heda:unitSymbol a owl:DatatypeProperty ;
    rdfs:label "unitSymbol" ;
    rdfs:comment "A schema attribute indicating this tag is an abbreviation or symbol representing a type of unit. Unit symbols represent both the singular and the plural and thus cannot be pluralized." ;
    rdfs:domain hed:HedUnit ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaAttributeDatatypeProperty ;
    heda:boolProperty true ;
    heda:unitProperty true .

heda:valueClass a owl:ObjectProperty ;
    rdfs:label "valueClass" ;
    rdfs:comment "A schema attribute specifying which value class this value tag belongs to." ;
    rdfs:domain hed:HedTag ;
    rdfs:range hed:HedValueClass ;
    rdfs:subPropertyOf hed:schemaAttributeObjectProperty ;
    heda:nodeProperty true .

heda:valueClassProperty a owl:AnnotationProperty ;
    rdfs:label "valueClassProperty" ;
    rdfs:comment "Indicates that the schema attribute is meant to be applied to value classes." ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf hed:schemaProperty .

<https://purl.org/hed/aux#$> a hed:HedUnit ;
    rdfs:label "$" ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:currencyUnits ;
    heda:unitPrefix true ;
    heda:unitSymbol true .

hedu:B a hed:HedUnit ;
    rdfs:label "B" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:memorySizeUnits ;
    heda:unitSymbol true .

hedu:Hz a hed:HedUnit ;
    rdfs:label "Hz" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:frequencyUnits ;
    heda:unitSymbol true .

hedu:T a hed:HedUnit ;
    rdfs:label "T" ;
    heda:SIUnit true ;
    heda:conversionFactor "10^-15" ;
    heda:unitClass hedu:magneticFieldUnits ;
    heda:unitSymbol true .

hedu:Volt a hed:HedUnit ;
    rdfs:label "Volt" ;
    heda:SIUnit true ;
    heda:conversionFactor "0.000001" ;
    heda:unitClass hedu:electricPotentialUnits .

hedu:byte a hed:HedUnit ;
    rdfs:label "byte" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:memorySizeUnits .

hedu:candela a hed:HedUnit ;
    rdfs:label "candela" ;
    rdfs:comment "Units used to express light intensity." ;
    heda:SIUnit true ;
    heda:unitClass hedu:intensityUnits .

hedu:cd a hed:HedUnit ;
    rdfs:label "cd" ;
    rdfs:comment "Units used to express light intensity." ;
    heda:SIUnit true ;
    heda:unitClass hedu:intensityUnits ;
    heda:unitSymbol true .

hedu:dB a hed:HedUnit ;
    rdfs:label "dB" ;
    rdfs:comment "Intensity expressed as ratio to a threshold. May be used for sound intensity." ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:intensityUnits ;
    heda:unitSymbol true .

hedu:day a hed:HedUnit ;
    rdfs:label "day" ;
    heda:conversionFactor "86400" ;
    heda:unitClass hedu:timeUnits .

hedu:degree a hed:HedUnit ;
    rdfs:label "degree" ;
    heda:conversionFactor "0.0174533" ;
    heda:unitClass hedu:angleUnits .

hedu:degree_Celsius a hed:HedUnit ;
    rdfs:label "degree Celsius" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:temperatureUnits .

hedu:dollar a hed:HedUnit ;
    rdfs:label "dollar" ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:currencyUnits .

hedu:euro a hed:HedUnit ;
    rdfs:label "euro" ;
    heda:unitClass hedu:currencyUnits .

hedu:foot a hed:HedUnit ;
    rdfs:label "foot" ;
    heda:conversionFactor "0.3048" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:g a hed:HedUnit ;
    rdfs:label "g" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:weightUnits ;
    heda:unitSymbol true .

hedu:gram a hed:HedUnit ;
    rdfs:label "gram" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:weightUnits .

hedu:hertz a hed:HedUnit ;
    rdfs:label "hertz" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:frequencyUnits .

hedu:hour a hed:HedUnit ;
    rdfs:label "hour" ;
    rdfs:comment "Should be in 24-hour format." ;
    heda:conversionFactor "3600" ;
    heda:unitClass hedu:timeUnits .

hedu:inch a hed:HedUnit ;
    rdfs:label "inch" ;
    heda:conversionFactor "0.0254" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:kph a hed:HedUnit ;
    rdfs:label "kph" ;
    heda:conversionFactor "0.277778" ;
    heda:unitClass hedu:speedUnits ;
    heda:unitSymbol true .

hedu:lb a hed:HedUnit ;
    rdfs:label "lb" ;
    heda:conversionFactor "453.592" ;
    heda:unitClass hedu:weightUnits .

hedu:m a hed:HedUnit ;
    rdfs:label "m" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:physicalLengthUnits ;
    heda:unitSymbol true .

hedu:m-per-s a hed:HedUnit ;
    rdfs:label "m-per-s" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:speedUnits ;
    heda:unitSymbol true .

hedu:m-per-s_2 a hed:HedUnit ;
    rdfs:label "m-per-s^2" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:accelerationUnits ;
    heda:unitSymbol true .

hedu:m-per-s_3 a hed:HedUnit ;
    rdfs:label "m-per-s^3" ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:jerkUnits ;
    heda:unitSymbol true .

hedu:m_2 a hed:HedUnit ;
    rdfs:label "m^2" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:areaUnits ;
    heda:unitSymbol true .

hedu:m_3 a hed:HedUnit ;
    rdfs:label "m^3" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:volumeUnits ;
    heda:unitSymbol true .

hedu:meter a hed:HedUnit ;
    rdfs:label "meter" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:metre a hed:HedUnit ;
    rdfs:label "metre" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:mile a hed:HedUnit ;
    rdfs:label "mile" ;
    heda:conversionFactor "1609.34" ;
    heda:unitClass hedu:physicalLengthUnits .

hedu:minute a hed:HedUnit ;
    rdfs:label "minute" ;
    heda:conversionFactor "60" ;
    heda:unitClass hedu:timeUnits .

hedu:mph a hed:HedUnit ;
    rdfs:label "mph" ;
    heda:conversionFactor "0.44704" ;
    heda:unitClass hedu:speedUnits ;
    heda:unitSymbol true .

hedu:oC a hed:HedUnit ;
    rdfs:label "oC" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:temperatureUnits ;
    heda:unitSymbol true .

hedu:point a hed:HedUnit ;
    rdfs:label "point" ;
    heda:unitClass hedu:currencyUnits .

hedu:posixPath a hed:HedValueClass ;
    rdfs:label "posixPath" ;
    rdfs:comment "Posix path specification." ;
    heda:allowedCharacter "/",
        ":",
        "digits",
        "letters" .

hedu:pound a hed:HedUnit ;
    rdfs:label "pound" ;
    heda:conversionFactor "453.592" ;
    heda:unitClass hedu:weightUnits .

hedu:rad a hed:HedUnit ;
    rdfs:label "rad" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:angleUnits ;
    heda:unitSymbol true .

hedu:radian a hed:HedUnit ;
    rdfs:label "radian" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:angleUnits .

hedu:s a hed:HedUnit ;
    rdfs:label "s" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:timeUnits ;
    heda:unitSymbol true .

hedu:second a hed:HedUnit ;
    rdfs:label "second" ;
    heda:SIUnit true ;
    heda:conversionFactor "1.0" ;
    heda:unitClass hedu:timeUnits .

hedu:tesla a hed:HedUnit ;
    rdfs:label "tesla" ;
    heda:SIUnit true ;
    heda:conversionFactor "10^-15" ;
    heda:unitClass hedu:magneticFieldUnits .

hedu:v a hed:HedUnit ;
    rdfs:label "v" ;
    heda:SIUnit true ;
    heda:conversionFactor "0.000001" ;
    heda:unitClass hedu:electricPotentialUnits ;
    heda:unitSymbol true .

hedum:E a hed:HedUnitModifier ;
    rdfs:label "E" ;
    rdfs:comment "SI unit multiple representing 10^18." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^18" .

hedum:G a hed:HedUnitModifier ;
    rdfs:label "G" ;
    rdfs:comment "SI unit multiple representing 10^9." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^9" .

hedum:M a hed:HedUnitModifier ;
    rdfs:label "M" ;
    rdfs:comment "SI unit multiple representing 10^6." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^6" .

hedum:P a hed:HedUnitModifier ;
    rdfs:label "P" ;
    rdfs:comment "SI unit multiple representing 10^15." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^15" .

hedum:T a hed:HedUnitModifier ;
    rdfs:label "T" ;
    rdfs:comment "SI unit multiple representing 10^12." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^12" .

hedum:Y a hed:HedUnitModifier ;
    rdfs:label "Y" ;
    rdfs:comment "SI unit multiple representing 10^24." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^24" .

hedum:Z a hed:HedUnitModifier ;
    rdfs:label "Z" ;
    rdfs:comment "SI unit multiple representing 10^21." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^21" .

hedum:a a hed:HedUnitModifier ;
    rdfs:label "a" ;
    rdfs:comment "SI unit submultiple representing 10^-18." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-18" .

hedum:atto a hed:HedUnitModifier ;
    rdfs:label "atto" ;
    rdfs:comment "SI unit submultiple representing 10^-18." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-18" .

hedum:c a hed:HedUnitModifier ;
    rdfs:label "c" ;
    rdfs:comment "SI unit submultiple representing 10^-2." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "0.01" .

hedum:centi a hed:HedUnitModifier ;
    rdfs:label "centi" ;
    rdfs:comment "SI unit submultiple representing 10^-2." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "0.01" .

hedum:d a hed:HedUnitModifier ;
    rdfs:label "d" ;
    rdfs:comment "SI unit submultiple representing 10^-1." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "0.1" .

hedum:da a hed:HedUnitModifier ;
    rdfs:label "da" ;
    rdfs:comment "SI unit multiple representing 10^1." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10.0" .

hedum:deca a hed:HedUnitModifier ;
    rdfs:label "deca" ;
    rdfs:comment "SI unit multiple representing 10^1." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10.0" .

hedum:deci a hed:HedUnitModifier ;
    rdfs:label "deci" ;
    rdfs:comment "SI unit submultiple representing 10^-1." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "0.1" .

hedum:exa a hed:HedUnitModifier ;
    rdfs:label "exa" ;
    rdfs:comment "SI unit multiple representing 10^18." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^18" .

hedum:f a hed:HedUnitModifier ;
    rdfs:label "f" ;
    rdfs:comment "SI unit submultiple representing 10^-15." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-15" .

hedum:femto a hed:HedUnitModifier ;
    rdfs:label "femto" ;
    rdfs:comment "SI unit submultiple representing 10^-15." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-15" .

hedum:giga a hed:HedUnitModifier ;
    rdfs:label "giga" ;
    rdfs:comment "SI unit multiple representing 10^9." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^9" .

hedum:h a hed:HedUnitModifier ;
    rdfs:label "h" ;
    rdfs:comment "SI unit multiple representing 10^2." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "100.0" .

hedum:hecto a hed:HedUnitModifier ;
    rdfs:label "hecto" ;
    rdfs:comment "SI unit multiple representing 10^2." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "100.0" .

hedum:k a hed:HedUnitModifier ;
    rdfs:label "k" ;
    rdfs:comment "SI unit multiple representing 10^3." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "1000.0" .

hedum:kilo a hed:HedUnitModifier ;
    rdfs:label "kilo" ;
    rdfs:comment "SI unit multiple representing 10^3." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "1000.0" .

hedum:m a hed:HedUnitModifier ;
    rdfs:label "m" ;
    rdfs:comment "SI unit submultiple representing 10^-3." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "0.001" .

hedum:mega a hed:HedUnitModifier ;
    rdfs:label "mega" ;
    rdfs:comment "SI unit multiple representing 10^6." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^6" .

hedum:micro a hed:HedUnitModifier ;
    rdfs:label "micro" ;
    rdfs:comment "SI unit submultiple representing 10^-6." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-6" .

hedum:milli a hed:HedUnitModifier ;
    rdfs:label "milli" ;
    rdfs:comment "SI unit submultiple representing 10^-3." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "0.001" .

hedum:n a hed:HedUnitModifier ;
    rdfs:label "n" ;
    rdfs:comment "SI unit submultiple representing 10^-9." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-9" .

hedum:nano a hed:HedUnitModifier ;
    rdfs:label "nano" ;
    rdfs:comment "SI unit submultiple representing 10^-9." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-9" .

hedum:p a hed:HedUnitModifier ;
    rdfs:label "p" ;
    rdfs:comment "SI unit submultiple representing 10^-12." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-12" .

hedum:peta a hed:HedUnitModifier ;
    rdfs:label "peta" ;
    rdfs:comment "SI unit multiple representing 10^15." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^15" .

hedum:pico a hed:HedUnitModifier ;
    rdfs:label "pico" ;
    rdfs:comment "SI unit submultiple representing 10^-12." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-12" .

hedum:tera a hed:HedUnitModifier ;
    rdfs:label "tera" ;
    rdfs:comment "SI unit multiple representing 10^12." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^12" .

hedum:u a hed:HedUnitModifier ;
    rdfs:label "u" ;
    rdfs:comment "SI unit submultiple representing 10^-6." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-6" .

hedum:y a hed:HedUnitModifier ;
    rdfs:label "y" ;
    rdfs:comment "SI unit submultiple representing 10^-24." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-24" .

hedum:yocto a hed:HedUnitModifier ;
    rdfs:label "yocto" ;
    rdfs:comment "SI unit submultiple representing 10^-24." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-24" .

hedum:yotta a hed:HedUnitModifier ;
    rdfs:label "yotta" ;
    rdfs:comment "SI unit multiple representing 10^24." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^24" .

hedum:z a hed:HedUnitModifier ;
    rdfs:label "z" ;
    rdfs:comment "SI unit submultiple representing 10^-21." ;
    heda:SIUnitSymbolModifier true ;
    heda:conversionFactor "10^-21" .

hedum:zepto a hed:HedUnitModifier ;
    rdfs:label "zepto" ;
    rdfs:comment "SI unit submultiple representing 10^-21." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^-21" .

hedum:zetta a hed:HedUnitModifier ;
    rdfs:label "zetta" ;
    rdfs:comment "SI unit multiple representing 10^21." ;
    heda:SIUnitModifier true ;
    heda:conversionFactor "10^21" .

hed:Epilogue a hed:HedElement ;
    rdfs:label "epilogue" ;
    hed:elementValue """This schema is released under the Creative Commons Attribution 4.0 International and is a product of the HED Working Group. The DOI for the latest version of the HED standard schema is 10.5281/zenodo.7876037.
""" .

hed:Prologue a hed:HedElement ;
    rdfs:label "epilogue" ;
    hed:elementValue """The HED standard schema is a hierarchically-organized vocabulary for annotating events and experimental structure. HED annotations consist of comma-separated tags drawn from this vocabulary. This vocabulary can be augmented by terms drawn from specialized library schema. 

Each term in this vocabulary has a human-readable description and may include additional attributes that give additional properties or that specify how tools should treat the tag during analysis. The meaning of these attributes is described in the Additional schema properties section.

""" .

hed:Version a hed:HeaderMember ;
    rdfs:label "version" ;
    hed:HeaderAttribute "8.2.0" .

hed:XSI a hed:HeaderMember ;
    rdfs:label "xmlns:xsi" ;
    hed:HeaderAttribute "http://www.w3.org/2001/XMLSchema-instance" .

hed:XSINoNamespaceSchemaLocation a hed:HeaderMember ;
    rdfs:label "xsi:noNamespaceSchemaLocation" ;
    hed:HeaderAttribute "https://github.com/hed-standard/hed-specification/raw/master/hedxml/HED8.0.0.xsd" .

hedt:2D-view a hed:HedTag ;
    rdfs:label "2D-view" ;
    rdfs:comment "A view showing only two dimensions." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:3D-view a hed:HedTag ;
    rdfs:label "3D-view" ;
    rdfs:comment "A view showing three dimensions." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:Above a hed:HedTag ;
    rdfs:label "Above" ;
    rdfs:comment "(A, (Above, B)) means A is in a place or position that is higher than B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Abrupt a hed:HedTag ;
    rdfs:label "Abrupt" ;
    rdfs:comment "Marked by sudden change." ;
    hed:hasHedParent hedt:Data-variability-attribute .

hedt:Acceleration-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:accelerationUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Acceleration .

hedt:Across-from a hed:HedTag ;
    rdfs:label "Across-from" ;
    rdfs:comment "(A, (Across-from, B)) means A is on the opposite side of something from B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Adjacent-to a hed:HedTag ;
    rdfs:label "Adjacent-to" ;
    rdfs:comment "(A, (Adjacent-to, B)) indicates that A is next to B in time or space." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Aerial-view a hed:HedTag ;
    rdfs:label "Aerial-view" ;
    rdfs:comment "Elevated view of an object from above, with a perspective as though the observer were a bird." ;
    hed:hasHedParent hedt:Map-view .

hedt:After a hed:HedTag ;
    rdfs:label "After" ;
    rdfs:comment "(A, (After B)) means A happens at a time subsequent to a reference time related to B." ;
    hed:hasHedParent hedt:Temporal-relation .

hedt:Age-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Age .

hedt:Agent-action a hed:HedTag ;
    rdfs:label "Agent-action" ;
    rdfs:comment "Any action engaged in by an agent (see the Agent subtree for agent categories). A participant response to an experiment stimulus should include the tag Agent-property/Agent-task-role/Experiment-participant." ;
    heda:suggestedTag hedt:Agent,
        hedt:Task-event-role ;
    hed:hasHedParent hedt:Event .

hedt:Ahead-of a hed:HedTag ;
    rdfs:label "Ahead-of" ;
    rdfs:comment "(A, (Ahead-of, B)) indicates that A is further forward in time or space in B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Aircraft a hed:HedTag ;
    rdfs:label "Aircraft" ;
    rdfs:comment "A vehicle which is able to travel through air in an atmosphere." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Alarm-sound a hed:HedTag ;
    rdfs:label "Alarm-sound" ;
    rdfs:comment "A loud signal often loud continuous ringing to alert people to a problem or condition that requires urgent attention." ;
    hed:hasHedParent hedt:Named-object-sound .

hedt:Alert a hed:HedTag ;
    rdfs:label "Alert" ;
    rdfs:comment "Condition of heightened watchfulness or preparation for action." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:AliceBlue a hed:HedTag ;
    rdfs:label "AliceBlue" ;
    rdfs:comment "CSS-color 0xF0F8FF." ;
    hed:hasHedParent hedt:White-color .

hedt:Allow a hed:HedTag ;
    rdfs:label "Allow" ;
    rdfs:comment "Allow access to something such as allowing a car to pass." ;
    hed:hasHedParent hedt:Think .

hedt:Ambidextrous a hed:HedTag ;
    rdfs:label "Ambidextrous" ;
    rdfs:comment "Having no overall dominance in the use of right or left hand or foot in the performance of tasks that require one hand or foot." ;
    hed:hasHedParent hedt:Handedness .

hedt:And a hed:HedTag ;
    rdfs:label "And" ;
    rdfs:comment "(A, (And, B)) means A and B are both in effect." ;
    hed:hasHedParent hedt:Logical-relation .

hedt:Anesthetized a hed:HedTag ;
    rdfs:label "Anesthetized" ;
    rdfs:comment "Having lost sensation to pain or having senses dulled due to the effects of an anesthetic." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:Angle-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:angleUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Angle .

hedt:Angry a hed:HedTag ;
    rdfs:label "Angry" ;
    rdfs:comment "Experiencing emotions characterized by marked annoyance or hostility." ;
    hed:hasHedParent hedt:Agent-emotional-state .

hedt:Animal a hed:HedTag ;
    rdfs:label "Animal" ;
    rdfs:comment "A living organism that has membranous cell walls, requires oxygen and organic foods, and is capable of voluntary movement." ;
    hed:hasHedParent hedt:Organism .

hedt:Animal-agent a hed:HedTag ;
    rdfs:label "Animal-agent" ;
    rdfs:comment "An agent that is an animal." ;
    hed:hasHedParent hedt:Agent .

hedt:Animation a hed:HedTag ;
    rdfs:label "Animation" ;
    rdfs:comment "A form of graphical illustration that changes with time to give a sense of motion or represent dynamic changes in the portrayal." ;
    hed:hasHedParent hedt:Visualization .

hedt:Ankle a hed:HedTag ;
    rdfs:label "Ankle" ;
    rdfs:comment "A gliding joint between the distal ends of the tibia and fibula and the proximal end of the talus." ;
    hed:hasHedParent hedt:Lower-extremity .

hedt:AntiqueWhite a hed:HedTag ;
    rdfs:label "AntiqueWhite" ;
    rdfs:comment "CSS-color 0xFAEBD7." ;
    hed:hasHedParent hedt:White-color .

hedt:Approximately-equal-to a hed:HedTag ;
    rdfs:label "Approximately-equal-to" ;
    rdfs:comment "(A, (Approximately-equal-to, B)) indicates that A and B have almost the same value. Here A and B could refer to sizes, orders, positions or other quantities." ;
    hed:hasHedParent hedt:Comparative-relation .

hedt:Aqua a hed:HedTag ;
    rdfs:label "Aqua" ;
    rdfs:comment "CSS-color 0x00FFFF." ;
    hed:hasHedParent hedt:Cyan-color .

hedt:Aquamarine a hed:HedTag ;
    rdfs:label "Aquamarine" ;
    rdfs:comment "CSS-color 0x7FFFD4." ;
    hed:hasHedParent hedt:Cyan-color .

hedt:Area-Placeholder a hed:HedPlaceholder ;
    rdfs:label "#" ;
    heda:takesValue true ;
    heda:unitClass hedu:areaUnits ;
    heda:valueClass hedu:numericClass ;
    hed:hasHedParent hedt:Area .

hedt:Around a hed:HedTag ;
    rdfs:label "Around" ;
    rdfs:comment "(A, (Around, B)) means A is in or near the present place or situation of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Aroused a hed:HedTag ;
    rdfs:label "Aroused" ;
    rdfs:comment "In a state reactive to stimuli leading to increased heart rate and blood pressure, sensory alertness, mobility and readiness to respond." ;
    hed:hasHedParent hedt:Agent-emotional-state .

hedt:Arrow a hed:HedTag ;
    rdfs:label "Arrow" ;
    rdfs:comment "A shape with a pointed end indicating direction." ;
    hed:hasHedParent hedt:2D-shape .

hedt:Art-installation a hed:HedTag ;
    rdfs:label "Art-installation" ;
    rdfs:comment "A large-scale, mixed-media constructions, often designed for a specific place or for a temporary period of time." ;
    hed:hasHedParent hedt:Visualization .

hedt:Asleep a hed:HedTag ;
    rdfs:label "Asleep" ;
    rdfs:comment "Having entered a periodic, readily reversible state of reduced awareness and metabolic activity, usually accompanied by physical relaxation and brain activity." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:Asynchronous-with a hed:HedTag ;
    rdfs:label "Asynchronous-with" ;
    rdfs:comment "(A, (Asynchronous-with, B)) means A happens at times not occurring at the same time or having the same period or phase as B." ;
    hed:hasHedParent hedt:Temporal-relation .

hedt:Attend-to a hed:HedTag ;
    rdfs:label "Attend-to" ;
    rdfs:comment "Focus mental experience on specific targets." ;
    hed:hasHedParent hedt:Think .

hedt:Attentive a hed:HedTag ;
    rdfs:label "Attentive" ;
    rdfs:comment "Concentrating and focusing mental energy on the task or surroundings." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:Attic a hed:HedTag ;
    rdfs:label "Attic" ;
    rdfs:comment "A room or a space immediately below the roof of a building." ;
    hed:hasHedParent hedt:Building .

hedt:Audio-clip a hed:HedTag ;
    rdfs:label "Audio-clip" ;
    rdfs:comment "A short segment of audio." ;
    hed:hasHedParent hedt:Media-clip .

hedt:Audiovisual-clip a hed:HedTag ;
    rdfs:label "Audiovisual-clip" ;
    rdfs:comment "A short media segment containing both audio and video." ;
    hed:hasHedParent hedt:Media-clip .

hedt:Augmented-reality a hed:HedTag ;
    rdfs:label "Augmented-reality" ;
    rdfs:comment "Using technology that enhances real-world experiences with computer-derived digital overlays to change some aspects of perception of the natural environment. The digital content is shown to the user through a smart device or glasses and responds to changes in the environment." ;
    hed:hasHedParent hedt:Environmental-property .

hedt:Avatar-agent a hed:HedTag ;
    rdfs:label "Avatar-agent" ;
    rdfs:comment "An agent associated with an icon or avatar representing another agent." ;
    hed:hasHedParent hedt:Agent .

hedt:Awake a hed:HedTag ;
    rdfs:label "Awake" ;
    rdfs:comment "In a non sleeping state." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:Away-from a hed:HedTag ;
    rdfs:label "Away-from" ;
    rdfs:comment "(A, (Away-from, B)) indicates that A is going or has moved away from B. The meaning depends on A and B." ;
    hed:hasHedParent hedt:Directional-relation .

hedt:Awed a hed:HedTag ;
    rdfs:label "Awed" ;
    rdfs:comment "Filled with wonder. Feeling grand, sublime or powerful emotions characterized by a combination of joy, fear, admiration, reverence, and/or respect." ;
    hed:hasHedParent hedt:Agent-emotional-state .

hedt:Azure a hed:HedTag ;
    rdfs:label "Azure" ;
    rdfs:comment "CSS-color 0xF0FFFF." ;
    hed:hasHedParent hedt:White-color .

hedt:Background-subtask a hed:HedTag ;
    rdfs:label "Background-subtask" ;
    rdfs:comment "A part of the task which should be performed in the background as for example inhibiting blinks due to instruction while performing the primary task." ;
    hed:hasHedParent hedt:Task-relationship .

hedt:Background-view a hed:HedTag ;
    rdfs:label "Background-view" ;
    rdfs:comment "Parts of the view that are farthest from the viewer and usually the not part of the visual focus." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:Barking a hed:HedTag ;
    rdfs:label "Barking" ;
    rdfs:comment "Sharp explosive cries like sounds made by certain animals, especially a dog, fox, or seal." ;
    hed:hasHedParent hedt:Named-animal-sound .

hedt:Basement a hed:HedTag ;
    rdfs:label "Basement" ;
    rdfs:comment "The part of a building that is wholly or partly below ground level." ;
    hed:hasHedParent hedt:Building .

hedt:Beep a hed:HedTag ;
    rdfs:label "Beep" ;
    rdfs:comment "A short, single tone, that is typically high-pitched and generally made by a computer or other machine." ;
    hed:hasHedParent hedt:Named-object-sound .

hedt:Before a hed:HedTag ;
    rdfs:label "Before" ;
    rdfs:comment "(A, (Before B)) means A happens at a time earlier in time or order than B." ;
    hed:hasHedParent hedt:Temporal-relation .

hedt:Behavioral-evidence a hed:HedTag ;
    rdfs:label "Behavioral-evidence" ;
    rdfs:comment "An indication or conclusion based on the behavior of an agent." ;
    hed:hasHedParent hedt:Task-effect-evidence .

hedt:Behind a hed:HedTag ;
    rdfs:label "Behind" ;
    rdfs:comment "(A, (Behind, B)) means A is at or to the far side of B, typically so as to be hidden by it." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Beige a hed:HedTag ;
    rdfs:label "Beige" ;
    rdfs:comment "CSS-color 0xF5F5DC." ;
    hed:hasHedParent hedt:White-color .

hedt:Belongs-to a hed:HedTag ;
    rdfs:label "Belongs-to" ;
    rdfs:comment "(A, (Belongs-to, B)) indicates that A is a member of B." ;
    hed:hasHedParent hedt:Connective-relation .

hedt:Below a hed:HedTag ;
    rdfs:label "Below" ;
    rdfs:comment "(A, (Below, B)) means A is in a place or position that is lower than the position of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Bend a hed:HedTag ;
    rdfs:label "Bend" ;
    rdfs:comment "Move body in a bowed or curved manner." ;
    hed:hasHedParent hedt:Move-body .

hedt:Between a hed:HedTag ;
    rdfs:label "Between" ;
    rdfs:comment "(A, (Between, (B, C))) means A is in the space or interval separating B and C." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Bicycle a hed:HedTag ;
    rdfs:label "Bicycle" ;
    rdfs:comment "A human-powered, pedal-driven, single-track vehicle, having two wheels attached to a frame, one behind the other." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Big-toe a hed:HedTag ;
    rdfs:label "Big-toe" ;
    rdfs:comment "The largest toe on the inner side of the foot." ;
    hed:hasHedParent hedt:Foot .

hedt:Bilateral-to a hed:HedTag ;
    rdfs:label "Bilateral-to" ;
    rdfs:comment "(A, (Bilateral, B)) means A is on both sides of B or affects both sides of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Bisque a hed:HedTag ;
    rdfs:label "Bisque" ;
    rdfs:comment "CSS-color 0xFFE4C4." ;
    hed:hasHedParent hedt:Brown-color .

hedt:Bistable-view a hed:HedTag ;
    rdfs:label "Bistable-view" ;
    rdfs:comment "Something having two stable visual forms that have two distinguishable stable forms as in optical illusions." ;
    hed:hasHedParent hedt:Visual-presentation .

hedt:Bite a hed:HedTag ;
    rdfs:label "Bite" ;
    rdfs:comment "Seize with teeth or jaws an object or organism so as to grip or break the surface covering." ;
    hed:hasHedParent hedt:Move-face .

hedt:Bitter a hed:HedTag ;
    rdfs:label "Bitter" ;
    rdfs:comment "Having a sharp, pungent taste." ;
    hed:hasHedParent hedt:Gustatory-attribute .

hedt:Black a hed:HedTag ;
    rdfs:label "Black" ;
    rdfs:comment "CSS-color 0x000000." ;
    hed:hasHedParent hedt:Gray-color .

hedt:BlanchedAlmond a hed:HedTag ;
    rdfs:label "BlanchedAlmond" ;
    rdfs:comment "CSS-color 0xFFEBCD." ;
    hed:hasHedParent hedt:Brown-color .

hedt:Bleating a hed:HedTag ;
    rdfs:label "Bleating" ;
    rdfs:comment "Wavering cries like sounds made by a sheep, goat, or calf." ;
    hed:hasHedParent hedt:Named-animal-sound .

hedt:Blink a hed:HedTag ;
    rdfs:label "Blink" ;
    rdfs:comment "Shut and open the eyes quickly." ;
    hed:hasHedParent hedt:Move-eyes .

hedt:Blow a hed:HedTag ;
    rdfs:label "Blow" ;
    rdfs:comment "Expel air through pursed lips." ;
    hed:hasHedParent hedt:Breathe .

hedt:Blue a hed:HedTag ;
    rdfs:label "Blue" ;
    rdfs:comment "CSS-color 0x0000FF." ;
    hed:hasHedParent hedt:Blue-color .

hedt:BlueViolet a hed:HedTag ;
    rdfs:label "BlueViolet" ;
    rdfs:comment "CSS-color 0x8A2BE2." ;
    hed:hasHedParent hedt:Purple-color .

hedt:Boat a hed:HedTag ;
    rdfs:label "Boat" ;
    rdfs:comment "A watercraft of any size which is able to float or plane on water." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Body a hed:HedTag ;
    rdfs:label "Body" ;
    rdfs:comment "The biological structure representing an organism." ;
    hed:hasHedParent hedt:Anatomical-item .

hedt:Book a hed:HedTag ;
    rdfs:label "Book" ;
    rdfs:comment "A volume made up of pages fastened along one edge and enclosed between protective covers." ;
    hed:hasHedParent hedt:Document .

hedt:Boundary-of a hed:HedTag ;
    rdfs:label "Boundary-of" ;
    rdfs:comment "(A, (Boundary-of, B)) means A is on or part of the edge or boundary of B." ;
    hed:hasHedParent hedt:Spatial-relation .

hedt:Braille a hed:HedTag ;
    rdfs:label "Braille" ;
    rdfs:comment "A display using a system of raised dots that can be read with the fingers by people who are blind." ;
    hed:hasHedParent hedt:Visualization .

hedt:Brain-dead a hed:HedTag ;
    rdfs:label "Brain-dead" ;
    rdfs:comment "Characterized by the irreversible absence of cortical and brain stem functioning." ;
    hed:hasHedParent hedt:Agent-cognitive-state .

hedt:Brown a hed:HedTag ;
    rdfs:label "Brown" ;
    rdfs:comment "CSS-color 0xA52A2A." ;
    hed:hasHedParent hedt:Brown-color .

hedt:BurlyWood a hed:HedTag ;
    rdfs:label "BurlyWood" ;
    rdfs:comment "CSS-color 0xDEB887." ;
    hed:hasHedParent hedt:Brown-color .

hedt:Burp a hed:HedTag ;
    rdfs:label "Burp" ;
    rdfs:comment "Noisily release air from the stomach through the mouth. Belch." ;
    hed:hasHedParent hedt:Move-face .

hedt:Buttocks a hed:HedTag ;
    rdfs:label "Buttocks" ;
    rdfs:comment "The round fleshy parts that form the lower rear area of a human trunk." ;
    hed:hasHedParent hedt:Torso .

hedt:Buzz a hed:HedTag ;
    rdfs:label "Buzz" ;
    rdfs:comment "A persistent vibratory sound often made by a buzzer device and used to indicate something incorrect." ;
    hed:hasHedParent hedt:Named-object-sound .

hedt:CadetBlue a hed:HedTag ;
    rdfs:label "CadetBlue" ;
    rdfs:comment "CSS-color 0x5F9EA0." ;
    hed:hasHedParent hedt:Blue-color .

hedt:Calf a hed:HedTag ;
    rdfs:label "Calf" ;
    rdfs:comment "The fleshy part at the back of the leg below the knee." ;
    hed:hasHedParent hedt:Lower-extremity .

hedt:Car a hed:HedTag ;
    rdfs:label "Car" ;
    rdfs:comment "A wheeled motor vehicle used primarily for the transportation of human passengers." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Cart a hed:HedTag ;
    rdfs:label "Cart" ;
    rdfs:comment "A cart is a vehicle which has two wheels and is designed to transport human passengers or cargo." ;
    hed:hasHedParent hedt:Vehicle .

hedt:Cartoon a hed:HedTag ;
    rdfs:label "Cartoon" ;
    rdfs:comment "A type of illustration, sometimes animated, typically in a non-realistic or semi-realistic style. The specific meaning has evolved over time, but the modern usage usually refers to either an image or series of images intended for satire, caricature, or humor. A motion picture that relies on a sequence of illustrations for its animation." ;
    hed:hasHedParent hedt:Image .

hedt:Cellphone a hed:HedTag ;
    rdfs:label "Cellphone" ;
    rdfs:comment "A telephone with access to a cellular radio system so it can be used over a wide area, without a physical connection to a network." ;
    hed:hasHedParent hedt:Computing-device .

hedt:Ceramic a hed:HedTag ;
    rdfs:label "Ceramic" ;
    rdfs:comment "A hard, brittle, heat-resistant and corrosion-resistant material made by shaping and then firing a nonmetallic mineral, such as clay, at a high temperature." ;
    hed:hasHedParent hedt:Manufactured-material .

hedt:Character a hed:HedTag ;
    rdfs:label "Character" ;
    rdfs:comment "A mark or symbol used in writing." ;
    hed:hasHedParent hedt:Language-item .

hedt:Chartreuse a hed:HedTag ;
    rdfs:label "Chartreuse" ;
    rdfs:comment "CSS-color 0x7FFF00." ;
    hed:hasHedParent hedt:Green-color .

hedt:Cheek a hed:HedTag ;
    rdfs:label "Cheek" ;
    rdfs:comment "The fleshy part of the face bounded by the eyes, nose, ear, and jaw line." ;
    hed:hasHedParent hedt:Face .

hedt:Chew a hed:HedTag ;
    rdfs:label "Chew" ;
    rdfs:comment "Repeatedly grinding, tearing, and or crushing with teeth or jaws." ;
    hed:hasHedParent hedt:Move-face .

hedt:Chin a hed:HedTag ;
    rdfs:label "Chin" ;
    rdfs:comment "The part of the face below the lower lip and including the protruding part of the lower jaw." ;
    hed:hasHedParent hedt:Face .

hedt:Chirping a hed:HedTag ;
    rdfs:label "Chirping" ;
    rdfs:comment "Short, sharp, high-pitched noises like sounds made by small birds or an insects." ;
    hed:hasHedParent hedt:Named-animal-sound .

hedt:Chocolate a hed:HedTag ;
    rdfs:label "Chocolate" ;
    rdfs:comment "CSS-color 0xD2691E." ;
    hed:hasHedParent hedt:Brown-color .

hedt:Circle a hed:HedTag ;
    rdfs:label "Circle" ;
    rdfs:comment "A ring-shaped structure with every point equidistant from the center." ;
    hed:hasHedParent hedt:Ellipse .

hedt:Clap-hands a hed:HedTag ;
    rdfs:label "Clap-hands" ;
    rdfs:comment "Strike the palms of against one another resoundingly, and usually repeatedly, especially to express approval." ;
    hed:hasHedParent hedt:Communicate-gesturally .

hedt:Clause a hed:HedTag ;
    rdfs:label "Clause" ;
    rdfs:comment "A  unit of grammatical organization next below the sentence in rank, usually consisting of a subject and predicate." ;
    hed:hasHedParent hedt:Language-item .

hedt:Clear-throat a hed:HedTag ;
    rdfs:label "Clear-throat" ;
    rdfs:comment "Cough slightly so as to speak more clearly, attract attention, or to express hesitancy before saying something awkward." ;
