        hedt:Move-head ;
    hed:hasHedParent hedt:Communicate-gesturally .

hedt:Click a hed:HedTag ;
    rdfs:label "Click" ;
    rdfs:comment "The sound made by a mechanical cash register, often to designate a reward." ;
    hed:hasHedParent hedt:Named-object-sound .

hedt:Clock-face a hed:HedTag ;
    rdfs:label "Clock-face" ;
    rdfs:comment "A location identifier based on clockface numbering or anatomic subregion." ;
    hed:hasHedParent hedt:Clock .

hedt:Clockface a hed:HedTag ;
    rdfs:label "Clockface" ;
    rdfs:comment "The dial face of a clock. A location identifier based on clockface numbering or anatomic subregion." ;
