  {
    "@id": "https://purl.org/hed/tag#Syncope",
    "@type": [
      "https://purl.org/hed#HedTag"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Episode with loss of consciousness and muscle tone that is abrupt in onset, of short duration and followed by rapid recovery; it occurs in response to transient impairment of cerebral perfusion. Typical prodromal symptoms often herald onset of syncope and postictal symptoms are minimal. Syncopal convulsions resulting from cerebral anoxia are common but are not a form of epilepsy, nor are there any accompanying EEG ictal discharges."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Syncope"
      }
