      "https://purl.org/hed#HedTag"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Temporal intermittent rhythmic delta activity (TIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at over the temporal areas of one side of the head. Comment: most commonly associated with temporal lobe epilepsy."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Temporal-intermittent-rhythmic-delta-activity-morphology"
      }
    ],
