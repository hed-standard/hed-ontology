    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Occipital intermittent rhythmic delta activity (OIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 2-3 Hz over the occipital or posterior head regions of one or both sides of the head. Frequently blocked or attenuated by opening the eyes. Comment: most commonly associated with unspecified encephalopathy, in children."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
