    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Benign epileptiform Transients of Sleep (BETS). Small sharp spikes (SSS) of very short duration and low amplitude, often followed by a small theta wave, occurring in the temporal regions during drowsiness and light sleep. They occur on one or both sides (often asynchronously). The main negative and positive components are of about equally spiky character. Rarely seen in children, they are seen most often in adults and the elderly. Two thirds of the patients have a history of epileptic seizures."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Small-sharp-spikes"
      }
    ],
    "https://purl.org/hed#hasHedParent": [
      {
        "@id": "https://purl.org/hed/tag#Uncertain-significant-pattern"
      }
    ],
    "https://purl.org/hed#suggestedTag": [
      {
        "@id": "https://purl.org/hed/tag#Brain-laterality"
      },
      {
        "@id": "https://purl.org/hed/tag#Brain-region"
      },
      {
        "@id": "https://purl.org/hed/tag#Sensors"
      },
      {
        "@id": "https://purl.org/hed/tag#Appearance-mode"
      },
      {
        "@id": "https://purl.org/hed/tag#Discharge-pattern"
      }
    ]
  },
  {
