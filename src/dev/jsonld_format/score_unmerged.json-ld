    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Frontal intermittent rhythmic delta activity (FIRDA). Fairly regular or approximately sinusoidal waves, mostly occurring in bursts at 1.5-2.5 Hz over the frontal areas of one or both sides of the head. Comment: most commonly associated with unspecified encephalopathy, in adults."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
