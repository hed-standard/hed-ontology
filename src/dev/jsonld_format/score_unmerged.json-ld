    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Episode of non epileptic nature included in NREM parasomnias, characterized by sudden arousal and complex behavior but without full alertness, usually lasting a few minutes and occurring almost in all children at least occasionally. Amnesia of the episode is the rule."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
