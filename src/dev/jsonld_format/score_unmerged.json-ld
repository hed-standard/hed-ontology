  {
    "@id": "https://purl.org/hed/tag#Automatism-motor-seizure",
    "@type": [
      "https://purl.org/hed#HedTag"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A more or less coordinated motor activity usually occurring when cognition is impaired and for which the subject is usually (but not always) amnesic afterward. This often resembles a voluntary movement and may consist of an inappropriate continuation of preictal motor activity. Definition from ILAE 2017 Classification of Seizure Types Expanded Version"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Automatism-motor-seizure"
