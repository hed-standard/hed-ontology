    "@type": [
      "https://purl.org/hed#HedTag"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Disorder characterized by exaggerated startle response and hypertonicity that may occur during the first year of life and in severe cases during the neonatal period. Children usually present with marked irritability and recurrent startles in response to handling and sounds. Severely affected infants can have severe jerks and stiffening, sometimes with breath-holding spells."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
