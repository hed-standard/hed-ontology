  {
    "@id": "https://purl.org/hed/tag#Sleep-periodic-limb-movement",
    "@type": [
      "https://purl.org/hed#HedTag"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "PLMS. Periodic limb movement in sleep. Episodes are characterized by brief (0.5- to 5.0-second) lower-extremity movements during sleep, which typically occur at 20- to 40-second intervals, most commonly during the first 3 hours of sleep. The affected individual is usually not aware of the movements or of the transient partial arousals."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
