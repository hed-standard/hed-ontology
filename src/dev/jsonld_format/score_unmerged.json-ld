      },
      {
        "@id": "https://purl.org/hed/tag#Brain-region"
      },
      {
        "@id": "https://purl.org/hed/tag#Sensors"
      },
      {
        "@id": "https://purl.org/hed/tag#Appearance-mode"
      },
      {
        "@id": "https://purl.org/hed/tag#Discharge-pattern"
      }
    ]
  },
