  {
    "@id": "https://purl.org/hed/tag#Seizure-semiology-manifestation",
    "@type": [
      "https://purl.org/hed#HedTag"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Seizure semiology refers to the clinical features or signs that are observed during a seizure, such as the type of movements or behaviors exhibited by the person having the seizure, the duration of the seizure, the level of consciousness, and any associated symptoms such as aura or postictal confusion. In other words, seizure semiology describes the physical manifestations of a seizure. Semiology is described according to the ILAE Glossary of Descriptive Terminology for Ictal Semiology (Blume et al., 2001). Besides the name, the semiologic finding can also be characterized by the somatotopic modifier, laterality, body part and centricity. Uses Location-property tags."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Seizure-semiology-manifestation"
      }
    ],
    "https://purl.org/hed#hasHedParent": [
      {
        "@id": "https://purl.org/hed/tag#Episode-property"
      }
    ],
    "https://purl.org/hed#requireChild": [
      {
        "@value": true
      }
    ]
  },
